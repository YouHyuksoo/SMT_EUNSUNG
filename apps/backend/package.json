{
  "name": "@eunsung/backend",
  "version": "0.1.0",
  "description": "은성전장 MES Backend API Server",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest --runInBand",
    "test:ci": "jest --runInBand --detectOpenHandles",
    "test:changed": "jest --onlyChanged",
    "test:architecture": "jest architecture --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate:create": "typeorm migration:create",
    "db:migrate:run": "typeorm migration:run -d dist/database/data-source.js",
    "db:migrate:revert": "typeorm migration:revert -d dist/database/data-source.js",
    "db:test": "ts-node src/database/test-connection.ts",
    "db:seed-roles": "ts-node src/seeds/seed-roles.ts"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.6",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/typeorm": "^11.0.0",
    "@smt/shared": "workspace:*",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.11.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron": "^4.4.0",
    "cron-parser": "^5.5.0",
    "multer": "^2.0.2",
    "oracledb": "^6.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serialport": "^13.0.0",
    "sqlite-vec": "^0.1.9",
    "typeorm": "^0.3.20",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@golevelup/ts-jest": "^2.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/oracledb": "^6.10.1",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
