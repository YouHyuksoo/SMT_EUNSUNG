{
  "name": "@eunsung/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gen:registry": "node scripts/gen-page-registry.mjs",
    "gen:menu": "node scripts/gen-menu-registration.mjs",
    "check:pages": "node scripts/check-page-registration.mjs",
    "predev": "node scripts/gen-page-registry.mjs && node scripts/check-page-registration.mjs",
    "prebuild": "node scripts/gen-page-registry.mjs && node scripts/check-page-registration.mjs",
    "dev": "set NODE_NO_WARNINGS=1 && next dev --turbopack -H 0.0.0.0 -p 3100",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3100",
    "lint": "next lint",
    "typecheck": "node scripts/gen-page-registry.mjs && node scripts/check-page-registration.mjs && tsc --noEmit --pretty false",
    "test": "node scripts/gen-page-registry.mjs && node scripts/gen-menu-registration.mjs && node scripts/check-page-registration.mjs && node --test \"src/**/*.eunsung.structure.test.mjs\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
