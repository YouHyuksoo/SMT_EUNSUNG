 column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_2d_barcode.run_no" )
 column=(type=char(30) updatewhereclause=yes name=serial_no dbname="ip_product_2d_barcode.serial_no" )
 column=(type=datetime updatewhereclause=yes name=run_date dbname="ip_product_2d_barcode.run_date" )
 column=(type=char(50) updatewhereclause=yes name=item_code dbname="ip_product_2d_barcode.item_code" )
 column=(type=char(20) updatewhereclause=yes name=magazine_no dbname="ip_product_2d_barcode.magazine_no" )
 column=(type=char(50) updatewhereclause=yes name=box_no dbname="ip_product_2d_barcode.box_no" )
 column=(type=char(50) updatewhereclause=yes name=pallete_no dbname="ip_product_2d_barcode.pallete_no" )
