 retrieve="  SELECT 'SPI' AS WORKSTAGE_NAME ,

         ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BOX_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"PALLETE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"CARRIER_BARCODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_YN~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_QTY~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BARCODE_STATUS~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"CSTID~",  
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"SEQ_NO~", 
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"PID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"DEFECT_CODE~",
         TO_DATE(~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~",'YYYY/MM/DD HH24:MI:SS') INSPECT_DATE,   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"LINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"EQUIPMENTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"RUN_NO~",

		IP_PRODUCT_MODEL_MASTER.SMT_MODEL_NAME , 

	   (
         SELECT MAX(H.LINE_ONOFF_DATE) 
           FROM IB_SMT_LINE_ONOFF_HISTORY H 
         WHERE H.LINE_CODE   = IQ_MACHINE_INSPECT_DATA_SPI.LINE_CODE 
              AND H.LINE_ONOFF = 'OFF' 
              AND H.LINE_ONOFF_DATE <    (SELECT MAX(TO_DATE(B.INSPECT_DATE,'YYYY/MM/DD HH24:MI:SS'))
													   FROM  IQ_MACHINE_INSPECT_SPI B
												  	 WHERE B.PID         = ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" 
														 AND B.line_code =  ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"LINE_CODE~" 
													  ) 
         )  AS MIN_DATETIME,

        (SELECT  MAX(TO_DATE(B.INSPECT_DATE,'YYYY/MM/DD HH24:MI:SS'))
            FROM   IQ_MACHINE_INSPECT_DATA_SPI B
          WHERE B.PID          = ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" 
			 AND B.line_code =  ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"LINE_CODE~" 
	   ) AS MAX_DATETIME

    FROM ~"IP_PRODUCT_2D_BARCODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~"  ,
		 IP_PRODUCT_MODEL_MASTER 
   WHERE  IQ_MACHINE_INSPECT_DATA_SPI.PID = ip_product_2d_barcode.serial_no (+) 
	  AND ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~" = ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_NAME~"  		
       AND ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"PID~" = :arg_serial_no  
       AND  ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"ORGANIZATION_ID~" = :arg_org  

UNION ALL

  SELECT 'AOI' AS WORKSTAGE_NAME ,

		 ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BOX_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"PALLETE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"CARRIER_BARCODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_YN~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_QTY~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BARCODE_STATUS~",   

         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"CSTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"SEQ_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"PID~" ,   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"DEFECT_CODE~",
          TO_DATE(~"IQ_MACHINE_INSPECT_DATA_AOI~".~"INSPECT_DATE~",'YYYY/MM/DD HH24:MI:SS') INSPECT_DATE, 
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"LINE_CODE~",    
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"EQUIPMENTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"RUN_NO~",

		IP_PRODUCT_MODEL_MASTER.SMT_MODEL_NAME ,

	  ( SELECT MAX(H.LINE_ONOFF_DATE) FROM IB_SMT_LINE_ONOFF_HISTORY H 
         WHERE H.LINE_CODE   = IQ_MACHINE_INSPECT_DATA_AOI.LINE_CODE 
              AND H.LINE_ONOFF = 'OFF' 
              AND H.LINE_ONOFF_DATE <  (
														SELECT MAX(TO_DATE(B.INSPECT_DATE,'YYYY/MM/DD HH24:MI:SS'))
														  FROM IQ_MACHINE_INSPECT_AOI B
														WHERE B.PID         = ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" 
														    AND B.line_code =  ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"LINE_CODE~" 
									  			    )
        )  AS MIN_DATE,

        (
          SELECT  MAX(TO_DATE(B.INSPECT_DATE,'YYYY/MM/DD HH24:MI:SS'))
            FROM  IQ_MACHINE_INSPECT_AOI B
           WHERE B.PID          = ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" 
			  AND B.line_code =  ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"LINE_CODE~" 
	    ) AS MAX_DATETIME

    FROM ~"IP_PRODUCT_2D_BARCODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~"  ,
		IP_PRODUCT_MODEL_MASTER
   WHERE IQ_MACHINE_INSPECT_DATA_AOI.PID = ip_product_2d_barcode.serial_no (+)
       AND  ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~" = ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_NAME~"   
       AND  ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"PID~" = :arg_serial_no 
       AND  ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"ORGANIZATION_ID~" = :arg_org     

UNION ALL

  SELECT 'START' AS WORKSTAGE_NAME ,

     	~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BOX_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"PALLETE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"CARRIER_BARCODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_YN~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_QTY~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BARCODE_STATUS~",   

         ''   AS CSTID,   
         ''   AS SEQ_NO,   
         ''   AS PID ,   
         ''   AS RESULT,   
         ''   AS DEFECT_CODE,
         NULL   AS INSPECT_DATE, 
         ''   AS FILE_NAME,   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~",    
         ''   AS EQUIPMENTID,   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"RUN_NO~",

		IP_PRODUCT_MODEL_MASTER.SMT_MODEL_NAME ,

	  ( SELECT MAX(H.LINE_ONOFF_DATE) FROM IB_SMT_LINE_ONOFF_HISTORY H WHERE H.LINE_CODE = IP_PRODUCT_WORKSTAGE_IO.LINE_CODE
              AND H.LINE_ONOFF = 'OFF' 
              AND H.LINE_ONOFF_DATE <  IP_PRODUCT_WORKSTAGE_IO.IO_DATE 
       )  AS MIN_DATE ,


         IP_PRODUCT_WORKSTAGE_IO.IO_DATE AS  MAX_DATETIME

    FROM ~"IP_PRODUCT_2D_BARCODE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~"  ,
		IP_PRODUCT_MODEL_MASTER
   WHERE ( IP_PRODUCT_WORKSTAGE_IO.SERIAL_NO = ip_product_2d_barcode.serial_no (+)) and  
              (~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~" = ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_NAME~") AND  
    			(IP_PRODUCT_WORKSTAGE_IO.SERIAL_NO = :arg_serial_no ) AND  
   			(IP_PRODUCT_WORKSTAGE_IO.WORKSTAGE_CODE = 'W020' ) AND  
	         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ORGANIZATION_ID~" = :arg_org )   

" arguments=(("arg_serial_no", string),("arg_org", number))  sort="workstage_name A model_name A magazine_no A serial_no A " )
