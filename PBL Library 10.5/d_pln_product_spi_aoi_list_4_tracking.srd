 column=(type=char(50) updatewhereclause=yes name=iq_machine_inspect_data_spi_run_no dbname="iq_machine_inspect_data_spi.run_no" )
 column=(type=char(50) updatewhereclause=yes name=smt_model_name dbname="ip_product_model_master.smt_model_name" )
