 column=(type=char(20) updatewhereclause=yes name=lot_no dbname="ip_product_2d_barcode.lot_no" )
 column=(type=datetime updatewhereclause=yes name=qc_scan_date dbname="ip_product_2d_barcode.qc_scan_date" )
 column=(type=char(100) updatewhereclause=yes name=model_name dbname="ip_product_2d_barcode.model_name" )
 column=(type=number updatewhereclause=yes name=ip_product_2d_barcode_lot_qty dbname="ip_product_2d_barcode.lot_qty" )
 column=(type=char(1) updatewhereclause=yes name=ip_product_2d_barcode_barcode_status dbname="ip_product_2d_barcode.barcode_status" )
 column=(type=char(50) updatewhereclause=yes name=iq_machine_inspect_data_spi_cstid dbname="iq_machine_inspect_data_spi.cstid" )
 column=(type=char(10) updatewhereclause=yes name=iq_machine_inspect_data_spi_seq_no dbname="iq_machine_inspect_data_spi.seq_no" )
 column=(type=char(100) updatewhereclause=yes name=iq_machine_inspect_data_spi_pid dbname="iq_machine_inspect_data_spi.pid" )
 column=(type=char(10) updatewhereclause=yes name=iq_machine_inspect_data_spi_result dbname="iq_machine_inspect_data_spi.result" )
