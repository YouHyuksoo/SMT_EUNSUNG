 column=(type=number updatewhereclause=yes name=organization_id dbname="iq_machine_inspect_data_sp.organization_id" )
 retrieve="select pid, 
         result, 
         defect_code, 
         inspect_date, 
         f_get_line_name( line_code, organization_id) line_code, 
         equipmentid, 
         run_no, 
         cstid, 
         seq_no, 
         sso_dist_table, 
         sso_table_speed, 
         pressure1, 
         speed1, 
         pressure2, 
         speed2, 
         frequency, 
         temprature, 
         front_sqg, 
         rear_sqg, 
         matal_mask 
         enter_date, 
         enter_by, 
         organization_id  
  from iq_machine_inspect_data_sp   
 where PID like :ARG_SERIAL_NO 
   AND ORGANIZATION_ID = :ARG_ORG
" update="iq_machine_inspect_data_sp" updatewhere=0 updatekeyinplace=no arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="pid A inspect_date A " )
