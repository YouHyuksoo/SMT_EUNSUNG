 column=(type=datetime updatewhereclause=yes name=enter_date dbname="ip_product_workstage_io.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_workstage_io.enter_by" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_workstage_io.organization_id" )
 retrieve="select  wip_seq, 
          io_date, 
          run_no, 
          model_name, 
          serial_no, 
          f_get_line_name( line_code, organization_id) line_code,        
          f_get_workstage_name(workstage_code) as workstage_code,
          io_deficit, 
          from_line_code,           
	 	f_get_workstage_name(from_workstage_code) as from_workstage_code,	 
          enter_date, 
          enter_by, 
          organization_id   
  from ip_product_workstage_io
 where serial_no like :ARG_SERIAL_NO 
    AND ORGANIZATION_ID = :ARG_ORG 
 order by wip_seq                        
" arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="serial_no A io_date A " )
