 column=(type=char(240) updatewhereclause=yes name=tb_vis_inout_issueno_hub_to_subinv_desc dbname="tb_vis_inout_issueno_hub.to_subinv_desc" dbalias=".to_subinv_desc" )
 column=(type=number updatewhereclause=yes name=tb_vis_inout_issueno_hub_transaction_qty dbname="transaction_qty" )
 column=(type=char(30) updatewhereclause=yes name=tb_vis_inout_issueno_hub_wh_keeper dbname="tb_vis_inout_issueno_hub.wh_keeper" dbalias=".wh_keeper" )
 column=(type=char(1000) updatewhereclause=yes name=comments dbname="im_item_receipt_slip.comments" dbalias=".comments" )
 retrieve="  SELECT ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_DATE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_SEQUENCE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_STATUS~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_BARCODE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"ITEM_CODE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"REEL_QTY~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_UNIT_QTY~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_SUM_QTY~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_SLIP_NO~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"ENTER_DATE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"ENTER_BY~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"ECO_ITEM_YN~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_TYPE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT_SLIP~".~"FROM_SUPPLIER_CODE~",   

         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"SITE~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_DATE~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_TYPE~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_SUBINVENTORY~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_SUBINV_DESC~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_LOCATOR~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"DESCRIPTION~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"SPEC~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"TO_SUBINVENTORY~",   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"TO_SUBINV_DESC~",   
         NVL(~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_QTY~",0) * -1 TRANSACTION_QTY,   
         ~"TB_VIS_INOUT_ISSUENO_HUB~".~"WH_KEEPER~",   

         ~"IM_ITEM_RECEIPT_SLIP~".~"COMMENTS~"  

    FROM ~"IM_ITEM_RECEIPT_SLIP~",   
           (  SELECT      ~"TB_VIS_INOUT_ISSUENO_HUB~".~"SITE~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"ISSUE_NO~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_DATE~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_TYPE~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_SUBINVENTORY~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_SUBINV_DESC~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_LOCATOR~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"DESCRIPTION~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"SPEC~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"TO_SUBINVENTORY~",   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"TO_SUBINV_DESC~",   
							SUM(~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_QTY~") TRANSACTION_QTY ,   
							~"TB_VIS_INOUT_ISSUENO_HUB~".~"WH_KEEPER~"
       			   FROM  ~"TB_VIS_INOUT_ISSUENO_HUB~"  
				 GROUP BY   ~"TB_VIS_INOUT_ISSUENO_HUB~".~"SITE~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"ISSUE_NO~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_DATE~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"TRANSACTION_TYPE~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_SUBINVENTORY~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_SUBINV_DESC~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"FROM_LOCATOR~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"DESCRIPTION~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"SPEC~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"TO_SUBINVENTORY~",   
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"TO_SUBINV_DESC~",     
					~"TB_VIS_INOUT_ISSUENO_HUB~".~"WH_KEEPER~"
          )  TB_VIS_INOUT_ISSUENO_HUB
   WHERE ( im_item_receipt_slip.receipt_slip_no = TB_VIS_INOUT_ISSUENO_HUB.issue_no (+)) and  
         ( ( ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_DATE~" <= :arg_dateend ) AND  
         ( ~"IM_ITEM_RECEIPT_SLIP~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_SLIP_NO~" like :arg_slip_no ) AND  
         ( ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_TYPE~" like :arg_receipt_type ) AND  
         ( ~"IM_ITEM_RECEIPT_SLIP~".~"RECEIPT_STATUS~" <> 'C' ) AND  
         ( ~"IM_ITEM_RECEIPT_SLIP~".~"ORGANIZATION_ID~" = :arg_org ) )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_slip_no", string),("arg_receipt_type", string),("arg_org", number))  sort="receipt_type A receipt_date A receipt_sequence D " )
group(level=1 header.height=0 trailer.height=72 by=("receipt_type" ) header.color="536870912" trailer.color="12639424" )
