 column=(type=char(5) updatewhereclause=yes name=tb_vis_inout_issueno_hub_site dbname="tb_vis_inout_issueno_hub.site" dbalias=".site" )
 column=(type=datetime updatewhereclause=yes name=tb_vis_inout_issueno_hub_transaction_date dbname="tb_vis_inout_issueno_hub.transaction_date" dbalias=".transaction_date" )
 column=(type=char(200) updatewhereclause=yes name=tb_vis_inout_issueno_hub_transaction_type dbname="tb_vis_inout_issueno_hub.transaction_type" dbalias=".transaction_type" )
 column=(type=char(10) updatewhereclause=yes name=tb_vis_inout_issueno_hub_from_subinventory dbname="tb_vis_inout_issueno_hub.from_subinventory" dbalias=".from_subinventory" )
 column=(type=char(240) updatewhereclause=yes name=tb_vis_inout_issueno_hub_from_subinv_desc dbname="tb_vis_inout_issueno_hub.from_subinv_desc" dbalias=".from_subinv_desc" )
 column=(type=char(30) updatewhereclause=yes name=tb_vis_inout_issueno_hub_from_locator dbname="tb_vis_inout_issueno_hub.from_locator" dbalias=".from_locator" )
