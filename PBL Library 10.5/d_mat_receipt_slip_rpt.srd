table(column=(type=datetime update=yes updatewhereclause=yes name=receipt_date dbname="im_item_receipt_slip.receipt_date" dbalias=".receipt_date" )
 column=(type=number update=yes updatewhereclause=yes name=receipt_sequence dbname="im_item_receipt_slip.receipt_sequence" dbalias=".receipt_sequence" )
 column=(type=char(1) update=yes updatewhereclause=yes name=receipt_status dbname="im_item_receipt_slip.receipt_status" dbalias=".receipt_status" )
 column=(type=char(100) update=yes updatewhereclause=yes name=receipt_barcode dbname="im_item_receipt_slip.receipt_barcode" dbalias=".receipt_barcode" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="im_item_receipt_slip.item_code" dbalias=".item_code" )
 column=(type=number update=yes updatewhereclause=yes name=reel_qty dbname="im_item_receipt_slip.reel_qty" dbalias=".reel_qty" )
