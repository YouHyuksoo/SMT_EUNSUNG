 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="im_item_receipt_slip.last_modify_date" dbalias=".last_modify_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="im_item_receipt_slip.last_modify_by" dbalias=".last_modify_by" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="im_item_receipt_slip.organization_id" dbalias=".organization_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=eco_item_yn dbname="im_item_receipt_slip.eco_item_yn" dbalias=".eco_item_yn" )
