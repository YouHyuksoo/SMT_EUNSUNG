 crosstab(band = foreground  crosstabonly = yes 
 columns = "receipt_date, location_code, receipt_deficit" rows = "item_code, supplier_code" values = "sum(receipt_qty for crosstab)" sourcenames = "receipt_date, location_code, supplier_code, receipt_deficit, receipt_qty, item_code")
