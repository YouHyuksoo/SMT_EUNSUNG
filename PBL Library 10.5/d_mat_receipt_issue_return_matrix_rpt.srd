$PBExportComments$D_MAT_RECEIPT_ISSUE_RPT CREATE DATE :2006-12-22 CREATED BY : ADMIN
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=72 color="536870912" )
header[3](height=60 color="536870912" )
header[4](height=60 color="536870912" )
summary(height=72 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="supplier_code" )
 column=(type=number updatewhereclause=yes name=receipt_qty dbname="receipt_qty" )
 retrieve="  SELECT TO_CHAR(~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~", 'YYYYMMDD')  RECEIPT_DATE,  
         f_get_basecode( 'MATERIAL LOCATION CODE' , ~"IM_ITEM_RECEIPT~".~"LOCATION_CODE~",    :ARG_LANG ,  ORGANIZATION_ID ) LOCATION_CODE ,
         F_GET_SUPPLIER_NAME( ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~",  ORGANIZATION_ID )   SUPPLIER_CODE ,
         f_get_basecode( 'RECEIPT ISSUE DEFICIT' , ~"IM_ITEM_RECEIPT~".~"RECEIPT_DEFICIT~",  :ARG_LANG ,  ORGANIZATION_ID ) RECEIPT_DEFICIT ,
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_QTY~",   
         ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~"  
    FROM ~"IM_ITEM_RECEIPT~"   
 WHERE SUPPLIER_CODE LIKE :ARG_SUPPLIER_CODE
    AND ITEM_CODE LIKE :ARG_ITEM_CODE
    AND RECEIPT_DATE >= :ARG_DATESET
    AND RECEIPT_DATE <= :ARG_DATEEND
    AND ORGANIZATION_ID = :ARG_ORG
union all


  SELECT TO_CHAR(~"IM_ITEM_ISSUE~".~"ISSUE_DATE~",   'YYYYMMDD' ) ISSUE_DATE ,
         f_get_basecode( 'MATERIAL LOCATION CODE' , ~"IM_ITEM_ISSUE~".~"LOCATION_CODE~",    :ARG_LANG ,  ORGANIZATION_ID ) LOCATION_CODE ,
          F_GET_SUPPLIER_NAME( ~"IM_ITEM_ISSUE~".~"SUPPLIER_CODE~",   ORGANIZATION_ID ) SUPPLIER_CODE,
         f_get_basecode( 'RECEIPT ISSUE DEFICIT' , ~"IM_ITEM_ISSUE~".~"ISSUE_DEFICIT~",  :ARG_LANG ,  ORGANIZATION_ID ) ISSUE_DEFICIT ,       
         ~"IM_ITEM_ISSUE~".~"ISSUE_QTY~",   
         ~"IM_ITEM_ISSUE~".~"ITEM_CODE~"  
    FROM ~"IM_ITEM_ISSUE~"   
WHERE SUPPLIER_CODE LIKE :ARG_SUPPLIER_CODE
    AND ITEM_CODE LIKE :ARG_ITEM_CODE
    AND ISSUE_DATE >= :ARG_DATESET
    AND ISSUE_DATE <= :ARG_DATEEND
    AND ORGANIZATION_ID = :ARG_ORG
" arguments=(("ARG_SUPPLIER_CODE", string),("ARG_ITEM_CODE", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LANG", string),("ARG_ORG", number))  sort="item_code A supplier_code A " )
group(level=1 header.height=0 trailer.height=0 by=("item_code" ) header.color="536870912" trailer.color="134217729" )
