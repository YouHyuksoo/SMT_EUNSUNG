 retrieve="  SELECT ~"ID_PRODUCT_CLASS~".~"PRODUCT_CLASS_CODE~",   
         ~"ID_PRODUCT_CLASS~".~"ORGANIZATION_ID~",   
         ~"ID_PRODUCT_CLASS~".~"PRODUCT_CLASS_NAME~",   
         ~"ID_PRODUCT_CLASS~".~"PRODUCT_DIVISION~",   
         ~"ID_PRODUCT_CLASS~".~"ENTER_BY~",   
         ~"ID_PRODUCT_CLASS~".~"LAST_MODIFY_DATE~",   
         ~"ID_PRODUCT_CLASS~".~"LAST_MODIFY_BY~",   
         ~"ID_PRODUCT_CLASS~".~"ENTER_DATE~",   
         ~"ID_PRODUCT_CLASS~".~"PRODUCT_CLASS_FIRST_GROUP~",   
         ~"ID_PRODUCT_CLASS~".~"PRODUCT_CLASS_SECOND_GROUP~",   
         ~"ID_PRODUCT_CLASS~".~"PRODUCT_CLASS_THIRD_GROUP~",   
         rowid  
    FROM ~"ID_PRODUCT_CLASS~"  
   WHERE ( ~"ID_PRODUCT_CLASS~".~"PRODUCT_CLASS_CODE~" like :ARG_PRODUCT_CLASS ) AND  
         ( ~"ID_PRODUCT_CLASS~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" update="ID_PRODUCT_CLASS" updatewhere=1 updatekeyinplace=no arguments=(("ARG_PRODUCT_CLASS", string),("ARG_ORG", number)) )
