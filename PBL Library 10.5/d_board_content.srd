 retrieve="SELECT  ~"ISYS_PUB_BOARD~".~"SEQ_NO~" ,
           ~"ISYS_PUB_BOARD~".~"USER_ID~" ,
           ~"ISYS_PUB_BOARD~".~"USER_NAME~" ,
           ~"ISYS_PUB_BOARD~".~"PASSWORD~" ,
           ~"ISYS_PUB_BOARD~".~"EMAIL_ADDRESS~" ,
           ~"ISYS_PUB_BOARD~".~"REG_DATE~" ,
           ~"ISYS_PUB_BOARD~".~"TITLE~" ,
           ~"ISYS_PUB_BOARD~".~"HIT_COUNT~" ,
           ~"ISYS_PUB_BOARD~".~"CONTENT~" ,
           ~"ISYS_PUB_BOARD~".~"REPLY_SEQUENCE~" ,
           ~"ISYS_PUB_BOARD~".~"PARENT_SEQ_NO~" ,
           ~"ISYS_PUB_BOARD~".~"APPLICATION_NAME~" ,
           ~"ISYS_PUB_BOARD~".~"ENTER_DATE~" ,
           ~"ISYS_PUB_BOARD~".~"LAST_MODIFY_DATE~" ,
           ~"ISYS_PUB_BOARD~".~"ENTER_BY~" ,
           ~"ISYS_PUB_BOARD~".~"ORGANIZATION_ID~" ,
           ~"ISYS_PUB_BOARD~".~"LAST_MODIFY_BY~"     
        FROM ~"ISYS_PUB_BOARD~"      
        WHERE ( ~"ISYS_PUB_BOARD~".~"SEQ_NO~" = :arg_seq_no )   " update="ISYS_PUB_BOARD" updatewhere=0 updatekeyinplace=yes arguments=(("arg_seq_no", number)) )
