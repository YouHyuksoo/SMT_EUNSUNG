 column=(type=char(100) updatewhereclause=yes name=code_mean dbname="code_mean" )
 retrieve="  SELECT   CODE_NAME ,
		   DECODE(:ARG_LANG, 'K', CODE_MEAN_KOR, 'E', CODE_MEAN_ENG ,CODE_MEAN_LOCAL ) AS CODE_MEAN 
    FROM ~"ISYS_BASECODE~"  
   WHERE ~"ISYS_BASECODE~".~"CODE_TYPE~" = 'NATION CODE'
        AND ~"ISYS_BASECODE~".~"ORGANIZATION_ID~" = :ARG_ORG    
" arguments=(("ARG_LANG", string),("ARG_ORG", string)) )
