 retrieve="SELECT CODE_NAME ,
		 DECODE(:ARG_LANG, 'K', CODE_MEAN_KOR, 'E', CODE_MEAN_ENG ,CODE_MEAN_LOCAL ) AS CODE_MEAN   ,
		CODE_VALUE  
FROM  ISYS_BASECODE      
WHERE  CODE_TYPE       = 'LABEL STEP'
     AND  ORGANIZATION_ID = :ARG_ORG   " arguments=(("ARG_LANG", string),("ARG_ORG", string))  sort="code_name A " )
