 retrieve="  SELECT 'BOM' DIV ,
		ID_ENG_BOM_SMT.PARENT_ITEM_CODE,   
         ID_ENG_BOM_SMT.CHILD_ITEM_CODE,   
         ID_ENG_BOM_SMT.DATESET,   
         ID_ENG_BOM_SMT.SORT_SEQUENCE,   
         ID_ENG_BOM_SMT.ITEM_UNIT_QTY,   
         ID_ENG_BOM_SMT.WORKSTAGE_CODE,   
         ID_ENG_BOM_SMT.DATEEND,   
         ID_ENG_BOM_SMT.BOM_WORK_NO,   
         ID_ENG_BOM_SMT.ENTER_BY,   
         ID_ENG_BOM_SMT.ENTER_DATE,   
         ID_ENG_BOM_SMT.LAST_MODIFY_BY,   
         ID_ENG_BOM_SMT.LAST_MODIFY_DATE,   
         ID_ITEM_A.ITEM_NAME,   
         ID_ITEM_A.ITEM_SPEC,   
         ID_ITEM_A.ITEM_UOM,   
         ID_ITEM_B.ITEM_NAME,   
         ID_ITEM_B.ITEM_SPEC,   
         ID_ENG_BOM_SMT.ITEM_TYPE,   
         ID_ENG_BOM_SMT.LINE_TYPE,   
         ID_ENG_BOM_SMT.BOM_LEVEL,   
         ID_ENG_BOM_SMT.ORGANIZATION_ID,   
         ID_ENG_BOM_SMT.LOCATION_CODE,   
         SUBSTR(ID_ENG_BOM_SMT.LOCATION_CODE,1,1) TABLE_ID ,   
         ID_ENG_BOM_SMT.LINE_CODE,   
         ID_ENG_BOM_SMT.MACHINE,   
         IB_LINE_MASTER.LINE_NAME,   
         IB_LINE_MASTER.MACHINE_NAME,   
         '*'||ID_ENG_BOM_SMT.LOCATION_CODE||'*' LOCATION_BARCODE,   
        IB_LINE_MASTER.line_division  line_division ,
         '*'||ID_ENG_BOM_SMT.PARENT_ITEM_CODE||'*' PARENT_ITEM_BARCODE,   
         REPLACE( ID_ENG_BOM_SMT.LOCATION_INFO,',',' ') LOCATION_INFO  ,

	   ID_ENG_BOM_SMT.VERSION,   
	   ID_ENG_BOM_SMT.PCB_ITEM,   
	   ID_ENG_BOM_SMT.MARKING_NO,
	   ID_ENG_BOM_SMT.COMMENTS ,
	
       IB_LINE_MASTER.SHOW_TABLE_YN	 SHOW_TABLE_YN
		
    FROM ID_ENG_BOM_SMT,   
         ID_ITEM ID_ITEM_A,   
         ID_ITEM ID_ITEM_B,   
         IB_LINE_MASTER,   
         IB_MACHINE_LOCATION  
   WHERE ( ID_ENG_BOM_SMT.CHILD_ITEM_CODE = ID_ITEM_A.ITEM_CODE (+)) AND  
         ( ID_ENG_BOM_SMT.ORGANIZATION_ID = ID_ITEM_A.ORGANIZATION_ID (+)) AND  
         ( ID_ENG_BOM_SMT.PARENT_ITEM_CODE = ID_ITEM_B.ITEM_CODE (+)) AND  
         ( ID_ENG_BOM_SMT.ORGANIZATION_ID = ID_ITEM_B.ORGANIZATION_ID (+)) AND  
         ( ID_ENG_BOM_SMT.LINE_CODE = IB_LINE_MASTER.LINE_CODE (+)) AND  
         ( ID_ENG_BOM_SMT.ORGANIZATION_ID = IB_LINE_MASTER.ORGANIZATION_ID (+)) AND  
         ( ID_ENG_BOM_SMT.MACHINE = IB_LINE_MASTER.MACHINE (+)) AND  


         ( ID_ENG_BOM_SMT.ORGANIZATION_ID = IB_MACHINE_LOCATION.ORGANIZATION_ID) AND  
         ( ID_ENG_BOM_SMT.LOCATION_CODE = IB_MACHINE_LOCATION.LOCATION_CODE) AND  

         ( ID_ENG_BOM_SMT.PARENT_ITEM_CODE LIKE :ARG_PARENT_ITEM ) AND  
         ( ID_ENG_BOM_SMT.LINE_CODE LIKE :ARG_LINE_CODE ) AND  
         ( ID_ENG_BOM_SMT.MACHINE LIKE :ARG_MACHINE ) AND  
         ( ID_ENG_BOM_SMT.DATESET <= :ARG_DATESET ) AND  
         ( ID_ENG_BOM_SMT.DATEEND >= :ARG_DATESET ) AND  
 	    ( NVL(ID_ENG_BOM_SMT.PCB_ITEM ,'*')  LIKE :ARG_TOPBOT )    AND
         ( ID_ENG_BOM_SMT.ORGANIZATION_ID = :ARG_ORG )    
/*
UNION ALL

  SELECT F_GET_DUAL_LANG_TEXT( 'REPLACE'  , 'C' ,  ID_ENG_BOM_SMT_REPLACE.ORGANIZATION_ID )  DIV ,
		ID_ENG_BOM_SMT_REPLACE.PARENT_ITEM_CODE,   
         ID_ENG_BOM_SMT_REPLACE.CHILD_ITEM_CODE,   
         ID_ENG_BOM_SMT_REPLACE.DATESET,   
         ID_ENG_BOM_SMT_REPLACE.SORT_SEQUENCE,   
         ID_ENG_BOM_SMT_REPLACE.ITEM_UNIT_QTY,   
         ID_ENG_BOM_SMT_REPLACE.WORKSTAGE_CODE,   
         ID_ENG_BOM_SMT_REPLACE.DATEEND,   
         ID_ENG_BOM_SMT_REPLACE.BOM_WORK_NO,   
         ID_ENG_BOM_SMT_REPLACE.ENTER_BY,   
         ID_ENG_BOM_SMT_REPLACE.ENTER_DATE,   
         ID_ENG_BOM_SMT_REPLACE.LAST_MODIFY_BY,   
         ID_ENG_BOM_SMT_REPLACE.LAST_MODIFY_DATE,   
         ID_ITEM_A.ITEM_NAME,   
         ID_ITEM_A.ITEM_SPEC,   
         ID_ITEM_A.ITEM_UOM,   
         ID_ITEM_B.ITEM_NAME,   
         ID_ITEM_B.ITEM_SPEC,   
         ID_ENG_BOM_SMT_REPLACE.ITEM_TYPE,   
         ID_ENG_BOM_SMT_REPLACE.LINE_TYPE,   
         ID_ENG_BOM_SMT_REPLACE.BOM_LEVEL,   
         ID_ENG_BOM_SMT_REPLACE.ORGANIZATION_ID,   
         ID_ENG_BOM_SMT_REPLACE.LOCATION_CODE,   
         SUBSTR(ID_ENG_BOM_SMT_REPLACE.LOCATION_CODE,1,1) TABLE_ID ,   
         ID_ENG_BOM_SMT_REPLACE.LINE_CODE,   
         ID_ENG_BOM_SMT_REPLACE.MACHINE,   
         IB_LINE_MASTER.LINE_NAME,   
         IB_LINE_MASTER.MACHINE_NAME,   
         '*'||ID_ENG_BOM_SMT_REPLACE.LOCATION_CODE||'*' LOCATION_BARCODE,   
        IB_LINE_MASTER.line_division  line_division ,
         '*'||ID_ENG_BOM_SMT_REPLACE.PARENT_ITEM_CODE||'*' PARENT_ITEM_BARCODE,   
         ID_ENG_BOM_SMT_REPLACE.REPLACE_ITEM_CODE LOCATION_INFO  ,

   ID_ENG_BOM_SMT_REPLACE.VERSION,   
	   ID_ENG_BOM_SMT_REPLACE.PCB_ITEM,   
	   ID_ENG_BOM_SMT_REPLACE.MARKING_NO,
	   ID_ENG_BOM_SMT_REPLACE.COMMENTS ,

       IB_LINE_MASTER.SHOW_TABLE_YN	 SHOW_TABLE_YN
    FROM ID_ENG_BOM_SMT_REPLACE,   
         ID_ITEM ID_ITEM_A,   
         ID_ITEM ID_ITEM_B,   
         IB_LINE_MASTER,   
         IB_MACHINE_LOCATION  
   WHERE ( ID_ENG_BOM_SMT_REPLACE.CHILD_ITEM_CODE = ID_ITEM_A.ITEM_CODE (+)) AND  
         ( ID_ENG_BOM_SMT_REPLACE.ORGANIZATION_ID = ID_ITEM_A.ORGANIZATION_ID (+)) AND  
         ( ID_ENG_BOM_SMT_REPLACE.PARENT_ITEM_CODE = ID_ITEM_B.ITEM_CODE (+)) AND  
         ( ID_ENG_BOM_SMT_REPLACE.ORGANIZATION_ID = ID_ITEM_B.ORGANIZATION_ID (+)) AND  

         ( ID_ENG_BOM_SMT_REPLACE.LINE_CODE = IB_LINE_MASTER.LINE_CODE (+)) AND  
  	     ( ID_ENG_BOM_SMT_REPLACE.MACHINE = IB_LINE_MASTER.MACHINE (+)) AND  
   		( ID_ENG_BOM_SMT_REPLACE.ORGANIZATION_ID = IB_LINE_MASTER.ORGANIZATION_ID (+)) AND  
         ( ID_ENG_BOM_SMT_REPLACE.ORGANIZATION_ID = IB_MACHINE_LOCATION.ORGANIZATION_ID) AND  
         ( ID_ENG_BOM_SMT_REPLACE.LOCATION_CODE = IB_MACHINE_LOCATION.LOCATION_CODE) AND  
         ( ID_ENG_BOM_SMT_REPLACE.PARENT_ITEM_CODE LIKE :ARG_PARENT_ITEM ) AND  
         ( ID_ENG_BOM_SMT_REPLACE.LINE_CODE LIKE :ARG_LINE_CODE ) AND  
         ( ID_ENG_BOM_SMT_REPLACE.MACHINE LIKE :ARG_MACHINE ) AND  
         ( ID_ENG_BOM_SMT_REPLACE.DATESET <= :ARG_DATESET ) AND  
         ( ID_ENG_BOM_SMT_REPLACE.DATEEND >= :ARG_DATESET ) AND  
         ( ID_ENG_BOM_SMT_REPLACE.ORGANIZATION_ID = :ARG_ORG )  AND 
		
         ( ID_ENG_BOM_SMT_REPLACE.PARENT_ITEM_CODE ,  ID_ENG_BOM_SMT_REPLACE.CHILD_ITEM_CODE ) 
         IN ( SELECT ID_ENG_BOM_SMT.PARENT_ITEM_CODE ,  ID_ENG_BOM_SMT.CHILD_ITEM_CODE 
               FROM  ID_ENG_BOM_SMT
			WHERE      
         ( ID_ENG_BOM_SMT.PARENT_ITEM_CODE LIKE :ARG_PARENT_ITEM ) AND  
         ( ID_ENG_BOM_SMT.LINE_CODE LIKE :ARG_LINE_CODE ) AND  
         ( ID_ENG_BOM_SMT.MACHINE LIKE :ARG_MACHINE ) AND  
         ( ID_ENG_BOM_SMT.DATESET <= :ARG_DATESET ) AND  
         ( ID_ENG_BOM_SMT.DATEEND >= :ARG_DATESET ) AND  
         ( ID_ENG_BOM_SMT.ORGANIZATION_ID = :ARG_ORG )    
  	) 

  */
" arguments=(("ARG_PARENT_ITEM", string),("ARG_DATESET", datetime),("ARG_LINE_CODE", string),("ARG_MACHINE", string),("ARG_TOPBOT", string),("ARG_ORG", number))  sort="line_code A                     machine A                     parent_item_code A                     INTEGER(table_id) A                    sort_sequence A " )
