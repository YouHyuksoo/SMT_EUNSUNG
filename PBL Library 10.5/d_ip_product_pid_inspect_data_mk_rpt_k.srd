 column=(type=char(20) updatewhereclause=yes name=result_code dbname="iq_machine_inspect_data_mk.result_code" )
 column=(type=char(20) updatewhereclause=yes name=dateset dbname="iq_machine_inspect_data_mk.dateset" )
 column=(type=char(20) updatewhereclause=yes name=equipmentid dbname="iq_machine_inspect_data_mk.equipmentid" )
