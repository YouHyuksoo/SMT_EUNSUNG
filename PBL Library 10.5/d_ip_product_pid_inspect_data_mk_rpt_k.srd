 column=(type=char(100) updatewhereclause=yes name=cstid dbname="iq_machine_inspect_data_mk.cstid" )
 column=(type=char(20) updatewhereclause=yes name=seq dbname="iq_machine_inspect_data_mk.seq" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="iq_machine_inspect_data_mk.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="iq_machine_inspect_data_mk.enter_by" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="iq_machine_inspect_data_mk.organization_id" )
 column=(type=char(4000) updatewhereclause=yes name=line_code dbname="line_code" )
 retrieve=" select pid, 
          result_code,
          dateset, 
          equipmentid, 
          run_no,
          cstid, 
          seq,
          enter_date, 
          enter_by, 
          organization_id  ,
          f_get_line_name( line_code, organization_id)  line_code
  from iq_machine_inspect_data_mk 
where PID LIKE :ARG_SERIAL_NO 
   AND ORGANIZATION_ID = :ARG_ORG
" arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="pid A dateset A " )
