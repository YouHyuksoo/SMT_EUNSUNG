 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_jig~" ) COLUMN(NAME=~"imcn_jig.jig_code~") COLUMN(NAME=~"imcn_jig.organization_id~") COLUMN(NAME=~"imcn_jig.jig_name~") COLUMN(NAME=~"imcn_jig.jig_type~") COLUMN(NAME=~"imcn_jig.capacity~") COLUMN(NAME=~"imcn_jig.acquisition_date~") COLUMN(NAME=~"imcn_jig.acquisition_type~") COLUMN(NAME=~"imcn_jig.jig_model_name~") COLUMN(NAME=~"imcn_jig.line_code~") COLUMN(NAME=~"imcn_jig.customer_code~") COLUMN(NAME=~"imcn_jig.use_status~") COLUMN(NAME=~"imcn_jig.manual_location_comment~") COLUMN(NAME=~"imcn_jig.nation_code~") COLUMN(NAME=~"imcn_jig.workstage_code~") COLUMN(NAME=~"imcn_jig.enter_by~") COLUMN(NAME=~"imcn_jig.enter_date~") COLUMN(NAME=~"imcn_jig.last_modify_by~") COLUMN(NAME=~"imcn_jig.last_modify_date~") COLUMN(NAME=~"imcn_jig.use_rate~") COLUMN(NAME=~"imcn_jig.uph_value~") COLUMN(NAME=~"imcn_jig.capacity_uom~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"imcn_jig.supplier_code~") COLUMN(NAME=~"imcn_jig.jig_status~") COMPUTE(NAME=~"DECODE( NVL( LENGTH(IMCN_JIG.JIG_IMAGE) ,0 ) ,0 , 'N' , 'Y' ) JIG_IMAGE_EXISTS_YN~") COLUMN(NAME=~"imcn_jig.break_value~") COLUMN(NAME=~"imcn_jig.hit_value~") COLUMN(NAME=~"imcn_jig.machine_code~") COLUMN(NAME=~"imcn_jig.jig_lot_no~") COLUMN(NAME=~"imcn_jig.jig_spec~") COLUMN(NAME=~"imcn_jig.item_code~") COLUMN(NAME=~"imcn_jig.location_address~") COMPUTE(NAME=~"ROWID~")WHERE(    EXP1 =~"( ~~~"IMCN_JIG~~~".~~~"JIG_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_jig_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG~~~".~~~"JIG_TYPE~~~"~"   OP =~"like~"    EXP2 =~":arg_jig_type )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG~~~".~~~"LINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_line_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org )~" ) ) ARG(NAME = ~"arg_jig_code~" TYPE = string)  ARG(NAME = ~"arg_jig_type~" TYPE = string)  ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IMCN_JIG" updatewhere=0 updatekeyinplace=yes arguments=(("arg_jig_code", string),("arg_jig_type", string),("arg_line_code", string),("arg_org", number))  sort="jig_type A jig_code A jig_lot_no A " )
