 retrieve="  SELECT ~"IM_ITEM_UNIT_PRICE~".~"LINE_TYPE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"UNIT_PRICE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"ENTER_DATE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"ENTER_BY~",   
         ~"IM_ITEM_UNIT_PRICE~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_UNIT_PRICE~".~"PRICE_CHANGE_CONFIRM_YN~",   
         ~"IM_ITEM_UNIT_PRICE~".~"CONFIRM_DATE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"PRICE_TYPE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"CURRENCY~",   
         ~"IM_ITEM_UNIT_PRICE~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"IM_ITEM_UNIT_PRICE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_UNIT_PRICE~".~"STANDARD_UNIT_PRICE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"DATESET~",   
         ~"IM_ITEM_UNIT_PRICE~".~"DATEEND~",   
         ~"IM_ITEM_UNIT_PRICE~".~"DELIVERY~",   
         ~"IM_ITEM_UNIT_PRICE~".~"TAX_RATE~",
         f_get_mat_last_unit_price_cfm( IM_ITEM_UNIT_PRICE.SUPPLIER_CODE , IM_ITEM_UNIT_PRICE.ITEM_CODE , IM_ITEM_UNIT_PRICE.LINE_TYPE , IM_ITEM_UNIT_PRICE.DATESET , IM_ITEM_UNIT_PRICE.ORGANIZATION_ID ) LAST_BUY_PRICE ,
	    f_get_mat_mm_avg_price( TO_CHAR(add_months(SYSDATE,-1),'YYYYMM') , IM_ITEM_UNIT_PRICE.ITEM_CODE , IM_ITEM_UNIT_PRICE.LINE_TYPE , IM_ITEM_UNIT_PRICE.ORGANIZATION_ID ) LAST_AVG_PRICE ,
	    f_get_mat_mm_avg_price( TO_CHAR(SYSDATE,'YYYYMM') , IM_ITEM_UNIT_PRICE.ITEM_CODE , IM_ITEM_UNIT_PRICE.LINE_TYPE , IM_ITEM_UNIT_PRICE.ORGANIZATION_ID ) AVG_PRICE
    FROM ~"IM_ITEM_UNIT_PRICE~",   
         ~"ID_ITEM~",   
         ~"ICOM_SUPPLIER~"  
   WHERE ( ~"IM_ITEM_UNIT_PRICE~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_UNIT_PRICE~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_UNIT_PRICE~".~"SUPPLIER_CODE~" = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" ) and  
         ( ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" = ~"IM_ITEM_UNIT_PRICE~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_UNIT_PRICE~".~"DATESET~" <= :arg_dateset) AND  
         ~"IM_ITEM_UNIT_PRICE~".~"DATEEND~" >= :arg_dateset AND  
         ( ~"IM_ITEM_UNIT_PRICE~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_UNIT_PRICE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_UNIT_PRICE~".~"ORGANIZATION_ID~" = :arg_org_id )    
" arguments=(("arg_dateset", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_org_id", number))  sort="organization_id A supplier_code A item_code A " )
group(level=1 header.height=92 trailer.height=0 by=("organization_id" , "supplier_code" ) header.suppress=yes header.color="65535" trailer.color="536870912" )
