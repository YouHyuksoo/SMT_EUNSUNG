 column=(type=char(10) update=yes updatewhereclause=yes name=attribute02 dbname="iq_iqc_inspect_history.attribute02" )
 column=(type=char(10) update=yes updatewhereclause=yes name=attribute03 dbname="iq_iqc_inspect_history.attribute03" )
 column=(type=char(10) update=yes updatewhereclause=yes name=attribute04 dbname="iq_iqc_inspect_history.attribute04" )
 column=(type=char(10) update=yes updatewhereclause=yes name=attribute05 dbname="iq_iqc_inspect_history.attribute05" )
 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="iq_iqc_inspect_history.enter_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=enter_by dbname="iq_iqc_inspect_history.enter_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="iq_iqc_inspect_history.last_modify_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="iq_iqc_inspect_history.last_modify_by" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="iq_iqc_inspect_history.organization_id" )
 column=(type=char(20) updatewhereclause=yes name=defect_code dbname="iq_iqc_inspect_history.defect_code" )
 column=(type=char(30) updatewhereclause=yes name=bad_reason_code dbname="iq_iqc_inspect_history.bad_reason_code" )
 column=(type=number updatewhereclause=yes name=inspect_qty dbname="iq_iqc_inspect_history.inspect_qty" )
 column=(type=number updatewhereclause=yes name=defect_qty dbname="iq_iqc_inspect_history.defect_qty" )
 retrieve="select  inspect_date, 
        inspect_sequence, 
        model_name, 
        model_suffix, 
        item_code, 
        lot_no, 
        inspect_type, 
        inspect_result, 
        comments, 
        inspector, 
        attribute01, 
        attribute02, 
        attribute03, 
        attribute04, 
        attribute05, 
        enter_date, 
        enter_by, 
        last_modify_date, 
        last_modify_by, 
        organization_id ,
        defect_code ,
        bad_reason_code ,
	   inspect_qty ,
	   defect_qty

  from iq_iqc_inspect_history 
where inspect_date >= :arg_sdate 
    and inspect_date <  :arg_edate + 1
   
    and inspect_type like :arg_inspect_type
    and organization_id = :arg_org 

    and model_name like :arg_model
    and item_code    like :arg_item
    and lot_no    like :arg_pid" arguments=(("arg_sdate", datetime),("arg_edate", datetime),("arg_inspect_type", string),("arg_org", number),("arg_model", string),("arg_item", string),("arg_pid", string))  sort="inspector A model_name A inspect_date A " )
