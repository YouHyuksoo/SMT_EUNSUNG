table(column=(type=datetime update=yes updatewhereclause=yes name=inspect_date dbname="iq_iqc_inspect_history.inspect_date" )
 column=(type=number update=yes updatewhereclause=yes name=inspect_sequence dbname="iq_iqc_inspect_history.inspect_sequence" )
 column=(type=char(30) update=yes updatewhereclause=yes name=model_name dbname="iq_iqc_inspect_history.model_name" )
