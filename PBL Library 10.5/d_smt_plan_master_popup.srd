 column=(type=char(30) updatewhereclause=yes name=machine dbname="machine" )
 column=(type=char(30) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(1) updatewhereclause=yes name=check_status dbname="check_status" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="organization_id" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="location_code" )
 column=(type=char(200) updatewhereclause=yes name=item_barcode dbname="item_barcode" )
 column=(type=char(10) updatewhereclause=yes name=table_id dbname="table_id" )
 column=(type=datetime updatewhereclause=yes name=feeding_date dbname="feeding_date" )
 column=(type=datetime updatewhereclause=yes name=recycle_date dbname="recycle_date" )
 column=(type=number update=yes updatewhereclause=yes name=feeding_qty dbname="feeding_qty" )
 column=(type=datetime updatewhereclause=yes name=change_date dbname="change_date" )
 column=(type=number updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=number updatewhereclause=yes name=product_actual_qty dbname="product_actual_qty" )
 column=(type=char(30) updatewhereclause=yes name=pcb_item dbname="pcb_item" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="item_unit_qty" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="parent_item_code" )
 column=(type=datetime updatewhereclause=yes name=last_actual_date dbname="last_actual_date" )
 column=(type=number updatewhereclause=yes name=passed_time dbname="passed_time" )
 column=(type=number updatewhereclause=yes name=remain_qty dbname="remain_qty" )
 column=(type=number updatewhereclause=yes name=return_qty dbname="return_qty" )
 column=(type=number updatewhereclause=yes name=feeding_count dbname="feeding_count" )
 column=(type=char(82) updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number updatewhereclause=yes name=product_acceptable_qty dbname="product_acceptable_qty" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="location_address" )
 column=(type=number updatewhereclause=yes name=real_st dbname="real_st" )
 column=(type=char(1) updatewhereclause=yes name=line_status dbname="line_status" )
 column=(type=number updatewhereclause=yes name=remain_time dbname="remain_time" )
 column=(type=number updatewhereclause=yes name=st_value dbname="st_value" )
 column=(type=char(4000) updatewhereclause=yes name=use_status dbname="use_status" )
 column=(type=char(30) updatewhereclause=yes name=nsnp_status dbname="nsnp_status" )
 column=(type=number updatewhereclause=yes name=new_scan_qty dbname="new_scan_qty" )
 retrieve="SELECT X.PLAN_DATE,   
         X.MODEL_NAME,   
         X.MODEL_SUFFIX AS MODEL_SUFFIX,   
         X.ITEM_CODE,   
         X.LOT_NO,   
         X.CHIPNAME,   
         X.CHECK_YN,   
         X.SELECTED_DATE,   
         X.MACHINE,   
         X.LINE_CODE,   
         X.CHECK_STATUS,   
         X.ORGANIZATION_ID,   
         X.LOCATION_CODE,   
         X.ITEM_BARCODE,   
         X.TABLE_ID,   
         X.FEEDING_DATE,   
         X.RECYCLE_DATE,   
         X.FEEDING_QTY,   
         X.CHANGE_DATE,   
		X.PLAN_QTY ,
         X.PRODUCT_ACTUAL_QTY,   
         X.PCB_ITEM  ,
		X.ITEM_UNIT_QTY  ,
		X.PARENT_ITEM_CODE,
		X.LAST_ACTUAL_DATE,
		X.PASSED_TIME ,
		X.REMAIN_QTY ,
		X.RETURN_QTY ,
		X.FEEDING_COUNT ,
		X.INVENTORY_QTY ,
		X.Product_Acceptable_Qty,
		X.ITEM_NAME ITEM_NAME , 
		X.ITEM_SPEC ITEM_SPEC ,
		X.LOCATION_ADDRESS ,
         X.REAL_ST,
		X.LINE_STATUS ,
         X.REMAIN_TIME ,
         X.ST_VALUE  ,

		X.USE_STATUS ,
		X.NSNP_STATUS NSNP_STATUS ,

		X.NEW_SCAN_QTY
FROM
(  
SELECT A.PLAN_DATE,   
         A.MODEL_NAME,   
         A.MODEL_SUFFIX AS MODEL_SUFFIX,   
         A.ITEM_CODE,   
         A.LOT_NO,   
         A.CHIPNAME,   
         A.CHECK_YN,   
         A.SELECTED_DATE,   
         A.MACHINE,   
         A.LINE_CODE,   
         A.CHECK_STATUS,   
         A.ORGANIZATION_ID,   
         A.LOCATION_CODE,   
         A.ITEM_BARCODE,   
         A.TABLE_ID,   
         A.FEEDING_DATE,   
         A.RECYCLE_DATE,   
         A.FEEDING_QTY,   
         A.CHANGE_DATE,   
		0 PLAN_QTY ,
         A.PRODUCT_ACTUAL_QTY,   
         A.PCB_ITEM  ,
		A.ITEM_UNIT_QTY  ,
		A.PARENT_ITEM_CODE  AS PARENT_ITEM_CODE,
		A.LAST_ACTUAL_DATE  AS LAST_ACTUAL_DATE,
		( SYSDATE  - A.LAST_ACTUAL_DATE ) * 24 * 60 * 60 AS PASSED_TIME ,
		NVL( A.FEEDING_QTY , 0)  - ( NVL(A.PRODUCT_ACTUAL_QTY,0) )  REMAIN_QTY ,
		RETURN_QTY ,
		FEEDING_COUNT ,
		(SELECT SUM(D.INVENTORY_QTY)||'('||COUNT(*) ||')'  FROM IM_ITEM_INVENTORY  D WHERE D.ITEM_CODE =  A.ITEM_CODE AND D.INVENTORY_QTY > 0 AND LOCATION_CODE IN ('M01' , 'M05' , 'M06' ) )  INVENTORY_QTY ,
		CASE WHEN NVL( A.ITEM_UNIT_QTY, 0 ) = 0 THEN 1
                      ELSE ROUND(( NVL( A.FEEDING_QTY , 0)  - ( NVL(A.PRODUCT_ACTUAL_QTY,0) ) + F_GET_LINE_SCAN_QTY(A.ITEM_CODE, A.LINE_CODE, A.ORGANIZATION_ID) ) / NVL( A.ITEM_UNIT_QTY, 0 )) END  Product_Acceptable_Qty,
		B.ITEM_NAME ITEM_NAME , 
		B.ITEM_SPEC ITEM_SPEC ,
		B.LOCATION_ADDRESS ,
         C.REAL_ST AS REAL_ST,
		C.LINE_STATUS  LINE_STATUS ,

		DECODE( NVL(A.item_unit_qty * C.REAL_ST,0) , 0 , 0 ,TRUNC(  (NVL( A.FEEDING_QTY , 0)- NVL(A.PRODUCT_ACTUAL_QTY,0) ) / A.item_unit_qty * C.REAL_ST / 60 , 0 ) ) REMAIN_TIME ,

		f_get_product_st(  A.PARENT_ITEM_CODE,    A.LINE_CODE,   '*' , '*' , A.ORGANIZATION_ID ) ST_VALUE  ,

		f_get_nsnp_use_status( A.LINE_CODE , A.ORGANIZATION_ID ) USE_STATUS ,
		C.NSNP_STATUS NSNP_STATUS ,

		(SELECT E.NEW_SCAN_QTY FROM IM_ITEM_RECEIPT_BARCODE E WHERE E.ITEM_CODE = A.ITEM_CODE AND E.LOT_NO = A.LOT_NO ) NEW_SCAN_QTY

    FROM IB_PRODUCT_PLANDATA  A , ID_ITEM B , IP_PRODUCT_LINE  C
   WHERE  A.ITEM_CODE = B.ITEM_CODE(+) 
	    AND A.ORGANIZATION_ID = B.ORGANIZATION_ID(+) 
        AND A.LINE_CODE = C.LINE_CODE(+)
 		 AND A.ORGANIZATION_ID = C.ORGANIZATION_ID(+) 
		AND A.LINE_CODE  = :arg_line_code
		AND A.MODEL_NAME  = :arg_model_name
         AND  A.ACTIVE_YN LIKE :ARG_ACTIVE 
         AND A.ITEM_UNIT_QTY > 0 
         AND A.PRODUCT_ACTUAL_QTY > 0 
		AND A.ITEM_UNIT_QTY <= :arg_item_unit_qty
         AND A.ORGANIZATION_ID = :arg_org
		AND A.LOCATION_CODE NOT LIKE 'TRAY%'
) X" arguments=(("arg_line_code", string),("arg_model_name", string),("arg_active", string),("arg_item_unit_qty", number),("arg_org", number))  sort="line_code A model_name A remain_time A location_code A " )
