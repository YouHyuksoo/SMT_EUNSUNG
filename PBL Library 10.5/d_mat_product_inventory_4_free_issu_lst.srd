 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"is_product_inventory~" )  TABLE(NAME=~"id_item~" ) COMPUTE(NAME=~"'N' check_yn~") COMPUTE(NAME=~"'INTERNAL' WAREHOSUE_TYPE~") COLUMN(NAME=~"is_product_inventory.item_code~") COLUMN(NAME=~"is_product_inventory.organization_id~") COLUMN(NAME=~"is_product_inventory.product_line_type~") COLUMN(NAME=~"is_product_inventory.inventory_price~") COLUMN(NAME=~"is_product_inventory.inventory_qty~") COLUMN(NAME=~"is_product_inventory.inventory_amt~") COLUMN(NAME=~"is_product_inventory.location_code~") COLUMN(NAME=~"is_product_inventory.enter_date~") COLUMN(NAME=~"is_product_inventory.enter_by~") COLUMN(NAME=~"is_product_inventory.last_modify_date~") COLUMN(NAME=~"is_product_inventory.last_modify_by~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_type~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"is_product_inventory.mfs~") COMPUTE(NAME=~"( IS_PRODUCT_INVENTORY.INVENTORY_QTY - NVL(IS_PRODUCT_INVENTORY.REQUEST_QTY,0) )  ISSUE_QTY~") COLUMN(NAME=~"is_product_inventory.shipment_qty~") COLUMN(NAME=~"is_product_inventory.request_qty~")    JOIN (LEFT=~"id_item.item_code~"    OP =~"=~"RIGHT=~"is_product_inventory.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"is_product_inventory.organization_id~" )WHERE(    EXP1 =~"( ~~~"IS_PRODUCT_INVENTORY~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IS_PRODUCT_INVENTORY~~~".~~~"INVENTORY_QTY~~~" - nvl(~~~"IS_PRODUCT_INVENTORY~~~".~~~"REQUEST_QTY~~~",0)~"   OP =~">~"    EXP2 =~"0~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IS_PRODUCT_INVENTORY~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_item_code", string),("arg_org_id", number))  sort="organization_id A warehosue_type A item_code A " )
