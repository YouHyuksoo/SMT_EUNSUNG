 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"icom_exchange_rate~" ) COLUMN(NAME=~"icom_exchange_rate.dateset~") COLUMN(NAME=~"icom_exchange_rate.currency~") COLUMN(NAME=~"icom_exchange_rate.exchange_rate~") COLUMN(NAME=~"icom_exchange_rate.selling_rate~") COLUMN(NAME=~"icom_exchange_rate.buying_rate~") COLUMN(NAME=~"icom_exchange_rate.enter_by~") COLUMN(NAME=~"icom_exchange_rate.enter_date~") COLUMN(NAME=~"icom_exchange_rate.last_modify_by~") COLUMN(NAME=~"icom_exchange_rate.last_modify_date~") COLUMN(NAME=~"icom_exchange_rate.basis_currency~")WHERE(    EXP1 =~"( ~~~"ICOM_EXCHANGE_RATE~~~".~~~"DATESET~~~"~"   OP =~">=~"    EXP2 =~":ARG_DATESET )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"ICOM_EXCHANGE_RATE~~~".~~~"DATESET~~~"~"   OP =~"<=~"    EXP2 =~":ARG_DATEEND )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"ICOM_EXCHANGE_RATE~~~".~~~"CURRENCY~~~"~"   OP =~"LIKE~"    EXP2 =~":ARG_CURRENCY_CODE )~" ) ) ARG(NAME = ~"ARG_DATESET~" TYPE = datetime)  ARG(NAME = ~"ARG_DATEEND~" TYPE = datetime)  ARG(NAME = ~"ARG_CURRENCY_CODE~" TYPE = string) " update="ICOM_EXCHANGE_RATE" updatewhere=1 updatekeyinplace=no arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_CURRENCY_CODE", string))  sort="dateset A currency A " )
