 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_mold_purchase_order~" )  TABLE(NAME=~"imcn_mold~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"imcn_mold_purchase_order.order_no~") COLUMN(NAME=~"imcn_mold_purchase_order.organization_id~") COLUMN(NAME=~"imcn_mold_purchase_order.purchase_order_date~") COLUMN(NAME=~"imcn_mold_purchase_order.delivery_date~") COLUMN(NAME=~"imcn_mold_purchase_order.order_qty~") COLUMN(NAME=~"imcn_mold_purchase_order.unit_price~") COLUMN(NAME=~"imcn_mold_purchase_order.currency~") COLUMN(NAME=~"imcn_mold_purchase_order.enter_date~") COLUMN(NAME=~"imcn_mold_purchase_order.enter_by~") COLUMN(NAME=~"imcn_mold_purchase_order.mold_code~") COLUMN(NAME=~"imcn_mold_purchase_order.last_modify_date~") COLUMN(NAME=~"imcn_mold_purchase_order.last_modify_by~") COLUMN(NAME=~"imcn_mold.mold_name~") COLUMN(NAME=~"imcn_mold.mold_spec~") COLUMN(NAME=~"imcn_mold_purchase_order.supplier_code~") COLUMN(NAME=~"imcn_mold_purchase_order.order_group_no~") COLUMN(NAME=~"imcn_mold_purchase_order.incidental_expense_code~") COLUMN(NAME=~"imcn_mold_purchase_order.delivery_method~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"imcn_mold_purchase_order.receipt_qty~")    JOIN (LEFT=~"imcn_mold_purchase_order.mold_code~"    OP =~"=~"RIGHT=~"imcn_mold.mold_code~" )    JOIN (LEFT=~"imcn_mold.organization_id~"    OP =~"=~"RIGHT=~"imcn_mold_purchase_order.organization_id~" )    JOIN (LEFT=~"imcn_mold_purchase_order.supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier.supplier_code~" )    JOIN (LEFT=~"icom_supplier.organization_id~"    OP =~"=~"RIGHT=~"imcn_mold_purchase_order.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"MOLD_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_mold_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"DELIVERY_DATE~~~"~"   OP =~">=~"    EXP2 =~":arg_dateset )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"DELIVERY_DATE~~~"~"   OP =~"<=~"    EXP2 =~":arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"(~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_mold_code~" TYPE = string)  ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_supplier_code", string),("arg_mold_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org_id", number))  sort="order_group_no A purchase_order_date A supplier_code A mold_code A " )
