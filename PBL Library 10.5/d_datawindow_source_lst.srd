 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"isys_report_source~" ) COLUMN(NAME=~"isys_report_source.datawindow_name~") COLUMN(NAME=~"isys_report_source.organization_id~") COLUMN(NAME=~"isys_report_source.report_title~") COLUMN(NAME=~"isys_report_source.report_style~") COLUMN(NAME=~"isys_report_source.presentation_style~") COLUMN(NAME=~"isys_report_source.comments~") COLUMN(NAME=~"isys_report_source.version~") COLUMN(NAME=~"isys_report_source.enter_by~") COLUMN(NAME=~"isys_report_source.enter_date~") COLUMN(NAME=~"isys_report_source.last_modify_by~") COLUMN(NAME=~"isys_report_source.last_modify_date~") COMPUTE(NAME=~"F_CHECK_REPORT_MENU_EXISTS( DATAWINDOW_NAME , ORGANIZATION_ID ) MENU_EXISTS_YN~") COLUMN(NAME=~"isys_report_source.report_group~")WHERE(    EXP1 =~"~~~"ISYS_REPORT_SOURCE~~~".~~~"DATAWINDOW_NAME~~~"~"   OP =~"like~"    EXP2 =~":arg_datawindow_name~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"ISYS_REPORT_SOURCE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_datawindow_name~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="ISYS_REPORT_SOURCE" updatewhere=1 updatekeyinplace=no arguments=(("arg_datawindow_name", string),("arg_org", number))  sort="organization_id A datawindow_name A " )
