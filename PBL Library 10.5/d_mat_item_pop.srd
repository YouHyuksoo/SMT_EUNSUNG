 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_master~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"im_item_master.item_code~") COLUMN(NAME=~"im_item_master.supplier_code~") COLUMN(NAME=~"im_item_master.dateset~") COLUMN(NAME=~"im_item_master.organization_id~") COLUMN(NAME=~"im_item_master.order_type~") COLUMN(NAME=~"im_item_master.order_rate~") COLUMN(NAME=~"im_item_master.order_leadtime~") COLUMN(NAME=~"im_item_master.order_bad_rate~") COLUMN(NAME=~"im_item_master.mim_order_qty~") COLUMN(NAME=~"im_item_master.packing_qty~") COLUMN(NAME=~"im_item_master.longterm_delivery_yn~") COLUMN(NAME=~"im_item_master.warehouse_charge~") COLUMN(NAME=~"im_item_master.order_charge~") COLUMN(NAME=~"im_item_master.dateend~") COLUMN(NAME=~"im_item_master.main_vendor_yn~") COLUMN(NAME=~"im_item_master.payment_type~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"id_item.item_type~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.line_type~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"id_item.item_class~") COLUMN(NAME=~"id_item.raw_material~") COLUMN(NAME=~"id_item.item_division~")    JOIN (LEFT=~"im_item_master.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_master.organization_id~" )    JOIN (LEFT=~"im_item_master.supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier.supplier_code~" )    JOIN (LEFT=~"icom_supplier.organization_id~"    OP =~"=~"RIGHT=~"im_item_master.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_MASTER~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_MASTER~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_MASTER~~~".~~~"DATESET~~~"~"   OP =~"<=~"    EXP2 =~":arg_date~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_MASTER~~~".~~~"DATEEND~~~"~"   OP =~">=~"    EXP2 =~":arg_date~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_MASTER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_date~" TYPE = datetime)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_date", datetime),("arg_org_id", number))  sort="organization_id A item_class A " )
