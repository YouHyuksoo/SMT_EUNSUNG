column(band=detail id=2 alignment="2" tabsequence=32766 border="0" color="33554432" x="457" y="4" height="52" width="215" format="[general]" html.valueishtml="0"  name=location_address_rack visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="1073741824" )
column(band=detail id=3 alignment="2" tabsequence=32766 border="0" color="33554432" x="384" y="4" height="52" width="64" format="[general]" html.valueishtml="0"  name=abc_grade visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="0" background.color="1073741824~tIF ( ABC_GRADE = 'A' , 255 ,   if ( abc_grade = 'B' ,    RGB(255,255,128) ,  RGB(255,255,255) ) )" )
