    FROM ‾"ID_ENG_BOM_SMT‾"  
   WHERE ( ‾"ID_ENG_BOM_SMT‾".‾"LINE_CODE‾" like :arg_line_code ) AND  
         ( ‾"ID_ENG_BOM_SMT‾".‾"PARENT_ITEM_CODE‾"||ID_ENG_BOM_SMT.PCB_ITEM in ( :arg_parent_item_code ) ) AND  
         ( ‾"ID_ENG_BOM_SMT‾".‾"ORGANIZATION_ID‾" = :arg_org )    
