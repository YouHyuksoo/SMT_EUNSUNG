summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=actual_date dbname="ip_product_fg_receipt.actual_date" )
 column=(type=char(1) updatewhereclause=yes name=shift_code dbname="ip_product_fg_receipt.shift_code" )
 column=(type=char(2) updatewhereclause=yes name=work_time_zone dbname="ip_product_fg_receipt.work_time_zone" )
 column=(type=datetime updatewhereclause=yes name=receipt_date dbname="ip_product_fg_receipt.receipt_date" )
 column=(type=number updatewhereclause=yes name=receipt_sequence dbname="ip_product_fg_receipt.receipt_sequence" )
 column=(type=char(100) updatewhereclause=yes name=barcode dbname="ip_product_fg_receipt.barcode" )
 column=(type=char(2) updatewhereclause=yes name=pack_type dbname="ip_product_fg_receipt.pack_type" )
 column=(type=char(1) updatewhereclause=yes name=txn_deficit dbname="ip_product_fg_receipt.txn_deficit" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 column=(type=char(20) updatewhereclause=yes name=model_name dbname="ip_product_fg_receipt.model_name" )
 column=(type=char(10) updatewhereclause=yes name=model_suffix dbname="ip_product_fg_receipt.model_suffix" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="ip_product_fg_receipt.item_code" )
 column=(type=char(10) updatewhereclause=yes name=item_type dbname="ip_product_fg_receipt.item_type" )
 column=(type=char(30) updatewhereclause=yes name=mfs dbname="ip_product_fg_receipt.mfs" )
 column=(type=char(5) updatewhereclause=yes name=line_code dbname="ip_product_fg_receipt.line_code" )
 column=(type=char(5) updatewhereclause=yes name=workstage_code dbname="ip_product_fg_receipt.workstage_code" )
 column=(type=char(5) updatewhereclause=yes name=machine_code dbname="ip_product_fg_receipt.machine_code" )
 column=(type=char(10) updatewhereclause=yes name=product_location_code dbname="ip_product_fg_receipt.location_code" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_fg_receipt.enter_by" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="ip_product_fg_receipt.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="ip_product_fg_receipt.last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="ip_product_fg_receipt.last_modify_date" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_fg_receipt.organization_id" )
 retrieve="select 
         actual_date, 
		shift_code, 
		work_time_zone, 

         receipt_date, 
		receipt_sequence, 
		barcode, 
		pack_type, 
		txn_deficit, 
		qty * decode( txn_deficit, '1', 1 , -1) as qty , 
		model_name, 
		model_suffix, 
		item_code, 
		item_type, 
		mfs, 
		line_code, 
		workstage_code, 
		machine_code, 
		location_code, 
		enter_by, 
		enter_date, 
		last_modify_by, 
		last_modify_date, 
		organization_id 
		
  from ip_product_fg_receipt 
where receipt_date >= :arg_sdate 
   and receipt_date <  :arg_edate + 1 
   and model_name like :arg_model 
   and barcode       like :arg_barcode  
   and txn_deficit    like :arg_txntype " arguments=(("arg_lang", string),("arg_sdate", datetime),("arg_edate", datetime),("arg_model", string),("arg_barcode", string),("arg_txntype", string))  sort="receipt_date A receipt_sequence A " )
