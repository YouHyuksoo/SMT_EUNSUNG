table(column=(type=char(30) update=yes updatewhereclause=yes name=part_no dbname="part_no" )
 column=(type=char(1000) updatewhereclause=yes name=item_spec_1 dbname="item_spec_1" )
 column=(type=number updatewhereclause=yes name=component_qty_1 dbname="component_qty_1" )
 column=(type=char(8) updatewhereclause=yes name=expiry_date_1 dbname="expiry_date_1" )
 column=(type=char(20) updatewhereclause=yes name=eco_no_1 dbname="eco_no_1" )
 column=(type=char(30) updatewhereclause=yes name=parent_part_no_1 dbname="parent_part_no_1" )
 column=(type=char(20) updatewhereclause=yes name=substitute_item_1 dbname="substitute_item_1" )
 column=(type=char(2000) updatewhereclause=yes name=location_info_1 dbname="location_info_1" )
 column=(type=char(1000) updatewhereclause=yes name=item_spec_2 dbname="item_spec_2" )
 column=(type=number updatewhereclause=yes name=component_qty_2 dbname="component_qty_2" )
 column=(type=char(8) updatewhereclause=yes name=expiry_date_2 dbname="expiry_date_2" )
 column=(type=char(20) updatewhereclause=yes name=eco_no_2 dbname="eco_no_2" )
 column=(type=char(30) updatewhereclause=yes name=parent_part_no_2 dbname="parent_part_no_2" )
 column=(type=char(20) updatewhereclause=yes name=substitute_item_2 dbname="substitute_item_2" )
 column=(type=char(2000) updatewhereclause=yes name=location_info_2 dbname="location_info_2" )
 retrieve="SELECT     PART_NO                PART_NO,   
			 MAX(ITEM_SPEC_1)       ITEM_SPEC_1,   
			 MAX(COMPONENT_QTY_1)   COMPONENT_QTY_1,   
			 MAX(EXPIRY_DATE_1)     EXPIRY_DATE_1,   
			 MAX(ECO_NO_1)          ECO_NO_1,   
			 MAX(PARENT_PART_NO_1)  PARENT_PART_NO_1,   
			 MAX(SUBSTITUTE_ITEM_1) SUBSTITUTE_ITEM_1,   
			 MAX(LOCATION_INFO_1)   LOCATION_INFO_1,
			 MAX(ITEM_SPEC_2)       ITEM_SPEC_2,   
			 MAX(COMPONENT_QTY_2)   COMPONENT_QTY_2,   
			 MAX(EXPIRY_DATE_2)     EXPIRY_DATE_2,   
			 MAX(ECO_NO_2)          ECO_NO_2,   
			 MAX(PARENT_PART_NO_2)  PARENT_PART_NO_2,   
			 MAX(SUBSTITUTE_ITEM_2) SUBSTITUTE_ITEM_2,   
			 MAX(LOCATION_INFO_2)   LOCATION_INFO_2
FROM (       
			SELECT A.DIV                  DIV,
					 A.PART_NO,
					 A.PART_NO||'-'||A.PARENT_PART_NO             PART_NO2,
					 A.ITEM_SPEC           ITEM_SPEC_1,   
					 A.COMPONENT_QTY      COMPONENT_QTY_1,   
					 A.EXPIRY_DATE        EXPIRY_DATE_1,   
					 A.ECO_NO              ECO_NO_1,   
					 A.PARENT_PART_NO     PARENT_PART_NO_1,   
					 A.SUBSTITUTE_ITEM    SUBSTITUTE_ITEM_1,   
					 A.LOCATION_INFO      LOCATION_INFO_1,
					'' ITEM_SPEC_2,   
					 0  COMPONENT_QTY_2,   
					 '' EXPIRY_DATE_2,   
					 '' ECO_NO_2,   
					 '' PARENT_PART_NO_2,   
					 '' SUBSTITUTE_ITEM_2,   
					 '' LOCATION_INFO_2   
			  FROM 
					(  SELECT 'FILE1' DIV ,
								ID_ENG_BOM_EXCEL_LG_CPR1.PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR1.ITEM_SPEC,   
								ID_ENG_BOM_EXCEL_LG_CPR1.COMPONENT_QTY,   
								ID_ENG_BOM_EXCEL_LG_CPR1.EXPIRY_DATE,   
								ID_ENG_BOM_EXCEL_LG_CPR1.ECO_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR1.PARENT_PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR1.SUBSTITUTE_ITEM,   
								ID_ENG_BOM_EXCEL_LG_CPR1.LOCATION_INFO  
			
						 FROM ID_ENG_BOM_EXCEL_LG_CPR1   
			
					MINUS
			
					  SELECT  'FILE1' DIV ,
			
								ID_ENG_BOM_EXCEL_LG_CPR2.PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR2.ITEM_SPEC,   
								ID_ENG_BOM_EXCEL_LG_CPR2.COMPONENT_QTY,   
								ID_ENG_BOM_EXCEL_LG_CPR2.EXPIRY_DATE,   
								ID_ENG_BOM_EXCEL_LG_CPR2.ECO_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR2.PARENT_PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR2.SUBSTITUTE_ITEM,   
								ID_ENG_BOM_EXCEL_LG_CPR2.LOCATION_INFO  
						 FROM ID_ENG_BOM_EXCEL_LG_CPR2   
					) A
			
			UNION ALL
			
			SELECT B.DIV    DIV ,
					 B.PART_NO,
					 B.PART_NO||'-'||B.PARENT_PART_NO             PART_NO2,
					 '' ITEM_SPEC_1,   
					 0  COMPONENT_QTY_1,   
					 '' EXPIRY_DATE_1,   
					 '' ECO_NO_1,   
					 '' PARENT_PART_NO_1,   
					 '' SUBSTITUTE_ITEM_1,   
					 '' LOCATION_INFO_1,  
					 B.ITEM_SPEC           ITEM_SPEC_2,   
					 B.COMPONENT_QTY      COMPONENT_QTY_2,   
					 B.EXPIRY_DATE        EXPIRY_DATE_2,   
					 B.ECO_NO              ECO_NO_2,   
					 B.PARENT_PART_NO     PARENT_PART_NO_2,   
					 B.SUBSTITUTE_ITEM    SUBSTITUTE_ITEM_2,   
					 B.LOCATION_INFO      LOCATION_INFO_2
			  FROM  
					(
			
					  SELECT  'FILE2' DIV ,
			
								ID_ENG_BOM_EXCEL_LG_CPR2.PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR2.ITEM_SPEC,   
								ID_ENG_BOM_EXCEL_LG_CPR2.COMPONENT_QTY,   
								ID_ENG_BOM_EXCEL_LG_CPR2.EXPIRY_DATE,   
								ID_ENG_BOM_EXCEL_LG_CPR2.ECO_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR2.PARENT_PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR2.SUBSTITUTE_ITEM,   
								ID_ENG_BOM_EXCEL_LG_CPR2.LOCATION_INFO  
						 FROM ID_ENG_BOM_EXCEL_LG_CPR2   
			
					MINUS 
			
					  SELECT  'FILE2' DIV ,
								ID_ENG_BOM_EXCEL_LG_CPR1.PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR1.ITEM_SPEC,   
								ID_ENG_BOM_EXCEL_LG_CPR1.COMPONENT_QTY,   
								ID_ENG_BOM_EXCEL_LG_CPR1.EXPIRY_DATE,   
								ID_ENG_BOM_EXCEL_LG_CPR1.ECO_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR1.PARENT_PART_NO,   
								ID_ENG_BOM_EXCEL_LG_CPR1.SUBSTITUTE_ITEM,   
								ID_ENG_BOM_EXCEL_LG_CPR1.LOCATION_INFO  
						 FROM ID_ENG_BOM_EXCEL_LG_CPR1   ) B
			)
GROUP BY PART_NO, PART_NO2
ORDER BY PART_NO, PART_NO2" )
