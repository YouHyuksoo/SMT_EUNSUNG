 column=(type=number updatewhereclause=yes name=s_qty dbname="s_qty" )
 column=(type=number updatewhereclause=yes name=s_good dbname="s_good" )
 column=(type=number updatewhereclause=yes name=s_pass dbname="s_pass" )
 column=(type=number updatewhereclause=yes name=s_fail dbname="s_fail" )
 column=(type=number updatewhereclause=yes name=s_percent dbname="s_percent" )
 column=(type=number updatewhereclause=yes name=t_qty dbname="t_qty" )
 column=(type=number updatewhereclause=yes name=t_good dbname="t_good" )
 column=(type=number updatewhereclause=yes name=t_pass dbname="t_pass" )
 column=(type=number updatewhereclause=yes name=t_fail dbname="t_fail" )
 column=(type=number updatewhereclause=yes name=t_percent dbname="t_percent" )
 column=(type=number updatewhereclause=yes name=u_qty dbname="u_qty" )
 column=(type=number updatewhereclause=yes name=u_good dbname="u_good" )
 column=(type=number updatewhereclause=yes name=u_pass dbname="u_pass" )
 column=(type=number updatewhereclause=yes name=u_fail dbname="u_fail" )
 column=(type=number updatewhereclause=yes name=u_percent dbname="u_percent" )
 column=(type=number updatewhereclause=yes name=v_qty dbname="v_qty" )
 column=(type=number updatewhereclause=yes name=v_good dbname="v_good" )
 column=(type=number updatewhereclause=yes name=v_pass dbname="v_pass" )
 column=(type=number updatewhereclause=yes name=v_fail dbname="v_fail" )
 column=(type=number updatewhereclause=yes name=v_percent dbname="v_percent" )
 column=(type=number updatewhereclause=yes name=w_qty dbname="w_qty" )
 column=(type=number updatewhereclause=yes name=w_good dbname="w_good" )
 column=(type=number updatewhereclause=yes name=w_pass dbname="w_pass" )
 column=(type=number updatewhereclause=yes name=w_fail dbname="w_fail" )
 column=(type=number updatewhereclause=yes name=w_percent dbname="w_percent" )
 column=(type=number updatewhereclause=yes name=x_qty dbname="x_qty" )
 column=(type=number updatewhereclause=yes name=x_good dbname="x_good" )
 column=(type=number updatewhereclause=yes name=x_pass dbname="x_pass" )
 column=(type=number updatewhereclause=yes name=x_fail dbname="x_fail" )
 column=(type=number updatewhereclause=yes name=x_percent dbname="x_percent" )
 retrieve="SELECT LINE, PRODUCT, SIDE_TB,
      SUM(QTY) AS QTY,
      SUM(GOOD) AS GOOD,
      SUM(PASS) AS PASS,
      SUM(FAIL) AS FAIL,
      ROUND(SUM(GOOD) / CASE WHEN SUM(QTY) = 0 THEN 1 ELSE SUM(QTY) END * 100,2) PERCENT,
      
      SUM(CASE WHEN TIME = '06' THEN QTY ELSE 0 END) AS A_QTY,
      SUM(CASE WHEN TIME = '06' THEN GOOD ELSE 0 END) AS A_GOOD,
      SUM(CASE WHEN TIME = '06' THEN PASS ELSE 0 END) AS A_PASS,
      SUM(CASE WHEN TIME = '06' THEN FAIL ELSE 0 END) AS A_FAIL,
      ROUND(SUM(CASE WHEN TIME = '06' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '06' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '06' THEN QTY ELSE 0 END) END * 100,2) AS A_PERCENT,
      
      SUM(CASE WHEN TIME = '07' THEN QTY ELSE 0 END) AS B_QTY,
      SUM(CASE WHEN TIME = '07' THEN GOOD ELSE 0 END) AS B_GOOD,
      SUM(CASE WHEN TIME = '07' THEN PASS ELSE 0 END) AS B_PASS,
      SUM(CASE WHEN TIME = '07' THEN FAIL ELSE 0 END) AS B_FAIL,
      ROUND(SUM(CASE WHEN TIME = '07' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '07' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '07' THEN QTY ELSE 0 END) END * 100,2) AS B_PERCENT,
      
      SUM(CASE WHEN TIME = '08' THEN QTY ELSE 0 END) AS C_QTY,
      SUM(CASE WHEN TIME = '08' THEN GOOD ELSE 0 END) AS C_GOOD,
      SUM(CASE WHEN TIME = '08' THEN PASS ELSE 0 END) AS C_PASS,
      SUM(CASE WHEN TIME = '08' THEN FAIL ELSE 0 END) AS C_FAIL,
      ROUND(SUM(CASE WHEN TIME = '08' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '08' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '08' THEN QTY ELSE 0 END) END * 100,2) AS C_PERCENT,
      
      SUM(CASE WHEN TIME = '09' THEN QTY ELSE 0 END) AS D_QTY,
      SUM(CASE WHEN TIME = '09' THEN GOOD ELSE 0 END) AS D_GOOD,
      SUM(CASE WHEN TIME = '09' THEN PASS ELSE 0 END) AS D_PASS,
      SUM(CASE WHEN TIME = '09' THEN FAIL ELSE 0 END) AS D_FAIL,
      ROUND(SUM(CASE WHEN TIME = '09' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '09' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '09' THEN QTY ELSE 0 END) END * 100,2) AS D_PERCENT,
      
      SUM(CASE WHEN TIME = '10' THEN QTY ELSE 0 END) AS E_QTY,
      SUM(CASE WHEN TIME = '10' THEN GOOD ELSE 0 END) AS E_GOOD,
      SUM(CASE WHEN TIME = '10' THEN PASS ELSE 0 END) AS E_PASS,
      SUM(CASE WHEN TIME = '10' THEN FAIL ELSE 0 END) AS E_FAIL,
      ROUND(SUM(CASE WHEN TIME = '10' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '10' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '10' THEN QTY ELSE 0 END) END * 100,2) AS E_PERCENT,
      
      SUM(CASE WHEN TIME = '11' THEN QTY ELSE 0 END) AS F_QTY,
      SUM(CASE WHEN TIME = '11' THEN GOOD ELSE 0 END) AS F_GOOD,
      SUM(CASE WHEN TIME = '11' THEN PASS ELSE 0 END) AS F_PASS,
      SUM(CASE WHEN TIME = '11' THEN FAIL ELSE 0 END) AS F_FAIL,
      ROUND(SUM(CASE WHEN TIME = '11' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '11' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '11' THEN QTY ELSE 0 END) END * 100,2) AS F_PERCENT,
      
      SUM(CASE WHEN TIME = '12' THEN QTY ELSE 0 END) AS G_QTY,
      SUM(CASE WHEN TIME = '12' THEN GOOD ELSE 0 END) AS G_GOOD,
      SUM(CASE WHEN TIME = '12' THEN PASS ELSE 0 END) AS G_PASS,
      SUM(CASE WHEN TIME = '12' THEN FAIL ELSE 0 END) AS G_FAIL,
      ROUND(SUM(CASE WHEN TIME = '12' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '12' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '12' THEN QTY ELSE 0 END) END * 100,2) AS G_PERCENT,
      
      SUM(CASE WHEN TIME = '13' THEN QTY ELSE 0 END) AS H_QTY,
      SUM(CASE WHEN TIME = '13' THEN GOOD ELSE 0 END) AS H_GOOD,
      SUM(CASE WHEN TIME = '13' THEN PASS ELSE 0 END) AS H_PASS,
      SUM(CASE WHEN TIME = '13' THEN FAIL ELSE 0 END) AS H_FAIL,
      ROUND(SUM(CASE WHEN TIME = '13' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '13' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '13' THEN QTY ELSE 0 END) END * 100,2) AS H_PERCENT,
      
      SUM(CASE WHEN TIME = '14' THEN QTY ELSE 0 END) AS I_QTY,
      SUM(CASE WHEN TIME = '14' THEN GOOD ELSE 0 END) AS I_GOOD,
      SUM(CASE WHEN TIME = '14' THEN PASS ELSE 0 END) AS I_PASS,
      SUM(CASE WHEN TIME = '14' THEN FAIL ELSE 0 END) AS I_FAIL,
      ROUND(SUM(CASE WHEN TIME = '14' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '14' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '14' THEN QTY ELSE 0 END) END * 100,2) AS I_PERCENT,
      
      SUM(CASE WHEN TIME = '15' THEN QTY ELSE 0 END) AS J_QTY,
      SUM(CASE WHEN TIME = '15' THEN GOOD ELSE 0 END) AS J_GOOD,
      SUM(CASE WHEN TIME = '15' THEN PASS ELSE 0 END) AS J_PASS,
      SUM(CASE WHEN TIME = '15' THEN FAIL ELSE 0 END) AS J_FAIL,
      ROUND(SUM(CASE WHEN TIME = '15' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '15' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '15' THEN QTY ELSE 0 END) END * 100,2) AS J_PERCENT,
      
      SUM(CASE WHEN TIME = '16' THEN QTY ELSE 0 END) AS K_QTY,
      SUM(CASE WHEN TIME = '16' THEN GOOD ELSE 0 END) AS K_GOOD,
      SUM(CASE WHEN TIME = '16' THEN PASS ELSE 0 END) AS K_PASS,
      SUM(CASE WHEN TIME = '16' THEN FAIL ELSE 0 END) AS K_FAIL,
      ROUND(SUM(CASE WHEN TIME = '16' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '16' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '16' THEN QTY ELSE 0 END) END * 100,2) AS K_PERCENT,
      
      SUM(CASE WHEN TIME = '17' THEN QTY ELSE 0 END) AS L_QTY,
      SUM(CASE WHEN TIME = '17' THEN GOOD ELSE 0 END) AS L_GOOD,
      SUM(CASE WHEN TIME = '17' THEN PASS ELSE 0 END) AS L_PASS,
      SUM(CASE WHEN TIME = '17' THEN FAIL ELSE 0 END) AS L_FAIL,
      ROUND(SUM(CASE WHEN TIME = '17' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '17' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '17' THEN QTY ELSE 0 END) END * 100,2) AS L_PERCENT,
      
      SUM(CASE WHEN TIME = '18' THEN QTY ELSE 0 END) AS M_QTY,
      SUM(CASE WHEN TIME = '18' THEN GOOD ELSE 0 END) AS M_GOOD,
      SUM(CASE WHEN TIME = '18' THEN PASS ELSE 0 END) AS M_PASS,
      SUM(CASE WHEN TIME = '18' THEN FAIL ELSE 0 END) AS M_FAIL,
      ROUND(SUM(CASE WHEN TIME = '18' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '18' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '18' THEN QTY ELSE 0 END) END * 100,2) AS M_PERCENT,
      
      SUM(CASE WHEN TIME = '19' THEN QTY ELSE 0 END) AS N_QTY,
      SUM(CASE WHEN TIME = '19' THEN GOOD ELSE 0 END) AS N_GOOD,
      SUM(CASE WHEN TIME = '19' THEN PASS ELSE 0 END) AS N_PASS,
      SUM(CASE WHEN TIME = '19' THEN FAIL ELSE 0 END) AS N_FAIL,
      ROUND(SUM(CASE WHEN TIME = '19' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '19' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '19' THEN QTY ELSE 0 END) END * 100,2) AS N_PERCENT,
      
      SUM(CASE WHEN TIME = '20' THEN QTY ELSE 0 END) AS O_QTY,
      SUM(CASE WHEN TIME = '20' THEN GOOD ELSE 0 END) AS O_GOOD,
      SUM(CASE WHEN TIME = '20' THEN PASS ELSE 0 END) AS O_PASS,
      SUM(CASE WHEN TIME = '20' THEN FAIL ELSE 0 END) AS O_FAIL,
      ROUND(SUM(CASE WHEN TIME = '20' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '20' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '20' THEN QTY ELSE 0 END) END * 100,2) AS O_PERCENT,
      
      SUM(CASE WHEN TIME = '21' THEN QTY ELSE 0 END) AS P_QTY,
      SUM(CASE WHEN TIME = '21' THEN GOOD ELSE 0 END) AS P_GOOD,
      SUM(CASE WHEN TIME = '21' THEN PASS ELSE 0 END) AS P_PASS,
      SUM(CASE WHEN TIME = '21' THEN FAIL ELSE 0 END) AS P_FAIL,
      ROUND(SUM(CASE WHEN TIME = '21' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '21' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '21' THEN QTY ELSE 0 END) END * 100,2) AS P_PERCENT,
      
      SUM(CASE WHEN TIME = '22' THEN QTY ELSE 0 END) AS Q_QTY,
      SUM(CASE WHEN TIME = '22' THEN GOOD ELSE 0 END) AS Q_GOOD,
      SUM(CASE WHEN TIME = '22' THEN PASS ELSE 0 END) AS Q_PASS,
      SUM(CASE WHEN TIME = '22' THEN FAIL ELSE 0 END) AS Q_FAIL,
      ROUND(SUM(CASE WHEN TIME = '22' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '22' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '22' THEN QTY ELSE 0 END) END * 100,2) AS Q_PERCENT,
      
      SUM(CASE WHEN TIME = '23' THEN QTY ELSE 0 END) AS R_QTY,
      SUM(CASE WHEN TIME = '23' THEN GOOD ELSE 0 END) AS R_GOOD,
      SUM(CASE WHEN TIME = '23' THEN PASS ELSE 0 END) AS R_PASS,
      SUM(CASE WHEN TIME = '23' THEN FAIL ELSE 0 END) AS R_FAIL,
      ROUND(SUM(CASE WHEN TIME = '23' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '23' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '23' THEN QTY ELSE 0 END) END * 100,2) AS R_PERCENT,
      
      SUM(CASE WHEN TIME = '00' THEN QTY ELSE 0 END) AS S_QTY,
      SUM(CASE WHEN TIME = '00' THEN GOOD ELSE 0 END) AS S_GOOD,
      SUM(CASE WHEN TIME = '00' THEN PASS ELSE 0 END) AS S_PASS,
      SUM(CASE WHEN TIME = '00' THEN FAIL ELSE 0 END) AS S_FAIL,
      ROUND(SUM(CASE WHEN TIME = '00' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '00' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '00' THEN QTY ELSE 0 END) END * 100,2) AS S_PERCENT,
      
      SUM(CASE WHEN TIME = '01' THEN QTY ELSE 0 END) AS T_QTY,
      SUM(CASE WHEN TIME = '01' THEN GOOD ELSE 0 END) AS T_GOOD,
      SUM(CASE WHEN TIME = '01' THEN PASS ELSE 0 END) AS T_PASS,
      SUM(CASE WHEN TIME = '01' THEN FAIL ELSE 0 END) AS T_FAIL,
      ROUND(SUM(CASE WHEN TIME = '01' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '01' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '01' THEN QTY ELSE 0 END) END * 100,2) AS T_PERCENT,
      
      SUM(CASE WHEN TIME = '02' THEN QTY ELSE 0 END) AS U_QTY,
      SUM(CASE WHEN TIME = '02' THEN GOOD ELSE 0 END) AS U_GOOD,
      SUM(CASE WHEN TIME = '02' THEN PASS ELSE 0 END) AS U_PASS,
      SUM(CASE WHEN TIME = '02' THEN FAIL ELSE 0 END) AS U_FAIL,
      ROUND(SUM(CASE WHEN TIME = '02' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '02' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '02' THEN QTY ELSE 0 END) END * 100,2) AS U_PERCENT,
      
      SUM(CASE WHEN TIME = '03' THEN QTY ELSE 0 END) AS V_QTY,
      SUM(CASE WHEN TIME = '03' THEN GOOD ELSE 0 END) AS V_GOOD,
      SUM(CASE WHEN TIME = '03' THEN PASS ELSE 0 END) AS V_PASS,
      SUM(CASE WHEN TIME = '03' THEN FAIL ELSE 0 END) AS V_FAIL,
      ROUND(SUM(CASE WHEN TIME = '03' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '03' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '03' THEN QTY ELSE 0 END) END * 100,2) AS V_PERCENT,
      
      SUM(CASE WHEN TIME = '04' THEN QTY ELSE 0 END) AS W_QTY,
      SUM(CASE WHEN TIME = '04' THEN GOOD ELSE 0 END) AS W_GOOD,
      SUM(CASE WHEN TIME = '04' THEN PASS ELSE 0 END) AS W_PASS,
      SUM(CASE WHEN TIME = '04' THEN FAIL ELSE 0 END) AS W_FAIL,
      ROUND(SUM(CASE WHEN TIME = '04' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '04' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '04' THEN QTY ELSE 0 END) END * 100,2) AS W_PERCENT,
      
      SUM(CASE WHEN TIME = '05' THEN QTY ELSE 0 END) AS X_QTY,
      SUM(CASE WHEN TIME = '05' THEN GOOD ELSE 0 END) AS X_GOOD,
      SUM(CASE WHEN TIME = '05' THEN PASS ELSE 0 END) AS X_PASS,
      SUM(CASE WHEN TIME = '05' THEN FAIL ELSE 0 END) AS X_FAIL,
      ROUND(SUM(CASE WHEN TIME = '05' THEN GOOD ELSE 0 END) / CASE WHEN SUM(CASE WHEN TIME = '05' THEN QTY ELSE 0 END) = 0 THEN 1 ELSE SUM(CASE WHEN TIME = '05' THEN QTY ELSE 0 END) END * 100,2) AS X_PERCENT
      
FROM (      select A.LINE_CODE as LINE, A.C1 as PRODUCT, '' as SIDE_TB,
                  count(A.C1) as QTY,
                  SUM(CASE WHEN NVL(A.C9,' ') = 'GOOD' THEN 1 else 0 end) as GOOD,
                  SUM(CASE WHEN NVL(A.C9,' ') = 'PASS' then 1 else 0 end) as PASS,
                  SUM(CASE WHEN NVL(A.C9,' ') = 'FAIL' then 1 else 0 end) as FAIL,
                  to_char(ENTER_DATE,'YYYYMMDD') as ENTER_DATE,
                  to_char(ENTER_DATE,'HH') as TIME
            from iq_machine_inspect_spi A
            where to_char(ENTER_DATE,'YYYYMMDDHH') >= :arg_fdate AND
                     to_char(ENTER_DATE,'YYYYMMDDHH') < :arg_tdate AND
					A.C2 like :arg_model
            GROUP BY A.LINE_CODE, A.C1, A.ENTER_DATE
                                                      )
