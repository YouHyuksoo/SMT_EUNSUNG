table(column=(type=char(30) update=yes updatewhereclause=yes name=parent_item_code dbname="id_eng_bom_smt.parent_item_code" dbalias=".parent_item_code" )
 column=(type=datetime update=yes updatewhereclause=yes name=dateset dbname="dateset" )
 column=(type=datetime update=yes updatewhereclause=yes name=dateend dbname="dateend" )
 column=(type=number update=yes updatewhereclause=yes name=bom_level dbname="id_eng_bom_smt.bom_level" dbalias=".bom_level" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="id_eng_bom_smt.organization_id" dbalias=".organization_id" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="id_eng_bom_smt.line_code" dbalias=".line_code" )
 retrieve="  SELECT 
		DISTINCT 
         PARENT_ITEM_CODE,   
         TRUNC(DATESET)  DATESET,   
         TRUNC(DATEEND)  DATEEND ,   
         BOM_LEVEL,   
         ORGANIZATION_ID,   
         LINE_CODE

    FROM ID_ENG_BOM_SMT
   WHERE PARENT_ITEM_CODE IN ( SELECT MODEL_NAME FROM ID_ITEM WHERE SET_ITEM_YN = 'Y' ) AND
         ( PARENT_ITEM_CODE LIKE :ARG_PARENT_ITEM ) and
         ( LINE_CODE LIKE :ARG_LINE_CODE ) and
         ( MACHINE LIKE :ARG_MACHINE ) and
         ( DATESET <= :ARG_DATESET ) and
         ( DATEEND >= :ARG_DATESET ) and
		( BOM_LEVEL = '1' ) and 
         ( ORGANIZATION_ID = :ARG_ORG ) 
" arguments=(("ARG_PARENT_ITEM", string),("ARG_DATESET", datetime),("ARG_LINE_CODE", string),("ARG_MACHINE", string),("ARG_ORG", number))  sort="line_code A parent_item_code A " )
group(level=1 header.height=0 trailer.height=0 by=("organization_id" , "line_code" ) newpage=yes header.color="536870912" trailer.color="536870912" )
