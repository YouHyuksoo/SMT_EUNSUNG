 column=(type=number updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=number updatewhereclause=yes name=issue_amt dbname="issue_amt" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="item_uom" )
 column=(type=char(1) updatewhereclause=yes name=item_division dbname="item_division" )
 retrieve="SELECT  ORGANIZATION_ID , ITEM_CODE , ITEM_TYPE , LINE_TYPE ,
              avg( RECEIPT_PRICE ) RECEIPT_PRICE, 
              sum(RECEIPT_QTY)  RECEIPT_QTY, 
              sum(RECEIPT_AMT) RECEIPT_AMT,
              avg(ISSUE_PRICE )  ISSUE_PRICE, 
              sum(ISSUE_QTY)  ISSUE_QTY, 
              sum(ISSUE_AMT) ISSUE_AMT ,
              ITEM_NAME , ITEM_SPEC , ITEM_UOM , ITEM_DIVISION
FROM
(  SELECT
          ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DATE~"         RECEIPT_ISSUE_DATE,   

         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ORGANIZATION_ID~"   ORGANIZATION_ID,   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_CODE~" ITEM_CODE,   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_TYPE~" ITEM_TYPE,   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"LINE_TYPE~" LINE_TYPE,   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_PRICE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_QTY~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_AMT~",   
	    0 ISSUE_PRICE , 0  ISSUE_QTY , 0 ISSUE_AMT ,

         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",
         ~"ID_ITEM~".~"ITEM_DIVISION~"

    FROM ~"IM_ITEM_WORKSTAGE_RECEIPT~", 
         ~"ID_ITEM~"

   WHERE  ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( 
		( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DATE~" >= :arg_dateset ) AND  
		( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DATE~" <= :arg_dateend ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"MATERIAL_MFS~" like :arg_mfs ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_STATUS~" = 'N' ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ORGANIZATION_ID~" = :arg_org ) )

UNION ALL

  SELECT ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ISSUE_DATE~",   
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ITEM_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"LINE_TYPE~",   

	    0 RECEIPT_PRICE , 0  RECEIPT_QTY , 0 RECEIPT_AMT ,

         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ISSUE_PRICE~",   
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ISSUE_QTY~",   
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ISSUE_AMT~",   

         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~"  ,
         ~"ID_ITEM~".~"ITEM_DIVISION~"
    FROM ~"IM_ITEM_WORKSTAGE_ISSUE~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ISSUE_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ISSUE_DATE~" <= :arg_dateend ) AND  
         ( ~"IM_ITEM_WORKSTAGE_ISSUE~".~"MATERIAL_MFS~" like :arg_mfs ) AND  
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ITEM_CODE~" like :arg_item_code AND  
         ~"IM_ITEM_WORKSTAGE_ISSUE~".~"LINE_CODE~" like :arg_line_code AND  
         ( ~"IM_ITEM_WORKSTAGE_ISSUE~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_ISSUE~".~"ORGANIZATION_ID~" = :arg_org ) )    
) 

GROUP BY ORGANIZATION_ID , ITEM_CODE , ITEM_TYPE , LINE_TYPE , ITEM_NAME , ITEM_SPEC , ITEM_UOM ,ITEM_DIVISION" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_mfs", string),("arg_item_code", string),("arg_line_code", string),("arg_workstage_code", string),("arg_org", number))  sort="organization_id A item_division A item_code A " )
