table(column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="organization_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_type dbname="item_type" )
 column=(type=char(10) update=yes updatewhereclause=yes name=line_type dbname="line_type" )
