footer(height=0 color="536870912" )
detail(height=72 color="536870912" height.autosize=yes )
table(column=(type=char(7) updatewhereclause=yes name=div dbname="div" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="id_eng_bom_smt.parent_item_code" )
 column=(type=char(30) updatewhereclause=yes name=child_item_code dbname="id_eng_bom_smt.child_item_code" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="id_eng_bom_smt.item_unit_qty" )
 column=(type=char(10) updatewhereclause=yes name=workstage_code dbname="id_eng_bom_smt.workstage_code" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="id_eng_bom_smt.line_code" )
 column=(type=char(20) updatewhereclause=yes name=machine dbname="id_eng_bom_smt.machine" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="id_eng_bom_smt.location_code" )
 column=(type=char(10) updatewhereclause=yes name=table_id dbname="id_eng_bom_smt.table_id" )
 column=(type=char(30) updatewhereclause=yes name=pcb_item dbname="id_eng_bom_smt.pcb_item" )
 column=(type=char(0) updatewhereclause=yes name=our_barcode dbname="our_barcode" )
 column=(type=number updatewhereclause=yes name=feeding_qty dbname="feeding_qty" )
 column=(type=number updatewhereclause=yes name=actual_qty dbname="actual_qty" )
 column=(type=number updatewhereclause=yes name=unfeeding_qty dbname="unfeeding_qty" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" )
 column=(type=char(1) updatewhereclause=yes name=feeder_shaft dbname="id_eng_bom_smt.feeder_shaft" )
 column=(type=number updatewhereclause=yes name=unit_price dbname="unit_price" )
 retrieve="  SELECT 'BOM'  DIV ,
          ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"CHILD_ITEM_CODE~",   

         ~"ID_ENG_BOM_SMT~".~"ITEM_UNIT_QTY~",   
         ~"ID_ENG_BOM_SMT~".~"WORKSTAGE_CODE~",   

         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   

         ~"ID_ENG_BOM_SMT~".~"LINE_CODE~" , 
         ~"ID_ENG_BOM_SMT~".~"MACHINE~" , 
         ~"ID_ENG_BOM_SMT~".~"LOCATION_CODE~",
         ~"ID_ENG_BOM_SMT~".~"TABLE_ID~",
		~"ID_ENG_BOM_SMT~".~"PCB_ITEM~",
		'' OUR_BARCODE ,
		F_GET_SHAFT_FEEDING_QTY(ID_ENG_BOM_SMT.LINE_CODE , PARENT_ITEM_CODE , LOCATION_CODE , PCB_ITEM  , FEEDER_SHAFT )  FEEDING_QTY,
         F_GET_FEEDER_ACTUAL_QTY( ID_ENG_BOM_SMT.LINE_CODE , PARENT_ITEM_CODE , LOCATION_CODE , PCB_ITEM )  ACTUAL_QTY ,
		F_GET_UNFEEDING_QTY(  ID_ENG_BOM_SMT.LINE_CODE , ID_ENG_BOM_SMT.PARENT_ITEM_CODE , ID_ENG_BOM_SMT.CHILD_ITEM_CODE , ID_ENG_BOM_SMT.LOCATION_CODE  ,ID_ENG_BOM_SMT.FEEDER_SHAFT ) UNFEEDING_QTY ,
		f_get_mat_inventory_qty_all( ID_ENG_BOM_SMT.CHILD_ITEM_CODE , ID_ENG_BOM_SMT.organization_id) INVENTORY_QTY ,
		
		 ~"ID_ITEM_A~".~"LOCATION_ADDRESS~" LOCATION_ADDRESS ,

		  ~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT~"  ,
		 f_get_mat_max_unit_price_cfm( ID_ENG_BOM_SMT.CHILD_ITEM_CODE , 'F' , SYSDATE , ~"ID_ENG_BOM_SMT~".~"ORGANIZATION_ID~" ) UNIT_PRICE
		
    FROM ~"ID_ENG_BOM_SMT~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~"
   WHERE ( id_eng_bom_smt.child_item_code = ID_ITEM_A.item_code (+)) and  
         ( id_eng_bom_smt.organization_id = ID_ITEM_A.organization_id (+)) and  
 
         ( ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~" = :ARG_PARENT_ITEM ) and
         ( ~"ID_ENG_BOM_SMT~".~"LINE_CODE~" = :ARG_LINE_CODE ) and
         ( ~"ID_ENG_BOM_SMT~".~"DATESET~" <= :ARG_DATESET ) and
         ( NVL(~"ID_ENG_BOM_SMT~".~"DATEEND~",  TO_DATE('99991231','YYYYMMDD')) >= :ARG_DATESET ) and
         ( ~"ID_ENG_BOM_SMT~".~"PCB_ITEM~" LIKE :ARG_TOPBOT ) and
         ( NVL(~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT~" ,'A') LIKE :ARG_FEEDER_SHAFT ) and
         ( ~"ID_ENG_BOM_SMT~".~"ORGANIZATION_ID~" = :ARG_ORG ) 


UNION ALL 
  SELECT 'REPLACE' DIV ,
		~"ID_ENG_BOM_SMT_REPLACE~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"REPLACE_ITEM_CODE~",   
 
  
         ~"ID_ENG_BOM_SMT_REPLACE~".~"ITEM_UNIT_QTY~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"WORKSTAGE_CODE~",   

         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   


         ~"ID_ENG_BOM_SMT_REPLACE~".~"LINE_CODE~" , 
         ~"ID_ENG_BOM_SMT_REPLACE~".~"MACHINE~" , 
         ~"ID_ENG_BOM_SMT_REPLACE~".~"LOCATION_CODE~",
         ~"ID_ENG_BOM_SMT_REPLACE~".~"TABLE_ID~",
		~"ID_ENG_BOM_SMT_REPLACE~".~"PCB_ITEM~",
		'' OUR_BARCODE ,
		0  FEEDING_QTY,
		0 ACTUAL_QTY ,
		0 UNFEEDING_QTY ,
		f_get_mat_inventory_qty_all( ID_ENG_BOM_SMT_REPLACE.CHILD_ITEM_CODE , ID_ENG_BOM_SMT_REPLACE.organization_id) INVENTORY_QTY ,
	     ~"ID_ITEM_A~".~"LOCATION_ADDRESS~" LOCATION_ADDRESS ,

		'' FEEDER_SHAFT ,

 		f_get_mat_max_unit_price_cfm( ID_ENG_BOM_SMT_REPLACE.CHILD_ITEM_CODE , 'F' , SYSDATE , ~"ID_ENG_BOM_SMT_REPLACE~".~"ORGANIZATION_ID~" ) UNIT_PRICE

    FROM ~"ID_ENG_BOM_SMT_REPLACE~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~"
   WHERE ( ID_ENG_BOM_SMT_REPLACE.child_item_code = ID_ITEM_A.item_code (+)) and  
         ( ID_ENG_BOM_SMT_REPLACE.organization_id = ID_ITEM_A.organization_id (+)) and  

         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"PARENT_ITEM_CODE~" = :ARG_PARENT_ITEM ) and
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"LINE_CODE~" = :ARG_LINE_CODE ) and
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"DATESET~" <= :ARG_DATESET ) and
         ( NVL(~"ID_ENG_BOM_SMT_REPLACE~".~"DATEEND~",  TO_DATE('99991231','YYYYMMDD')) >= :ARG_DATESET ) and
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"PCB_ITEM~" LIKE :ARG_TOPBOT ) and
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"ORGANIZATION_ID~" = :ARG_ORG ) 
" arguments=(("ARG_PARENT_ITEM", string),("ARG_DATESET", datetime),("ARG_LINE_CODE", string),("ARG_TOPBOT", string),("ARG_FEEDER_SHAFT", string),("arg_org", number))  sort="line_code A production_quantity A location_code A " )
