 retrieve="  SELECT ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_SPEC~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_TYPE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PART_NO~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SITE_CODE~",   
