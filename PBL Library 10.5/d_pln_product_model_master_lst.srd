         ~"IP_PRODUCT_MODEL_MASTER~".~"PCB_TOTAL_QTY~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"ENTER_BY~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CUSTOMER_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CUSTOMER_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MARKING_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_DIVISION~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"BARCODE_TYPE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PACKING_PCS_QTY~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PACKING_TRAY_BOX_QTY~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"ARRAY_TYPE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"DATESET~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"DATEEND~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CONFIRM_DATE~",    
         ~"IP_PRODUCT_MODEL_MASTER~".~"VERSION~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SERIAL_NO_LENGTH~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PACKING_BOX_MAX_PSC_QTY~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PACKING_BOX_MIN_PSC_QTY~",    
         ~"IP_PRODUCT_MODEL_MASTER~".~"SPI_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MARKING_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"AOI_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"REFLOW_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"FUNCTION_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"ICT_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MARKING_CONDITION~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"POWER_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CARRIER_BARCODE_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SORDER_CREAM_CHECK_YN~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"NG_PROCESS~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SERIAL_ARRAY_LENGTH~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CARRIER_BARCODE_POSITION~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"REVISION~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MAGAZINE_PRINT_X~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MAGAZINE_PRINT_Y~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MAGAZINE_NO_LENGTH~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"USE_CALENDAR~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CUSTOMER_MODEL_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"EC_NO~",   
         F_CHECK_BOM_EXISTS( ITEM_CODE , ORGANIZATION_ID ) BOM_EXISTS,   
         F_CHECK_SMT_BOM_EXISTS( SMT_MODEL_NAME, ORGANIZATION_ID ) SMT_BOM_EXISTS,   
         F_CHECK_JIG_EXISTS( MASTER_MODEL_NAME, ORGANIZATION_ID ) JIG_EXISTS,   
         F_CHECK_CALENDER_EXISTS( MODEL_NAME, ORGANIZATION_ID ) CALENDER_EXISTS,   

         ~"IP_PRODUCT_MODEL_MASTER~".~"PRODUCT_CLASS~",   		
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SW_VERSION~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"HW_VERSION~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SW_FILENAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PID_PRINT_X~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PID_PRINT_Y~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"TOP_ITEM_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"BOTTOM_ITEM_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"INSERT_ITEM_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PCB_ITEM_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SOLDER_TYPE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SOLDER_ITEM_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MASTER_SAMPLE_PID1~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MASTER_SAMPLE_PID2~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MASTER_SAMPLE_PID3~" ,
		 ~"IP_PRODUCT_MODEL_MASTER~".~"SMT_MODEL_NAME~" 
    FROM ~"IP_PRODUCT_MODEL_MASTER~"  
   WHERE ( ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_NAME~" like :ARG_MODEL_NAME ) AND  
         ~"IP_PRODUCT_MODEL_MASTER~".~"CUSTOMER_CODE~" like :ARG_CUSTOMER_CODE AND  
         ~"IP_PRODUCT_MODEL_MASTER~".~"ITEM_CODE~" like :ARG_ITEM_CODE AND  
         NVL(~"IP_PRODUCT_MODEL_MASTER~".~"MASTER_MODEL_NAME~" ,'*') like :ARG_MASTER_MODEL_NAME AND  
         ~"IP_PRODUCT_MODEL_MASTER~".~"ORGANIZATION_ID~" = :ARG_ORG   
" update="IP_PRODUCT_MODEL_MASTER" updatewhere=0 updatekeyinplace=no arguments=(("ARG_MODEL_NAME", string),("ARG_CUSTOMER_CODE", string),("ARG_ITEM_CODE", string),("ARG_MASTER_MODEL_NAME", string),("ARG_ORG", number))  sort="customer_code A model_name A " )
