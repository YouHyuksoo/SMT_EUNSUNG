 retrieve="  SELECT 
          'N' CHECK_YN ,
          ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"CHECK_YYYYMM~",   
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"ITEM_BARCODE~",   
         NVL(~"IM_ASSY_INVENTORY_CHECK_BCD~".~"BARCODE_QTY~",0) BARCODE_QTY,   
         NVL(~"IM_ASSY_INVENTORY_CHECK_BCD~".~"INVENTORY_QTY~",0)  INVENTORY_QTY,   
		~"IM_ASSY_INVENTORY_CHECK_BCD~".~"LOCATION_CODE_PHYSICAL~"   ,
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"ORGANIZATION_ID~",   
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"ENTER_BY~",   
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"ENTER_DATE~",   
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"LAST_MODIFY_BY~",   
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"LAST_MODIFY_DATE~",   

         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"LOT_NO~",   
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"LINE_CODE~",   
		~"IM_ASSY_INVENTORY_CHECK_BCD~".~"CHECK_TYPE~" ,
          ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"WORKSTAGE_CODE~",

         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"MODEL_NAME~",   
         ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"MODEL_SUFFIX~",   
		~"IM_ASSY_INVENTORY_CHECK_BCD~".~"ITEM_CODE~" ,


		IP_PRODUCT_2D_BARCODE.MODEL_NAME , 
		IP_PRODUCT_2D_BARCODE.MODEL_SUFFIX  ,
		~"IM_ASSY_INVENTORY_CHECK_BCD~".~"PCB_ITEM~" ,

		
		~"IM_ASSY_INVENTORY_CHECK_BCD~".~"REVERSE_YN~"
    FROM ~"IM_ASSY_INVENTORY_CHECK_BCD~",   
              IP_PRODUCT_2D_BARCODE

 
   WHERE( IM_ASSY_INVENTORY_CHECK_BCD.ITEM_BARCODE = IP_PRODUCT_2D_BARCODE.SERIAL_NO (+)) and  

         ( ( ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"CHECK_YYYYMM~" = :arg_yyyymm ) AND  
         ( ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"ITEM_BARCODE~" like :arg_item_barcode ) AND  
         ( NVL(~"IM_ASSY_INVENTORY_CHECK_BCD~".~"BARCODE_QTY~",0) = DECODE(:arg_check_qty , 0 , 0 , NVL(~"IM_ASSY_INVENTORY_CHECK_BCD~".~"BARCODE_QTY~",0) ) ) AND  
         ( NVL(~"IM_ASSY_INVENTORY_CHECK_BCD~".~"LINE_CODE~",'*')  LIKE :arg_location_code ) AND 
         ( NVL(~"IM_ASSY_INVENTORY_CHECK_BCD~".~"WORKSTAGE_CODE~",'*')  LIKE :arg_workstage_code ) AND 
         ( ~"IM_ASSY_INVENTORY_CHECK_BCD~".~"ORGANIZATION_ID~" = :arg_org ) )    
" update="IM_ASSY_INVENTORY_CHECK_BCD" updatewhere=0 updatekeyinplace=no arguments=(("arg_yyyymm", string),("arg_item_barcode", string),("arg_check_qty", number),("arg_location_code", string),("arg_workstage_code", string),("arg_org", number))  sort="line_code A model_name A model_suffix A " )
