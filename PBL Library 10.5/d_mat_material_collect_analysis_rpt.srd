HA$PBExportHeader$d_mat_material_collect_analysis_rpt.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=33554431 processing=0 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 0 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no )
header(height=476 color="536870912" )
summary(height=112 color="65535" )
footer(height=88 color="536870912" )
detail(height=92 color="536870912~tif ( mod(  getrow() , 2 )  = 0 , rgb(255,255,255) , rgb(219,219,219) )" )
table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(10) updatewhereclause=yes name=line_type dbname="line_type" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="item_uom" )
 column=(type=number updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=number updatewhereclause=yes name=issue_amt dbname="issue_amt" )
 column=(type=number updatewhereclause=yes name=bad_issue_qty dbname="bad_issue_qty" )
 column=(type=number updatewhereclause=yes name=bad_issue_amt dbname="bad_issue_amt" )
 column=(type=number updatewhereclause=yes name=workstage_issue_qty dbname="workstage_issue_qty" )
 column=(type=number updatewhereclause=yes name=workstage_issue_amt dbname="workstage_issue_amt" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="organization_id" )
 retrieve="select  item_code, line_type ,item_name,  item_spec, item_uom, 
                    
            sum(issue_qty)  issue_qty, 
            sum(issue_amt) issue_amt,

            sum(bad_issue_qty)  bad_issue_qty, 
            sum(bad_issue_amt) bad_issue_amt,

           sum(workstage_issue_qty)  workstage_issue_qty, 
            sum(workstage_issue_amt) workstage_issue_amt,

            organization_id           
from (

 select  a.item_code item_code,   
            a.line_type line_type, 
            b.item_name item_name,  
            b.item_spec item_spec, 
            b.item_uom item_uom, 
                    
            sum( decode( issue_account , 'M001' , a.issue_qty,0  ))  issue_qty, 
            sum( decode( issue_account , 'M001' , a.issue_amt,0 )) issue_amt,

            0 bad_issue_qty,
		  0 bad_issue_amt,


		 0 workstage_issue_qty, 
           0 workstage_issue_amt,
           
            a.organization_id   organization_id         
 from    im_item_issue  a, 
            id_item    b
 where   a.item_code = b.item_code(+) 
 and      a.organization_id = b.organization_id(+)  
 and      a.issue_date between :arg_dateset   and  :arg_dateend
 and      a.item_code like :arg_item_code
 and      a.organization_id = :arg_org_id 
 and      b.item_division = 'R'
 and      a.issue_status <> 'C'
group by a.item_code, a.line_type , b.item_name, b.item_spec, b.item_uom, a.organization_id
 
union all

 select  a.item_code item_code,   
             a.line_type  line_type, 
             b.item_name item_name,  
             b.item_spec item_spec, 
             b.item_uom item_uom, 
             
		 0 issue_qty,
           0 issue_amt,
		  sum( decode( a.issue_account , 'M002' , a.issue_qty,0  ))  bad_issue_qty, 
            sum( decode( a.issue_account , 'M002' , a.issue_amt,0 )) bad_issue_amt,
       
            sum(a.issue_qty)            workstage_issue_qty, 
            sum(nvl(a.issue_amt,0)) workstage_issue_amt,
           
            a.organization_id   organization_id        
 from    im_item_workstage_issue  a, 
            id_item    b
 where   a.item_code = b.item_code(+) 
 and      a.organization_id = b.organization_id(+)  
 and      a.issue_date between :arg_dateset   and  :arg_dateend
 and      a.item_code like :arg_item_code
 and      a.organization_id = :arg_org_id 
 and      b.item_division = 'R'
 and      a.issue_status <> 'C'
group by a.item_code, a.line_type , b.item_name, b.item_spec, b.item_uom, a.organization_id
 
) 
group by item_code, line_type , item_name, item_spec, item_uom, organization_id" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_org_id", number))  sort="item_code A line_type A " )
