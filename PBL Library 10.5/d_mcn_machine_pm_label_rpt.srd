detail(height=2010 color="536870912" )
table(column=(type=char(4000) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(4000) updatewhereclause=yes name=machine_type dbname="machine_type" )
 column=(type=char(100) updatewhereclause=yes name=machine_code dbname="imcn_machine_pm_master.machine_code" dbalias=".machine_code" )
 column=(type=char(100) updatewhereclause=yes name=machine_name dbname="imcn_machine.machine_name" dbalias=".machine_name" )
 column=(type=char(4000) updatewhereclause=yes name=pm_type dbname="pm_type" )
 column=(type=char(134) updatewhereclause=yes name=pm_barcode dbname="pm_barcode" )
 retrieve="  SELECT f_get_line_NAME(IMCN_MACHINE.LINE_CODE, IMCN_MACHINE_PM_MASTER.ORGANIZATION_ID) LINE_CODE ,
			F_GET_BASECODE( 'MACHINE TYPE' , IMCN_MACHINE.MACHINE_TYPE , :ARG_LANG ,  IMCN_MACHINE_PM_MASTER.ORGANIZATION_ID ) MACHINE_TYPE ,
              IMCN_MACHINE_PM_MASTER.MACHINE_CODE,   
		     IMCN_MACHINE.MACHINE_NAME MACHINE_NAME ,
	     	 F_GET_BASECODE( 'PM TYPE' , IMCN_MACHINE_PM_MASTER.PM_TYPE , :arg_lang , IMCN_MACHINE_PM_MASTER.ORGANIZATION_ID ) PM_TYPE , 

 		    '*'||IMCN_MACHINE.LINE_CODE||' '||IMCN_MACHINE_PM_MASTER.MACHINE_CODE||' '||IMCN_MACHINE_PM_MASTER.PM_TYPE||'*' PM_BARCODE  	 
    FROM IMCN_MACHINE_PM_MASTER , IMCN_MACHINE
   WHERE IMCN_MACHINE_PM_MASTER.MACHINE_CODE  = IMCN_MACHINE.MACHINE_CODE(+) AND
			IMCN_MACHINE_PM_MASTER.ORGANIZATION_ID  = IMCN_MACHINE.ORGANIZATION_ID(+) AND

             ( IMCN_MACHINE_PM_MASTER.LINE_CODE like :arg_line_code ) AND  
			( IMCN_MACHINE_PM_MASTER.MACHINE_CODE like :arg_machine_code ) AND 
			( IMCN_MACHINE_PM_MASTER.PM_TYPE like :arg_pm_type ) AND 
			IMCN_MACHINE.MACHINE_TYPE LIKE :ARG_MACHINE_TYPE AND 
			( IMCN_MACHINE_PM_MASTER.ORGANIZATION_ID = :arg_org ) 
" arguments=(("arg_line_code", string),("arg_machine_code", string),("arg_machine_type", string),("arg_pm_type", string),("arg_lang", string),("arg_org", number))  sort="machine_code A pm_type A " )
