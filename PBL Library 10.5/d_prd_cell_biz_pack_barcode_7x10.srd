 column=(type=datetime updatewhereclause=yes name=print_date dbname="ip_product_pack_master.print_date" )
 column=(type=char(4000) updatewhereclause=yes name=org_name dbname="org_name" )
 retrieve="
select 
           f_bacode_code128('B',pack_barcode) as pack_label , 
          pack_barcode  , 
       model_name, 
       pack_type, 
       pack_qty, 
       to_char(pack_date,'yyyy-mm-dd') pack_date, 
       nvl(attr5, 'VN-DONGDO')  company , 
      sysdate as print_date , 
      f_get_org_name(organization_id) as org_name
  from ip_product_pack_master
where pack_barcode = :arg_barcode 
" update="ip_product_pack_master" updatewhere=0 updatekeyinplace=no arguments=(("arg_barcode", string)) )
