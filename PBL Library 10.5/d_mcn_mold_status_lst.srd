footer(height=0 color="536870912" )
detail(height=340 color="536870912" )
table(column=(type=number updatewhereclause=yes name=total_count dbname="total_count" )
 column=(type=number updatewhereclause=yes name=mold_in_count dbname="mold_in_count" )
 column=(type=number updatewhereclause=yes name=mold_out_count dbname="mold_out_count" )
 column=(type=number updatewhereclause=yes name=mold_rent_count dbname="mold_rent_count" )
 column=(type=number updatewhereclause=yes name=mold_rent_wait_count dbname="mold_rent_wait_count" )
 column=(type=number updatewhereclause=yes name=mold_not_confirm_count dbname="mold_not_confirm_count" )
 column=(type=number updatewhereclause=yes name=mold_mass_count dbname="mold_mass_count" )
 column=(type=number updatewhereclause=yes name=mold_stop_count dbname="mold_stop_count" )
 column=(type=number updatewhereclause=yes name=mold_obsolete_count dbname="mold_obsolete_count" )
 column=(type=number updatewhereclause=yes name=mold_repair_count dbname="mold_repair_count" )
 column=(type=number updatewhereclause=yes name=mold_destroy_count dbname="mold_destroy_count" )
 column=(type=number updatewhereclause=yes name=mold_shortremain_qty dbname="mold_shortremain_qty" )
 column=(type=number updatewhereclause=yes name=mold_shortnon_qty dbname="mold_shortnon_qty" )
 retrieve="  SELECT COUNT(*) TOTAL_COUNT ,
              SUM( DECODE( MOLD_IN_OUT , 'I' , 1 , 0 ) ) MOLD_IN_COUNT ,
			 SUM( DECODE( MOLD_IN_OUT , 'O' , 1 , 0 ) ) MOLD_OUT_COUNT ,

			 SUM( DECODE( RENT_STATUS , 'N' , 1 , 0 ) ) MOLD_RENT_COUNT ,
			 SUM( DECODE( RENT_STATUS , 'C' , 1 , 'W' , 1 , 0 ) ) MOLD_RENT_WAIT_COUNT ,

			 SUM( DECODE( MOLD_USE_STATUS , 'N' , 1 , 0 ) ) MOLD_NOT_CONFIRM_COUNT ,
			 SUM( DECODE( MOLD_USE_STATUS , 'P' , 1 , 0 ) ) MOLD_MASS_COUNT ,
			 SUM( DECODE( MOLD_USE_STATUS , 'T' , 1 , 0 ) ) MOLD_STOP_COUNT ,
			 SUM( DECODE( MOLD_USE_STATUS , 'D' , 1 , 0 ) ) MOLD_OBSOLETE_COUNT ,
			 SUM( DECODE( MOLD_USE_STATUS , 'R' , 1 , 0 ) ) MOLD_REPAIR_COUNT ,
			 SUM( DECODE( MOLD_USE_STATUS , 'S' , 1 , 0 ) ) MOLD_DESTROY_COUNT,
			
			SUM( CASE WHEN nvl(BREAK_VALUE ,0) >=nvl( ACTUAL_VALUE ,0) THEN 1 ELSE 0  END ) MOLD_SHORTREMAIN_QTY ,
			SUM( CASE WHEN nvl(BREAK_VALUE,0) < nvl(ACTUAL_VALUE ,0) THEN 1 ELSE 0  END ) MOLD_SHORTNON_QTY 

    FROM ~"IMCN_MOLD_INVENTORY~"   , IMCN_MOLD
WHERE ( ~"IMCN_MOLD_INVENTORY~".~"MOLD_CODE~" = ~"IMCN_MOLD~".~"MOLD_CODE~" ) and  
         ( ~"IMCN_MOLD_INVENTORY~".~"ORGANIZATION_ID~" = ~"IMCN_MOLD~".~"ORGANIZATION_ID~" ) and
         ( ~"IMCN_MOLD_INVENTORY~".~"MOLD_CODE~" like :arg_mold_code ) AND  
         ( ~"IMCN_MOLD_INVENTORY~".~"MOLD_USE_STATUS~" like :arg_mold_use_status ) AND  
         ( ~"IMCN_MOLD~".~"MOLD_GROUP~" like :arg_mold_group ) AND  
         ( ~"IMCN_MOLD_INVENTORY~".~"MOLD_CODE~" <> '*' ) AND  
         ( ~"IMCN_MOLD_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org )
" arguments=(("ARG_MOLD_CODE", string),("ARG_MOLD_USE_STATUS", string),("ARG_MOLD_GROUP", string),("ARG_ORG", number)) )
