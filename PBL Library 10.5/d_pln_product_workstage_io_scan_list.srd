 retrieve="  SELECT ~"IP_PRODUCT_WORKSTAGE_IO~".~"IO_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"IO_SEQUENCE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"RUN_NO~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"SERIAL_NO~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_CODE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"IO_DEFICIT~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"IO_QTY~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"ENTER_BY~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"OUT_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_TYPE~",  
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"LOT_NO~"
    FROM ~"IP_PRODUCT_WORKSTAGE_IO~"  
   WHERE ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~" = :arg_line_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_CODE~" = :arg_workstage_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_NAME~" like :arg_model_name ) AND  
         (~"IP_PRODUCT_WORKSTAGE_IO~".~"ACTUAL_DATE~"    =  :arg_date)   AND 
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"IO_DEFICIT~" = 'I' ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ORGANIZATION_ID~" = :arg_org )    
" update="IP_PRODUCT_WORKSTAGE_IO" updatewhere=1 updatekeyinplace=no arguments=(("arg_line_code", string),("arg_workstage_code", string),("arg_model_name", string),("arg_date", datetime),("arg_org", number))  sort="io_date D io_sequence D " )
