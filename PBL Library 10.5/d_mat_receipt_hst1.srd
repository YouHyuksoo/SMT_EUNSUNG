FT=~"im_item_receipt.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_receipt.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_RECEIPT~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"RECEIPT_DATE~~~"~"   OP =~"between~"    EXP2 =~":arg_dateset and :arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(~~~"IM_ITEM_RECEIPT~~~".~~~"LOCATION_CODE~~~" , '*')~"   OP =~"like~"    EXP2 =~":arg_location_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"(NVL(~~~"IM_ITEM_RECEIPT~~~".~~~"INVOICE_NO~~~",'*')~"   OP =~"like~"    EXP2 =~":arg_invoice_no)~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_location_code~" TYPE = string)  ARG(NAME = ~"arg_invoice_no~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " update="ID_ITEM" updatewhere=2 updatekeyinplace=no arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_location_code", string),("arg_invoice_no", string),("arg_org_id", number))  sort="organization_id A receipt_type A receipt_date A item_code A receipt_sequence A " )
