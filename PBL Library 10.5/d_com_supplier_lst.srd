 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"icom_supplier.organization_id~") COLUMN(NAME=~"icom_supplier.business_no~") COLUMN(NAME=~"icom_supplier.business_category~") COLUMN(NAME=~"icom_supplier.business_status~") COLUMN(NAME=~"icom_supplier.business_type~") COLUMN(NAME=~"icom_supplier.payment_type~") COLUMN(NAME=~"icom_supplier.bank_account~") COLUMN(NAME=~"icom_supplier.owner_name~") COLUMN(NAME=~"icom_supplier.address~") COLUMN(NAME=~"icom_supplier.tel_no~") COLUMN(NAME=~"icom_supplier.fax_no~") COLUMN(NAME=~"icom_supplier.enter_date~") COLUMN(NAME=~"icom_supplier.last_modify_date~") COLUMN(NAME=~"icom_supplier.enter_by~") COLUMN(NAME=~"icom_supplier.last_modify_by~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"icom_supplier.supplier_name_eng~") COLUMN(NAME=~"icom_supplier.supplier_charge_name~") COLUMN(NAME=~"icom_supplier.dateset~") COLUMN(NAME=~"icom_supplier.dateend~") COLUMN(NAME=~"icom_supplier.bank_address~") COLUMN(NAME=~"icom_supplier.bank_address_eng~") COLUMN(NAME=~"icom_supplier.bank_name~") COLUMN(NAME=~"icom_supplier.bank_name_eng~") COLUMN(NAME=~"icom_supplier.employee_qty~") COLUMN(NAME=~"icom_supplier.handphone_no~") COLUMN(NAME=~"icom_supplier.home_page~") COLUMN(NAME=~"icom_supplier.email_address~") COLUMN(NAME=~"icom_supplier.found_date~") COLUMN(NAME=~"icom_supplier.custom_code~") COLUMN(NAME=~"icom_supplier.virtual_receipt_yn~") COLUMN(NAME=~"icom_supplier.business_tax_no~") COLUMN(NAME=~"icom_supplier.payment_cycle~") COLUMN(NAME=~"icom_supplier.trade_type~") COLUMN(NAME=~"icom_supplier.trade_code~") COLUMN(NAME=~"icom_supplier.nation_code~") COLUMN(NAME=~"icom_supplier.supplier_code~")WHERE(    EXP1 =~"( ~~~"ICOM_SUPPLIER~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":ARG_SUPPLIER_CODE )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(~~~"ICOM_SUPPLIER~~~".~~~"BUSINESS_CATEGORY~~~", '*') like:arg_business_category ) AND ( ~~~"ICOM_SUPPLIER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG )~" ) ) ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_business_category~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="ICOM_SUPPLIER" updatewhere=0 updatekeyinplace=yes arguments=(("arg_supplier_code", string),("arg_business_category", string),("arg_org", number))  sort="organization_id A business_status A supplier_code A " )
