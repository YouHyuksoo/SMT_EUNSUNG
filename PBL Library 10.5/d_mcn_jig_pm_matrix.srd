 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_jig_weekly_pm_calendar~" )  TABLE(NAME=~"imcn_jig~" ) COLUMN(NAME=~"imcn_jig_weekly_pm_calendar.plan_yyyy~") COLUMN(NAME=~"imcn_jig_weekly_pm_calendar.plan_weeks~") COLUMN(NAME=~"imcn_jig_weekly_pm_calendar.jig_code~") COLUMN(NAME=~"imcn_jig_weekly_pm_calendar.machine_charge~") COLUMN(NAME=~"imcn_jig_weekly_pm_calendar.machine_care_status~") COLUMN(NAME=~"imcn_jig.jig_name~") COLUMN(NAME=~"imcn_jig.jig_type~") COLUMN(NAME=~"imcn_jig.use_status~") COLUMN(NAME=~"imcn_jig_weekly_pm_calendar.plan_mm~")    JOIN (LEFT=~"imcn_jig_weekly_pm_calendar.jig_code~"    OP =~"=~"RIGHT=~"imcn_jig.jig_code~"    OUTER1 =~"imcn_jig_weekly_pm_calendar.jig_code~" )    JOIN (LEFT=~"imcn_jig_weekly_pm_calendar.organization_id~"    OP =~"=~"RIGHT=~"imcn_jig.organization_id~"    OUTER1 =~"imcn_jig_weekly_pm_calendar.organization_id~" )WHERE(    EXP1 =~"~~~"IMCN_JIG_WEEKLY_PM_CALENDAR~~~".~~~"PLAN_YYYY~~~"~"   OP =~"=~"    EXP2 =~":arg_yyyy~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_JIG~~~".~~~"JIG_TYPE~~~"~"   OP =~"like~"    EXP2 =~":arg_jig_type~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_JIG_WEEKLY_PM_CALENDAR~~~".~~~"JIG_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_jig_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_JIG_WEEKLY_PM_CALENDAR~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ORDER(NAME=~"imcn_jig_weekly_pm_calendar.plan_mm~" ASC=yes )  ORDER(NAME=~"imcn_jig_weekly_pm_calendar.plan_weeks~" ASC=yes ) ARG(NAME = ~"arg_yyyy~" TYPE = string)  ARG(NAME = ~"arg_jig_type~" TYPE = string)  ARG(NAME = ~"arg_jig_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_yyyy", string),("arg_jig_type", string),("arg_jig_code", string),("arg_org", number))  sort="plan_yyyy A jig_type A jig_code A " )
