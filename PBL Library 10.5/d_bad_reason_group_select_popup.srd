footer(height=0 color="536870912" )
detail(height=188 color="536870912" )
table(column=(type=char(100) updatewhereclause=yes name=code_mean dbname="code_mean" )
 column=(type=char(30) updatewhereclause=yes name=code_name dbname="isys_code_master.code_name" dbalias=".code_name" )
 retrieve="  SELECT decode( :arg_lang ,'C' ,MAX(CODE_NAME_DESCRIPTION_LOCAL),  'K' , MAX(CODE_NAME_DESCRIPTION_KOR ) , MAX(CODE_NAME_DESCRIPTION_ENG)  ) CODE_MEAN,   
			CODE_GROUP_SECOND  CODE_NAME
			
FROM ISYS_CODE_MASTER  
WHERE CODE_TYPE = 'WQC BAD REASON CODE'    
AND ( CODE_GROUP_SECOND <> '*' AND CODE_GROUP_THIRD <> '*' ) 
AND ORGANIZATION_ID = :ARG_ORG
GROUP BY 			CODE_GROUP,   
			CODE_GROUP_SECOND" arguments=(("ARG_LANG", string),("ARG_ORG", number))  sort="code_mean A " )
