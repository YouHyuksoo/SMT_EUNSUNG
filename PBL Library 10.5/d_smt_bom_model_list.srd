text(band=header alignment="2" text="Pcb Item" border="0" color="33554432" x="814" y="8" height="120" width="187" html.valueishtml="0"  name=pcb_item_t visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="15780518" )
