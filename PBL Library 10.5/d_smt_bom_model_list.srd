HA$PBExportHeader$d_smt_bom_model_list.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=132 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="id_eng_bom_smt.parent_item_code" dbalias=".parent_item_code" )
 column=(type=char(30) updatewhereclause=yes name=pcb_item dbname="id_eng_bom_smt.pcb_item" dbalias=".pcb_item" )
 retrieve="  SELECT 'N' CHECK_YN , ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~"   , PCB_ITEM
    FROM ~"ID_ENG_BOM_SMT~"   
WHERE PARENT_ITEM_CODE LIKE :arg_model_name
  AND  LINE_CODE LIKE :ARG_LINE_CODE
  AND PCB_ITEM LIKE :ARG_PCB_ITEM
  AND  ORGANIZATION_ID = :ARG_ORG
  AND  PARENT_ITEM_CODE  IN ( SELECT SMT_MODEL_NAME 
                                                   FROM IP_PRODUCT_MODEL_MASTER 
                                                 WHERE CUSTOMER_CODE LIKE :arg_customer_code 
                                                     AND  DATEEND >= TRUNC(:ARG_DATEEND) ) 
  AND  DATEEND >= TRUNC(SYSDATE) 
GROUP BY PARENT_ITEM_CODE  , PCB_ITEM
" arguments=(("arg_line_code", string),("arg_model_name", string),("arg_pcb_item", string),("arg_customer_code", string),("arg_org", number),("arg_dateend", datetime))  sort="parent_item_code A " )
text(band=header alignment="2" text="Check Yn" border="0" color="33554432" x="114" y="4" height="120" width="146" html.valueishtml="0"  name=check_yn_t visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="15780518" )
