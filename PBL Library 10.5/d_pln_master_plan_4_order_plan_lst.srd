         ~"IP_PRODUCT_ACTUAL_TIME_V~".~"J_TIME_ACTUAL~",
		F_GET_MODEL_PRODUCT_ST( IP_PRODUCT_MI_PLAN.MODEL_NAME , IP_PRODUCT_MI_PLAN.LINE_CODE , IP_PRODUCT_MI_PLAN.PCB_ITEM , IP_PRODUCT_MI_PLAN.WORKSTAGE_CODE ,  IP_PRODUCT_MI_PLAN.ORGANIZATION_ID ) MODEL_ST ,
		F_GET_CARRIER_SIZE(  IP_PRODUCT_MI_PLAN.MODEL_NAME , IP_PRODUCT_MI_PLAN.ORGANIZATION_ID ) CARRIER_SIZE ,


         ~"IP_PRODUCT_MI_PLAN~".~"PLAN_TIME1~" +  
         ~"IP_PRODUCT_MI_PLAN~".~"PLAN_TIME2~"+   
         ~"IP_PRODUCT_MI_PLAN~".~"PLAN_TIME3~"+  
         ~"IP_PRODUCT_MI_PLAN~".~"PLAN_TIME4~"+   
         ~"IP_PRODUCT_MI_PLAN~".~"PLAN_TIME5~"+     
