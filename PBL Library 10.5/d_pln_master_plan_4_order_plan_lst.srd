         ~"IP_PRODUCT_MI_PLAN~".~"ENTER_BY~",   
         ~"IP_PRODUCT_MI_PLAN~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_MI_PLAN~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
