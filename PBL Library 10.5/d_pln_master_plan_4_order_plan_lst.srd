         ~"IP_PRODUCT_MI_PLAN~".~"PLAN_CAPA_QTY~" ,
		~"IP_PRODUCT_MI_PLAN~".~"MC_TIME~" ,
         ~"IP_PRODUCT_MI_PLAN~".~"TIME1_DESC~" ,
         ~"IP_PRODUCT_MI_PLAN~".~"TIME2_DESC~",   
         ~"IP_PRODUCT_MI_PLAN~".~"TIME3_DESC~",  
         ~"IP_PRODUCT_MI_PLAN~".~"TIME4_DESC~",   
         ~"IP_PRODUCT_MI_PLAN~".~"TIME5_DESC~",     
         ~"IP_PRODUCT_MI_PLAN~".~"TIME6_DESC~",     
         ~"IP_PRODUCT_MI_PLAN~".~"TIME7_DESC~",     
         ~"IP_PRODUCT_MI_PLAN~".~"TIME8_DESC~",     
         ~"IP_PRODUCT_MI_PLAN~".~"TIME9_DESC~",     
         ~"IP_PRODUCT_MI_PLAN~".~"TIME10_DESC~"



    FROM ~"IP_PRODUCT_MI_PLAN~",   
              ~"ID_ITEM~",   
              ~"IP_PRODUCT_ACTUAL_TIME_V~" 
   WHERE ( ip_product_mi_plan.item_code = id_item.item_code (+)) and  
         ( ip_product_mi_plan.organization_id = id_item.organization_id (+)) and  
         ( ~"IP_PRODUCT_MI_PLAN~".~"PLAN_DATE~" = ~"IP_PRODUCT_ACTUAL_TIME_V~".~"ACTUAL_DATE~"(+) ) and  
         ( ~"IP_PRODUCT_MI_PLAN~".~"LINE_CODE~" = ~"IP_PRODUCT_ACTUAL_TIME_V~".~"LINE_CODE~"(+) ) and  
         ( ~"IP_PRODUCT_MI_PLAN~".~"MODEL_NAME~" = ~"IP_PRODUCT_ACTUAL_TIME_V~".~"MODEL_NAME~"(+) ) and  
         ( ~"IP_PRODUCT_MI_PLAN~".~"WORKSTAGE_CODE~" = ~"IP_PRODUCT_ACTUAL_TIME_V~".~"WORKSTAGE_CODE~"(+) ) and  
         ( ( ~"IP_PRODUCT_MI_PLAN~".~"PLAN_DATE~" >= :arg_dateset ) AND  
         ( ~"IP_PRODUCT_MI_PLAN~".~"PLAN_DATE~" <= :arg_dateend ) AND  
         ( ~"IP_PRODUCT_MI_PLAN~".~"MODEL_NAME~" like :arg_model_name) AND  
         ~"IP_PRODUCT_MI_PLAN~".~"LINE_CODE~" like :arg_line_code AND  
         ( ~"IP_PRODUCT_MI_PLAN~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_model_name", string),("arg_line_code", string),("arg_org_id", number))  sort="organization_id A line_code A plan_date A plan_priority A model_name A " )
