table(column=(type=char(20) update=yes updatewhereclause=yes name=role_code dbname="isys_role.role_code" )
 column=(type=char(100) update=yes updatewhereclause=yes name=role_name dbname="role_name" )
 retrieve="  SELECT ~"ISYS_ROLE~".~"ROLE_CODE~",   
            MAX(~"ISYS_ROLE~".~"ROLE_NAME~") ROLE_NAME
    FROM ~"ISYS_ROLE~"  
   WHERE   ( ~"ISYS_ROLE~".~"ORGANIZATION_ID~" = :ARG_ORG )    
GROUP BY  ~"ISYS_ROLE~".~"ROLE_CODE~"
" arguments=(("ARG_ORG", number))  sort="role_code A " )
