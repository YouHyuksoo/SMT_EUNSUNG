HA$PBExportHeader$d_mat_receipt_sum_rpt.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=33554431 processing=0 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 0 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no )
header(height=472 color="536870912" )
summary(height=84 color="65535" )
footer(height=96 color="536870912" )
detail(height=76 color="536870912~tif ( mod(  getrow() , 2 )  = 0 , rgb(255,255,255) , rgb(219,219,219) )" )
table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="im_item_receipt.item_code" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 column=(type=char(1) updatewhereclause=yes name=virtual_receipt_yn dbname="id_item.virtual_receipt_yn" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="im_item_receipt.supplier_code" )
 column=(type=char(100) updatewhereclause=yes name=supplier_name dbname="icom_supplier.supplier_name" )
 column=(type=char(1) updatewhereclause=yes name=receipt_type dbname="im_item_receipt.receipt_type" )
 column=(type=number updatewhereclause=yes name=receipt_qty dbname="receipt_qty" )
 column=(type=number updatewhereclause=yes name=receipt_price dbname="receipt_price" )
 column=(type=number updatewhereclause=yes name=receipt_amt dbname="receipt_amt" )
 column=(type=number updatewhereclause=yes name=foreign_receipt_amt dbname="foreign_receipt_amt" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_receipt.organization_id" )
 column=(type=char(30) updatewhereclause=yes name=invoice_no dbname="im_item_receipt.invoice_no" )
 retrieve=" select   a.item_code,   b.item_name,  b.item_spec, b.item_uom, b.virtual_receipt_yn, 
            a.supplier_code, c.supplier_name,
            a.receipt_type,
            sum(a.receipt_qty) receipt_qty,
            avg(a.unit_price) receipt_price,
            sum(a.receipt_amt) receipt_amt,
            sum(a.foreign_receipt_amt) foreign_receipt_amt, 
            a.organization_id ,
            a.invoice_no
 from     im_item_receipt  a, 
            id_item    b,
            icom_supplier  c 
 where   a.item_code = b.item_code 
 and      a.organization_id = b.organization_id 
 and      a.supplier_code = c.supplier_code
 and      a.organization_id = c.organization_id
 and      a.receipt_date between :arg_dateset   and  :arg_dateend
 and      a.supplier_code like :arg_supplier_code
 and      a.item_code like :arg_item_code
 and      a.invoice_no like :arg_invoice_no
 and      a.organization_id = :arg_org_id 
 and      a.receipt_status <> 'C'
group by a.item_code, b.item_name, b.item_spec, b.item_uom, b.virtual_receipt_yn, a.supplier_code, c.supplier_name, a.receipt_type,a.organization_id ,a.invoice_no
 
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_invoice_no", string),("arg_org_id", number))  sort="organization_id A supplier_code A item_code A " )
group(level=1 header.height=84 trailer.height=0 by=("organization_id" , "supplier_code" ) header.color="65280" trailer.color="16777215" )
