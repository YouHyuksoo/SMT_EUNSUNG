table(column=(type=char(30) updatewhereclause=yes name=jig_code dbname="imcn_jig.jig_code" dbalias=".jig_code" )
 column=(type=char(20) updatewhereclause=yes name=jig_lot_no dbname="imcn_jig.jig_lot_no" dbalias=".jig_lot_no" )
 column=(type=char(22) updatewhereclause=yes name=barcode dbname="barcode" )
 column=(type=char(100) updatewhereclause=yes name=jig_name dbname="imcn_jig.jig_name" dbalias=".jig_name" )
 column=(type=char(100) updatewhereclause=yes name=jig_spec dbname="imcn_jig.jig_spec" dbalias=".jig_spec" )
 retrieve="  SELECT ~"IMCN_JIG~".~"JIG_CODE~",   
			~"IMCN_JIG~".~"JIG_LOT_NO~",   
			'*'||~"IMCN_JIG~".~"JIG_LOT_NO~"||'*' BARCODE,   
			~"IMCN_JIG~".~"JIG_NAME~",   
			~"IMCN_JIG~".~"JIG_SPEC~"  
    FROM ~"IMCN_JIG~"
   WHERE
        ( ~"IMCN_JIG~".~"JIG_CODE~" like :arg_jig_code ) AND
        ( ~"IMCN_JIG~".~"JIG_TYPE~" like :arg_jig_type ) AND
         ( ~"IMCN_JIG~".~"JIG_LOT_NO~" like :arg_jig_lot_no ) AND  
         ( ~"IMCN_JIG~".~"JIG_NAME~" like :arg_jig_name ) AND  
         ( ~"IMCN_JIG~".~"ORGANIZATION_ID~" = :arg_org )     
" arguments=(("arg_jig_code", string),("arg_jig_type", string),("arg_jig_lot_no", string),("arg_jig_name", string),("arg_org", number))  sort="jig_code A " )
