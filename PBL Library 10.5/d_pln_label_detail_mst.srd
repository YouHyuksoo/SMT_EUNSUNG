         ~"ISYS_LABEL_FORM~".~"LABEL_FORM_NAME~",   
         ~"ISYS_LABEL_FORM~".~"LABEL_FORM_TYPE~",   
         model_name||'_'||label_form_no||'.bmp'   as label_image   ,


		f_gen_label_data_4_bartender( '' , model_name , label_form_no , 'V1' , SYSDATE , '1' , 'PREVIEW' , '' )  V1_DATA ,
