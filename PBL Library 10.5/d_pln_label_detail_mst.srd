    FROM ~"ISYS_LABEL_FORM~"  
   WHERE ( ~"ISYS_LABEL_FORM~".~"MODEL_NAME~" = :arg_model_name ) AND  
         ( ~"ISYS_LABEL_FORM~".~"LABEL_FORM_NO~" = :arg_label_form_no ) AND  
         ( ~"ISYS_LABEL_FORM~".~"ORGANIZATION_ID~" = :arg_org )    
