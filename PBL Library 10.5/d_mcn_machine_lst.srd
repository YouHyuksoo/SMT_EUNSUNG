 retrieve="  SELECT rowid,   
         'N' CHECK_YN,   
         ~"IMCN_MACHINE~".~"MACHINE_CODE~",   
         ~"IMCN_MACHINE~".~"ORGANIZATION_ID~",   
         ~"IMCN_MACHINE~".~"MACHINE_NAME~",   
         ~"IMCN_MACHINE~".~"MACHINE_TYPE~",   
         ~"IMCN_MACHINE~".~"CAPACITY~",   
         ~"IMCN_MACHINE~".~"RESERVED_CAPACITY~",   
         ~"IMCN_MACHINE~".~"ACQUISITION_DATE~",   
         ~"IMCN_MACHINE~".~"ACQUISITION_TYPE~",   
         ~"IMCN_MACHINE~".~"MACHINE_MODEL_NAME~",   
         ~"IMCN_MACHINE~".~"LINE_CODE~",   
         ~"IMCN_MACHINE~".~"CUSTOMER_CODE~",   
         ~"IMCN_MACHINE~".~"USE_STATUS~",   
         ~"IMCN_MACHINE~".~"MANUAL_LOCATION_COMMENT~",   
         ~"IMCN_MACHINE~".~"NATION_CODE~",   
         ~"IMCN_MACHINE~".~"WORKSTAGE_CODE~",   
         ~"IMCN_MACHINE~".~"ENTER_BY~",   
         ~"IMCN_MACHINE~".~"ENTER_DATE~",   
         ~"IMCN_MACHINE~".~"LAST_MODIFY_BY~",   
         ~"IMCN_MACHINE~".~"LAST_MODIFY_DATE~",   
         ~"IMCN_MACHINE~".~"USE_RATE~",   
         ~"IMCN_MACHINE~".~"UPH_VALUE~",   
         ~"IMCN_MACHINE~".~"CAPACITY_UOM~",   
         ~"IMCN_MACHINE~".~"SUPPLIER_CODE~",   
         ~"IMCN_MACHINE~".~"MACHINE_STATUS~",   
         ~"IMCN_MACHINE~".~"MOLD_CODE~",   
         ~"IMCN_MACHINE~".~"MOLD_VERSION~",   
         ~"IMCN_MACHINE~".~"MOLD_SET_SERIAL~",   
         ~"IMCN_MACHINE~".~"MACHINE_IMAGE_FILE_NAME~",   
         ~"IMCN_MACHINE~".~"MES_DISPLAY_YN~",   
         ~"IMCN_MACHINE~".~"MES_DISPLAY_SEQUENCE~",   
         ~"IMCN_MACHINE~".~"MOLD_EXISTS_YN~",   
         ~"IMCN_MACHINE~".~"MACHINE_STATUS_CODE~",   
         ~"IMCN_MACHINE~".~"CALLING_PLC_ADDRESS~",   
         ~"IMCN_MACHINE~".~"ACTION_DATE~",   
         ~"IMCN_MACHINE~".~"ACTUAL_PLC_ADDRESS~",   
         ~"IMCN_MACHINE~".~"USE_TPM_YN~",   
         ~"IMCN_MACHINE~".~"MACHINE_SPEC~",   
         ~"IMCN_MACHINE~".~"MODEL_NAME~",   
         ~"IMCN_MACHINE~".~"DEPARTMENT_CODE~",   
         ~"IMCN_MACHINE~".~"IP_ADDRESS~",   
         ~"IMCN_MACHINE~".~"PORT_NO~",   
         ~"IMCN_MACHINE~".~"DIO_PORT~",   
         ~"IMCN_MACHINE~".~"SCANNER_PORT~",   
         ~"IMCN_MACHINE~".~"EQUIPMENT_PORT~",   
         ~"IMCN_MACHINE~".~"DIO_ADDRESS~",   
         ~"IMCN_MACHINE~".~"BCR_CODE~",   
         ~"IMCN_MACHINE~".~"BUFFER_TYPE~",   
         ~"IMCN_MACHINE~".~"PROCESS_WAIT_TIME~",   
         ~"IMCN_MACHINE~".~"JIG_TYPE~",   
         ~"IMCN_MACHINE~".~"HIT_VALUE~",   
         ~"IMCN_MACHINE~".~"BREAK_VALUE~",   
         ~"IMCN_MACHINE~".~"MAIN_POWER~",   
         ~"IMCN_MACHINE~".~"MACHINE_LENGTH~",   
         ~"IMCN_MACHINE~".~"POWER_CONSUMPTION~",   
         ~"IMCN_MACHINE~".~"SCANNER_ADDRESS~",   
         ~"IMCN_MACHINE~".~"MIN_TEMP_VALUE~",   
         ~"IMCN_MACHINE~".~"MAX_TEMP_VALUE~",   
         ~"IMCN_MACHINE~".~"STD_TEMP_VALUE~",   
         ~"IMCN_MACHINE~".~"MIN_HUMIDITY_VALUE~",   
         ~"IMCN_MACHINE~".~"MAX_HUMIDITY_VALUE~",   
         ~"IMCN_MACHINE~".~"STD_HUMIDITY_VALUE~",   
         ~"IMCN_MACHINE~".~"NSNP_MINUS_CHECK_YN~",   
         ~"IMCN_MACHINE~".~"MACHINE_STATUS_DESCRIPTION~"  ,
         ~"IMCN_MACHINE~".~"TEMP_OFFSET~"  ,
         ~"IMCN_MACHINE~".~"HUMIDITY_OFFSET~"  
    FROM ~"IMCN_MACHINE~"  
   WHERE ( ~"IMCN_MACHINE~".~"MACHINE_CODE~" like :arg_machine_code ) AND  
         ( ~"IMCN_MACHINE~".~"MACHINE_TYPE~" like :arg_machine_type ) AND  
         ( ~"IMCN_MACHINE~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IMCN_MACHINE~".~"ACQUISITION_TYPE~" like :arg_acquisition_type ) AND  
         ( ~"IMCN_MACHINE~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_machine_code", string),("arg_machine_type", string),("arg_line_code", string),("arg_acquisition_type", string),("arg_org", number))  sort="organization_id A line_code A mes_display_sequence A " )
