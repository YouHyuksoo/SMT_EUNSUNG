release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=68 color="536870912" )
summary(height=68 color="536870912" )
footer(height=1296 color="536870912" )
detail(height=56 color="536870912" )
table(column=(type=char(4000) updatewhereclause=yes name=workstage_code dbname="workstage_code" )
 column=(type=number updatewhereclause=yes name=in_qty dbname="in_qty" )
 column=(type=number updatewhereclause=yes name=out_qty dbname="out_qty" )
 column=(type=number updatewhereclause=yes name=bad_qty dbname="bad_qty" )
 column=(type=number updatewhereclause=yes name=rty dbname="rty" )
 retrieve="  SELECT F_GET_WORKSTAGE_NAME(WORKSTAGE_CODE) WORKSTAGE_CODE,
			SUM(IN_QTY) IN_QTY,
			SUM(OUT_QTY) OUT_QTY,
			SUM(BAD_QTY) BAD_QTY,
			SUM(OUT_QTY) / SUM(IN_QTY) RTY 
FROM 
(
SELECT A.WORKSTAGE_CODE  ,
		   OUT_QTY , IN_QTY , BAD_QTY
    FROM IP_PRODUCT_RUN_CARD_IO    A
WHERE  A.OUT_DATE >= TRUNC(SYSDATE) - 30
     AND IN_QTY > 0 AND OUT_QTY > 0 
ORDER BY WORKSTAGE_CODE
)
GROUP BY WORKSTAGE_CODE
"  sort="workstage_code A " )
text(band=header alignment="2" text="Workstage Code" border="2" color="33554432" x="160" y="8" height="56" width="832" html.valueishtml="0"  name=workstage_code_t visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="33327873" )
