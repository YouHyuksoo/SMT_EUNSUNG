 retrieve="SELECT * FROM 
(
  SELECT 'INTERNAL' WAREHOUSE_TYPE ,
         ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_HOLD~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_AMT~",   
         ~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"COMMENTS~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_BY~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_BY~", 
         ~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~" ,
         ~"ID_ITEM~".~"ITEM_DIVISION~"
    FROM ~"IM_ITEM_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
)" arguments=(("arg_item_code", string),("arg_org_id", number))  sort="organization_id A item_division A line_type A warehouse_type A item_code A " )
