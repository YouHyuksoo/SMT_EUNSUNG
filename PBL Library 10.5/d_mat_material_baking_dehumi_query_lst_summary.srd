table(column=(type=char(30) updatewhereclause=yes name=chamber_type dbname="im_item_baking_master.chamber_type" )
 column=(type=char(10) update=yes updatewhereclause=yes name=chamber_code dbname="im_item_baking_master.chamber_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="im_item_baking_master.item_code" )
 column=(type=number updatewhereclause=yes name=count_num dbname="count_num" )
 column=(type=number update=yes updatewhereclause=yes name=lot_qty dbname="lot_qty" )
 column=(type=datetime updatewhereclause=yes name=min_scan_date dbname="min_scan_date" )
 column=(type=datetime updatewhereclause=yes name=max_scan_date dbname="max_scan_date" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="id_item.supplier_code" )
 column=(type=char(4000) updatewhereclause=yes name=machine_name dbname="machine_name" )
 retrieve="  SELECT ~"IM_ITEM_BAKING_MASTER~".~"CHAMBER_TYPE~" ,
              ~"IM_ITEM_BAKING_MASTER~".~"CHAMBER_CODE~",   
              ~"IM_ITEM_BAKING_MASTER~".~"ITEM_CODE~",
              SUM(1)                                                                        COUNT_NUM,
              SUM(~"IM_ITEM_BAKING_MASTER~".~"LOT_QTY~")                LOT_QTY, 
              MIN(~"IM_ITEM_BAKING_MASTER~".~"INPUT_SCAN_DATE~")  MIN_SCAN_DATE, 
              MAX(~"IM_ITEM_BAKING_MASTER~".~"INPUT_SCAN_DATE~")  MAX_SCAN_DATE ,
			ID_ITEM.ITEM_NAME , ID_ITEM.ITEM_SPEC ,
			ID_ITEM.SUPPLIER_CODE  AS SUPPLIER_CODE,
              F_GET_MACHINE_NAME(~"IM_ITEM_BAKING_MASTER~".~"CHAMBER_CODE~")  MACHINE_NAME
 
    FROM ~"IM_ITEM_BAKING_MASTER~" , ID_ITEM
 WHERE  ( ~"IM_ITEM_BAKING_MASTER~".~"ITEM_CODE~" = ID_ITEM.ITEM_CODE(+) ) AND 
              ( ~"IM_ITEM_BAKING_MASTER~".~"ITEM_CODE~" like :arg_item_code ) AND  
              ( ~"IM_ITEM_BAKING_MASTER~".~"LOT_NO~" like :arg_lot_no )             AND  
              ( ~"IM_ITEM_BAKING_MASTER~".~"INPUT_SCAN_DATE~" IS NOT NULL ) AND  
              ( ~"IM_ITEM_BAKING_MASTER~".~"OUTPUT_SCAN_DATE~" IS NULL )     AND  
              ( ~"IM_ITEM_BAKING_MASTER~".~"ORGANIZATION_ID~" = :arg_org )    AND   
              ( ~"IM_ITEM_BAKING_MASTER~".~"CHAMBER_TYPE~" = :arg_type )       AND
              ( ~"IM_ITEM_BAKING_MASTER~".~"CHAMBER_CODE~"  like :arg_location )    
    GROUP BY ~"IM_ITEM_BAKING_MASTER~".~"CHAMBER_TYPE~" ,
                    ~"IM_ITEM_BAKING_MASTER~".~"CHAMBER_CODE~",   
                    ~"IM_ITEM_BAKING_MASTER~".~"ITEM_CODE~" ,
					ID_ITEM.ITEM_NAME , ID_ITEM.ITEM_SPEC  , ID_ITEM.SUPPLIER_CODE
  " arguments=(("arg_item_code", string),("arg_lot_no", string),("arg_org", number),("arg_type", string),("arg_location", string))  sort="item_code A " )
