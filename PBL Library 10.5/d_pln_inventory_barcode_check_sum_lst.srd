HA$PBExportHeader$d_pln_inventory_barcode_check_sum_lst.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=144 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(6) update=yes updatewhereclause=yes name=check_yyyymm dbname="im_assy_inventory_check_bcd.check_yyyymm" dbalias=".check_yyyymm" )
 column=(type=number update=yes updatewhereclause=yes name=barcode_qty dbname="barcode_qty" )
 column=(type=char(30) update=yes updatewhereclause=yes name=line_code dbname="im_assy_inventory_check_bcd.line_code" dbalias=".line_code" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="im_assy_inventory_check_bcd.model_name" dbalias=".model_name" )
 column=(type=char(10) updatewhereclause=yes name=model_suffix dbname="im_assy_inventory_check_bcd.model_suffix" dbalias=".model_suffix" )
 column=(type=char(50) updatewhereclause=yes name=item_code dbname="im_assy_inventory_check_bcd.item_code" dbalias=".item_code" )
 column=(type=char(1) updatewhereclause=yes name=reverse_yn dbname="reverse_yn" )
 column=(type=char(2000) updatewhereclause=yes name=reverse_error dbname="reverse_error" )
 column=(type=char(30) updatewhereclause=yes name=master_item_code dbname="master_item_code" )
 retrieve="  SELECT 
          'N' CHECK_YN ,
          IM_ASSY_INVENTORY_CHECK_BCD.CHECK_YYYYMM,   
         SUM( NVL(IM_ASSY_INVENTORY_CHECK_BCD.BARCODE_QTY,0)) BARCODE_QTY,   
         IM_ASSY_INVENTORY_CHECK_BCD.LINE_CODE,   
	IM_ASSY_INVENTORY_CHECK_BCD.MODEL_NAME , 
				IM_ASSY_INVENTORY_CHECK_BCD.MODEL_SUFFIX  ,
				IM_ASSY_INVENTORY_CHECK_BCD.ITEM_CODE ,
         MAX(NVL(IM_ASSY_INVENTORY_CHECK_BCD.REVERSE_YN , 'N'))  REVERSE_YN ,   
         MAX(IM_ASSY_INVENTORY_CHECK_BCD.REVERSE_ERROR) REVERSE_ERROR ,
		MAX(IM_ASSY_INVENTORY_CHECK_BCD.MASTER_ITEM_CODE)  MASTER_ITEM_CODE

    FROM IM_ASSY_INVENTORY_CHECK_BCD,   
              IP_PRODUCT_2D_BARCODE
   WHERE( IM_ASSY_INVENTORY_CHECK_BCD.ITEM_BARCODE = IP_PRODUCT_2D_BARCODE.SERIAL_NO (+)) and  
			( IM_ASSY_INVENTORY_CHECK_BCD.CHECK_YYYYMM = :arg_yyyymm ) AND  
			( IM_ASSY_INVENTORY_CHECK_BCD.ITEM_BARCODE  LIKE :arg_item_barcode ) AND 		
			( NVL(IM_ASSY_INVENTORY_CHECK_BCD.LINE_CODE,'*')  LIKE :arg_line_code ) AND 		
			( IM_ASSY_INVENTORY_CHECK_BCD.ORGANIZATION_ID = :arg_org ) 


GROUP BY 	IM_ASSY_INVENTORY_CHECK_BCD.MODEL_NAME , 
				IM_ASSY_INVENTORY_CHECK_BCD.MODEL_SUFFIX  ,
				IM_ASSY_INVENTORY_CHECK_BCD.ITEM_CODE ,
				IM_ASSY_INVENTORY_CHECK_BCD.LINE_CODE, 
				IM_ASSY_INVENTORY_CHECK_BCD.CHECK_YYYYMM 
			" arguments=(("arg_yyyymm", string),("arg_item_barcode", string),("arg_line_code", string),("arg_org", number))  sort="line_code A " )
group(level=1 header.height=0 trailer.height=80 by=("line_code" ) header.color="536870912" trailer.color="134217728" )
