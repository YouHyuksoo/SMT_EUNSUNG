 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="im_item_manual_input_history.last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="im_item_manual_input_history.last_modify_date" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_manual_input_history.organization_id" )
 column=(type=char(100) updatewhereclause=yes name=comments dbname="im_item_manual_input_history.comments" )
 retrieve="
select M.input_date,
       M.line_code,
       M.run_no,
       R.model_name,
       M.WORKSTAGE_CODE,
       M.material_lot,
       M.ENTER_BY,
       M.ENTER_DATE,
       M.LAST_MODIFY_BY,
       M.LAST_MODIFY_DATE,
       M.ORGANIZATION_ID,
       M.COMMENTS
from IM_ITEM_MANUAL_INPUT_HISTORY M,
       IP_PRODUCT_RUN_CARD          R
where M.run_no                = R.run_no (+)
   and M.ORGANIZATION_ID = R.ORGANIZATION_ID (+)
   and  M.input_date >= trunc(:arg_dateset)
   and  M.input_date <   trunc(:arg_dateend) +1
   and  M.line_code              like :arg_line_code
   and  M.workstage_code    like :arg_workstage_code
   and  M.run_no                  like :arg_run_no
   and  R.model_name          like :arg_model_name
   and  R.ORGANIZATION_ID = :arg_org " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_workstage_code", string),("arg_run_no", string),("arg_model_name", string),("arg_org", number))  sort="input_date A line_code A run_no A model_name A " )
