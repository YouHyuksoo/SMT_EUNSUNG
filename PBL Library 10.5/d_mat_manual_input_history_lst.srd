table(column=(type=datetime updatewhereclause=yes name=input_date dbname="im_item_manual_input_history.input_date" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="im_item_manual_input_history.line_code" )
 column=(type=char(20) updatewhereclause=yes name=run_no dbname="im_item_manual_input_history.run_no" )
 column=(type=char(100) updatewhereclause=yes name=model_name dbname="ip_product_run_card.model_name" )
