 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"ip_product_model_master~" ) COLUMN(NAME=~"ip_product_model_master.model_name~") COLUMN(NAME=~"ip_product_model_master.model_spec~") COLUMN(NAME=~"ip_product_model_master.model_type~") COLUMN(NAME=~"ip_product_model_master.part_no~") COLUMN(NAME=~"ip_product_model_master.customer_code~") COLUMN(NAME=~"ip_product_model_master.customer_name~") COLUMN(NAME=~"ip_product_model_master.model_division~") COLUMN(NAME=~"ip_product_model_master.revision~") COMPUTE(NAME=~"F_CHECK_BOM_EXISTS( ITEM_CODE , ORGANIZATION_ID ) BOM_EXISTS~") COMPUTE(NAME=~"F_CHECK_SMT_BOM_EXISTS( MODEL_NAME, ORGANIZATION_ID ) SMT_BOM_EXISTS~") COMPUTE(NAME=~"F_CHECK_JIG_EXISTS( MODEL_NAME, ORGANIZATION_ID ) JIG_EXISTS~") COMPUTE(NAME=~"F_CHECK_CALENDER_EXISTS( MODEL_NAME, ORGANIZATION_ID ) CALENDER_EXISTS~") COLUMN(NAME=~"ip_product_model_master.model_suffix~") COLUMN(NAME=~"ip_product_model_master.item_code~") COLUMN(NAME=~"ip_product_model_master.master_model_name~") COLUMN(NAME=~"ip_product_model_master.smt_model_name~") COLUMN(NAME=~"ip_product_model_master.carrier_size~")WHERE(    EXP1 =~"( ~~~"IP_PRODUCT_MODEL_MASTER~~~".~~~"MODEL_NAME~~~"~"   OP =~"like~"    EXP2 =~":ARG_MODEL_NAME )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IP_PRODUCT_MODEL_MASTER~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":ARG_ITEM_CODE~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IP_PRODUCT_MODEL_MASTER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG~" ) ) ARG(NAME = ~"ARG_MODEL_NAME~" TYPE = string)  ARG(NAME = ~"ARG_ITEM_CODE~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " arguments=(("ARG_MODEL_NAME", string),("ARG_ITEM_CODE", string),("ARG_ORG", number))  sort="customer_code A model_name A " )
