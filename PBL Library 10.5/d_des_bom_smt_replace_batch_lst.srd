 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(300) updatewhereclause=yes name=item_replace_spec dbname="item_replace_spec" )
 retrieve="  SELECT CHILD_ITEM_CODE,   
              REPLACE_ITEM_CODE,   
              USE_YN,
              ENTER_BY,
              ENTER_DATE,
              LAST_MODIFY_BY,
              LAST_MODIFY_DATE,
              ORGANIZATION_ID,
              (select item_spec
                  from id_item
                 where item_code = x.child_item_code
                  and rownum = 1
              ) ITEM_SPEC,
              (select item_spec
                  from id_item
                 where item_code = x.replace_item_code
                  and rownum = 1
              ) ITEM_REPLACE_SPEC
    FROM ID_ENG_BOM_SMT_REPLACE_BATCH  X
    WHERE CHILD_ITEM_CODE like :ARG_CHILD_ITEM 
       AND REPLACE_ITEM_CODE like :ARG_REPLACE_ITEM 
       AND ORGANIZATION_ID = :ARG_ORG     
" update="ID_ENG_BOM_SMT_REPLACE_BATCH" updatewhere=0 updatekeyinplace=no arguments=(("ARG_CHILD_ITEM", string),("ARG_REPLACE_ITEM", string),("ARG_ORG", number))  sort="child_item_code A " )
