header[2](height=0 color="536870912" )
header[3](height=124 color="536870912" )
summary(height=80 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) updatewhereclause=yes name=model_suffix dbname="model_suffix" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 retrieve="select y.model_name, 
       y.model_suffix, 
       y.line_code, 
       f_get_line_name(y.line_code, 1) as line_name, 
       y.workstage_code||'('|| z.workstage_name||')' as workstage_code , 
       z.workstage_name, 
       y.inventory_qty 
  from (   
				select x.model_name, 
						x.model_suffix, 
						x.workstage_code, 
						x.line_code, 
						sum(x.inventory_qty) inventory_qty
				from ip_product_workstage_inv x
				where model_name like :arg_model
				and workstage_code like :arg_workstage_code
				
				group by x.model_name, 
					x.model_suffix, 
					x.workstage_code,
					x.line_code

       ) y , ip_product_workstage z 
  where y.workstage_code = z.workstage_code" arguments=(("arg_model", string),("arg_workstage_code", string))  sort="model_name A model_suffix A " )
group(level=1 header.height=0 trailer.height=84 by=("model_name" ) header.color="536870912" trailer.color="134217744" )
