 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="iq_item_iqc.enter_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="iq_item_iqc.last_modify_date" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="iq_item_iqc.last_modify_by" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="iq_item_iqc.item_code" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="iq_item_iqc.organization_id" )
 column=(type=char(30) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(100) updatewhereclause=yes name=customer_name dbname="icom_customer.customer_name" )
 retrieve="  SELECT ~"IQ_ITEM_IQC~".~"INSPECT_DATE~",   
		''	check_in ,
         ~"IQ_ITEM_IQC~".~"INSPECT_SEQUENCE~",   
         ~"IQ_ITEM_IQC~".~"IQC_INSPECT_NO~",   
         ~"IQ_ITEM_IQC~".~"MFS~",   
         ~"IQ_ITEM_IQC~".~"RECEIPT_QTY~",   
         ~"IQ_ITEM_IQC~".~"BAD_QTY~",   
         ~"IQ_ITEM_IQC~".~"INSPECT_RESULT~",   
         ~"IQ_ITEM_IQC~".~"SUPPLIER_CODE~",   
         ~"IQ_ITEM_IQC~".~"INSPECT_BY~",   
         ~"IQ_ITEM_IQC~".~"ENTER_DATE~",   
         ~"IQ_ITEM_IQC~".~"ENTER_BY~",   
         ~"IQ_ITEM_IQC~".~"LAST_MODIFY_DATE~",   
         ~"IQ_ITEM_IQC~".~"LAST_MODIFY_BY~",   
         ~"IQ_ITEM_IQC~".~"ITEM_CODE~",   
         ~"IQ_ITEM_IQC~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ICOM_CUSTOMER~".~"CUSTOMER_NAME~"  
    FROM ~"ICOM_CUSTOMER~",   
         ~"ID_ITEM~",   
         ~"IQ_ITEM_IQC~"  
   WHERE ( ~"IQ_ITEM_IQC~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IQ_ITEM_IQC~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ~"IQ_ITEM_IQC~".~"SUPPLIER_CODE~" = ~"ICOM_CUSTOMER~".~"CUSTOMER_CODE~" ) and  
         ( ~"ICOM_CUSTOMER~".~"ORGANIZATION_ID~" = ~"IQ_ITEM_IQC~".~"ORGANIZATION_ID~" )    
" )
