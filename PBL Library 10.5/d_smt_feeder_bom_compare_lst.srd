table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="id_eng_bom_temp_item_code" )
 column=(type=char(20) updatewhereclause=yes name=id_item_pcb_item dbname="id_item_pcb_item" )
 column=(type=number updatewhereclause=yes name=item_code_1 dbname="id_eng_bom_temp_item_code_1" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="id_eng_bom_temp_item_unit_qty" )
 retrieve="  SELECT  'BOM' DIVISION ,
         NVL(T.CHILD_ITEM_CODE ,'*') ITEM_CODE ,   
          A.ITEM_CLASS PCB_ITEM ,
		NVL(T.ITEM_UNIT_QTY ,0) ITEM_UNIT_QTY
    FROM ID_ENG_BOM_TEMP T , ID_ITEM A
   WHERE ( T.PARENT_ITEM_CODE = A.ITEM_CODE ) AND  
         ( T.session_id = :arg_session_id ) AND  
         ( T.organization_id = :arg_org )   AND 
          A.ITEM_CLASS LIKE :ARG_TOPBOT
            
UNION all

SELECT 'FEEDER' DIVISION , 
            NVL(PARTNAME ,'*') ITEM_CODE ,
            PCB_ITEM , 
            NVL(ITEM_UNIT_QTY ,0 ) ITEM_UNIT_QTY
 FROM IB_MNT_PLANDATA
" arguments=(("arg_session_id", number),("arg_topbot", string),("arg_org", number))  sort="id_item_pcb_item A item_code A " )
