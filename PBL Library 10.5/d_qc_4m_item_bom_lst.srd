footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=id_eng_bom_child_item_code dbname="id_eng_bom.child_item_code" dbalias="a.child_item_code" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="item_unit_qty" )
 column=(type=char(10) updatewhereclause=yes name=id_eng_bom_line_type dbname="id_eng_bom.line_type" dbalias="a.line_type" )
 column=(type=char(1000) updatewhereclause=yes name=id_eng_bom_location_info dbname="id_eng_bom.location_info" dbalias="a.location_info" )
 column=(type=char(300) updatewhereclause=yes name=id_item_item_name dbname="id_item.item_name" dbalias="b.item_name" )
 column=(type=char(300) updatewhereclause=yes name=id_item_item_spec dbname="id_item.item_spec" dbalias="b.item_spec" )
 retrieve="     SELECT DISTINCT 
                            a.child_item_code,
                            decode(a.child_item_code , :ARG_PARENT_ITEM_CODE ,1,a.item_unit_qty)  item_unit_qty,
                     
                            a.line_type ,
                            a.location_info ,
						 b.item_name , 
						 b.item_spec  
        
            FROM id_eng_bom a , id_item b
            WHERE a.child_item_code = b.item_code(+) AND 
				     a.dateset <= TRUNC(SYSDATE) AND
                       a.dateend >=  TRUNC(SYSDATE)  AND
                       b.KEYITEM_YN = 'Y'
            START WITH a.child_item_code = :ARG_PARENT_ITEM_CODE 
                         AND a.parent_item_code = '*'
					  AND	a.dateset <=   TRUNC(SYSDATE)  
					  AND a.dateend >=  TRUNC(SYSDATE) 
									
            CONNECT BY PRIOR a.child_item_code = a.parent_item_code AND
                            a.dateset  <=  TRUNC(SYSDATE) AND
                            a.dateend >=  TRUNC(SYSDATE) 
" arguments=(("ARG_PARENT_ITEM_CODE", string)) )
