 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_mold_request~" )  TABLE(NAME=~"imcn_mold_inventory~" ) COLUMN(NAME=~"imcn_mold_request.mold_code~") COLUMN(NAME=~"imcn_mold_request.organization_id~") COLUMN(NAME=~"imcn_mold_request.mold_version~") COLUMN(NAME=~"imcn_mold_request.mold_set_serial~") COLUMN(NAME=~"imcn_mold_request.request_date~") COLUMN(NAME=~"imcn_mold_request.request_sequence~") COLUMN(NAME=~"imcn_mold_request.request_qty~") COLUMN(NAME=~"imcn_mold_request.request_status~") COLUMN(NAME=~"imcn_mold_request.issue_date~") COLUMN(NAME=~"imcn_mold_request.issue_qty~") COLUMN(NAME=~"imcn_mold_request.enter_by~") COLUMN(NAME=~"imcn_mold_request.enter_date~") COLUMN(NAME=~"imcn_mold_request.last_modify_by~") COLUMN(NAME=~"imcn_mold_request.last_modify_date~") COLUMN(NAME=~"imcn_mold_inventory.inventory_qty~") COLUMN(NAME=~"imcn_mold_inventory.location_code~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"imcn_mold_inventory.supplier_code~") COLUMN(NAME=~"imcn_mold_request.issue_sequence~")    JOIN (LEFT=~"imcn_mold_request.mold_code~"    OP =~"=~"RIGHT=~"imcn_mold_inventory.mold_code~" )    JOIN (LEFT=~"imcn_mold_request.organization_id~"    OP =~"=~"RIGHT=~"imcn_mold_inventory.organization_id~" )    JOIN (LEFT=~"imcn_mold_request.mold_version~"    OP =~"=~"RIGHT=~"imcn_mold_inventory.mold_version~" )    JOIN (LEFT=~"imcn_mold_request.mold_set_serial~"    OP =~"=~"RIGHT=~"imcn_mold_inventory.mold_set_serial~" )WHERE(    EXP1 =~"~~~"IMCN_MOLD_REQUEST~~~".~~~"MOLD_CODE~~~"~"   OP =~"like~"    EXP2 =~":ARG_MOLD_CODE~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_REQUEST~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_REQUEST~~~".~~~"REQUEST_STATUS~~~"~"   OP =~"=~"    EXP2 =~"'R'~" ) ) ARG(NAME = ~"ARG_MOLD_CODE~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " update="IMCN_MOLD_REQUEST" updatewhere=0 updatekeyinplace=yes arguments=(("ARG_MOLD_CODE", string),("ARG_ORG", number))  sort="request_date A request_sequence A " )
