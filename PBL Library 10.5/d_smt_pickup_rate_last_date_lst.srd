table(column=(type=char(4000) updatewhereclause=yes name=line_name dbname="line_name" )
 column=(type=char(50) updatewhereclause=yes name=machine_code dbname="iq_machine_inspect_pickup_rate.machine_code" )
 column=(type=datetime updatewhereclause=yes name=last_updated_date dbname="last_updated_date" )
 column=(type=char(8) updatewhereclause=yes name=passed_time dbname="passed_time" )
 retrieve="SELECT f_get_line_name(LINE_CODE, 1) LINE_NAME, 
       MACHINE_CODE, 
       MAX(ENTER_DATE)                                                                                      LAST_UPDATED_DATE,
       TO_CHAR(TRUNC(SYSDATE)+(SYSDATE - MAX(ENTER_DATE)),'HH24:MI:SS')  PASSED_TIME
  FROM IQ_MACHINE_INSPECT_PICKUP_RATE
 WHERE ACTUAL_DATE >= TRUNC(SYSDATE)
 GROUP BY LINE_CODE, MACHINE_CODE
 ORDER BY LINE_CODE, MACHINE_CODE
" )
