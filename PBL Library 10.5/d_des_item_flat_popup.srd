 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"id_item.item_code~") COLUMN(NAME=~"id_item.set_item_yn~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"id_item.item_type~") COLUMN(NAME=~"id_item.line_type~") COLUMN(NAME=~"id_item.organization_id~") COLUMN(NAME=~"id_item.dateset~") COLUMN(NAME=~"id_item.drawing_no~") COMPUTE(NAME=~"DECODE( SIGN( id_item.dateend - TRUNC( SYSDATE )), 1, 'RUNNING', 'EXPIRED' ) status~") COLUMN(NAME=~"id_item.item_class~") COLUMN(NAME=~"id_item.safety_inventory~") COLUMN(NAME=~"id_item.manufacture_leadtime~") COLUMN(NAME=~"id_item.item_division~")WHERE(    EXP1 =~"( ( id_item.item_code~"   OP =~"LIKE~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( id_item.organization_id~"   OP =~"=~"    EXP2 =~":arg_organization_id ) )~" ) ) ARG(NAME = ~"ARG_ITEM_CODE~" TYPE = string)  ARG(NAME = ~"ARG_ORGANIZATION_ID~" TYPE = number) " update="ID_ITEM" updatewhere=0 updatekeyinplace=no arguments=(("ARG_ITEM_CODE", string),("ARG_ORGANIZATION_ID", number))  sort="status D set_item_yn D item_code A " )
