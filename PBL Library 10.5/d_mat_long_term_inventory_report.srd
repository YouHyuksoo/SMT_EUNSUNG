$PBExportComments$D_MAT_RECEIPT_ISSUE_RPT CREATE DATE :2006-12-22 CREATED BY : ADMIN
release 10.5;
datawindow(units=0 timer_interval=0 color=16777215 processing=9 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=132 color="553648127" )
summary(height=80 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="553648127" )
table(column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="im_item_inventory.supplier_code" dbalias=".supplier_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="im_item_inventory.item_code" dbalias=".item_code" )
 column=(type=char(30) updatewhereclause=yes name=material_mfs dbname="im_item_inventory.material_mfs" dbalias=".material_mfs" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="im_item_inventory.inventory_qty" dbalias=".inventory_qty" )
 column=(type=char(20) updatewhereclause=yes name=location_address_rack dbname="im_item_inventory.location_address_rack" dbalias=".location_address_rack" )
 column=(type=datetime updatewhereclause=yes name=last_receipt_date dbname="im_item_inventory.last_receipt_date" dbalias=".last_receipt_date" )
 retrieve="SELECT SUPPLIER_CODE,
            ITEM_CODE,
            MATERIAL_MFS,
            INVENTORY_QTY,
            LOCATION_ADDRESS_RACK,
            LAST_RECEIPT_DATE
  FROM IM_ITEM_INVENTORY
 WHERE LAST_RECEIPT_DATE <= ADD_MONTHS(TO_DATE(:arg_date), (TO_NUMBER(:arg_term) * -1))
   AND ITEM_CODE LIKE :arg_item_code
   AND MATERIAL_MFS LIKE :arg_material_mfs
   AND SUPPLIER_CODE LIKE :arg_supplier_code
   AND ORGANIZATION_ID = :arg_org
   AND INVENTORY_QTY > 0" arguments=(("arg_date", datetime),("arg_term", string),("arg_item_code", string),("arg_material_mfs", string),("arg_supplier_code", string),("arg_org", number))  sort="item_code A material_mfs A " )
