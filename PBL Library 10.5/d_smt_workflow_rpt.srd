release 10.5;
datawindow(units=0 timer_interval=60000 color=16777215 processing=0 HTMLDW=no print.printername="" print.documentname="Feeder Layout" print.orientation = 0 print.margin.left = 220 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no )
header(height=252 color="536870912" )
summary(height=2928 color="536870912" )
footer(height=108 color="536870912" )
detail(height=0 color="536870912~tif (  mod( getrow() ,2 ) = 0 , RGB(192,192,192 ), rgb(255,255,255) )" height.autosize=yes )
table(column=(type=char(30) updatewhereclause=yes name=model_name dbname="ib_product_plandata.model_name" )
 column=(type=char(34) updatewhereclause=yes name=feeder_layout_image dbname="feeder_layout_image" )
 column=(type=char(2000) updatewhereclause=yes name=feeder_layout_comments dbname="ib_smt_bom_image.feeder_layout_comments" )
 retrieve="  SELECT 	IB_PRODUCT_PLANDATA.MODEL_NAME,   
		 IB_PRODUCT_PLANDATA.MODEL_NAME||'.JPG' FEEDER_LAYOUT_IMAGE ,
		IB_SMT_BOM_IMAGE.MODEL_COMMENTS  FEEDER_LAYOUT_COMMENTS

    FROM IB_PRODUCT_PLANDATA,     IB_SMT_BOM_IMAGE 
   WHERE IB_PRODUCT_PLANDATA.MODEL_NAME = IB_SMT_BOM_IMAGE.MODEL_NAME AND
         ( IB_PRODUCT_PLANDATA.MODEL_NAME = :ARG_PARENT_ITEM ) AND  
         ( IB_PRODUCT_PLANDATA.LINE_CODE    LIKE :ARG_LINE_CODE ) AND  
	     ( NVL(IB_PRODUCT_PLANDATA.PCB_ITEM ,'*')  LIKE :ARG_TOPBOT )    AND
         ( IB_PRODUCT_PLANDATA.ORGANIZATION_ID = :ARG_ORG )    

" arguments=(("ARG_PARENT_ITEM", string),("ARG_LINE_CODE", string),("ARG_TOPBOT", string),("ARG_ORG", number))  sort="model_name A " )
