 retrieve="  SELECT ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_YYYYMM~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_DATE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"MFS~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_PRIORITY~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ORGANIZATION_ID~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ITEM_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PRODUCT_LINE_TYPE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"WORK_DIVISION~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ORDER_QTY~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PRODUCT_ACTUAL_QTY~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"LINE_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"CUSTOMER_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"CUSTOMER_ORDER_NO~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"DELIVERY_DATE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ORIGIN_MFS~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"SHIFT_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TRANSFER_YN~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_STATUS~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ENTER_BY~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ENTER_DATE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"LAST_MODIFY_BY~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"LAST_MODIFY_DATE~",   
         '' check_yn,   
         '' check_copy_yn,   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_DATE_SEQUENCE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"WORKSTAGE_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"MACHINE_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"SHIPPING_ACCOUNT~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ROUTE_NO~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PARENT_ITEM_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"LOT_DIVIDE_YN~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"CUSTOMER_ORDER_NO_ORIGIN~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"MOLD_CODE~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"MOLD_VERSION~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"MOLD_SET_SERIAL~",   
         F_GET_PRODUCT_ST( IP_ASSEMBLY_MASTER_PLAN.ITEM_CODE , IP_ASSEMBLY_MASTER_PLAN.LINE_CODE , IP_ASSEMBLY_MASTER_PLAN.WORKSTAGE_CODE , IP_ASSEMBLY_MASTER_PLAN.MACHINE_CODE , IP_ASSEMBLY_MASTER_PLAN.ORGANIZATION_ID ) ST_VALUE,   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"REQUIRMENT_TIME~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"IDLE_TIME~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ACTIVE_YN~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_START_TIME~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_END_TIME~",   
         ~"ID_ITEM~".~"MODEL_NAME~",   
         ~"ID_ITEM~".~"MODEL_SUFFIX~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME1~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME2~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME3~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME4~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME5~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME6~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME7~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME8~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME9~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME10~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME11~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_TIME12~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"D1_ORDER_QTY~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"D2_ORDER_QTY~",   
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"D3_ORDER_QTY~",
		ID_ITEM.ITEM_CLASS  ITEM_CLASS
    FROM ~"IP_ASSEMBLY_MASTER_PLAN~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IP_ASSEMBLY_MASTER_PLAN~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IP_ASSEMBLY_MASTER_PLAN~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_DATE~" >= :arg_dateset ) AND  
         ( ~"IP_ASSEMBLY_MASTER_PLAN~".~"PLAN_DATE~" <= :arg_dateend ) AND  
         ( ~"IP_ASSEMBLY_MASTER_PLAN~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"ORIGIN_MFS~" like :arg_origin_mfs AND  
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"MFS~" like :arg_mfs AND  
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"LINE_CODE~" like :arg_line_code AND  
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"WORKSTAGE_CODE~" like :arg_workstage_code AND  
         ~"IP_ASSEMBLY_MASTER_PLAN~".~"MACHINE_CODE~" like :arg_machine_code AND  
         ( ~"IP_ASSEMBLY_MASTER_PLAN~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" update="IP_ASSEMBLY_MASTER_PLAN" updatewhere=0 updatekeyinplace=yes arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_origin_mfs", string),("arg_mfs", string),("arg_line_code", string),("arg_workstage_code", string),("arg_machine_code", string),("arg_org_id", number))  sort="organization_id A plan_status A line_code A plan_yyyymm A plan_date A plan_priority A " )
