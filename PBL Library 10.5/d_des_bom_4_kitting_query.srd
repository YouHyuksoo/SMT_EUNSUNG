 retrieve="  SELECT ~"ID_ENG_BOM_TEMP~".~"SESSION_ID~",   
         ~"ID_ENG_BOM_TEMP~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_TEMP~".~"CHILD_ITEM_CODE~",   
         ~"ID_ENG_BOM_TEMP~".~"ORGANIZATION_ID~",   
         ~"ID_ENG_BOM_TEMP~".~"DATESET~",   
         LPAD(BOM_LEVEL ,BOM_LEVEL , '.' ) BOM_LEVEL,   
         ~"ID_ENG_BOM_TEMP~".~"SORT_SEQUENCE~",   
         ~"ID_ENG_BOM_TEMP~".~"SORT_ORDER~",   
         ~"ID_ENG_BOM_TEMP~".~"ITEM_UNIT_QTY~",   
         ~"ID_ENG_BOM_TEMP~".~"ITEM_UNIT_QTY_EXT~",   
         ~"ID_ENG_BOM_TEMP~".~"MODEL_UNIT_QTY~",   
         ~"ID_ENG_BOM_TEMP~".~"MODEL_UNIT_QTY_EXT~",   
         ~"ID_ENG_BOM_TEMP~".~"WORKSTAGE_CODE~",   
         ~"ID_ENG_BOM_TEMP~".~"ASSY_EXPLOSION_YN~",   
         ~"ID_ENG_BOM_TEMP~".~"DATEEND~",   
         ~"ID_ENG_BOM_TEMP~".~"LOSS_RATE~",   
         ~"ID_ENG_BOM_TEMP~".~"SCRAP_RATE~",   
         ~"ID_ENG_BOM_TEMP~".~"ENTER_BY~",   
         ~"ID_ENG_BOM_TEMP~".~"ENTER_DATE~",   
         ~"ID_ENG_BOM_TEMP~".~"LAST_MODIFY_BY~",   
         ~"ID_ENG_BOM_TEMP~".~"LAST_MODIFY_DATE~",   
         ~"ID_ENG_BOM_TEMP~".~"LOCATION_INFO~",  
         ~"B~".~"ITEM_CODE~" ITEM_CODE ,   
         ~"A~".~"ORGANIZATION_ID~" ,   

         ~"A~".~"ITEM_NAME~" PARENT_ITEM_NAME ,   
         ~"A~".~"ITEM_SPEC~" PARENT_ITEM_SPEC,   
         ~"A~".~"ITEM_UOM~" PARENT_ITEM_UOM,   
         ~"A~".~"ITEM_TYPE~" PARENT_ITEM_TYPE,   
         ~"A~".~"LINE_TYPE~" PARENT_LINE_TYPE,   
         ~"A~".~"DRAWING_NO~" PARENT_DRAWING_NO,   
         ~"B~".~"ROUTE_NO~" ROUTE_NO,   
         ~"B~".~"ITEM_NAME~" CHILD_ITEM_NAME,   
         ~"B~".~"ITEM_SPEC~" CHILD_ITEM_SPEC,   
         ~"B~".~"ITEM_UOM~" CHILD_ITEM_UOM,   
         ~"B~".~"DRAWING_NO~" CHILD_DRAWING_NO,   
         ~"B~".~"ITEM_TYPE~" CHILD_ITEM_TYPE,   
         ~"B~".~"LINE_TYPE~" CHILD_LINE_TYPE ,   
         ~"ID_ENG_BOM_TEMP~".~"ITEM_TYPE~",   
         ~"ID_ENG_BOM_TEMP~".~"LINE_TYPE~",   
         '' STATUS,   
         ~"ID_ENG_BOM_TEMP~".~"BOM_WORK_NO~" 

    FROM ~"ID_ENG_BOM_TEMP~",   
         ~"ID_ITEM~" ~"A~",   
         ~"ID_ITEM~" ~"B~" 
   WHERE ( ~"ID_ENG_BOM_TEMP~".~"PARENT_ITEM_CODE~" = ~"A~".~"ITEM_CODE~"(+) ) and  
         ( ~"ID_ENG_BOM_TEMP~".~"ORGANIZATION_ID~" = ~"A~".~"ORGANIZATION_ID~"(+) ) and  
         ( ~"ID_ENG_BOM_TEMP~".~"CHILD_ITEM_CODE~" = ~"B~".~"ITEM_CODE~"(+) ) and  
         ( ~"ID_ENG_BOM_TEMP~".~"ORGANIZATION_ID~" = ~"B~".~"ORGANIZATION_ID~"(+) ) and  

         ( ID_eng_bom_temp.session_id = :arg_session_id ) AND  
         ( ID_eng_bom_temp.organization_id = :arg_organization_id )    
" arguments=(("ARG_SESSION_ID", number),("ARG_ORGANIZATION_ID", number))  sort="sort_order A sort_sequence A child_item_code A " )
