 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"iq_product_wqc~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"iq_product_wqc.inspect_date~") COLUMN(NAME=~"iq_product_wqc.inspect_sequence~") COLUMN(NAME=~"iq_product_wqc.organization_id~") COLUMN(NAME=~"iq_product_wqc.wqc_inspect_no~") COLUMN(NAME=~"iq_product_wqc.mfs~") COLUMN(NAME=~"iq_product_wqc.item_code~") COLUMN(NAME=~"iq_product_wqc.line_code~") COLUMN(NAME=~"iq_product_wqc.workstage_code~") COLUMN(NAME=~"iq_product_wqc.machine_code~") COLUMN(NAME=~"iq_product_wqc.bad_reason_code~") COLUMN(NAME=~"iq_product_wqc.request_by~") COLUMN(NAME=~"iq_product_wqc.inspect_by~") COLUMN(NAME=~"iq_product_wqc.bad_cause_by~") COLUMN(NAME=~"iq_product_wqc.wqc_inspect_result~") COLUMN(NAME=~"iq_product_wqc.wqc_inspect_handling~") COLUMN(NAME=~"iq_product_wqc.comments~") COLUMN(NAME=~"iq_product_wqc.complete_yn~") COLUMN(NAME=~"iq_product_wqc.enter_date~") COLUMN(NAME=~"iq_product_wqc.enter_by~") COLUMN(NAME=~"iq_product_wqc.last_modify_date~") COLUMN(NAME=~"iq_product_wqc.last_modify_by~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"iq_product_wqc.inspect_bad_qty~") COLUMN(NAME=~"iq_product_wqc.wqc_request_group_no~") COLUMN(NAME=~"iq_product_wqc.carrying_out_yn~")    JOIN (LEFT=~"iq_product_wqc.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"iq_product_wqc.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~" )WHERE(    EXP1 =~"~~~"IQ_PRODUCT_WQC~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IQ_PRODUCT_WQC~~~".~~~"WQC_INSPECT_HANDLING~~~"~"   OP =~"=~"    EXP2 =~"'Q'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IQ_PRODUCT_WQC~~~".~~~"COMPLETE_YN~~~"~"   OP =~"<>~"    EXP2 =~"'Y'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IQ_PRODUCT_WQC~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_item_code", string),("arg_org", number))  sort="organization_id A carrying_out_yn A wqc_inspect_no A " )
