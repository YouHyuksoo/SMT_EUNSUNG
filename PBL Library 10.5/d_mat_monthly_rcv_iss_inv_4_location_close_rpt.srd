 retrieve="SELECT	LOCATION_CODE , ORGANIZATION_ID,

TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID),'MMDD')    T1, 
TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+1,'MMDD') T2, 
TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+2,'MMDD') T3, 
TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+3,'MMDD') T4, 
TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+4,'MMDD') T5, 
