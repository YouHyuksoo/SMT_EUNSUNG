			I19,
			I20,
			I21,
			I22,
			I23,
			I24,
			I25,
			I26,
			I27,
			I28,
			I29,
			I30,
			I31,

			NVL	(	(	SELECT	NVL(SUM(I.MM_INVENTORY_QTY), 0)	LAST_INV
							FROM		IM_ITEM_INVENTORY_CLOSE	I
							WHERE	      CLOSE_YYYYMM			=		TO_CHAR(ADD_MONTHS(TO_DATE(:ARG_YYYYMM||'01', 'YYYYMMDD'), -1), 'YYYYMM')
                          		AND        I.LOCATION_CODE = R.LOCATION_CODE
							AND		I.ORGANIZATION_ID		=		R.ORGANIZATION_ID
						), 0
					)		LAST_INV

FROM		(	SELECT	A.LOCATION_CODE ,
							A.ORGANIZATION_ID ,
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID),'MMDD') , A.DD_RECEIPT_QTY , 0 )) R01 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+1,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R02 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+2,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R03 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+3,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R04 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+4,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R05 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+5,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R06 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+6,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R07 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+7,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R08 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+8,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R09 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+9,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R10 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+10,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R11 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+11,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R12 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+12,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R13 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+13,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R14 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+14,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R15 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+15,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R16 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+16,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R17 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+17,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R18 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+18,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R19 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+19,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R20 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+20,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R21 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+21,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R22 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+22,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R23 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+23,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R24 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+24,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R25 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+25,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R26 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+26,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R27 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+27,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R28 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+28,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R29 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+29,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R30 ,  
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+30,'MMDD') , A.DD_RECEIPT_QTY , 0 )) R31 ,  
																															 
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID),'MMDD') , A.DD_SHIPPING_QTY , 0 )) I01 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+1,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I02 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+2,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I03 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+3,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I04 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+4,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I05 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+5,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I06 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+6,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I07 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+7,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I08 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+8,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I09 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+9,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I10 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+10,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I11 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+11,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I12 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+12,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I13 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+13,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I14 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+14,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I15 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+15,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I16 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+16,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I17 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+17,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I18 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+18,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I19 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+19,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I20 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+20,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I21 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+21,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I22 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+22,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I23 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+23,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I24 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+24,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I25 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+25,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I26 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+26,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I27 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+27,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I28 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+28,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I29 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+29,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I30 ,    
							SUM(	DECODE(  TO_CHAR(A.CLOSE_DATE,'MMDD') , TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)+30,'MMDD') , A.DD_SHIPPING_QTY , 0 )) I31 																							 

				  FROM ( SELECT     CLOSE_DATE , LOCATION_CODE ,
                                                SUM(DD_RECEIPT_QTY)  DD_RECEIPT_QTY, 
                                                SUM(DD_SHIPPING_QTY) DD_SHIPPING_QTY , 
                                                ORGANIZATION_ID
                                                  
                                                  FROM ( SELECT LOCATION_CODE , 
																	RECEIPT_DATE CLOSE_DATE  , 
																	SUM(RECEIPT_QTY) DD_RECEIPT_QTY , 
																	0 DD_SHIPPING_QTY , 
																	ORGANIZATION_ID
														FROM IM_ITEM_RECEIPT 
														WHERE RECEIPT_DATE >= F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)
														AND RECEIPT_DATE    <=   F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'END',ORGANIZATION_ID)
														AND LOCATION_CODE LIKE :ARG_LOCATION_CODE
														AND ORGANIZATION_ID = :ARG_ORG
														GROUP BY RECEIPT_DATE , LOCATION_CODE ,ORGANIZATION_ID 

								UNION ALL
								SELECT LOCATION_CODE ,  SHIPPING_DATE CLOSE_DATE  , 0 DD_RECEIPT_QTY , SUM(SHIPPING_QTY) DD_SHIPPING_QTY , ORGANIZATION_ID
								FROM IS_MATERIAL_SHIPPING
								WHERE SHIPPING_DATE >= F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)
								AND SHIPPING_DATE <=   F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'END',ORGANIZATION_ID)
                                    AND LOCATION_CODE LIKE :ARG_LOCATION_CODE
                                    AND ORGANIZATION_ID = :ARG_ORG
								GROUP BY SHIPPING_DATE , LOCATION_CODE ,  ORGANIZATION_ID 

								UNION ALL
								SELECT LOCATION_CODE ,  ISSUE_DATE CLOSE_DATE  , 0 DD_RECEIPT_QTY , SUM(ISSUE_QTY) DD_SHIPPING_QTY , ORGANIZATION_ID
								FROM IM_ITEM_ISSUE
								WHERE ISSUE_DATE >= F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)
								AND ISSUE_DATE <=   F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'END',ORGANIZATION_ID)
                                    AND LOCATION_CODE LIKE :ARG_LOCATION_CODE
                                    AND ORGANIZATION_ID = :ARG_ORG
								GROUP BY ISSUE_DATE , LOCATION_CODE ,  ORGANIZATION_ID 

                                    UNION ALL
								SELECT LOCATION_CODE ,  F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID) CLOSE_DATE  , 0 DD_RECEIPT_QTY , 0 DD_SHIPPING_QTY , ORGANIZATION_ID
								FROM IM_ITEM_INVENTORY
								WHERE INVENTORY_QTY <> 0
                                    AND LOCATION_CODE LIKE :ARG_LOCATION_CODE
								AND ORGANIZATION_ID = :ARG_ORG
								GROUP BY LOCATION_CODE , F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID) , ITEM_CODE ,LINE_TYPE , ORGANIZATION_ID
								) 
						GROUP BY CLOSE_DATE , LOCATION_CODE , ORGANIZATION_ID	
                                    )  A 

				WHERE A.CLOSE_DATE    >=F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',A.ORGANIZATION_ID)
				  AND A.CLOSE_DATE    <=F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'END',A.ORGANIZATION_ID)
				  AND A.ORGANIZATION_ID = :ARG_ORG
    	        GROUP BY  A.LOCATION_CODE ,				A.ORGANIZATION_ID
			)	R
" arguments=(("ARG_YYYYMM", string),("ARG_ITEM_CODE", string),("ARG_LOCATION_CODE", string),("ARG_ORG", number))  sort="organization_id A location_code A " )
