TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+8,'MMDD') T9, 
TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+9,'MMDD') T10, 
TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+10,'MMDD') T11,
TO_CHAR(F_GET_INVENTORY_CLOSE_DATE(:ARG_YYYYMM,'START',ORGANIZATION_ID)+11,'MMDD') T12,
