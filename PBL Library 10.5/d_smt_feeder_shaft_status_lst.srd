table(column=(type=char(1) updatewhereclause=yes name=feeder_shaft dbname="id_eng_bom_smt.feeder_shaft" )
 column=(type=char(1) updatewhereclause=yes name=feeder_shaft_status dbname="feeder_shaft_status" )
 retrieve="  SELECT DISTINCT ~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT~",   
              MAX(~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT_STATUS~") FEEDER_SHAFT_STATUS
    FROM ~"ID_ENG_BOM_SMT~"  
   WHERE ( ~"ID_ENG_BOM_SMT~".~"LINE_CODE~" = :ARG_LINE_CODE ) AND  
         ( ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~" = :ARG_MODEL_NAME ) AND  
         ( ~"ID_ENG_BOM_SMT~".~"PCB_ITEM~" = :ARG_PCB_ITEM ) AND  
         ( ~"ID_ENG_BOM_SMT~".~"ORGANIZATION_ID~" = :ARG_ORG )   
 GROUP BY  ~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT~" 
            
" arguments=(("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_PCB_ITEM", string),("ARG_ORG", number))  sort="feeder_shaft A " )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="33554432" x="119" y="8" height="64" width="114" format="[general]" html.valueishtml="0"  name=feeder_shaft_status visible="1" dddw.name=vd_basecode dddw.displaycolumn=code_mean dddw.datacolumn=code_name dddw.percentwidth=0 dddw.lines=0 dddw.limit=0 dddw.allowedit=no dddw.useasborder=no dddw.case=any  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="0" background.color="536870912~tif (  feeder_shaft_status = ~"W~" , RGB(255,255,128) ,  if (  feeder_shaft_status  =~"Y~"  , 255 , RGB(255,255,255) ) )" )
