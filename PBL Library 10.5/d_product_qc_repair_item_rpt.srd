 column=(type=number updatewhereclause=yes name=repair_qty dbname="ip_product_work_qc_repair_item.repair_qty" dbalias=".repair_qty" )
 column=(type=number updatewhereclause=yes name=repair_price dbname="repair_price" )
 column=(type=number updatewhereclause=yes name=repair_amt dbname="repair_amt" )
 column=(type=char(1000) updatewhereclause=yes name=comments dbname="ip_product_work_qc_repair_item.comments" dbalias=".comments" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_work_qc_repair_item.organization_id" dbalias=".organization_id" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="ip_product_work_qc_repair_item.enter_date" dbalias=".enter_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_work_qc_repair_item.enter_by" dbalias=".enter_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="ip_product_work_qc_repair_item.last_modify_date" dbalias=".last_modify_date" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="ip_product_work_qc_repair_item.last_modify_by" dbalias=".last_modify_by" )
 retrieve="  SELECT ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"RUN_NO~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"QC_SEQUENCE~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"MATERIAL_MFS~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"REPAIR_QTY~",   
         F_GET_MAT_INVENTORY_PRICE(~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ITEM_CODE~", 'F', ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ORGANIZATION_ID~")  REPAIR_PRICE,
         ROUND(F_GET_MAT_INVENTORY_PRICE(~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ITEM_CODE~", 'F', ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ORGANIZATION_ID~") 
                     * ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"REPAIR_QTY~" ) REPAIR_AMT,
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"COMMENTS~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ENTER_BY~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"LAST_MODIFY_BY~"  
    FROM ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~"  
   WHERE ( ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"RUN_NO~" LIKE :arg_run_no )
        AND ( ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"MATERIAL_MFS~" LIKE :arg_material_mfs )
        AND ( ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ENTER_DATE~" >= :arg_dateset )   
        AND ( ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ENTER_DATE~" <= :arg_dateend )   
        AND ( ~"IP_PRODUCT_WORK_QC_REPAIR_ITEM~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_run_no", string),("arg_material_mfs", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number)) )
