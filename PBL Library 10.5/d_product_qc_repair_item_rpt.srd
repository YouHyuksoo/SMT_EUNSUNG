 column=(type=number updatewhereclause=yes name=qc_sequence dbname="ip_product_work_qc_repair_item.qc_sequence" dbalias=".qc_sequence" )
 column=(type=char(30) updatewhereclause=yes name=material_mfs dbname="ip_product_work_qc_repair_item.material_mfs" dbalias=".material_mfs" )
