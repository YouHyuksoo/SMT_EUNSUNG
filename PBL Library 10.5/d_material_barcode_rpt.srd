 column=(type=char(4000) updatewhereclause=yes name=item_barcode dbname="item_barcode" )
 column=(type=datetime updatewhereclause=yes name=print_date dbname="print_date" )
 retrieve="  SELECT ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_CODE_BARCODE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_QTY~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"SUPPLIER_ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_SPEC~",   
         f_bacode_code128('B',item_code_barcode)  item_barcode,   
         trunc(~"IM_ITEM_INVENTORY_BARCODE~".~"PRINT_DATE~") print_date
    FROM ~"IM_ITEM_INVENTORY_BARCODE~"  
 WHERE 
		( ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_CODE~" like :arg_item_code) AND 
		( ~"IM_ITEM_INVENTORY_BARCODE~".~"SERIAL_NO~" like :arg_serial_no ) AND  
		( ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_CODE_BARCODE~" like :arg_item_code_barcode ) AND   
         ( ~"IM_ITEM_INVENTORY_BARCODE~".~"ORGANIZATION_ID~" = :arg_org )        
" arguments=(("arg_item_code", string),("arg_serial_no", string),("arg_item_code_barcode", string),("arg_org", number)) )
