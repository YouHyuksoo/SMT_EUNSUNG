 retrieve="  SELECT ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"CLOSE_YYYYMM~",   
         ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"LINE_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ORGANIZATION_ID~",   
         AVG(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"LAST_AVG_PRICE~") LAST_AVG_PRICE,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"LAST_INVENTORY_QTY~") LAST_INVENTORY_QTY,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"LAST_INVENTORY_AMT~") LAST_INVENTORY_AMT,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_RECEIPT_QTY~") MM_RECEIPT_QTY,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_RECEIPT_AMT~") MM_RECEIPT_AMT,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_ISSUE_QTY~") MM_ISSUE_QTY,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_ISSUE_AMT~") MM_ISSUE_AMT,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_MASS_ISSUE_QTY~") MM_MASS_ISSUE_QTY,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_MASS_ISSUE_AMT~") MM_MASS_ISSUE_AMT,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_BAD_ISSUE_QTY~") MM_BAD_ISSUE_QTY,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_BAD_ISSUE_AMT~") MM_BAD_ISSUE_AMT,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_EXTRA_ISSUE_QTY~") MM_EXTRA_ISSUE_QTY,      
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_EXTRA_ISSUE_AMT~") MM_EXTRA_ISSUE_AMT,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_INVENTORY_QTY~") MM_INVENTORY_QTY,   
         SUM(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_INVENTORY_AMT~") MM_INVENTORY_AMT,   
         AVG(~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MM_AVG_PRICE~") MM_AVG_PRICE,   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"IP_PRODUCT_LINE~".~"LINE_NAME~"
    FROM ~"IM_ITEM_WORKSTAGE_INV_CLOSE~",   
         ~"IP_PRODUCT_LINE~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"LINE_CODE~" = ~"IP_PRODUCT_LINE~".~"LINE_CODE~" ) and  
         ( ~"IP_PRODUCT_LINE~".~"ORGANIZATION_ID~" = ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"CLOSE_YYYYMM~" = :arg_yyyymm ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"MFS~" like :arg_mfs ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
GROUP BY  ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"CLOSE_YYYYMM~",   
         ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"LINE_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CLOSE~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"IP_PRODUCT_LINE~".~"LINE_NAME~"
" arguments=(("arg_yyyymm", string),("arg_line_code", string),("arg_workstage_code", string),("arg_mfs", string),("arg_item_code", string),("arg_org_id", number))  sort="organization_id A close_yyyymm A line_name A item_code A " )
group(level=1 header.height=88 trailer.height=0 by=("organization_id" , "close_yyyymm" , "line_name" ) header.color="65535" trailer.color="536870912" )
