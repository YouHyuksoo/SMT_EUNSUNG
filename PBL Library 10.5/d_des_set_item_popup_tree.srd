 column=(type=char(30) updatewhereclause=yes name=model_name dbname="id_item.model_name" dbalias=".model_name" )
 retrieve="  SELECT ~"ID_ITEM~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"SET_ITEM_YN~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"DATESET~",   
         ~"ID_ITEM~".~"DRAWING_NO~",   
         DECODE( SIGN( id_item.dateend - TRUNC( SYSDATE )), 1, 'RUNNING', 'EXPIRED' ) status,   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"SAFETY_INVENTORY~",   
         ~"ID_ITEM~".~"MANUFACTURE_LEADTIME~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"ID_ITEM~".~"ROUTE_NO~",   
         ~"ID_ITEM~".~"PART_NO~",
	    F_CHECK_BOM_EXISTS ( ITEM_CODE ,  ORGANIZATION_ID ) BOM_EXISTS ,
		~"ID_ITEM~".~"MODEL_NAME~"
    FROM ~"ID_ITEM~"  
   WHERE ( ( id_item.item_code LIKE :arg_item_code ) AND  
( id_item.model_name LIKE :arg_model_name ) AND  
         ( NVL( id_item.item_name, '*' ) LIKE :arg_item_name ) AND  
         ( id_item.item_type LIKE :arg_item_type ) AND  
         ( id_item.line_type LIKE :arg_line_type ) AND  
         ( id_item.dateend >= :arg_dateset ) AND  
          NVL(~"ID_ITEM~".~"DRAWING_NO~",'*') LIKE :ARG_DRAWING_NO AND
        ( id_item.set_item_yn = 'Y' )   AND
         ( id_item.organization_id = :arg_organization_id ) )    
" arguments=(("ARG_MODEL_NAME", string),("ARG_ITEM_CODE", string),("ARG_ITEM_NAME", string),("ARG_ITEM_TYPE", string),("ARG_LINE_TYPE", string),("ARG_DATESET", datetime),("ARG_DRAWING_NO", string),("ARG_ORGANIZATION_ID", number))  sort="status D item_division A set_item_yn D item_code A " )
