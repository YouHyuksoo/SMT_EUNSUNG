 column=(type=char(10) updatewhereclause=yes name=item_type dbname="id_item.item_type" dbalias=".item_type" )
 column=(type=char(10) updatewhereclause=yes name=line_type dbname="id_item.line_type" dbalias=".line_type" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="id_item.organization_id" dbalias=".organization_id" )
