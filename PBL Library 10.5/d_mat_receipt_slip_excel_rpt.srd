 retrieve="  SELECT A.TXN_DATE,   
         A.ITEM,   
         A.ITEM_TYPE,   
         A.SUBINVENTORY,   
         A.LOCATOR,   
         A.TRANSACTION_QTY,   
         A.DERIVED_ONHAND_QTY,   
         A.ARRIVAL_DEPARTMENT,   
         A.TRANSFER_SUBINVENTORY,   
         A.TRANSFER_LOCATOR,   
         A.TRANSACTION_TYPE,   
         A.REASON_CODE,   
         A.REASON,   
         A.SUPPLIER_CODE,   
         A.SUPPLIER_NAME,   
         A.WORK_ORDER,   
         A.SALES_ORDER,   
         A.ASSEMBLY,   
         A.LINE_CODE,   
         A.TRANSFER_ORG_CODE,   
         A.ITEM_DESC,   
         A.ITEM_SPEC,   
         A.MARKET,   
         A.CURRENCY,   
         A.UNIT_PRICE,   
         A.ARRIVAL_NO,   
         A.MPC,   
         A.SUPPLIER_REF_NO,   
         A.ORDER_NO,   
         A.INVOICE_NO,   
         A.EXCHANGE_RATE,   
         A.SHIPMENT_NUM,   
         A.ITEM_COST,   
         A.CREATION_DATE,   
         A.CREATED_BY,   
         A.ARRIVED_BY,   
         A.RECEIVED_BY,   
         A.ACCOUNT,   
         A.ACCOUNT_DESCRIPTION,   
         A.TAKEOVER_USER,   
         A.TAKEOVER_DATE,   
         A.TRANSACTION_ID,   
         A.REFERENCE_REASON_DETAIL,   
         A.CONTENT_LPN,   
         A.UIT,   
         A.DELIVERY_TYPE,   
         A.WH_KEEPER,   
         A.PACK_QTY,   
         A.BL_NO,   
         A.LOCATION,   
         A.TRANSACTION_DATE,   
         A.DROPSHIP_OSP,   
         A.NOTA_NO,   
         A.REASON_CODE2,   
         A.REASON_DESC,   
         A.MODEL_SUFFIX,   
         NVL(A.SCAN_YN   , 'N' ) SCAN_YN ,
		IM_ITEM_RECEIPT_SLIP.RECEIPT_DATE ,

         '*'||A.ITEM||'+'||    CASE WHEN A.TRANSACTION_QTY <=   A.PACK_QTY THEN  1 ELSE  TRUNC(DECODE(  A.PACK_QTY , 0 , 0 ,  A.TRANSACTION_QTY  /   A.PACK_QTY  ) ) END   ||'+'||A.TRANSACTION_QTY||'*' SLIP_ITEM_BARCODE ,

         '*'||A.TRANSACTION_ID||'*' SLIP_NO_BARCODE

    FROM IM_ITEM_RECEIPT_SLIP_EXCEL  A   , IM_ITEM_RECEIPT_SLIP 
WHERE A.TRANSACTION_ID = IM_ITEM_RECEIPT_SLIP.RECEIPT_SLIP_NO(+)
     AND A.TRANSACTION_DATE >= :ARG_DATESET
     AND A.TRANSACTION_DATE <= :ARG_DATEEND
     AND A.ITEM LIKE :ARG_ITEM_CODE
     AND A.TRANSACTION_ID LIKE :ARG_SLIP_NO
     AND A.SLIP_GROUP_NO LIKE :ARG_SLIP_GROUP_NO" arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_ITEM_CODE", string),("ARG_SLIP_NO", string),("ARG_SLIP_GROUP_NO", string))  sort="scan_yn A txn_date A item A " )
