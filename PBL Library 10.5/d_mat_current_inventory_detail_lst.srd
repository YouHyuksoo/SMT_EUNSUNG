 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_inventory~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"im_item_inventory.material_mfs~") COLUMN(NAME=~"im_item_inventory.item_code~") COLUMN(NAME=~"im_item_inventory.inventory_status~") COLUMN(NAME=~"im_item_inventory.organization_id~") COLUMN(NAME=~"im_item_inventory.line_type~") COLUMN(NAME=~"im_item_inventory.inventory_hold~") COLUMN(NAME=~"im_item_inventory.inventory_price~") COLUMN(NAME=~"im_item_inventory.inventory_qty~") COLUMN(NAME=~"im_item_inventory.inventory_amt~") COLUMN(NAME=~"im_item_inventory.location_code~") COLUMN(NAME=~"im_item_inventory.comments~") COLUMN(NAME=~"im_item_inventory.enter_date~") COLUMN(NAME=~"im_item_inventory.enter_by~") COLUMN(NAME=~"im_item_inventory.last_modify_date~") COLUMN(NAME=~"im_item_inventory.last_modify_by~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"id_item.item_division~") COMPUTE(NAME=~"'N' CHECK_YN~") COMPUTE(NAME=~"F_GET_MAT_FREE_QTY_MFS ( IM_ITEM_INVENTORY.MATERIAL_MFS , IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.LINE_TYPE , IM_ITEM_INVENTORY.ORGANIZATION_ID ) FREE_INVENTORY_QTY~") COLUMN(NAME=~"id_item.location_address~") COMPUTE(NAME=~"0 MOVE_QTY~") COMPUTE(NAME=~"'' DEST_LOCATION_CODE~") COMPUTE(NAME=~"F_GET_REEL_QTY( IM_ITEM_INVENTORY.ITEM_CODE , 1 , IM_ITEM_INVENTORY.INVENTORY_QTY , IM_ITEM_INVENTORY.ORGANIZATION_ID ) REEL_QTY1~") COMPUTE(NAME=~"F_GET_REEL_QTY( IM_ITEM_INVENTORY.ITEM_CODE , 2 , IM_ITEM_INVENTORY.INVENTORY_QTY , IM_ITEM_INVENTORY.ORGANIZATION_ID ) REEL_QTY2~") COMPUTE(NAME=~"f_get_mat_receipt_by_loc_mfs(IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.MATERIAL_MFS, IM_ITEM_INVENTORY.LOCATION_CODE , IM_ITEM_INVENTORY.ORGANIZATION_ID ) RECEIPT_QTY~") COMPUTE(NAME=~"f_get_mat_issue_by_loc_mfs(IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.MATERIAL_MFS, IM_ITEM_INVENTORY.LOCATION_CODE ,IM_ITEM_INVENTORY.ORGANIZATION_ID ) ISSUE_QTY~") COLUMN(NAME=~"im_item_inventory.manufacture_week~") COLUMN(NAME=~"im_item_inventory.last_receipt_date~") COLUMN(NAME=~"id_item.life_cycle~") COLUMN(NAME=~"im_item_inventory.baking_date~")    JOIN (LEFT=~"id_item.item_code~"    OP =~"=~"RIGHT=~"im_item_inventory.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_inventory.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_INVENTORY~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_INVENTORY~~~".~~~"MATERIAL_MFS~~~"~"   OP =~"like~"    EXP2 =~":arg_material_mfs )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_INVENTORY~~~".~~~"INVENTORY_HOLD~~~"~"   OP =~"like~"    EXP2 =~":arg_inventory_hold )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(~~~"IM_ITEM_INVENTORY~~~".~~~"LOCATION_CODE~~~" , '*')~"   OP =~"like~"    EXP2 =~":arg_location_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( SIGN(TRUNC(~~~"IM_ITEM_INVENTORY~~~".~~~"INVENTORY_QTY~~~",5))~"   OP =~">=~"    EXP2 =~":arg_sign )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_INVENTORY~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_material_mfs~" TYPE = string)  ARG(NAME = ~"arg_inventory_hold~" TYPE = string)  ARG(NAME = ~"arg_location_code~" TYPE = string)  ARG(NAME = ~"arg_sign~" TYPE = number)  ARG(NAME = ~"arg_org_id~" TYPE = number) " update="IM_ITEM_INVENTORY" updatewhere=0 updatekeyinplace=yes arguments=(("arg_item_code", string),("arg_material_mfs", string),("arg_inventory_hold", string),("arg_location_code", string),("arg_sign", number),("arg_org_id", number))  sort="organization_id A location_code A item_code A material_mfs A " )
