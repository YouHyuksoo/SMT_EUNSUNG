detail(height=2010 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="imcn_jig.line_code" dbalias=".line_code" )
 column=(type=char(4000) updatewhereclause=yes name=jig_type dbname="jig_type" )
 column=(type=char(100) updatewhereclause=yes name=jig_code dbname="imcn_jig_pm_master.jig_code" dbalias=".jig_code" )
 column=(type=char(20) updatewhereclause=yes name=jig_lot_no dbname="imcn_jig_pm_master.jig_lot_no" dbalias=".jig_lot_no" )
 column=(type=char(100) updatewhereclause=yes name=jig_name dbname="imcn_jig.jig_name" dbalias=".jig_name" )
 column=(type=char(4000) updatewhereclause=yes name=pm_type dbname="pm_type" )
 column=(type=char(54) updatewhereclause=yes name=pm_barcode dbname="pm_barcode" )
 retrieve="  SELECT IMCN_JIG.LINE_CODE LINE_CODE ,

			F_GET_BASECODE( 'JIG TYPE' , IMCN_JIG.JIG_TYPE , :ARG_LANG ,  IMCN_JIG_PM_MASTER.ORGANIZATION_ID ) JIG_TYPE ,
              IMCN_JIG_PM_MASTER.JIG_CODE,   
              IMCN_JIG_PM_MASTER.JIG_LOT_NO JIG_LOT_NO,   
		     IMCN_JIG.JIG_NAME JIG_NAME ,
	     	 F_GET_BASECODE( 'PM TYPE' , IMCN_JIG_PM_MASTER.PM_TYPE , :arg_lang , IMCN_JIG_PM_MASTER.ORGANIZATION_ID ) PM_TYPE , 

 		    '*'||IMCN_JIG.LINE_CODE||' '||IMCN_JIG_PM_MASTER.JIG_LOT_NO||' '||IMCN_JIG_PM_MASTER.PM_TYPE||'*' PM_BARCODE  	 
    FROM IMCN_JIG_PM_MASTER , IMCN_JIG
   WHERE IMCN_JIG_PM_MASTER.JIG_CODE  = IMCN_JIG.JIG_CODE(+) AND
			IMCN_JIG_PM_MASTER.ORGANIZATION_ID  = IMCN_JIG.ORGANIZATION_ID(+) AND

             ( IMCN_JIG_PM_MASTER.LINE_CODE like :arg_line_code ) AND  
			( IMCN_JIG_PM_MASTER.JIG_CODE like :arg_jig_code ) AND 
			( IMCN_JIG_PM_MASTER.PM_TYPE like :arg_pm_type ) AND 
			IMCN_JIG.JIG_TYPE LIKE :ARG_JIG_TYPE AND 
			( IMCN_JIG_PM_MASTER.ORGANIZATION_ID = :arg_org ) 
" arguments=(("arg_line_code", string),("arg_jig_code", string),("arg_jig_type", string),("arg_pm_type", string),("arg_lang", string),("arg_org", number))  sort="jig_code A pm_type A " )
