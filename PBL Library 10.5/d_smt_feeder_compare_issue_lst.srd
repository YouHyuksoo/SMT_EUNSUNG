table(column=(type=char(30) updatewhereclause=yes name=dest_line_code dbname="ib_product_plandata.dest_line_code" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="ib_product_plandata.model_name" )
 column=(type=char(1) updatewhereclause=yes name=pcb_item dbname="ib_product_plandata.pcb_item" )
 column=(type=char(1) updatewhereclause=yes name=feeder_shaft dbname="ib_product_plandata.feeder_shaft" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="ib_product_plandata.location_code" )
 column=(type=char(1) updatewhereclause=yes name=issue_deficit dbname="issue_deficit" )
 column=(type=char(100) updatewhereclause=yes name=item_code dbname="ib_product_plandata.item_code" )
 column=(type=char(30) updatewhereclause=yes name=line_code dbname="ib_product_plandata.line_code" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" )
 column=(type=char(10) updatewhereclause=yes name=msl_level dbname="id_item.msl_level" )
 retrieve="SELECT 	    :arg_line_code_new as dest_line_code,
				:arg_model_name_new as model_name ,
				:arg_pcb_item_new as pcb_item,
				:arg_shaft_new as feeder_shaft  ,
				P.LOCATION_CODE  AS LOCATION_CODE , 
				'3' issue_deficit ,
				P.ITEM_CODE AS ITEM_CODE,
				:ARG_LINE_CODE as line_code ,
				B.LOCATION_ADDRESS AS LOCATION_ADDRESS, 
				B.MSL_LEVEL  AS MSL_LEVEL
			 FROM  IB_PRODUCT_PLANDATA P , ID_iTEM B

		 WHERE  P.ITEM_CODE = B.ITEM_CODE(+)
            AND P.LINE_CODE =  :ARG_LINE_CODE_NEW
			  AND P.MODEL_NAME = :ARG_MODEL_NAME_NEW
			 AND P.FEEDER_SHAFT =   NVL(:ARG_SHAFT_NEW,'*')
			AND ( P.LOCATION_CODE , P.ITEM_CODE ) IN 
			 
		(			  
				( SELECT DECODE( SUBSTR(A.ITEM_CODE,1,3)   , 'EAX' , A.LOCATION_CODE , DECODE( 'Y' , 'Y' , F_SET_FEEDER_SHAFT_CHANGE( :ARG_LINE_CODE , :ARG_SHAFT_NEW , :ARG_SHAFT  ,  A.LOCATION_CODE ) , A.LOCATION_CODE ) ) LOCATION_CODE  ,
							 A.ITEM_CODE  ITEM_CODE
		
				FROM IB_PRODUCT_PLANDATA A 
				WHERE A.LINE_CODE = :ARG_LINE_CODE_NEW 
				AND A.MODEL_NAME = :ARG_MODEL_NAME_NEW
				AND A.PCB_ITEM = :ARG_PCB_ITEM_NEW
				AND NVL(A.FEEDER_SHAFT,'*') =  NVL(:ARG_SHAFT_NEW,'*')
			     AND A.REVISION = :arg_REVISION_NEW 
				AND A.ORGANIZATION_ID = :arg_org
				
				MINUS 
				
				 SELECT 	 B.LOCATION_CODE LOCATION_CODE,   	
							 B.ITEM_CODE ITEM_CODE
		
					FROM IB_PRODUCT_PLANDATA   B
					WHERE B.LINE_CODE = :ARG_LINE_CODE
					AND B.MODEL_NAME = :ARG_MODEL_NAME
					AND B.PCB_ITEM = :ARG_PCB_ITEM
					AND NVL(B.FEEDER_SHAFT,'*') = NVL(:ARG_SHAFT,'*')
				     AND B.REVISION = :arg_REVISION
					AND B.ORGANIZATION_ID = :arg_org
				) 
		)" arguments=(("arg_line_code", string),("arg_line_code_new", string),("arg_model_name", string),("arg_model_name_new", string),("arg_pcb_item", string),("arg_pcb_item_new", string),("arg_shaft", string),("ARG_SHAFT_NEW", string),("arg_revision", string),("arg_revision_new", string),("arg_org", number)) )
