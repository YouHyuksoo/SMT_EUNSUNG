 retrieve="  SELECT ~"ID_ITEM~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"VIRTUAL_RECEIPT_YN~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"BARCODE~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"ABC_GRADE~",   
         ~"ID_ITEM~".~"ENTER_DATE~",   
         ~"ID_ITEM~".~"RAW_MATERIAL~",   
         ~"ID_ITEM~".~"SAFETY_INVENTORY~",   
         ~"ID_ITEM~".~"WORK_BAD_RATE~",   
         ~"ID_ITEM~".~"MANUFACTURE_LEADTIME~",   
         ~"ID_ITEM~".~"ORDER_CYCLE~",   
         ~"ID_ITEM~".~"ORDER_RULE~",   
         ~"ID_ITEM~".~"HS_CODE~",   
         ~"ID_ITEM~".~"ENTER_BY~",   
         ~"ID_ITEM~".~"SVC_CODE~",   
         ~"ID_ITEM~".~"CAPACITY~",   
         ~"ID_ITEM~".~"LAST_MODIFY_DATE~",   
         ~"ID_ITEM~".~"LENGTH~",   
         ~"ID_ITEM~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"DATESET~",   
         ~"ID_ITEM~".~"DATEEND~",   
         ~"ID_ITEM~".~"SET_ITEM_YN~",   
         ~"ID_ITEM~".~"SPECIAL_PROPERTY~",   
         ~"ID_ITEM~".~"LAYER~",   
         ~"ID_ITEM~".~"PART_NO~",   
         ~"ID_ITEM~".~"HEIGHT~",   
         ~"ID_ITEM~".~"WEIGHT~",   
         ~"ID_ITEM~".~"DRAWING_NO~",   
         ~"ID_ITEM~".~"GRADIENT~",   
         ~"ID_ITEM~".~"DENSITY~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"ID_ITEM~".~"ISSUE_PACKING_QTY~",   
         ~"ID_ITEM~".~"INNER_DIAMETER~",   
         ~"ID_ITEM~".~"OUTER_DIAMETER~",   
         ~"ID_ITEM~".~"WIDTH~",   
         ~"ID_ITEM~".~"ROUTE_NO~",   
         ~"ID_ITEM~".~"TRANSFER_UOM~",   
        ~"ID_ITEM~".~"MODEL_NAME~",   
        ~"ID_ITEM~".~"MODEL_SUFFIX~",   	
         ROWID  
    FROM ~"ID_ITEM~"  
   WHERE ( ITEM_CODE IN 
(    select child_ITEM_CODE     from ID_ENG_BOM    
  where dateset <= TRUNC(SYSDATE)      
      and nvl(dateend, TRUNC(SYSDATE)) >= TRUNC(SYSDATE)      
      and organization_id = :ARG_ORGANIZATION_ID      
     start with child_item_code = :ARG_ITEM_CODE      
       and dateset <= TRUNC(SYSDATE)      
       and nvl(dateend, TRUNC(SYSDATE)) >= TRUNC(SYSDATE)      
       and organization_id = :ARG_ORGANIZATION_ID     
connect by prior PARENT_ITEM_CODE = CHILD_ITEM_CODE      
       and dateset <= TRUNC(SYSDATE)      
       and nvl(dateend, TRUNC(SYSDATE)) >= TRUNC(SYSDATE)      
       and organization_id = :ARG_ORGANIZATION_ID ) ) AND  
      (~"ID_ITEM~".~"ITEM_DIVISION~" = 'F') AND
      ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID )    
" update="ID_ITEM" updatewhere=0 updatekeyinplace=no arguments=(("ARG_ITEM_CODE", string),("ARG_ORGANIZATION_ID", number)) )
