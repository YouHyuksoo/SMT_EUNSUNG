 column=(type=char(20) updatewhereclause=yes name=parent_item_code dbname="parent_item_code" )
 column=(type=char(20) updatewhereclause=yes name=child_item_code dbname="child_item_code" )
 column=(type=number updatewhereclause=yes name=location_code dbname="location_code" )
 retrieve="  SELECT 'N' CHECK_DIFF_YN,   
         ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~"||~"ID_ENG_BOM_SMT~".~"PCB_ITEM~" AS PARENT_ITEM_CODE,   
         ~"ID_ENG_BOM_SMT~".~"CHILD_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"LOCATION_CODE~"  
    FROM ~"ID_ENG_BOM_SMT~"  
   WHERE ( ~"ID_ENG_BOM_SMT~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~"||ID_ENG_BOM_SMT.PCB_ITEM in ( :arg_model_name ) ) AND  
         ( ~"ID_ENG_BOM_SMT~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_line_code", string),("arg_model_name", stringlist),("arg_org", number))  sort="check_diff_yn A parent_item_code A child_item_code A " )
