boolean autovscroll = true
end type

type tabpage_2 from userobject within tab_1
integer x = 18
integer y = 112
integer width = 2976
integer height = 912
long backcolor = 12632256
string text = "SQL Select"
long tabtextcolor = 33554432
long tabbackcolor = 12632256
string picturename = "PasteSQL!"
long picturemaskcolor = 12632256
dw_column_sort dw_column_sort
cb_1 cb_1
cb_get_sql cb_get_sql
mle_2 mle_2
end type

on tabpage_2.create
this.dw_column_sort=create dw_column_sort
this.cb_1=create cb_1
this.cb_get_sql=create cb_get_sql
this.mle_2=create mle_2
this.Control[]={this.dw_column_sort,&
this.cb_1,&
this.cb_get_sql,&
this.mle_2}
end on

on tabpage_2.destroy
destroy(this.dw_column_sort)
destroy(this.cb_1)
destroy(this.cb_get_sql)
destroy(this.mle_2)
end on

type dw_column_sort from datawindow within tabpage_2
integer x = 1925
integer y = 120
integer width = 1042
integer height = 784
integer taborder = 30
string dragicon = "Dragrow.ico"
string title = "none"
string dataobject = "de_column_sort"
boolean hscrollbar = true
boolean vscrollbar = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event dragdrop;DragObject	ldo_control
int			i , li_row

if row < 1 then return

ldo_control = DraggedObject()

if ldo_control = dw_column_sort then
	li_row = dw_column_sort.GetRow()
	if li_row > 0 then
		
          dw_column_sort.RowsMove(li_row,li_row, Primary!,dw_column_sort, row, Primary!)		
			 
		do
			i++
			dw_column_sort.object.column_sort[i] = i
		     	
		loop until  i= dw_column_sort.rowcount()		
		
		dw_column_sort.sort()		
		dw_column_sort.scrolltorow(row)		
		dw_column_sort.setrow(row)		
		dw_column_sort.selectrow(0 , false) 
		dw_column_sort.selectrow(row , true) 
				
	end if
end if
end event

event clicked;Drag( begin!)
end event

type cb_1 from so_commandbutton within tabpage_2
integer x = 549
integer height = 100
integer taborder = 80
string text = "Set SQL Select"
end type

event clicked;call super::clicked;if selected_data_window.setsqlselect( mle_2.text) < 0 then 
	Messagebox("Error" , "Set SQL Failed!")
end if 

tab_1.tabpage_1.mle_1.text = selected_data_window.Describe("DataWindow.Syntax")
end event

type cb_get_sql from so_commandbutton within tabpage_2
integer x = 9
integer height = 100
integer taborder = 70
string text = "Get SQL Select"
end type

event clicked;call super::clicked;Int  lvi_row , lvi_count
String lvs_col_name
mle_2.text = selected_data_window.GETSQLSelect()
dw_column_sort.reset()

Gst_dw_colinfo.i_dw_colcount = 0
Gst_dw_colinfo.i_dw_colcount=Integer(  selected_data_window.Describe("DataWindow.Column.Count"))


For lvi_count = 1 to Gst_dw_colinfo.i_dw_colcount
		lvs_col_name	= selected_data_window.Describe('#'+String(lvi_count)+".Name")	
		
		lvi_row = dw_column_sort.insertrow(0)
	     dw_column_sort.setitem( lvi_count , 'column_name' , lvs_col_name )
		dw_column_sort.setitem( lvi_count , 'column_sort' , lvi_count ) 
next
end event

