type cb_apply from so_commandbutton within w_show_datawindow_popup
integer x = 14
integer y = 1848
integer width = 361
integer height = 108
integer taborder = 60
boolean bringtotop = true
string text = "Apply"
end type

event clicked;call super::clicked;Int lvi_count , lvi_dddw_count , lvi_v_count , lvi_h_count , lvi_pos
String lvs_col_name , MODIFY_STRING , LVS_RETURN , LVS_CODE_TYPE , lvs_column_type

if cbx_freeform.checked = true then 
	
	IF tab_1.tp_ff_property.em_h_count.text = '0' then
		Messagebox("Notify" , "Input Horizontal Line Count ")
		tab_1.tp_ff_property.em_h_count.setfocus()
		return
	end if
//====================================================================
// Freefrom Style
//====================================================================
                        
                         lvi_h_count = integer(tab_1.tp_ff_property.em_h_count.text) //$$HEX6$$38c15cb820002fac18c22000$$ENDHEX$$
								 
					f_set_column_dddw(selected_data_window)
					selected_data_window.Object.DataWindow.Color = Long(tab_1.tp_ff_property.ddlb_ff_dw_color.text)
					
					selected_data_window.Object.DataWindow.Header.Height = 0
					
					selected_data_window.Object.DataWindow.Detail.Height =Long( ( lvi_h_count  * long(tab_1.tp_ff_property.em_ff_title_height.text) ) + ( lvi_h_count *  long(tab_1.tp_ff_property.em_h_spacing.text) ) )
					selected_data_window.Object.DataWindow.Detail.Color =Long(tab_1.tp_ff_property.ddlb_ff_detail_color.text)
					
					Gst_dw_colinfo.i_dw_colcount = 0
					Gst_dw_colinfo.i_dw_colcount=Integer(  selected_data_window.Describe("DataWindow.Column.Count"))
					
					lvi_v_count = truncate( Gst_dw_colinfo.i_dw_colcount / lvi_h_count , 0 ) // $$HEX6$$00ac5cb820002fac18c22000$$ENDHEX$$
					
					//======================================================================
					// Column Object $$HEX2$$7cb92000$$ENDHEX$$Scan $$HEX2$$5cd5e4b2$$ENDHEX$$
					//======================================================================
                         long  lvl_v_inc , lvl_title_inc_y
                         long i ,j , lvl_title_x,lvl_title_y,lvl_col_x,lvl_col_y
					
					lvl_v_inc = 10 
					
					For lvi_count = 1 to Gst_dw_colinfo.i_dw_colcount
						
					      i++
					 
					     if i >  lvi_h_count then 

						   i = mod ( i , lvi_h_count )
							
						  lvl_title_y  = 0	
						  
						  lvl_v_inc = lvl_v_inc + long( tab_1.tp_ff_property.em_ff_title_width.text) + long(tab_1.tp_ff_property.em_v_spacing.text) +long( tab_1.tp_ff_property.em_ff_column_width.text) + long(tab_1.tp_ff_property.em_v_spacing.text) 
						
						end if 
							
						//========================================================================	
						//  $$HEX5$$abcc89d574c774ba2000$$ENDHEX$$y $$HEX28$$04c758ce7cb9200098cc4cc780bd30d12000200044c5c8b274ba20009dc900ac12acd0c5200000b3c1c020006cd030ae20009dc900ac2000$$ENDHEX$$
						//========================================================================							
						if  mod( i ,lvi_h_count )  = 1 then  //$$HEX7$$abcc88bcacc789d574c774ba2000$$ENDHEX$$
							lvl_title_inc_y = 10
						else
							
							lvl_title_inc_y = long(tab_1.tp_ff_property.em_ff_title_height.text) + long(tab_1.tp_ff_property.em_h_spacing.text)
							
						end if
						
						//========================================================================	
	
						lvl_title_y = lvl_title_y + lvl_title_inc_y
						lvl_title_x = lvl_v_inc
						
						lvl_col_y   = lvl_title_y							
						lvl_col_x   = lvl_title_x +  long( tab_1.tp_ff_property.em_ff_title_width.text) + long(tab_1.tp_ff_property.em_v_spacing.text)

						  
						lvs_col_name	= selected_data_window.Describe('#'+String(lvi_count)+".Name")	
						
						
						if  tab_1.tp_ff_property.cbx_trunc.checked = true then
							
							lvi_pos = Pos( selected_data_window.Describe(lvs_col_name+"_t.Text") , ':' , 1 )
							if lvi_pos < 1 then
							   	
							else
							   selected_data_window.Modify(lvs_col_name+"_t.Text='"+mid( selected_data_window.Describe(lvs_col_name+"_t.Text") , 1 , lvi_pos -1  )+"'")
							end if
						end if
						
						selected_data_window.Modify(lvs_col_name + "_t.x="+string(lvl_title_x))
						selected_data_window.Modify(lvs_col_name + "_t.y="+string(lvl_title_y))
						
						selected_data_window.Modify(lvs_col_name + "_t.height="+tab_1.tp_ff_property.em_ff_title_height.text)
						selected_data_window.Modify(lvs_col_name + "._t.Background.mode=2")		
						selected_data_window.Modify(lvs_col_name + "_t.Background.Color="+tab_1.tp_ff_property.ddlb_ff_title_color.text)
						selected_data_window.Modify(lvs_col_name + "_t.font.Height=-"+tab_1.tp_ff_property.em_ff_font_size.text)
//						selected_data_window.Modify(lvs_col_name + "_t.border=5")
						selected_data_window.Modify(lvs_col_name + "_t.width="+tab_1.tp_ff_property.em_ff_title_width.text)						
						
						if tab_1.tp_ff_property.ddlb_ff_title_font_weight.getcode() = '%' or isnull(tab_1.tp_ff_property.ddlb_ff_title_font_weight.getcode()) then 
						else
							selected_data_window.Modify(lvs_col_name + "_t.font.Weight="+tab_1.tp_ff_property.ddlb_ff_title_font_weight.getcode())	
						end if
						
						if tab_1.tp_ff_property.ddlb_ff_title_alignment.getcode() = '%' or isnull(tab_1.tp_ff_property.ddlb_ff_title_alignment.getcode()) then 
						else
							selected_data_window.Modify(lvs_col_name + "_t.Alignment="+tab_1.tp_ff_property.ddlb_ff_title_alignment.getcode())		
						end if
						
						
						selected_data_window.Modify(lvs_col_name + ".x="+string(lvl_col_x))
						selected_data_window.Modify(lvs_col_name + ".y="+string(lvl_col_y))
						
						selected_data_window.Modify(lvs_col_name + ".height="+tab_1.tp_ff_property.em_ff_column_height.text)	
						selected_data_window.Modify(lvs_col_name + ".border=5")
						selected_data_window.Modify(lvs_col_name + ".Background.mode=2")
						
						if selected_data_window.Describe(lvs_col_name+".tabsequence") = '0' then 
						else
							selected_data_window.Modify(lvs_col_name + ".Background.Color="+tab_1.tp_ff_property.ddlb_ff_column_color.text)
						end if
						
						
						selected_data_window.Modify(lvs_col_name + ".font.Height=-"+tab_1.tp_ff_property.em_ff_font_size.text)	
						selected_data_window.Modify(lvs_col_name + ".width="+tab_1.tp_ff_property.em_ff_column_width.text)						
					
						if tab_1.tp_ff_property.ddlb_ff_column_font_weight.getcode() = '%' or isnull(tab_1.tp_ff_property.ddlb_ff_column_font_weight.getcode()) then 
						else
							selected_data_window.Modify(lvs_col_name + ".font.Weight="+tab_1.tp_ff_property.ddlb_ff_column_font_weight.getcode())	
						end if	
					

         						lvs_column_type = mid(selected_data_window.Describe(lvs_col_name+ ".ColType"),1,4)
									
							if lvs_column_type = 'numb' then
										selected_data_window.Modify(lvs_col_name + ".Alignment=1")								
							elseif lvs_column_type = 'char' then
										selected_data_window.Modify(lvs_col_name + ".Alignment=0")
							elseif lvs_column_type = 'date' then
									if tab_1.tp_ff_property.ddlb_ff_date_column_alignment.getcode() = '%' or isnull(tab_1.tp_ff_property.ddlb_ff_date_column_alignment.getcode()) then 
									else
										selected_data_window.Modify(lvs_col_name + ".Alignment="+tab_1.tp_ff_property.ddlb_ff_date_column_alignment.getcode())		
									end if
							end if		
						
						st_msg.text = String(lvi_count)+" Rows Processed!"
						
						if tab_1.tp_ff_property.cbx_ff_dddw.checked = true then 
					
									  SELECT REPLACE( :lvs_col_name , '_' , ' ' ) INTO : LVS_CODE_TYPE 
										 FROM DUAL ;
										IF F_SQL_CHECK() < 0  THEN 
											RETURN -1
										END IF
										
									SELECT COUNT(*) 	INTO :LVI_DDDW_COUNT
										FROM ISYS_BASECODE
									 WHERE CODE_TYPE = UPPER(:LVS_CODE_TYPE)
										  AND ORGANIZATION_ID      = :gvi_organization_id ;
										  
										IF F_SQL_CHECK() < 0  THEN 
											RETURN -1
										END IF
									 
									 IF LVI_DDDW_COUNT < 1 THEN 
										
									 ELSE
										
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.ALLOWEDIT=NO')
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.AUTOHSCROLL=YES')	
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.AUTORETRIEVE=YES')		
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.USEASBORDER=YES')			
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.DATACOLUMN=CODE_NAME')				
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.DISPLAYCOLUMN=CODE_MEAN')					
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.HSCROLLBAR=YES')						
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.HSPLITSCROLL=YES')							
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.IMEMODE=0')								
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.LIMIT=8')									
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.NAME=vd_basecode')									     
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.NILISNULL=NO')									     	
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.PERCENTWIDTH=300')
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.REQUIRED=NO')	
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.SHOWLIST=NO')		
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.VSCROLLBAR=YES')
									
									END IF
							
						end if
						
					Next 
					selected_data_window.setredraw(true)
					tab_1.tabpage_1.mle_1.text = selected_data_window.Describe("DataWindow.Syntax")					

else
	
//====================================================================
// Grid / Tabular Style
//====================================================================

					f_set_column_dddw(selected_data_window)
					selected_data_window.Object.DataWindow.Color = Long(tab_1.tp_property.ddlb_dw_color.text)
					
					//selected_data_window.Modify("DataWindow.Header.Height='"+em_header_height.text+"'")
					selected_data_window.Object.DataWindow.Header.Height = Integer(tab_1.tp_property.em_header_height.text)
					selected_data_window.Object.DataWindow.Header.Color = Long(tab_1.tp_property.ddlb_header_color.text)
					
					//selected_data_window.Modify("DataWindow.Detail.Height='"+tab_1.tp_property.em_detail_height.text+"'")
					selected_data_window.Object.DataWindow.Detail.Height = Integer(tab_1.tp_property.em_detail_height.text)
					selected_data_window.Object.DataWindow.Detail.Color =Long(tab_1.tp_property.ddlb_detail_color.text)
					
					


					Gst_dw_colinfo.i_dw_colcount = 0
					Gst_dw_colinfo.i_dw_colcount=Integer(  selected_data_window.Describe("DataWindow.Column.Count"))
					
					//======================================================================
					// Column Object $$HEX2$$7cb92000$$ENDHEX$$Scan $$HEX2$$5cd5e4b2$$ENDHEX$$
					//======================================================================
					For lvi_count = 1 to Gst_dw_colinfo.i_dw_colcount
					
						lvs_col_name	= selected_data_window.Describe('#'+String(lvi_count)+".Name")	
						
						selected_data_window.Modify(lvs_col_name + "_t.y=8")
						selected_data_window.Modify(lvs_col_name + "_t.height="+tab_1.tp_property.em_title_height.text)
						selected_data_window.Modify(lvs_col_name + "_t.Background.Color="+tab_1.tp_property.ddlb_header_color.text)
						selected_data_window.Modify(lvs_col_name + "_t.font.Height=-"+tab_1.tp_property.em_font_size.text)
//						selected_data_window.Modify(lvs_col_name + "_t.border=5")
						
						if tab_1.tp_property.ddlb_title_font_weight.getcode() = '%' or isnull(tab_1.tp_property.ddlb_title_font_weight.getcode()) then 
						else
							selected_data_window.Modify(lvs_col_name + "_t.font.Weight="+tab_1.tp_property.ddlb_title_font_weight.getcode())	
						end if
						
						if tab_1.tp_property.ddlb_title_alignment.getcode() = '%' or isnull(tab_1.tp_property.ddlb_title_alignment.getcode()) then 
						else
							selected_data_window.Modify(lvs_col_name + "_t.Alignment="+tab_1.tp_property.ddlb_title_alignment.getcode())		
						end if
						
						selected_data_window.Modify(lvs_col_name + ".y=4")
						selected_data_window.Modify(lvs_col_name + ".height="+tab_1.tp_property.em_column_height.text)	
						selected_data_window.Modify(lvs_col_name + ".Background.Color="+tab_1.tp_property.ddlb_detail_color.text)
						selected_data_window.Modify(lvs_col_name + ".font.Height=-"+tab_1.tp_property.em_font_size.text)	
						if tab_1.tp_property.ddlb_column_font_weight.getcode() = '%' or isnull(tab_1.tp_property.ddlb_column_font_weight.getcode()) then 
						else
							selected_data_window.Modify(lvs_col_name + ".font.Weight="+tab_1.tp_property.ddlb_column_font_weight.getcode())	
						end if	
					
						
						if tab_1.tp_property.ddlb_column_alignment.getcode() = '%' or isnull(tab_1.tp_property.ddlb_column_alignment.getcode()) then 
						else
							selected_data_window.Modify(lvs_col_name + ".Alignment="+tab_1.tp_property.ddlb_column_alignment.getcode())		
						end if
						
						st_msg.text = String(lvi_count)+" Rows Processed!"
						
						if tab_1.tp_property.cbx_dddw.checked = true then 
					
									  SELECT REPLACE( :lvs_col_name , '_' , ' ' ) INTO : LVS_CODE_TYPE 
										 FROM DUAL ;
										IF F_SQL_CHECK() < 0  THEN 
											RETURN -1
										END IF
										
									SELECT COUNT(*) 	INTO :LVI_DDDW_COUNT
										FROM ISYS_BASECODE
									 WHERE CODE_TYPE = UPPER(:LVS_CODE_TYPE)
										  AND ORGANIZATION_ID      = :gvi_organization_id ;
										  
										IF F_SQL_CHECK() < 0  THEN 
											RETURN -1
										END IF
									 
									 IF LVI_DDDW_COUNT < 1 THEN 
										
									 ELSE
										
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.ALLOWEDIT=NO')
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.AUTOHSCROLL=YES')	
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.AUTORETRIEVE=YES')		
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.USEASBORDER=NO')			
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.DATACOLUMN=CODE_NAME')				
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.DISPLAYCOLUMN=CODE_MEAN')					
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.HSCROLLBAR=YES')						
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.HSPLITSCROLL=YES')							
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.IMEMODE=0')								
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.LIMIT=8')									
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.NAME=vd_basecode')									     
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.NILISNULL=NO')									     	
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.PERCENTWIDTH=300')
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.REQUIRED=NO')	
										selected_data_window.MODIFY(lvs_col_name+'.DDDW.SHOWLIST=NO')		
										  selected_data_window.MODIFY(lvs_col_name+'.DDDW.VSCROLLBAR=NO')
									
									END IF
							
						end if
						
					Next 
					
					if tab_1.tp_property.cbx_number.checked = true then 
					
						MODIFY_STRING = 'CREATE  COMPUTE(NAME=NO_1 VISIBLE="1" BAND=DETAIL FONT.CHARSET="0" FONT.FACE="TAHOMA" FONT.FAMILY="2" FONT.HEIGHT="-8" FONT.PITCH="2" FONT.WEIGHT="700" BACKGROUND.MODE="2" BACKGROUND.COLOR="'+tab_1.tp_property.ddlb_detail_color.text+'" COLOR="0" X="0" Y="4" HEIGHT="64" WIDTH="150" FORMAT="[GENERAL]" EXPRESSION="GETROW()" ALIGNMENT="0" BORDER="0" CROSSTAB.REPEAT=NO )'
						LVS_RETURN = selected_data_window.Modify(MODIFY_STRING)				
						
						MODIFY_STRING = 'CREATE TEXT(NAME=NO_1_T VISIBLE="1" BAND=HEADER FONT.CHARSET="0" FONT.FACE="TAHOMA" FONT.FAMILY="2" FONT.HEIGHT="-8" FONT.PITCH="2" FONT.WEIGHT="700" BACKGROUND.MODE="2" BACKGROUND.COLOR="'+tab_1.tp_property.ddlb_header_color.text+'" COLOR="33554432" ALIGNMENT="2" BORDER="0" X="0" Y="8" HEIGHT="116" WIDTH="150" TEXT="No" )'
						LVS_RETURN = selected_data_window.Modify(MODIFY_STRING)				
							
					end if
					
					if tab_1.tp_property.cbx_indicator.checked = true then 
						
						MODIFY_STRING = 'CREATE  COMPUTE(NAME=INDICATOR VISIBLE="1" BAND=DETAIL FONT.CHARSET="0" FONT.FACE="TAHOMA" FONT.FAMILY="2" FONT.HEIGHT="-8" FONT.PITCH="2" FONT.WEIGHT="700" BACKGROUND.MODE="2" BACKGROUND.COLOR="'+tab_1.tp_property.ddlb_detail_color.text+'" COLOR="0" X="0" Y="4" HEIGHT="64" WIDTH="100" FORMAT="[GENERAL]" EXPRESSION="TRIM(~'~')" ALIGNMENT="0" BORDER="0" CROSSTAB.REPEAT=NO )'
						LVS_RETURN = selected_data_window.Modify(MODIFY_STRING)			
					end if
					
					selected_data_window.setredraw(true)
					tab_1.tabpage_1.mle_1.text = selected_data_window.Describe("DataWindow.Syntax")
end if					
end event

type cb_import from so_commandbutton within w_show_datawindow_popup
integer x = 370
integer y = 1848
integer width = 361
integer height = 108
integer taborder = 70
boolean bringtotop = true
string text = "Import"
end type

event clicked;call super::clicked;msg = F_MSGBOX(1160)
if msg = 1 then 
else
	return
end if

string dwsyntax, ErrorBuffer
integer rtncode
dwsyntax = tab_1.tabpage_1.mle_1.text
if sle_object_name.text = '' or isnull(sle_object_name.text) then
	   Messagebox("Error" , "Liblary Import Failed!  Object Name Invalid" )
	return
end if

if sle_comment.text = '' then 
	sle_comment.text = sle_object_name.text
	rtncode = LibraryImport(uo_filename.text(), sle_object_name.text, ImportDataWindow!, dwsyntax, ErrorBuffer, sle_comment.text+" Create Date :"+string(today())+" Created By : "+Gvs_user_id)	
else
	rtncode = LibraryImport(uo_filename.text(), sle_object_name.text, ImportDataWindow!, dwsyntax, ErrorBuffer, sle_comment.text)	
end if

if rtncode < 1 then 
   Messagebox("Error" , "Liblary Import Failed!"+"~r~n"+ErrorBuffer )
else
     Messagebox("Notify" , "Liblary Import success" )	
	st_MSG.TEXT = 'Import success'
end if
end event

