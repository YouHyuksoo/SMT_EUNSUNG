event modified;call super::modified;Gst_dw_colinfo.i_dw_colcount=Integer(  selected_data_window.Describe("DataWindow.Column.Count"))

if this.text = '0' then 
	return
end if 

if  mod (  Gst_dw_colinfo.i_dw_colcount , Long( this.text )) > 0 then 
     em_v_count.text = string( Gst_dw_colinfo.i_dw_colcount / Long( this.text ) + 1 )
else
	em_v_count.text = string( Gst_dw_colinfo.i_dw_colcount / Long( this.text ))
end if
end event

