global type w_show_datawindow_popup from w_none_dw_popup_root
integer x = 827
integer y = 576
integer width = 3063
integer height = 2060
string title = "Show DataWindow"
boolean minbox = true
windowtype windowtype = popup!
boolean clientedge = true
boolean contexthelp = false
uo_filename uo_filename
sle_object_name sle_object_name
st_1 st_1
st_2 st_2
sle_comment sle_comment
st_11 st_11
tab_1 tab_1
cb_apply cb_apply
cb_import cb_import
cbx_tabular cbx_tabular
cbx_grid cbx_grid
cbx_freeform cbx_freeform
gb_1 gb_1
end type
global w_show_datawindow_popup w_show_datawindow_popup

on w_show_datawindow_popup.create
int iCurrent
call super::create
this.uo_filename=create uo_filename
this.sle_object_name=create sle_object_name
this.st_1=create st_1
this.st_2=create st_2
this.sle_comment=create sle_comment
this.st_11=create st_11
this.tab_1=create tab_1
this.cb_apply=create cb_apply
this.cb_import=create cb_import
this.cbx_tabular=create cbx_tabular
this.cbx_grid=create cbx_grid
this.cbx_freeform=create cbx_freeform
this.gb_1=create gb_1
iCurrent=UpperBound(this.Control)
this.Control[iCurrent+1]=this.uo_filename
this.Control[iCurrent+2]=this.sle_object_name
this.Control[iCurrent+3]=this.st_1
this.Control[iCurrent+4]=this.st_2
this.Control[iCurrent+5]=this.sle_comment
this.Control[iCurrent+6]=this.st_11
this.Control[iCurrent+7]=this.tab_1
this.Control[iCurrent+8]=this.cb_apply
this.Control[iCurrent+9]=this.cb_import
this.Control[iCurrent+10]=this.cbx_tabular
this.Control[iCurrent+11]=this.cbx_grid
this.Control[iCurrent+12]=this.cbx_freeform
this.Control[iCurrent+13]=this.gb_1
end on

on w_show_datawindow_popup.destroy
call super::destroy
destroy(this.uo_filename)
destroy(this.sle_object_name)
destroy(this.st_1)
destroy(this.st_2)
destroy(this.sle_comment)
destroy(this.st_11)
destroy(this.tab_1)
destroy(this.cb_apply)
destroy(this.cb_import)
destroy(this.cbx_tabular)
destroy(this.cbx_grid)
destroy(this.cbx_freeform)
destroy(this.gb_1)
end on

event open;call super::open;tab_1.tabpage_1.mle_1.setfocus()
tab_1.tabpage_1.mle_1.text = message.stringparm
sle_object_name.text = selected_data_window.dataobject

if gvi_user_level = 9 then 
	cb_import.enabled = true 
	tab_1.tabpage_1.mle_1.displayonly = false
end if

//==========================================
// Grid
//==========================================
tab_1.tp_property.ddlb_title_font_weight.redraw('FONT WEIGHT' )
tab_1.tp_property.ddlb_title_font_weight.selectitemno(3)
tab_1.tp_property.ddlb_column_font_weight.redraw('FONT WEIGHT' )
tab_1.tp_property.ddlb_column_font_weight.selectitemno(2)

tab_1.tp_property.ddlb_title_alignment.redraw('ALIGNMENT' )
tab_1.tp_property.ddlb_title_alignment.selectitemno(4)

tab_1.tp_property.ddlb_column_alignment.redraw('ALIGNMENT' )
tab_1.tp_property.ddlb_column_alignment.selectitemno(2)

//==========================================
// freeform
//==========================================
tab_1.tp_ff_property.ddlb_ff_title_font_weight.redraw('FONT WEIGHT' )
tab_1.tp_ff_property.ddlb_ff_title_font_weight.selectitemno(3)
tab_1.tp_ff_property.ddlb_ff_column_font_weight.redraw('FONT WEIGHT' )
tab_1.tp_ff_property.ddlb_ff_column_font_weight.selectitemno(2)

tab_1.tp_ff_property.ddlb_ff_title_alignment.redraw('ALIGNMENT' )
tab_1.tp_ff_property.ddlb_ff_title_alignment.selectitemno(3)

tab_1.tp_ff_property.ddlb_ff_date_column_alignment.redraw('ALIGNMENT' )
tab_1.tp_ff_property.ddlb_ff_date_column_alignment.selectitemno(2)

postevent('ue_post_open')
end event

event key;IF key = keyescape! THEN 
	CB_CLOSE.TRIGGEREVENT('CLICKED')
END IF

end event

event ue_post_open;call super::ue_post_open;string Lvs_processing
Lvs_processing = selected_data_window.Describe("DataWindow.Processing")

if Lvs_processing = '0' then 
	cbx_freeform.checked = true
	tab_1.selectedtab = 2
elseif Lvs_processing = '1' then 
	cbx_grid.checked = true	
	tab_1.selectedtab =1	
elseif Lvs_processing = '2' then 
	cbx_tabular.checked = true		
	tab_1.selectedtab = 1 	
end if
end event

