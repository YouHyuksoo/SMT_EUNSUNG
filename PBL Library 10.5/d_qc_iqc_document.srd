 retrieve="  SELECT  ~"IQ_IQC_DOCUMENT~".~"IQC_INSPECT_NO~" ,           ~"IQ_IQC_DOCUMENT~".~"SEQUENCE~" ,           ~"IQ_IQC_DOCUMENT~".~"ORGANIZATION_ID~" ,           ~"IQ_IQC_DOCUMENT~".~"REG_DATE~" ,           ~"IQ_IQC_DOCUMENT~".~"DOCUMENT_NAME~" ,           ~"IQ_IQC_DOCUMENT~".~"DOCUMENT_KEYWORD~" ,           ~"IQ_IQC_DOCUMENT~".~"ENTER_DATE~" ,           ~"IQ_IQC_DOCUMENT~".~"ENTER_BY~" ,           ~"IQ_IQC_DOCUMENT~".~"LAST_MODIFY_DATE~" ,           ~"IQ_IQC_DOCUMENT~".~"LAST_MODIFY_BY~"     FROM ~"IQ_IQC_DOCUMENT~"      WHERE ( ~"IQ_IQC_DOCUMENT~".~"IQC_INSPECT_NO~" = :arg_iqc_inspect_no ) And          ( ~"IQ_IQC_DOCUMENT~".~"ORGANIZATION_ID~" = :arg_org )   " update="IQ_IQC_DOCUMENT" updatewhere=1 updatekeyinplace=no arguments=(("arg_iqc_inspect_no", string),("arg_org", number)) )
