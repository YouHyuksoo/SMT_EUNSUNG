pacity_uom~") COLUMN(NAME=~"ip_product_workstage.use_rate~") COLUMN(NAME=~"ip_product_workstage.uph_value~") COLUMN(NAME=~"ip_product_workstage.capacity~") COLUMN(NAME=~"ip_product_workstage.mes_display_group~") COLUMN(NAME=~"ip_product_workstage.actual_plc_address~") COLUMN(NAME=~"ip_product_workstage.workstage_status~") COLUMN(NAME=~"ip_product_workstage.bad_qty_extract_yn~") COLUMN(NAME=~"ip_product_workstage.workstage_code_group~")WHERE(    EXP1 =~"NVL(~~~"IP_PRODUCT_WORKSTAGE~~~".~~~"LINE_CODE~~~" , '*')~"   OP =~"like~"    EXP2 =~":arg_line_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IP_PRODUCT_WORKSTAGE~~~".~~~"WORKSTAGE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_workstage_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IP_PRODUCT_WORKSTAGE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_workstage_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IP_PRODUCT_WORKSTAGE" updatewhere=0 updatekeyinplace=no arguments=(("arg_line_code", string),("arg_workstage_code", string),("arg_org", number))  sort="organization_id A line_code A workstage_start_yn D workstage_code A " )
