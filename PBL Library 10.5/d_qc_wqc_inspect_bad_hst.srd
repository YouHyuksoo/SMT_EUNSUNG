 retrieve="  SELECT ~"IQ_PRODUCT_WQC~".~"INSPECT_DATE~",   
         ~"IQ_PRODUCT_WQC~".~"INSPECT_SEQUENCE~",   
         ~"IQ_PRODUCT_WQC~".~"ORGANIZATION_ID~",   
         ~"IQ_PRODUCT_WQC~".~"SERIAL_NO~",   
         ~"IQ_PRODUCT_WQC~".~"MODEL_NAME~",   
         ~"IQ_PRODUCT_WQC~".~"MODEL_SUFFIX~",   
         ~"IQ_PRODUCT_WQC~".~"ITEM_CODE~",   
         ~"IQ_PRODUCT_WQC~".~"LINE_CODE~",   
         ~"IQ_PRODUCT_WQC~".~"WORKSTAGE_CODE~",   
         ~"IQ_PRODUCT_WQC~".~"MACHINE_CODE~",   
         ~"IQ_PRODUCT_WQC~".~"WQC_DIVISION~",   
         ~"IQ_PRODUCT_WQC~".~"INSPECT_QTY~",   
         ~"IQ_PRODUCT_WQC~".~"INSPECT_BAD_QTY~",   
         ~"IQ_PRODUCT_WQC~".~"REPAIR_RESULT~",   
         ~"IQ_PRODUCT_WQC~".~"LOCATION_INFOR~",   
          f_get_code_master ('VISUAL BAD REASON CODE', IQ_PRODUCT_WQC.BAD_REASON_CODE,:ARG_LANG,:ARG_ORG)	BAD_REASON_CODE,
         ~"IQ_PRODUCT_WQC~".~"INSPECT_BY~",   
         ~"IQ_PRODUCT_WQC~".~"COMMENTS~",   
         ~"IQ_PRODUCT_WQC~".~"ENTER_DATE~",   
         ~"IQ_PRODUCT_WQC~".~"ENTER_BY~",   
         ~"IQ_PRODUCT_WQC~".~"LAST_MODIFY_DATE~",   
         ~"IQ_PRODUCT_WQC~".~"LAST_MODIFY_BY~" 
    FROM ~"IQ_PRODUCT_WQC~"  
   WHERE ( ~"IQ_PRODUCT_WQC~".~"INSPECT_DATE~" >= trunc(:arg_dateset) ) AND  
         ( ~"IQ_PRODUCT_WQC~".~"INSPECT_DATE~" <  trunc(:arg_dateend +1) ) AND  
         ( ~"IQ_PRODUCT_WQC~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IQ_PRODUCT_WQC~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IQ_PRODUCT_WQC~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( ~"IQ_PRODUCT_WQC~".~"SERIAL_NO~" like :arg_serial_no ) AND  
         ( ~"IQ_PRODUCT_WQC~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_workstage_code", string),("arg_model_name", string),("arg_serial_no", string),("ARG_LANG", string),("arg_org", number))  sort="line_code A inspect_date A " )
