 column=(type=char(1) updatewhereclause=yes name=issue_status dbname="im_item_request.issue_status" dbalias=".issue_status" )
 column=(type=datetime updatewhereclause=yes name=issue_date dbname="im_item_request.issue_date" dbalias=".issue_date" )
 column=(type=number updatewhereclause=yes name=request_sequence dbname="im_item_request.request_sequence" dbalias=".request_sequence" )
 column=(type=number updatewhereclause=yes name=wait_time dbname="wait_time" )
 column=(type=char(1) updatewhereclause=yes name=abc_grade dbname="id_item.abc_grade" dbalias=".abc_grade" )
 retrieve="  SELECT ~"IM_ITEM_REQUEST~".~"REQUEST_DATE~",   
         ~"IM_ITEM_REQUEST~".~"LINE_CODE~",   
         ~"IM_ITEM_REQUEST~".~"MACHINE_CODE~",   
         ~"IM_ITEM_REQUEST~".~"ITEM_CODE~",   
         ~"IM_ITEM_REQUEST~".~"LOCATION_CODE~",   
         ~"IM_ITEM_REQUEST~".~"REQUEST_STATUS~",   
         ~"IM_ITEM_REQUEST~".~"CONFIRM_DATE~",   
         ~"IM_ITEM_REQUEST~".~"ENTER_BY~",   
         ~"IM_ITEM_REQUEST~".~"ENTER_DATE~",   
         ~"IM_ITEM_REQUEST~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_REQUEST~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_REQUEST~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",   
         ~"ID_ITEM~".~"MATERIAL_QTY~",   
         ~"IM_ITEM_REQUEST~".~"REQUEST_QTY~",   
         ~"IM_ITEM_REQUEST~".~"REQUEST_DEFICIT~",   
         ~"IM_ITEM_REQUEST~".~"MODEL_NAME~",   
         ~"IM_ITEM_REQUEST~".~"LOCATION_ADDRESS_RACK~",   
         ~"IM_ITEM_REQUEST~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_REQUEST~".~"ISSUE_STATUS~",   
         ~"IM_ITEM_REQUEST~".~"ISSUE_DATE~",   
         ~"IM_ITEM_REQUEST~".~"REQUEST_SEQUENCE~",   
         ( SYSDATE - REQUEST_DATE ) * 24 * 60 WAIT_TIME,   
         ~"ID_ITEM~".~"ABC_GRADE~"  
    FROM ~"IM_ITEM_REQUEST~",   
         ~"ID_ITEM~"  
   WHERE ( im_item_request.item_code = id_item.item_code (+)) and  
         ( im_item_request.organization_id = id_item.organization_id (+)) and  
         ( ( ~"IM_ITEM_REQUEST~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( NVL(~"IM_ITEM_REQUEST~".~"MACHINE_CODE~" , '*') like :arg_machine_code ) AND  
         ( ~"IM_ITEM_REQUEST~".~"ITEM_CODE~" like :arg_item ) AND  
         ( ~"IM_ITEM_REQUEST~".~"REQUEST_STATUS~" = 'R' ) AND  
         ( ~"ID_ITEM~".~"ABC_GRADE~" like :arg_abc_grade ) AND 
         ( NVL(~"ID_ITEM~".~"SUPPLIER_CODE~", '*') like :arg_supplier_code ) AND    
         ( ~"IM_ITEM_REQUEST~".~"ORGANIZATION_ID~" = :arg_org ) )    
" arguments=(("arg_line_code", string),("arg_machine_code", string),("arg_item", string),("arg_abc_grade", string),("arg_supplier_code", string),("arg_org", number))  sort="abc_grade A line_code A request_date A request_sequence A organization_id A " )
group(level=1 header.height=0 trailer.height=72 by=("abc_grade" ) newpage=yes resetpagecount=yes header.color="536870912" trailer.color="12632256" )
