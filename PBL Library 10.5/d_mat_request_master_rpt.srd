 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias=".item_spec" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" dbalias=".location_address" )
 column=(type=number updatewhereclause=yes name=id_item_material_qty dbname="id_item.material_qty" dbalias=".material_qty" )
 column=(type=number updatewhereclause=yes name=request_qty dbname="im_item_request.request_qty" dbalias=".request_qty" )
