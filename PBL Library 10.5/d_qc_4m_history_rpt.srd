release 10.5;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no )
header(height=632 color="536870912" )
summary(height=444 color="536870912" height.autosize=yes )
footer(height=152 color="536870912" )
detail(height=340 color="536870912" height.autosize=yes )
table(column=(type=char(30) updatewhereclause=yes key=yes name=model_name dbname="ip_product_model_master.model_name" )
 column=(type=char(30) updatewhereclause=yes name=model_suffix dbname="ip_product_model_master.model_suffix" )
 column=(type=number updatewhereclause=yes name=version dbname="ip_product_model_master.version" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_model_master.item_code" )
 column=(type=number updatewhereclause=yes key=yes name=organization_id dbname="ip_product_model_master.organization_id" )
 column=(type=char(100) updatewhereclause=yes name=sw_version_out dbname="sw_version_out" )
 column=(type=char(100) updatewhereclause=yes name=sw_version_in dbname="sw_version_in" )
 column=(type=char(100) updatewhereclause=yes name=hw_version dbname="ip_product_model_master.hw_version" )
 retrieve="  SELECT
			A.MODEL_NAME,   
			A.MODEL_SUFFIX,   
			A.VERSION,   
			A.ITEM_CODE ,

			A.ORGANIZATION_ID,   
			--A.SW_VERSION,   
			(SELECT OUTPUT_SW_VERSION
			  FROM (
					  SELECT ROW_NUMBER() OVER (PARTITION BY MODEL_NAME ORDER BY UPLOAD_DATE DESC) CNT , IS_NEW, MODEL_NAME, OUTPUT_SW_VERSION
					  FROM IP_PRODUCT_SOFTWARE_MASTER
					  WHERE IS_NEW = 'N' AND NVL(OUTPUT_SW_VERSION,' ') <> ' ') 
			  WHERE CNT = 1 AND MODEL_NAME = A.MODEL_NAME) SW_VERSION_OUT,
			(SELECT INPUT_SW_VERSION
			  FROM (
					  SELECT ROW_NUMBER() OVER (PARTITION BY MODEL_NAME ORDER BY UPLOAD_DATE DESC) CNT , IS_NEW, MODEL_NAME, INPUT_SW_VERSION
					  FROM IP_PRODUCT_SOFTWARE_MASTER
					  WHERE IS_NEW = 'N' AND NVL(OUTPUT_SW_VERSION,' ') <> ' ') 
			  WHERE CNT = 1 AND MODEL_NAME = A.MODEL_NAME) SW_VERSION_IN,
				A.HW_VERSION  
    FROM IP_PRODUCT_MODEL_MASTER A
   WHERE
         ( a.model_name = :arg_model_name ) AND  
         ( a.organization_id = :arg_org ) AND
		  ( a.MODEL_SUFFIX like :arg_suffix)" update="IP_PRODUCT_MODEL_MASTER" updatewhere=0 updatekeyinplace=no arguments=(("arg_model_name", string),("arg_org", number),("arg_suffix", string))  sort="model_name A " )
