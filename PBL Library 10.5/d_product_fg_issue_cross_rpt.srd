release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=120 color="536870912" )
summary(height=72 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=customer_code dbname="customer_code" )
 column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 retrieve="select  to_char(trunc(issue_date),'YYYY/MM/DD') actual_date, 
          model_name, 
          model_suffix, 
          customer_code,
          location_code,
         sum(decode(txn_deficit,3,1,-1)*qty)  qty,
          max(f_get_sal_last_price_cfm(customer_code,item_code, 'T',issue_date,organization_id)) issue_price
  from ip_product_fg_issue 
where issue_date >= :arg_sDate
   
   and issue_date < :arg_eDate + 1 
   and model_name like :arg_model 
  
 group by to_char(trunc(issue_date),'YYYY/MM/DD'), 
              model_name, 
              model_suffix, 
              customer_code,
              location_code" arguments=(("arg_sDate", datetime),("arg_eDate", datetime),("arg_model", string))  sort="customer_code A model_name A " )
group(level=1 header.height=0 trailer.height=0 by=("customer_code" ) header.color="536870912" trailer.color="536870912" )
