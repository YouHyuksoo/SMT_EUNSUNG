 column=(type=char(1) updatewhereclause=yes name=feeder_shaft_status dbname="id_eng_bom_smt.feeder_shaft_status" )
 retrieve="  SELECT ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT~",   
         ~"ID_ENG_BOM_SMT~".~"REVISION~",   
         ~"ID_ENG_BOM_SMT~".~"LINE_CODE~",   
	     ~"ID_ENG_BOM_SMT~".~"PCB_ITEM~" ,
         ~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT_STATUS~" 
    FROM ~"ID_ENG_BOM_SMT~"   
  WHERE PARENT_ITEM_CODE = :ARG_ITEM_CODE 
      AND REVISION LIKE :ARG_REVISION
      AND ORGANIZATION_ID = :ARG_ORG
GROUP BY ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT~",   
         ~"ID_ENG_BOM_SMT~".~"REVISION~",   
         ~"ID_ENG_BOM_SMT~".~"LINE_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"PCB_ITEM~"  ,
 ~"ID_ENG_BOM_SMT~".~"FEEDER_SHAFT_STATUS~" " arguments=(("ARG_ITEM_CODE", string),("ARG_REVISION", string),("ARG_ORG", number))  sort="line_code A parent_item_code A pcb_item A revision A feeder_shaft A " )
