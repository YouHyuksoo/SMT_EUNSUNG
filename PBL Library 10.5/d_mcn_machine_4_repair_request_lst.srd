 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_machine~" ) COLUMN(NAME=~"imcn_machine.machine_code~") COLUMN(NAME=~"imcn_machine.organization_id~") COLUMN(NAME=~"imcn_machine.machine_name~") COLUMN(NAME=~"imcn_machine.machine_type~") COLUMN(NAME=~"imcn_machine.capacity~") COLUMN(NAME=~"imcn_machine.acquisition_date~") COLUMN(NAME=~"imcn_machine.acquisition_type~") COLUMN(NAME=~"imcn_machine.machine_model_name~") COLUMN(NAME=~"imcn_machine.line_code~") COLUMN(NAME=~"imcn_machine.customer_code~") COLUMN(NAME=~"imcn_machine.use_status~") COLUMN(NAME=~"imcn_machine.manual_location_comment~") COLUMN(NAME=~"imcn_machine.nation_code~") COLUMN(NAME=~"imcn_machine.workstage_code~") COLUMN(NAME=~"imcn_machine.enter_by~") COLUMN(NAME=~"imcn_machine.enter_date~") COLUMN(NAME=~"imcn_machine.last_modify_by~") COLUMN(NAME=~"imcn_machine.last_modify_date~") COMPUTE(NAME=~"rowid~") COLUMN(NAME=~"imcn_machine.use_rate~") COLUMN(NAME=~"imcn_machine.uph_value~") COLUMN(NAME=~"imcn_machine.capacity_uom~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"imcn_machine.supplier_code~") COLUMN(NAME=~"imcn_machine.machine_status~") COLUMN(NAME=~"imcn_machine.mold_code~") COLUMN(NAME=~"imcn_machine.mold_version~") COLUMN(NAME=~"imcn_machine.mold_set_serial~") COLUMN(NAME=~"imcn_machine.actual_plc_address~") COLUMN(NAME=~"imcn_machine.use_tpm_yn~") COLUMN(NAME=~"imcn_machine.mes_display_yn~") COLUMN(NAME=~"imcn_machine.mold_exists_yn~") COLUMN(NAME=~"imcn_machine.machine_status_code~")WHERE(    EXP1 =~"~~~"IMCN_MACHINE~~~".~~~"MACHINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_machine_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_MACHINE~~~".~~~"MACHINE_TYPE~~~"~"   OP =~"like~"    EXP2 =~":arg_machine_type~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"NVL(~~~"IMCN_MACHINE~~~".~~~"LINE_CODE~~~" , '*')~"   OP =~"like~"    EXP2 =~":arg_line_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MACHINE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_machine_code~" TYPE = string)  ARG(NAME = ~"arg_machine_type~" TYPE = string)  ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_machine_code", string),("arg_machine_type", string),("arg_line_code", string),("arg_org", number))  sort="organization_id A machine_type A line_code A machine_code A " )
