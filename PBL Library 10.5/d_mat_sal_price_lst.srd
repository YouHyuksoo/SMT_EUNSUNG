 retrieve="  SELECT ~"IM_ITEM_SALE_PRICE~".~"ITEM_CODE~",   
         ~"IM_ITEM_SALE_PRICE~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_SALE_PRICE~".~"LINE_TYPE~",   
         ~"IM_ITEM_SALE_PRICE~".~"DATESET~",   
         ~"IM_ITEM_SALE_PRICE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_SALE_PRICE~".~"SALE_PRICE~",   
         ~"IM_ITEM_SALE_PRICE~".~"SALE_CURRENCY~",   
         ~"IM_ITEM_SALE_PRICE~".~"DELIVERY~",   
         ~"IM_ITEM_SALE_PRICE~".~"PRICE_TYPE~",   
         ~"IM_ITEM_SALE_PRICE~".~"STANDARD_SALE_PRICE~",   
         ~"IM_ITEM_SALE_PRICE~".~"APPROVAL_NO~",   
         ~"IM_ITEM_SALE_PRICE~".~"DATEEND~",   
         ~"IM_ITEM_SALE_PRICE~".~"PRICE_CHANGE_REASON~",   
         ~"IM_ITEM_SALE_PRICE~".~"PRICE_CHANGE_CONFIRM_YN~",   
         ~"IM_ITEM_SALE_PRICE~".~"ENTER_BY~",   
         ~"IM_ITEM_SALE_PRICE~".~"ENTER_DATE~",   
         ~"IM_ITEM_SALE_PRICE~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_SALE_PRICE~".~"LAST_MODIFY_DATE~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~" , 
         DECODE(  SIGN( IM_ITEM_SALE_PRICE.DATEEND - TRUNC(SYSDATE)) , 1 , DECODE( SIGN( IM_ITEM_SALE_PRICE.DATESET - TRUNC(SYSDATE) ) , 1 , 'FUTURE' , 'RUNNING' )    , 'EXPIRED') STATUS ,
         im_item_sale_price.rowid
    FROM ~"IM_ITEM_SALE_PRICE~",   
         ~"ICOM_SUPPLIER~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IM_ITEM_SALE_PRICE~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_SALE_PRICE~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_SALE_PRICE~".~"SUPPLIER_CODE~" = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" ) and  
         ( ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" = ~"IM_ITEM_SALE_PRICE~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_SALE_PRICE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_SALE_PRICE~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_SALE_PRICE~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_org_id", number))  sort="organization_id A status D " )
