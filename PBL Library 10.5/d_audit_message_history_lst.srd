 column=(type=datetime update=yes updatewhereclause=yes key=yes name=audit_date dbname="audit_date" )
 column=(type=number update=yes updatewhereclause=yes key=yes name=organization_id dbname="organization_id" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=msg_id dbname="msg_id" )
