 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="last_modify_by" )
 column=(type=char(100) updatewhereclause=yes name=detail dbname="detail" )
 column=(type=char(0) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 retrieve="SELECT A.*  , DECODE( :ARG_LANGUAGE , 'C' , B.DETAIL_LOC , 'E' , DETAIL_ENG , 'K' , DETAIL_KOR ) DETAIL , '' CHECK_YN
FROM 
(
  SELECT ~"ISYS_AUDIT_MESSAGE~".~"AUDIT_MESSAGE_ID~",   
         ~"ISYS_AUDIT_MESSAGE~".~"AUDIT_DATE~",   
         ~"ISYS_AUDIT_MESSAGE~".~"ORGANIZATION_ID~",   
         ~"ISYS_AUDIT_MESSAGE~".~"MSG_ID~",   
         ~"ISYS_AUDIT_MESSAGE~".~"CONFIRM_YN~",   
         ~"ISYS_AUDIT_MESSAGE~".~"CONFIRM_BY~",   
         ~"ISYS_AUDIT_MESSAGE~".~"CONFIRM_DATE~",   
         ~"ISYS_AUDIT_MESSAGE~".~"ENTER_DATE~",   
         ~"ISYS_AUDIT_MESSAGE~".~"ENTER_BY~",   
         ~"ISYS_AUDIT_MESSAGE~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_AUDIT_MESSAGE~".~"LAST_MODIFY_BY~"  
    FROM ~"ISYS_AUDIT_MESSAGE~"  
WHERE ~"ISYS_AUDIT_MESSAGE~".~"AUDIT_DATE~" >= :ARG_DATESET 
    AND ~"ISYS_AUDIT_MESSAGE~".~"AUDIT_DATE~"  <= :ARG_DATEEND
   AND   ~"ISYS_AUDIT_MESSAGE~".~"ORGANIZATION_ID~" = :ARG_ORG 

   UNION  ALL
  SELECT ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"AUDIT_MESSAGE_ID~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"AUDIT_DATE~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"ORGANIZATION_ID~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"MSG_ID~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"CONFIRM_YN~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"CONFIRM_BY~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"CONFIRM_DATE~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"ENTER_DATE~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"ENTER_BY~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"LAST_MODIFY_BY~"  
    FROM ~"ISYS_AUDIT_MESSAGE_HISTORY~"   
 WHERE ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"AUDIT_DATE~" >= :ARG_DATESET 
    AND ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"AUDIT_DATE~"  <= :ARG_DATEEND
   AND   ~"ISYS_AUDIT_MESSAGE_HISTORY~".~"ORGANIZATION_ID~" = :ARG_ORG ) A , ISYS_AUDIT_MESSAGE_CODE B

WHERE  A.MSG_ID = B.MSG_ID
    AND A.ORGANIZATION_ID = B.ORGANIZATION_ID " update="ISYS_AUDIT_MESSAGE" updatewhere=0 updatekeyinplace=yes arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LANGUAGE", string),("ARG_ORG", number))  sort="organization_id A confirm_yn D " )
