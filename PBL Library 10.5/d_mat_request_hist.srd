 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_request.organization_id" dbalias=".organization_id" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" dbalias=".item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias=".item_spec" )
 column=(type=datetime updatewhereclause=yes name=issue_date dbname="im_item_request.issue_date" dbalias=".issue_date" )
 column=(type=char(30) updatewhereclause=yes name=material_mfs dbname="im_item_request.material_mfs" dbalias=".material_mfs" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="im_item_request.model_name" dbalias=".model_name" )
 column=(type=number updatewhereclause=yes name=issue_qty dbname="im_item_request.issue_qty" dbalias=".issue_qty" )
 column=(type=char(30) updatewhereclause=yes name=confirm_by dbname="im_item_request.confirm_by" dbalias=".confirm_by" )
 retrieve="  SELECT ~"IM_ITEM_REQUEST~".~"REQUEST_DATE~",   
         ~"IM_ITEM_REQUEST~".~"LINE_CODE~",   
         ~"IM_ITEM_REQUEST~".~"MACHINE_CODE~",   
         ~"IM_ITEM_REQUEST~".~"ITEM_CODE~",   
         ~"IM_ITEM_REQUEST~".~"ITEM_BARCODE~",   
         ~"IM_ITEM_REQUEST~".~"LOCATION_CODE~",   
         ~"IM_ITEM_REQUEST~".~"REQUEST_STATUS~",   
         ~"IM_ITEM_REQUEST~".~"CONFIRM_DATE~",   
         ~"IM_ITEM_REQUEST~".~"ENTER_BY~",   
         ~"IM_ITEM_REQUEST~".~"ENTER_DATE~",   
         ~"IM_ITEM_REQUEST~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_REQUEST~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_REQUEST~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"IM_ITEM_REQUEST~".~"ISSUE_DATE~",   
         ~"IM_ITEM_REQUEST~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_REQUEST~".~"MODEL_NAME~",   
         ~"IM_ITEM_REQUEST~".~"ISSUE_QTY~",   
         ~"IM_ITEM_REQUEST~".~"CONFIRM_BY~"  
    FROM ~"IM_ITEM_REQUEST~",   
         ~"ID_ITEM~"  
   WHERE ( im_item_request.item_code = id_item.item_code (+)) and  
         ( im_item_request.organization_id = id_item.organization_id (+)) and  
         ( ( ~"IM_ITEM_REQUEST~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( NVL( ~"IM_ITEM_REQUEST~".~"MACHINE_CODE~",'*') like :arg_machine_code ) AND  
         ( ~"IM_ITEM_REQUEST~".~"ITEM_CODE~" like :arg_item ) AND  
        ( ~"IM_ITEM_REQUEST~".~"REQUEST_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_REQUEST~".~"REQUEST_DATE~" < :arg_dateend + 1 ) AND  
         ( ~"IM_ITEM_REQUEST~".~"ORGANIZATION_ID~" = :arg_org ) )    
order by f_get_line_name( IM_ITEM_REQUEST.line_code, IM_ITEM_REQUEST.organization_id ),
              IM_ITEM_REQUEST.REQUEST_DATE 
" arguments=(("arg_line_code", string),("arg_machine_code", string),("arg_item", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number)) )
