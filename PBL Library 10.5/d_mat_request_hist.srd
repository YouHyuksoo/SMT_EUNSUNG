 column=(type=char(1) update=yes updatewhereclause=yes name=request_status dbname="im_item_request.request_status" dbalias=".request_status" )
 column=(type=datetime updatewhereclause=yes name=confirm_date dbname="im_item_request.confirm_date" dbalias=".confirm_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="im_item_request.enter_by" dbalias=".enter_by" )
