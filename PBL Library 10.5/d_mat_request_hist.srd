table(column=(type=datetime updatewhereclause=yes name=request_date dbname="im_item_request.request_date" dbalias=".request_date" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="im_item_request.line_code" dbalias=".line_code" )
 column=(type=char(20) updatewhereclause=yes name=machine_code dbname="im_item_request.machine_code" dbalias=".machine_code" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="im_item_request.item_code" dbalias=".item_code" )
