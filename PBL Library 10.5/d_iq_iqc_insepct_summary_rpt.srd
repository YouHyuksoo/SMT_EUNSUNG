table(column=(type=datetime updatewhereclause=yes name=inspect_date dbname="inspect_date" )
 column=(type=char(20) updatewhereclause=yes name=shift_code dbname="shift_code" )
 column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) updatewhereclause=yes name=iqc_inspect_type dbname="inspect_type" )
 column=(type=char(20) updatewhereclause=yes name=item_class dbname="item_class" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="supplier_code" )
 column=(type=number updatewhereclause=yes name=inspect_qty dbname="inspect_qty" )
 column=(type=number updatewhereclause=yes name=defect_rate dbname="defect_rate" )
 column=(type=number updatewhereclause=yes name=defect_qty dbname="defect_qty" )
 retrieve="  SELECT ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECT_DATE~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"MODEL_NAME~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"SHIFT_CODE~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"SUPPLIER_CODE~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"ITEM_CLASS~",   
         SUM(~"IQ_IQC_INSPECT_HISTORY~".~"DEFECT_QTY~") AS DEFECT_QTY ,   
         MAX(~"IQ_IQC_INSPECT_HISTORY~".~"INSPECT_QTY~") AS INSPECT_QTY ,   
          F_GET_CODE_MASTER('IQC BAD REASON CODE' ,  ~"IQ_IQC_INSPECT_HISTORY~".~"BAD_REASON_CODE~",   :ARG_LANGUAGE , :ARG_ORG ) BAD_REASON_CODE , 
         ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECTOR~",  
         ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECT_TYPE~",  
          SUM(defect_qty ) / MAX( inspect_qty ) as defect_rate  
    FROM ~"IQ_IQC_INSPECT_HISTORY~"  
   WHERE ( ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECT_DATE~" >= :arg_dateset ) AND  
         ( ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECT_DATE~" < :arg_dateend +1) AND  
         ( ~"IQ_IQC_INSPECT_HISTORY~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( ~"IQ_IQC_INSPECT_HISTORY~".~"ITEM_CLASS~" like :arg_item_class ) AND  
         ( ~"IQ_IQC_INSPECT_HISTORY~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IQ_IQC_INSPECT_HISTORY~".~"SHIFT_CODE~" like :arg_shift_code ) AND  
         ( ~"IQ_IQC_INSPECT_HISTORY~".~"ORGANIZATION_ID~" = :arg_org )    

GROUP BY  ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECT_DATE~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"MODEL_NAME~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"SHIFT_CODE~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"SUPPLIER_CODE~",   
         ~"IQ_IQC_INSPECT_HISTORY~".~"ITEM_CLASS~",   
          F_GET_CODE_MASTER('IQC BAD REASON CODE' ,  ~"IQ_IQC_INSPECT_HISTORY~".~"BAD_REASON_CODE~",   :ARG_LANGUAGE , :ARG_ORG ) , 
         ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECTOR~",
         ~"IQ_IQC_INSPECT_HISTORY~".~"INSPECT_TYPE~"
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_model_name", string),("arg_item_class", string),("arg_supplier_code", string),("arg_shift_code", string),("arg_language", string),("arg_org", number))  sort="inspect_date A shift_code A model_name A item_class A supplier_code A inspect_qty A defect_rate A " )
