 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" dbalias=".item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias=".item_spec" )
 column=(type=char(10) updatewhereclause=yes name=msl_level dbname="id_item.msl_level" dbalias=".msl_level" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" dbalias=".location_address" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="im_item_receipt_barcode.supplier_code" dbalias=".supplier_code" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_receipt_barcode.organization_id" dbalias=".organization_id" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="im_item_receipt_barcode.enter_date" dbalias=".enter_date" )
 column=(type=char(1) updatewhereclause=yes name=lot_divide_yn dbname="im_item_receipt_barcode.lot_divide_yn" dbalias=".lot_divide_yn" )
 retrieve="  SELECT F_BACODE_CODE128( 'B' , IM_ITEM_RECEIPT_BARCODE.ITEM_BARCODE) ITEM_BARCODE_BARCODE,   
         IM_ITEM_RECEIPT_BARCODE.LOT_NO,   
         F_BACODE_CODE128( 'B' , IM_ITEM_RECEIPT_BARCODE.LOT_NO) LOT_NO_BARCODE,   
         IM_ITEM_RECEIPT_BARCODE.ITEM_BARCODE,   
         IM_ITEM_RECEIPT_BARCODE.SCAN_QTY,   
         '*'||IM_ITEM_RECEIPT_BARCODE.SCAN_QTY||'*' SCAN_QTY_BARCODE,   
         ID_ITEM.ITEM_NAME,   
         ID_ITEM.ITEM_SPEC,   
         ID_ITEM.MSL_LEVEL,   
         ID_ITEM.LOCATION_ADDRESS,   
         IM_ITEM_RECEIPT_BARCODE.SUPPLIER_CODE,   
         IM_ITEM_RECEIPT_BARCODE.ORGANIZATION_ID,   
         IM_ITEM_RECEIPT_BARCODE.ENTER_DATE,   
         IM_ITEM_RECEIPT_BARCODE.LOT_DIVIDE_YN  
    FROM IM_ITEM_RECEIPT_BARCODE,   
         ID_ITEM  
   WHERE ( im_item_receipt_barcode.item_code = id_item.item_code (+)) and  
         ( im_item_receipt_barcode.organization_id = id_item.organization_id (+)) and  
         ( IM_ITEM_RECEIPT_BARCODE.ITEM_CODE = :arg_item_code )   and 
         ( IM_ITEM_RECEIPT_BARCODE.RECEIPT_SLIP_NO  = :arg_slip_no)   and 
         ( IM_ITEM_RECEIPT_BARCODE.LOT_NO like :arg_lot_no )   and 
         ( IM_ITEM_RECEIPT_BARCODE.ORGANIZATION_ID = :arg_org )  
" arguments=(("arg_item_code", string),("arg_slip_no", string),("arg_lot_no", string),("arg_org", number)) )
