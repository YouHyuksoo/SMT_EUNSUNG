 column=(type=char(1) updatewhereclause=yes name=array_no dbname="iq_machine_inspect_data_spi.array_no" )
 column=(type=char(50) updatewhereclause=yes name=run_no dbname="iq_machine_inspect_data_spi.run_no" )
 column=(type=char(10) updatewhereclause=yes name=line_code dbname="iq_machine_inspect_data_spi.line_code" )
 column=(type=char(4000) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(4000) updatewhereclause=yes name=customer_model_name dbname="customer_model_name" )
 column=(type=char(18) updatewhereclause=yes name=row_pos dbname="row_pos" )
 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"CSTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"SEQ_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"PID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"MACHINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"DEFECT_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"ORGANIZATION_ID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"ARRAY_NO~"  ,
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"RUN_NO~",
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"LINE_CODE~",
         F_GET_RUN_MODEL_NAME(RUN_NO) MODEL_NAME,
		f_get_customer_model_by_run_no(RUN_NO) CUSTOMER_MODEL_NAME,
         ROWIDTOCHAR(rowid)   row_pos
    FROM ~"IQ_MACHINE_INSPECT_DATA_SPI~"  
  WHERE   ( ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~"  >= TO_CHAR(trunc(:ARG_DATESET),'YYYY/MM/DD HH24:MI:SS' ) ) 
       AND  ( ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~"  <   TO_CHAR(trunc(:ARG_DATEEND)+1 ,'YYYY/MM/DD HH24:MI:SS' ))
       AND  (~"IQ_MACHINE_INSPECT_DATA_SPI~".~"PID~" like :ARG_PID  )   
	  AND  (NVL(~"IQ_MACHINE_INSPECT_DATA_SPI~".~"LINE_CODE~",'*') LIKE :ARG_LINE_CODE ) 
      AND  F_GET_RUN_MODEL_NAME( RUN_NO) LIKE :ARG_MODEL_NAME 
      AND   RUN_NO  LIKE :ARG_RUN_NO 
" arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_PID", string),("ARG_MODEL_NAME", string),("ARG_RUN_NO", string))  sort="run_no A inspect_date A pid A " )
