 column=(type=char(100) updatewhereclause=yes name=line_name dbname="ib_line_master.line_name" )
 column=(type=char(100) updatewhereclause=yes name=machine_name dbname="ib_line_master.machine_name" )
 column=(type=char(10) updatewhereclause=yes name=table_id dbname="ib_product_plandata.table_id" )
 column=(type=char(10) updatewhereclause=yes name=feeder_type dbname="id_item.feeder_type" )
 column=(type=char(20) updatewhereclause=yes name=line_division dbname="ib_line_master.line_division" )
 column=(type=char(32) updatewhereclause=yes name=parent_item_barcode dbname="parent_item_barcode" )
 column=(type=char(30) updatewhereclause=yes name=pcb_item dbname="ib_product_plandata.pcb_item" )
 column=(type=char(4000) updatewhereclause=yes name=pcb_item_code dbname="pcb_item_code" )
 column=(type=char(10) updatewhereclause=yes name=revision dbname="ib_product_plandata.revision" )
 column=(type=char(1000) updatewhereclause=yes name=location_info dbname="location_info" )
 retrieve="  SELECT REPLACE_YN DIV ,
		~"IB_PRODUCT_PLANDATA~".~"MODEL_NAME~",   
         ~"IB_PRODUCT_PLANDATA~".~"ITEM_CODE~",   
         ~"IB_PRODUCT_PLANDATA~".~"ITEM_UNIT_QTY~",   
         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   
         ~"ID_ITEM_A~".~"ITEM_UOM~",   
         ~"ID_ITEM_B~".~"ITEM_NAME~" AS PARENT_ITEM_NAME,   
         ~"ID_ITEM_B~".~"ITEM_SPEC~",   
		 ~"ID_ITEM_A~".~"LOCATION_ADDRESS~",
         ~"IB_PRODUCT_PLANDATA~".~"ORGANIZATION_ID~",   
         ~"IB_PRODUCT_PLANDATA~".~"LOCATION_CODE~",   
         ~"IB_PRODUCT_PLANDATA~".~"LINE_CODE~", 
         '*'||~"IB_PRODUCT_PLANDATA~".~"LINE_CODE~"||'-'||~"IB_PRODUCT_PLANDATA~".~"MACHINE~"||'*' LINE_CODE_BARCODE,  
         ~"IB_PRODUCT_PLANDATA~".~"MACHINE~",   
         ~"IB_LINE_MASTER~".~"LINE_NAME~",   
         ~"IB_LINE_MASTER~".~"MACHINE_NAME~",   
         ~"IB_PRODUCT_PLANDATA~".~"TABLE_ID~",   
         ID_ITEM_A.FEEDER_SIZE  FEEDER_TYPE ,
         IB_LINE_MASTER.line_division  line_division ,
         '*'||IB_PRODUCT_PLANDATA.MODEL_NAME||'*' PARENT_ITEM_BARCODE,   
		~"IB_PRODUCT_PLANDATA~".~"PCB_ITEM~" ,
		F_GET_PCB_ITEM_BY_NAME ( :ARG_PARENT_ITEM ) PCB_ITEM_CODE ,
		REVISION ,
		REPLACE( IB_PRODUCT_PLANDATA.LOCATION_INFO,',',' ') LOCATION_INFO  
    FROM ~"IB_PRODUCT_PLANDATA~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~",   
         ~"ID_ITEM~" ~"ID_ITEM_B~",   
         ~"IB_LINE_MASTER~",   
         ~"IB_MACHINE_LOCATION~"  
   WHERE ( IB_PRODUCT_PLANDATA.ITEM_CODE = ID_ITEM_A.ITEM_CODE (+)) AND  
         ( IB_PRODUCT_PLANDATA.ORGANIZATION_ID = ID_ITEM_A.ORGANIZATION_ID (+)) AND  
         ( IB_PRODUCT_PLANDATA.MODEL_NAME = ID_ITEM_B.ITEM_CODE (+)) AND  
         ( IB_PRODUCT_PLANDATA.ORGANIZATION_ID = ID_ITEM_B.ORGANIZATION_ID (+)) AND  
         ( IB_PRODUCT_PLANDATA.LINE_CODE = IB_LINE_MASTER.LINE_CODE (+)) AND  
         ( IB_PRODUCT_PLANDATA.ORGANIZATION_ID = IB_LINE_MASTER.ORGANIZATION_ID (+)) AND  
         ( IB_PRODUCT_PLANDATA.MACHINE = IB_LINE_MASTER.MACHINE (+)) AND  

         ( IB_PRODUCT_PLANDATA.LINE_CODE = IB_MACHINE_LOCATION.LINE_CODE(+)) AND  
         ( IB_PRODUCT_PLANDATA.MACHINE = IB_MACHINE_LOCATION.MACHINE(+)) AND   

         ( IB_PRODUCT_PLANDATA.ORGANIZATION_ID = IB_MACHINE_LOCATION.ORGANIZATION_ID(+)) AND  
         ( IB_PRODUCT_PLANDATA.LOCATION_CODE = IB_MACHINE_LOCATION.LOCATION_CODE(+)) AND  

         ( ~"IB_PRODUCT_PLANDATA~".~"MODEL_NAME~" = :ARG_PARENT_ITEM ) AND  
         ( ~"IB_PRODUCT_PLANDATA~".~"LINE_CODE~" LIKE :ARG_LINE_CODE ) AND  
	     ( NVL(~"IB_PRODUCT_PLANDATA~".~"PCB_ITEM~" ,'*')  LIKE :ARG_TOPBOT )    AND
         ( ~"IB_PRODUCT_PLANDATA~".~"ORGANIZATION_ID~" = :ARG_ORG )    

" arguments=(("ARG_PARENT_ITEM", string),("ARG_LINE_CODE", string),("ARG_TOPBOT", string),("ARG_ORG", number))  sort="line_code A model_name A table_id A div A location_code A " )
