detail(height=204 color="536870912~tif (  mod( getrow() ,2 ) = 0 , RGB(192,192,192 ), rgb(255,255,255) )" height.autosize=yes )
table(column=(type=char(1) updatewhereclause=yes name=div dbname="ib_product_plandata.div" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="ib_product_plandata.model_name" )
 column=(type=char(100) updatewhereclause=yes name=item_code dbname="ib_product_plandata.item_code" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="ib_product_plandata.item_unit_qty" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
