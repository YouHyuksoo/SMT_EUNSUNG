 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_purchase_order~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"im_item_purchase_order.order_no~") COLUMN(NAME=~"im_item_purchase_order.organization_id~") COLUMN(NAME=~"im_item_purchase_order.purchase_order_date~") COLUMN(NAME=~"im_item_purchase_order.delivery_date~") COLUMN(NAME=~"im_item_purchase_order.delivery~") COLUMN(NAME=~"im_item_purchase_order.line_type~") COLUMN(NAME=~"im_item_purchase_order.order_type~") COLUMN(NAME=~"im_item_purchase_order.order_qty~") COLUMN(NAME=~"im_item_purchase_order.unit_price~") COLUMN(NAME=~"im_item_purchase_order.currency~") COLUMN(NAME=~"im_item_purchase_order.arrival_qty~") COLUMN(NAME=~"im_item_purchase_order.mfs~") COLUMN(NAME=~"im_item_purchase_order.enter_date~") COLUMN(NAME=~"im_item_purchase_order.enter_by~") COLUMN(NAME=~"im_item_purchase_order.item_code~") COLUMN(NAME=~"im_item_purchase_order.last_modify_date~") COLUMN(NAME=~"im_item_purchase_order.last_modify_by~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"im_item_purchase_order.supplier_code~") COLUMN(NAME=~"im_item_purchase_order.order_group_no~") COLUMN(NAME=~"im_item_purchase_order.incidental_expense_code~") COLUMN(NAME=~"im_item_purchase_order.origin_nation_code~") COLUMN(NAME=~"im_item_purchase_order.delivery_method~") COLUMN(NAME=~"im_item_purchase_order.delivery_place~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"id_item.item_division~") COLUMN(NAME=~"icom_supplier.fax_no~") COLUMN(NAME=~"icom_supplier.email_address~") COMPUTE(NAME=~"'N' CHECK_YN~")    JOIN (LEFT=~"im_item_purchase_order.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_purchase_order.organization_id~" )    JOIN (LEFT=~"im_item_purchase_order.supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier.supplier_code~" )    JOIN (LEFT=~"icom_supplier.organization_id~"    OP =~"=~"RIGHT=~"im_item_purchase_order.organization_id~" )WHERE(    EXP1 =~"~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"ORDER_GROUP_NO~~~"~"   OP =~"=~"    EXP2 =~":arg_order_group_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"(~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id )~" ) ) ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_order_group_no~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_supplier_code", string),("arg_order_group_no", string),("arg_org_id", number))  sort="order_group_no A purchase_order_date A supplier_code A item_code A " )
