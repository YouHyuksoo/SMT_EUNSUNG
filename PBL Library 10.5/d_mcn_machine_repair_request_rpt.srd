 retrieve="  SELECT ~"IMCN_MACHINE~".~"MACHINE_CODE~",   
         ~"IMCN_MACHINE~".~"ORGANIZATION_ID~",   
         ~"IMCN_MACHINE~".~"MACHINE_TYPE~",   
         ~"IMCN_MACHINE~".~"MACHINE_NAME~",   
         ~"IMCN_MACHINE~".~"MACHINE_SPEC~",   
         ~"IMCN_MACHINE~".~"SUPPLIER_CODE~",   
         ~"IMCN_MACHINE~".~"MACHINE_MODEL_NAME~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_REASON_CODE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_SEQUENCE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_STATUS~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_BY~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_DATE~",   
         ~"IMCN_MACHINE_REPAIR~".~"COMMENTS~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_TIME~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_REQUEST_DATE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_VENDOR_CODE~",   
        IMCN_MACHINE_REPAIR.REPAIR_COMMENTS  
    FROM ~"IMCN_MACHINE~",   
         ~"IMCN_MACHINE_REPAIR~"  
   WHERE ( ( ~"IMCN_MACHINE~".~"MACHINE_CODE~" = :arg_machine_code ) AND  
         ( ~"IMCN_MACHINE_REPAIR~".~"REPAIR_REQUEST_DATE~" = :arg_request_date ) AND  
         ( ~"IMCN_MACHINE_REPAIR~".~"REPAIR_SEQUENCE~" = :arg_request_sequence ) AND  
         ( ~"IMCN_MACHINE~".~"ORGANIZATION_ID~" = :arg_org ) )    
" arguments=(("arg_machine_code", string),("arg_request_date", datetime),("arg_request_sequence", number),("arg_org", number))  sort="organization_id A machine_code A " )
