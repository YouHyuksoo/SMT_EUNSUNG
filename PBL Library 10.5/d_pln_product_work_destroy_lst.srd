   OP =~"like~"    EXP2 =~":ARG_SERIAL_NO )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IP_PRODUCT_WORK_QC~~~".~~~"RECEIPT_DEFICIT~~~"~"   OP =~"=~"    EXP2 =~"'1' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IP_PRODUCT_WORK_QC~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG )~" ) ) ARG(NAME = ~"ARG_SERIAL_NO~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " update="IP_PRODUCT_WORK_QC" updatewhere=1 updatekeyinplace=no arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number)) )
