 retrieve="select  *
from im_item_work_order
where ( parent_item_code , item_code , organization_id  ) 
in ( select parent_item_code  , item_code , organization_id 
from id_eng_bom_temp
where session_id = :lvdb_session_id
and organization_id = :arg_org )
and issue_qty <> 0
and mfs = :arg_mfs
and origin_mfs = :arg_origin_mfs
and plan_date = :arg_plan_date
and plan_date_sequence = :arg_plan_sequence" update="im_item_work_order" updatewhere=1 updatekeyinplace=no arguments=(("lvdb_session_id", number),("arg_mfs", string),("arg_origin_mfs", string),("arg_plan_date", datetime),("arg_plan_sequence", number),("arg_org", number)) )
