 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" dbalias=".item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_address_rack dbname="im_item_inventory.location_address_rack" dbalias=".location_address_rack" )
 column=(type=char(4000) updatewhereclause=yes name=supplier_code dbname="supplier_code" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=datetime updatewhereclause=yes name=last_receipt_date dbname="last_receipt_date" )
 retrieve="SELECT  MAX(~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~" )  MATERIAL_MFS,      
			~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ,     
			~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~" ,   
			~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ,   
	     	~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~" ,  
			~"ID_ITEM~".~"ITEM_SPEC~" ,    
              ~"ID_ITEM~".~"ITEM_NAME~" ,      
			 IM_ITEM_INVENTORY.LOCATION_ADDRESS_RACK LOCATION_ADDRESS_RACK ,
			 f_get_supplier_name(IM_ITEM_INVENTORY.SUPPLIER_CODE, IM_ITEM_INVENTORY.ORGANIZATION_ID)  SUPPLIER_CODE,
			 SUM(INVENTORY_QTY) INVENTORY_QTY,
              MIN(LAST_RECEIPT_DATE) LAST_RECEIPT_DATE
FROM ~"IM_ITEM_INVENTORY~" ,           ~"ID_ITEM~"   
WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and      
( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) and   
( ~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~" like :arg_material_mfs ) and   
( nvl(~"IM_ITEM_INVENTORY~".~"SUPPLIER_CODE~",'*') like :arg_supplier_code ) and    
( NVL(~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~" , '*') like :arg_location_code ) and    
( DECODE( :ARG_SIGN , 0 , 0 , SIGN(TRUNC(~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~",5)))  = :arg_sign ) and   
( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) and
 NVL( IM_ITEM_INVENTORY.LOCATION_ADDRESS_RACK , '*') like :arg_location_rack and
 ID_ITEM.MSL_LEVEL||'*' >=  :arg_msl_level||'*'
GROUP BY     
			~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ,     
			~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~" ,   
			~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ,   
	     	~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~" ,  
			~"ID_ITEM~".~"ITEM_SPEC~" ,         
              ~"ID_ITEM~".~"ITEM_NAME~" , 
			 IM_ITEM_INVENTORY.LOCATION_ADDRESS_RACK ,
			 IM_ITEM_INVENTORY.SUPPLIER_CODE  " arguments=(("arg_item_code", string),("arg_material_mfs", string),("arg_supplier_code", string),("arg_location_code", string),("arg_sign", number),("arg_org_id", number),("arg_location_rack", string),("arg_msl_level", string))  sort="last_receipt_date A organization_id A location_address_rack A item_code A material_mfs A " )
