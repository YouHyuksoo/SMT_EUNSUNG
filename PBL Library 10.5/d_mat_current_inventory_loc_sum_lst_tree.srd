 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="im_item_inventory.item_code" dbalias=".item_code" )
 column=(type=char(1) update=yes updatewhereclause=yes name=inventory_status dbname="im_item_inventory.inventory_status" dbalias=".inventory_status" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="im_item_inventory.organization_id" dbalias=".organization_id" )
