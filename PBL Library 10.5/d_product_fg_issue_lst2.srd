footer(height=0 color="536870912" )
detail(height=96 color="536870912" )
table(column=(type=datetime updatewhereclause=yes key=yes name=issue_date dbname="ip_product_fg_issue.issue_date" )
 column=(type=number updatewhereclause=yes key=yes name=issue_sequence dbname="ip_product_fg_issue.issue_sequence" )
 column=(type=char(30) updatewhereclause=yes name=barcode dbname="ip_product_fg_issue.barcode" )
 column=(type=char(2) updatewhereclause=yes name=pack_type dbname="ip_product_fg_issue.pack_type" )
 column=(type=char(1) updatewhereclause=yes name=txn_deficit dbname="ip_product_fg_issue.txn_deficit" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 column=(type=char(100) updatewhereclause=yes name=model_name dbname="ip_product_fg_issue.model_name" )
 column=(type=char(30) updatewhereclause=yes name=model_suffix dbname="ip_product_fg_issue.model_suffix" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="ip_product_fg_issue.item_code" )
 column=(type=datetime updatewhereclause=yes name=actual_date dbname="ip_product_fg_issue.actual_date" )
 column=(type=char(1) updatewhereclause=yes name=shift_code dbname="ip_product_fg_issue.shift_code" )
 column=(type=char(2) updatewhereclause=yes name=work_time_zone dbname="ip_product_fg_issue.work_time_zone" )
 column=(type=char(20) updatewhereclause=yes name=customer_code dbname="ip_product_fg_issue.customer_code" )
 column=(type=char(10) updatewhereclause=yes name=product_location_code dbname="ip_product_fg_issue.location_code" )
 column=(type=char(30) updatewhereclause=yes name=pallet_no dbname="ip_product_fg_issue.pallet_no" )
 column=(type=char(30) updatewhereclause=yes name=ship_no dbname="ip_product_fg_issue.ship_no" )
 column=(type=datetime updatewhereclause=yes name=pallet_date dbname="ip_product_fg_issue.pallet_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_fg_issue.enter_by" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="ip_product_fg_issue.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="ip_product_fg_issue.last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="ip_product_fg_issue.last_modify_date" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_fg_issue.organization_id" )
 column=(type=number updatewhereclause=yes name=issue_price dbname="issue_price" )
 retrieve="select  issue_date, 
        issue_sequence, 
        barcode, 
        pack_type, 
        txn_deficit, 
 
        qty * decode(txn_deficit,3,1,-1) as qty, 
        model_name, 
        model_suffix, 
        item_code, 

        actual_date, 
        shift_code, 
        work_time_zone, 
        customer_code, 
        
        location_code, 
        pallet_no, 
        ship_no, 
        pallet_date, 
        enter_by, 
        enter_date, 
        last_modify_by, 
        last_modify_date, 
        organization_id, 
          f_get_sal_last_price_cfm(customer_code,item_code, 'T',issue_date,organization_id) as issue_price


  from ip_product_fg_issue 
where issue_date >= :arg_sDate
   and issue_date < :arg_eDate + 1 
   and model_name like :arg_model 
   and barcode like :arg_barcode 
   and txn_deficit like :arg_deficit " update="ip_product_fg_issue" updatewhere=0 updatekeyinplace=no arguments=(("arg_sDate", datetime),("arg_eDate", datetime),("arg_Model", string),("arg_barcode", string),("arg_deficit", string))  sort="model_name A issue_date A issue_sequence A " )
