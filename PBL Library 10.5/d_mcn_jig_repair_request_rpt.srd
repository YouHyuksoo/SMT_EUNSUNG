 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_jig~" )  TABLE(NAME=~"imcn_jig_repair~" ) COLUMN(NAME=~"imcn_jig.jig_code~") COLUMN(NAME=~"imcn_jig.organization_id~") COLUMN(NAME=~"imcn_jig.jig_type~") COLUMN(NAME=~"imcn_jig.jig_name~") COLUMN(NAME=~"imcn_jig.supplier_code~") COLUMN(NAME=~"imcn_jig_repair.repair_reason_code~") COLUMN(NAME=~"imcn_jig_repair.repair_sequence~") COLUMN(NAME=~"imcn_jig_repair.repair_status~") COLUMN(NAME=~"imcn_jig_repair.repair_by~") COLUMN(NAME=~"imcn_jig_repair.repair_date~") COLUMN(NAME=~"imcn_jig_repair.comments~") COLUMN(NAME=~"imcn_jig_repair.repair_time~") COLUMN(NAME=~"imcn_jig_repair.repair_request_date~") COLUMN(NAME=~"imcn_jig_repair.repair_vendor_code~") COLUMN(NAME=~"imcn_jig.jig_status~") COLUMN(NAME=~"imcn_jig.jig_model_name~") COLUMN(NAME=~"imcn_jig_repair.repair_comments~") COLUMN(NAME=~"imcn_jig_repair.repair_amt~")    JOIN (LEFT=~"imcn_jig.jig_code~"    OP =~"=~"RIGHT=~"imcn_jig_repair.jig_code~"    OUTER1 =~"imcn_jig.jig_code~" )    JOIN (LEFT=~"imcn_jig.organization_id~"    OP =~"=~"RIGHT=~"imcn_jig_repair.organization_id~"    OUTER1 =~"imcn_jig.organization_id~" )WHERE(    EXP1 =~"( ~~~"IMCN_JIG~~~".~~~"JIG_CODE~~~"~"   OP =~"=~"    EXP2 =~":arg_jig_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG_REPAIR~~~".~~~"REPAIR_REQUEST_DATE~~~"~"   OP =~"=~"    EXP2 =~":arg_request_date )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG_REPAIR~~~".~~~"REPAIR_SEQUENCE~~~"~"   OP =~"=~"    EXP2 =~":arg_request_sequence )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org )~" ) ) ARG(NAME = ~"arg_jig_code~" TYPE = string)  ARG(NAME = ~"arg_request_date~" TYPE = datetime)  ARG(NAME = ~"arg_request_sequence~" TYPE = number)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_jig_code", string),("arg_request_date", datetime),("arg_request_sequence", number),("arg_org", number))  sort="organization_id A jig_code A " )
