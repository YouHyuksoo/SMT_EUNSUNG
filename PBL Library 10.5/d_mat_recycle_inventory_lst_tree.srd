table(column=(type=char(8) updatewhereclause=yes name=warehouse_type dbname="warehouse_type" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="im_item_recycle_inventory.item_code" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_recycle_inventory.organization_id" )
 column=(type=char(10) updatewhereclause=yes name=line_type dbname="im_item_recycle_inventory.line_type" )
