 column=(type=number updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=number updatewhereclause=yes name=departure_qty dbname="departure_qty" )
 column=(type=number updatewhereclause=yes name=arrival_qty dbname="arrival_qty" )
 column=(type=number updatewhereclause=yes name=free_inventory_qty dbname="free_inventory_qty" )
 column=(type=number updatewhereclause=yes name=sale_inventory_qty dbname="sale_inventory_qty" )
 column=(type=char(20) update=yes updatewhereclause=yes name=location_code dbname="im_item_recycle_inventory.location_code" )
 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(1) updatewhereclause=yes name=item_division dbname="item_division" )
 column=(type=number updatewhereclause=yes name=safety_inventory dbname="safety_inventory" )
 retrieve="  SELECT 'INTERNAL' WAREHOUSE_TYPE ,
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_HOLD~",   
         DECODE ( SUM(~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_QTY~") , 0 , 0 , SUM(~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_AMT~") /  SUM(~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_QTY~") ) INVENTORY_PRICE,   
         SUM(~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_QTY~") INVENTORY_QTY,   
         SUM(~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_AMT~") INVENTORY_AMT,   
         F_GET_MAT_ORDER_QTY( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" ) ORDER_QTY , 
         F_GET_MAT_DEPARTURE_QTY( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" ) DEPARTURE_QTY , 
         F_GET_MAT_ARRIVAL_QTY( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" ) ARRIVAL_QTY , 
         F_GET_MAT_FREE_QTY( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" ) FREE_INVENTORY_QTY , 
         F_GET_MAT_SALE_QTY( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" ) SALE_INVENTORY_QTY , 
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LOCATION_CODE~",   
         MAX(~"ID_ITEM~".~"ITEM_SPEC~") ITEM_SPEC,   
         MAX(~"ID_ITEM~".~"ITEM_NAME~") ITEM_NAME,
         MAX(~"ID_ITEM~".~"ITEM_DIVISION~") ITEM_DIVISION ,
         MAX(~"ID_ITEM~".~"SAFETY_INVENTORY~") SAFETY_INVENTORY		
    FROM ~"IM_ITEM_RECYCLE_INVENTORY~",   ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
         (  SIGN(~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_QTY~") >= :arg_sign )     AND
         ( nvl(~"IM_ITEM_RECYCLE_INVENTORY~".~"LOCATION_CODE~",'*') like :arg_location_code )     AND
         ( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
GROUP BY
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~",  
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_HOLD~" ,
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LOCATION_CODE~"
" arguments=(("arg_item_code", string),("arg_sign", number),("arg_location_code", string),("arg_org_id", number))  sort="organization_id A location_code A item_division A line_type A warehouse_type A item_code A " )
