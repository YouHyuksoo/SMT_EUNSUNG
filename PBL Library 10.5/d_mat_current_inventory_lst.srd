table(column=(type=char(9) updatewhereclause=yes name=warehouse_type dbname="warehouse_type" )
 column=(type=char(9) updatewhereclause=yes name=supplier_name dbname="supplier_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="item_code" )
