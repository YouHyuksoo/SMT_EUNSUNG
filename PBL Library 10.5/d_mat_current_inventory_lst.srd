 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="enter_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=enter_by dbname="enter_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="last_modify_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="last_modify_by" )
 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="item_name" )
 retrieve="SELECT * FROM 
(
  SELECT 'INTERNAL' WAREHOUSE_TYPE ,
          'WAREHOUSE' SUPPLIER_NAME ,
         ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_HOLD~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_AMT~",   
         ~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"COMMENTS~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_BY~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~"
    FROM ~"IM_ITEM_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    

UNION ALL 

  SELECT 'WORKSTAGE' WAREHOUSE_TYPE ,
         'WORKSTAGE' SUPPLIER_NAME ,
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_HOLD~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_AMT~",   
         '*' LOCATION_CODE,   
         '',   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ENTER_DATE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ENTER_BY~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~"
    FROM ~"IM_ITEM_WORKSTAGE_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
)
WHERE  WAREHOUSE_TYPE LIKE :ARG_WAREHOUSE_TYPE" arguments=(("arg_item_code", string),("ARG_WAREHOUSE_TYPE", string),("arg_org_id", number))  sort="organization_id A warehouse_type A supplier_name A item_code A " )
