 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_unit_price~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"im_item_unit_price.supplier_code~") COLUMN(NAME=~"im_item_unit_price.item_code~") COLUMN(NAME=~"im_item_unit_price.delivery~") COLUMN(NAME=~"im_item_unit_price.dateset~") COLUMN(NAME=~"im_item_unit_price.currency~") COLUMN(NAME=~"im_item_unit_price.organization_id~") COLUMN(NAME=~"im_item_unit_price.dateend~") COLUMN(NAME=~"im_item_unit_price.unit_price~") COLUMN(NAME=~"im_item_unit_price.price_type~") COLUMN(NAME=~"im_item_unit_price.approval_no~") COLUMN(NAME=~"im_item_unit_price.standard_unit_price~") COLUMN(NAME=~"im_item_unit_price.line_type~") COLUMN(NAME=~"im_item_unit_price.price_change_reason~") COLUMN(NAME=~"im_item_unit_price.price_change_confirm_yn~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.drawing_no~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"id_item.item_division~")    JOIN (LEFT=~"im_item_unit_price.supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier.supplier_code~"    OUTER1 =~"im_item_unit_price.supplier_code~" )    JOIN (LEFT=~"im_item_unit_price.organization_id~"    OP =~"=~"RIGHT=~"icom_supplier.organization_id~"    OUTER1 =~"im_item_unit_price.organization_id~" )    JOIN (LEFT=~"im_item_unit_price.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"im_item_unit_price.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~" )WHERE(    EXP1 =~"~~~"IM_ITEM_UNIT_PRICE~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":ARG_ITEM_CODE~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_UNIT_PRICE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG ) ~" ) ) ARG(NAME = ~"ARG_ITEM_CODE~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " arguments=(("ARG_ITEM_CODE", string),("ARG_ORG", number))  sort="organization_id A supplier_code A item_code A dateset A " )
