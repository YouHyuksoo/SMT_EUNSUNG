detail(height=1375 color="536870912" )
table(column=(type=char(100) updatewhereclause=yes name=location_code dbname="ib_machine_location.location_code" dbalias=".location_code" )
 column=(type=char(102) updatewhereclause=yes name=location_barcoe dbname="location_barcoe" )
 retrieve="  SELECT ~"IB_MACHINE_LOCATION~".~"LOCATION_CODE~",   
              '*'|| ~"IB_MACHINE_LOCATION~".~"LOCATION_CODE~"||'*'LOCATION_BARCOE  
    FROM ~"IB_MACHINE_LOCATION~"  
   WHERE ( ~"IB_MACHINE_LOCATION~".~"LINE_CODE~" like :arg_line_code ) AND  
			( ~"IB_MACHINE_LOCATION~".~"MACHINE~" like :arg_machine ) AND
			( ~"IB_MACHINE_LOCATION~".~"TABLE_ID~" like :arg_table_id ) AND
			( ~"IB_MACHINE_LOCATION~".~"LOCATION_CODE~"  like '%'||:arg_lr) AND
			( SUBSTR(~"IB_MACHINE_LOCATION~".~"LOCATION_CODE~" , 2 , 3 )  >= :arg_start) AND
			( SUBSTR(~"IB_MACHINE_LOCATION~".~"LOCATION_CODE~" , 2 , 3 )  <= :arg_end) AND
			( ~"IB_MACHINE_LOCATION~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_line_code", string),("arg_machine", string),("arg_table_id", string),("arg_lr", string),("arg_start", string),("arg_end", string),("arg_org", number))  sort="location_code A " )
column(band=detail id=2 alignment="2" tabsequence=32766 border="0" color="33554432" x="105" y="26" height="687" width="3730" format="[general]" html.valueishtml="0"  name=location_barcoe visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no  font.face="Free 3 of 9" font.height="-20" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="1073741824" )
