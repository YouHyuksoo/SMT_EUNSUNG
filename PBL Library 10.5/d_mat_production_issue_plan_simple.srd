 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="ip_product_issue_plan.last_modify_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="ip_product_issue_plan.last_modify_date" )
 retrieve="select plan_date, 
         line_code,        
        model_name, 
        mfs,
        item_code, 
        item_type, 
        line_type, 
        order_qty,

        plan_yyyymm, 
   
        plan_priority, 
        plan_time,
        plan_date_sequence, 
         
        product_actual_qty, 
        organization_id, 
        enter_by, 
        enter_date, 
        last_modify_by, 
        last_modify_date
  from IP_PRODUCT_ISSUE_PLAN
where plan_date = to_date(:arg_date,'yyyymmdd')
  and organization_id = :arg_org " update="IP_PRODUCT_ISSUE_PLAN" updatewhere=1 updatekeyinplace=no arguments=(("arg_date", string),("arg_org", number)) )
