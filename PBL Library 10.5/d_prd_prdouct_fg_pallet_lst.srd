 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="ip_product_fg_pallet.last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="ip_product_fg_pallet.last_modify_date" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_fg_pallet.organization_id" )
 retrieve=" select 
        '' chk,
        pallet_no, 
        pallet_type,
        pallet_status,
        pallet_date, 
        model_name, 
        model_suffix, 
        pallet_qty, 
        ship_flag, 
        ship_date, 
        ship_to, 

        actual_date, 
        work_time_zone, 
        shift_code, 

        attr01, 
        attr02, 
        attr03, 
        attr04, 
        enter_by, 
        enter_date, 
        last_modify_by, 
        last_modify_date, 
        organization_id
  from ip_product_fg_pallet 
where pallet_no like :arg_pallet 
   and model_name like :arg_model 
   and pallet_date   >= :arg_sDate
   and pallet_date   < :arg_eDate + 1 " arguments=(("arg_pallet", string),("arg_model", string),("arg_sDate", datetime),("arg_eDate", datetime)) )
