 column=(type=char(300) updatewhereclause=yes name=ng_reviewresult dbname="iq_machine_inspect_aoi.ng_reviewresult" dbalias=".ng_reviewresult" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="iq_machine_inspect_aoi.enter_date" dbalias=".enter_date" )
 retrieve="SELECT LINE_CODE, 
       MACHINE_CODE, 
       C1 as DATA_TYPE, 
       C2 as PRODUCT_ID, 
       
       DECODE( c1,'[Header]', to_date(C3,'yyyymmddhh24miss') , '') as INSPECT_DATE ,
      
       

       DECODE( c1,'[Header]', C4 , '') as PCBModel ,
       
       
       DECODE( c1,'[Header]', C5 , '') as MACHINE_RESULT ,
                              
       DECODE( c1,'[Header]', C6 , '') as REVIEW_RESULT ,
       
       DECODE( c1,'[Header]', C7 , '') as Reviewer ,
       
       DECODE( c1,'[Detail]', C3 , '') as Array_INDEX ,
       DECODE( c1,'[Detail]', C4 , '') as Component ,
       DECODE( c1,'[Detail]', C5 , '') as LEAD_ID ,
       
       DECODE( c1,'[Detail]', C6 , '') as NG_InspType ,
       
       DECODE( c1,'[Detail]', C7 , '') as NG_MachineResult, 
       
       C8 as NG_ReviewResult,
       enter_date 
  FROM IQ_MACHINE_INSPECT_AOI 
where C2 like :arg_pid
   and DECODE( c1,'[Header]', C3 , '')  >= :arg_sdate
   and DECODE( c1,'[Header]', C3 , '')  <= :arg_edate
   and line_code like :arg_line_code
   and length(c3) = 14" arguments=(("arg_pid", string),("arg_sdate", string),("arg_edate", string),("arg_line_code", string)) )
