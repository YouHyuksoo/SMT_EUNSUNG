table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="iq_machine_inspect_aoi.line_code" dbalias=".line_code" )
 column=(type=char(20) updatewhereclause=yes name=machine_code dbname="iq_machine_inspect_aoi.machine_code" dbalias=".machine_code" )
 column=(type=char(300) updatewhereclause=yes name=data_type dbname="iq_machine_inspect_aoi.data_type" dbalias=".data_type" )
 column=(type=char(300) updatewhereclause=yes name=product_id dbname="iq_machine_inspect_aoi.product_id" dbalias=".product_id" )
 column=(type=datetime updatewhereclause=yes name=inspect_date dbname="inspect_date" )
 column=(type=char(300) updatewhereclause=yes name=pcbmodel dbname="pcbmodel" )
 column=(type=char(300) updatewhereclause=yes name=machine_result dbname="machine_result" )
 column=(type=char(300) updatewhereclause=yes name=review_result dbname="review_result" )
 column=(type=char(300) updatewhereclause=yes name=reviewer dbname="reviewer" )
