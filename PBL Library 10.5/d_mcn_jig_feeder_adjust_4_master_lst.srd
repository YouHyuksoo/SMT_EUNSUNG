 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_jig_feeder_adjust~" )  TABLE(NAME=~"imcn_jig~" ) COLUMN(NAME=~"imcn_jig_feeder_adjust.jig_code~") COLUMN(NAME=~"imcn_jig_feeder_adjust.jig_lot_no~") COLUMN(NAME=~"imcn_jig_feeder_adjust.adjust_date~") COLUMN(NAME=~"imcn_jig_feeder_adjust.adjust_sequence~") COLUMN(NAME=~"imcn_jig_feeder_adjust.enter_by~") COLUMN(NAME=~"imcn_jig_feeder_adjust.enter_date~") COLUMN(NAME=~"imcn_jig_feeder_adjust.last_modify_by~") COLUMN(NAME=~"imcn_jig_feeder_adjust.last_modify_date~") COLUMN(NAME=~"imcn_jig_feeder_adjust.organization_id~") COLUMN(NAME=~"imcn_jig_feeder_adjust.comments~") COLUMN(NAME=~"imcn_jig.jig_name~") COLUMN(NAME=~"imcn_jig.jig_spec~")    JOIN (LEFT=~"imcn_jig_feeder_adjust.jig_code~"    OP =~"=~"RIGHT=~"imcn_jig.jig_code~"    OUTER1 =~"imcn_jig_feeder_adjust.jig_code~" )    JOIN (LEFT=~"imcn_jig_feeder_adjust.jig_lot_no~"    OP =~"=~"RIGHT=~"imcn_jig.jig_lot_no~"    OUTER1 =~"imcn_jig_feeder_adjust.jig_lot_no~" )    JOIN (LEFT=~"imcn_jig_feeder_adjust.organization_id~"    OP =~"=~"RIGHT=~"imcn_jig.organization_id~"    OUTER1 =~"imcn_jig_feeder_adjust.organization_id~" )WHERE(    EXP1 =~"~~~"IMCN_JIG_FEEDER_ADJUST~~~".~~~"JIG_LOT_NO~~~"~"   OP =~"=~"    EXP2 =~":arg_jig_lot_no~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_JIG_FEEDER_ADJUST~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_jig_lot_no~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IMCN_JIG_FEEDER_ADJUST" updatewhere=0 updatekeyinplace=no arguments=(("arg_jig_lot_no", string),("arg_org", number)) )
