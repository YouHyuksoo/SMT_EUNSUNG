 column=(type=char(0) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 retrieve="  SELECT 
         DECODE( :ARG_LANGUAGE , 'E' , ~"ISYS_WINDOW~".~"WINDOW_GROUP_ENG~",   'K' , ~"ISYS_WINDOW~".~"WINDOW_GROUP_KOR~",   ~"ISYS_WINDOW~".~"WINDOW_GROUP_LOCAL~" ) WINDOW_GROUP ,
         ~"ISYS_WINDOW~".~"WINDOW_NAME~",   

         DECODE( :ARG_LANGUAGE , 'E' , ~"ISYS_WINDOW~".~"WINDOW_DESCRIPTION_ENG~",   'K' , ~"ISYS_WINDOW~".~"WINDOW_DESCRIPTION_KOR~",   ~"ISYS_WINDOW~".~"WINDOW_DESCRIPTION_LOCAL~" ) WINDOW_DESCRIPTION ,
         ~"ISYS_WINDOW~".~"ORGANIZATION_ID~",   
         ~"ISYS_WINDOW~".~"ENTER_DATE~",   
         ~"ISYS_WINDOW~".~"ENTER_BY~",   
         ~"ISYS_WINDOW~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_WINDOW~".~"LAST_MODIFY_BY~",   
         ~"ISYS_WINDOW~".~"WINDOW_TYPE~",   
         ~"ISYS_WINDOW~".~"VERSION~",   
         '' CHECK_YN  
    FROM ~"ISYS_WINDOW~"  
   WHERE ( ~"ISYS_WINDOW~".~"WINDOW_NAME~" like :ARG_WINDOW_NAME ) AND  
         ( ~"ISYS_WINDOW~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID ) AND
WINDOW_NAME NOT IN ( SELECT WINDOW_NAME FROM ISYS_ROLE WHERE ROLE_CODE LIKE :ARG_ROLE_CODE AND ORGANIZATION_ID = :ARG_ORGANIZATION_ID )
" update="ISYS_WINDOW" updatewhere=1 updatekeyinplace=no arguments=(("ARG_WINDOW_NAME", string),("ARG_ROLE_CODE", string),("ARG_LANGUAGE", string),("ARG_ORGANIZATION_ID", number))  sort="organization_id A window_type A window_name A " )
