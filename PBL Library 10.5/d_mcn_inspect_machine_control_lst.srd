IMCN_MACHINE~~~".~~~"MACHINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_machine_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_MACHINE~~~".~~~"MACHINE_TYPE~~~"~"   OP =~"like~"    EXP2 =~":arg_machine_type~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MACHINE~~~".~~~"LINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_line_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MACHINE~~~".~~~"WORKSTAGE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_workstage_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"NVL(~~~"IMCN_MACHINE~~~".~~~"USE_STATUS~~~" , 'U')~"   OP =~"like~"    EXP2 =~":arg_use_status~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MACHINE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_machine_code~" TYPE = string)  ARG(NAME = ~"arg_machine_type~" TYPE = string)  ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_workstage_code~" TYPE = string)  ARG(NAME = ~"arg_use_status~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IMCN_MACHINE" updatewhere=0 updatekeyinplace=yes arguments=(("arg_machine_code", string),("arg_machine_type", string),("arg_line_code", string),("arg_workstage_code", string),("arg_use_status", string),("arg_org", number))  sort="organization_id A line_code A machine_code A mes_display_sequence A " )
