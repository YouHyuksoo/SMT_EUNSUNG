 retrieve="PBSELECT( VERSION(400) TABLE(NAME=‾"im_item_workstage_inventory‾" )  TABLE(NAME=‾"id_item‾" ) COMPUTE(NAME=‾"'N' CHECK_YN‾") COLUMN(NAME=‾"im_item_workstage_inventory.organization_id‾") COLUMN(NAME=‾"im_item_workstage_inventory.workstage_code‾") COLUMN(NAME=‾"im_item_workstage_inventory.machine_code‾") COLUMN(NAME=‾"im_item_workstage_inventory.material_mfs‾") COLUMN(NAME=‾"im_item_workstage_inventory.mfs‾") COLUMN(NAME=‾"im_item_workstage_inventory.item_code‾") COLUMN(NAME=‾"id_item.item_type‾") COLUMN(NAME=‾"im_item_workstage_inventory.line_type‾") COLUMN(NAME=‾"im_item_workstage_inventory.line_code‾") COLUMN(NAME=‾"im_item_workstage_inventory.inventory_qty‾") COLUMN(NAME=‾"im_item_workstage_inventory.enter_date‾") COLUMN(NAME=‾"im_item_workstage_inventory.enter_by‾") COLUMN(NAME=‾"im_item_workstage_inventory.last_modify_date‾") COLUMN(NAME=‾"im_item_workstage_inventory.last_modify_by‾") COLUMN(NAME=‾"id_item.item_name‾") COLUMN(NAME=‾"id_item.item_spec‾") COLUMN(NAME=‾"id_item.item_uom‾") COLUMN(NAME=‾"id_item.item_division‾") COMPUTE(NAME=‾"F_CHECK_BOM_EXISTS( ID_ITEM.ITEM_CODE , ID_ITEM.ORGANIZATION_ID ) BOM_EXISTS_YN‾") COMPUTE(NAME=‾"0 ISSUE_QTY‾") COLUMN(NAME=‾"im_item_workstage_inventory.inventory_price‾")    JOIN (LEFT=‾"im_item_workstage_inventory.item_code‾"    OP =‾"=‾"RIGHT=‾"id_item.item_code‾" )    JOIN (LEFT=‾"im_item_workstage_inventory.organization_id‾"    OP =‾"=‾"RIGHT=‾"id_item.organization_id‾" )WHERE(    EXP1 =‾"( ( ‾‾‾"IM_ITEM_WORKSTAGE_INVENTORY‾‾‾".‾‾‾"MFS‾‾‾"‾"   OP =‾"like‾"    EXP2 =‾":arg_mfs )‾"    LOGIC =‾"and‾" ) WHERE(    EXP1 =‾"( ‾‾‾"IM_ITEM_WORKSTAGE_INVENTORY‾‾‾".‾‾‾"ITEM_CODE‾‾‾"‾"   OP =‾"like‾"    EXP2 =‾":arg_item )‾"    LOGIC =‾"and‾" ) WHERE(    EXP1 =‾"( ‾‾‾"ID_ITEM‾‾‾".‾‾‾"ITEM_DIVISION‾‾‾"‾"   OP =‾"in‾"    EXP2 =‾"('W' , 'R' , 'B' ) )‾"    LOGIC =‾"and‾" ) WHERE(    EXP1 =‾"‾‾‾"IM_ITEM_WORKSTAGE_INVENTORY‾‾‾".‾‾‾"INVENTORY_QTY‾‾‾"‾"   OP =‾">‾"    EXP2 =‾"0‾"    LOGIC =‾"and‾" ) WHERE(    EXP1 =‾"( ‾‾‾"IM_ITEM_WORKSTAGE_INVENTORY‾‾‾".‾‾‾"ORGANIZATION_ID‾‾‾"‾"   OP =‾"=‾"    EXP2 =‾":arg_org ) )‾" ) ) ARG(NAME = ‾"arg_mfs‾" TYPE = string)  ARG(NAME = ‾"arg_item‾" TYPE = string)  ARG(NAME = ‾"arg_org‾" TYPE = number) " update="IM_ITEM_WORKSTAGE_INVENTORY" updatewhere=0 updatekeyinplace=yes arguments=(("arg_mfs", string),("arg_item", string),("arg_org", number))  sort="organization_id A item_division A workstage_code A mfs A item_code A " )
