table(column=(type=char(50) updatewhereclause=yes key=yes name=barcode dbname="ip_product_pack_serial.barcode" )
 column=(type=datetime updatewhereclause=yes name=final_inspect_date dbname="ip_product_pack_serial.final_inspect_date" )
 column=(type=char(2) updatewhereclause=yes name=final_inspect_flag dbname="ip_product_pack_serial.final_inspect_flag" )
 column=(type=char(50) updatewhereclause=yes name=pack_barcode dbname="ip_product_pack_serial.pack_barcode" )
 column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_pack_serial.run_no" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="ip_product_pack_serial.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_pack_serial.enter_by" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_pack_serial.organization_id" )
 retrieve="select barcode, 
         final_inspect_date, 
         final_inspect_flag, 
         pack_barcode, 
         run_no,  
         enter_date, 
         enter_by, 
         organization_id 
  from ip_product_pack_serial
 where barcode like :ARG_SERIAL_NO 
   AND ORGANIZATION_ID = :ARG_ORG
" update="ip_product_pack_serial" updatewhere=0 updatekeyinplace=no arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="barcode A final_inspect_date A " )
