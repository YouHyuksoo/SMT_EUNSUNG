 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"ib_line_master~" ) COLUMN(NAME=~"ib_line_master.line_code~") COLUMN(NAME=~"ib_line_master.machine~") COLUMN(NAME=~"ib_line_master.line_name~") COLUMN(NAME=~"ib_line_master.machine_name~") COLUMN(NAME=~"ib_line_master.enter_date~") COLUMN(NAME=~"ib_line_master.enter_by~") COLUMN(NAME=~"ib_line_master.last_modify_date~") COLUMN(NAME=~"ib_line_master.last_modify_by~") COLUMN(NAME=~"ib_line_master.organization_id~") COLUMN(NAME=~"ib_line_master.line_status~") COMPUTE(NAME=~"'' check_yn~")WHERE(    EXP1 =~"~~~"IB_LINE_MASTER~~~".~~~"LINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_line_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IB_LINE_MASTER~~~".~~~"MACHINE~~~"~"   OP =~"like~"    EXP2 =~":arg_machine_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IB_LINE_MASTER~~~".~~~"LINE_CODE~~~"~"   OP =~"<>~"    EXP2 =~"'*'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IB_LINE_MASTER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_machine_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_line_code", string),("arg_machine_code", string),("arg_org", number))  sort="line_code A machine A " )
