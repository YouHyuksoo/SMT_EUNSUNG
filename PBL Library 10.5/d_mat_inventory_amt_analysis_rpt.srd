HA$PBExportHeader$d_mat_inventory_amt_analysis_rpt.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=1 )
header(height=360 color="536870912" )
summary(height=84 color="536870912" )
footer(height=84 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=division dbname="division" )
 column=(type=char(20) updatewhereclause=yes name=location_code dbname="location_code" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number updatewhereclause=yes name=inventory_amt dbname="inventory_amt" )
 column=(type=number updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=number updatewhereclause=yes name=ready_issue_qty dbname="ready_issue_qty" )
 column=(type=number updatewhereclause=yes name=cycle_day dbname="cycle_day" )
 retrieve="select 'M' DIVISION , location_code , sum(inventory_qty) INVENTORY_QTY, sum(inventory_amt) INVENTORY_AMT ,
         SUM(F_GET_MAT_ISSUE_BY_DATE( ITEM_CODE , LINE_TYPE ,LOCATION_CODE, TRUNC(SYSDATE) , ORGANIZATION_ID )) ISSUE_QTY ,
	    SUM(F_GET_MAT_ISSUE_BY_DATE( ITEM_CODE , LINE_TYPE , LOCATION_CODE, TRUNC(SYSDATE) , ORGANIZATION_ID )) * 3 READY_ISSUE_QTY ,
		DECODE( SUM(F_GET_MAT_ISSUE_BY_DATE( ITEM_CODE , LINE_TYPE , LOCATION_CODE , TRUNC(SYSDATE) , ORGANIZATION_ID )) , 0, 0, sum(inventory_qty)  / SUM(F_GET_MAT_ISSUE_BY_DATE( ITEM_CODE , LINE_TYPE , LOCATION_CODE ,  TRUNC(SYSDATE) , ORGANIZATION_ID )) 	) CYCLE_DAY
 from im_item_inventory
where organization_id = :arg_org
group by  location_code 

union all

select 'A' DIVISION , location_code , sum(inventory_qty) ,  sum(inventory_amt) INVENTORY_AMT ,
         SUM(F_GET_ASSY_ISSUE_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE ,LOCATION_CODE, TRUNC(SYSDATE) , ORGANIZATION_ID )) ,
	    SUM(F_GET_ASSY_ISSUE_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE , LOCATION_CODE , TRUNC(SYSDATE) , ORGANIZATION_ID )) * 3 READY_ISSUE_QTY ,
		DECODE( SUM(F_GET_ASSY_ISSUE_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE ,LOCATION_CODE ,  TRUNC(SYSDATE) , ORGANIZATION_ID )) , 0, 0, sum(inventory_qty)  / SUM(F_GET_ASSY_ISSUE_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE , LOCATION_CODE , TRUNC(SYSDATE) , ORGANIZATION_ID )) 	)
 from is_assembly_inventory
where organization_id = :arg_org
group by  location_code 

union all

select 'P' DIVISION , location_code , sum(inventory_qty) ,  sum(inventory_amt) INVENTORY_AMT ,
         SUM(F_GET_SAL_PROD_SHIP_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE , LOCATION_CODE , TRUNC(SYSDATE) , ORGANIZATION_ID )) ,
	     SUM(F_GET_SAL_PROD_SHIP_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE , LOCATION_CODE , TRUNC(SYSDATE) , ORGANIZATION_ID )) * 3 READY_ISSUE_QTY ,
		DECODE( SUM(F_GET_SAL_PROD_SHIP_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE ,LOCATION_CODE , TRUNC(SYSDATE) , ORGANIZATION_ID )) , 0, 0, sum(inventory_qty)  / SUM(F_GET_SAL_PROD_SHIP_BY_DATE( ITEM_CODE , PRODUCT_LINE_TYPE , LOCATION_CODE , TRUNC(SYSDATE) , ORGANIZATION_ID )) 	)
 from is_PRODUCT_inventory
where organization_id = :arg_org
group by  location_code 
" arguments=(("ARG_ORG", number))  sort="division A location_code A " )
group(level=1 header.height=0 trailer.height=76 by=("division" ) header.color="536870912" trailer.color="536870912" )
