header(height=128 color="553648127" )
summary(height=0 color="536870912" )
footer(height=0 color="12632256" )
detail(height=72 color="553648127" )
table(column=(type=char(20) updatewhereclause=yes name=sample_type dbname="imcn_sample.sample_type" dbalias=".sample_type" )
 column=(type=char(30) updatewhereclause=yes name=sample_code dbname="imcn_sample.sample_code" dbalias=".sample_code" )
 column=(type=char(100) updatewhereclause=yes name=sample_name dbname="imcn_sample.sample_name" dbalias=".sample_name" )
 column=(type=char(100) updatewhereclause=yes name=sample_spec dbname="imcn_sample.sample_spec" dbalias=".sample_spec" )
 column=(type=char(30) updatewhereclause=yes name=sample_lot_no dbname="imcn_sample.sample_lot_no" dbalias=".sample_lot_no" )
 column=(type=char(1) updatewhereclause=yes name=sample_status dbname="imcn_sample.sample_status" dbalias=".sample_status" )
 column=(type=char(20) updatewhereclause=yes name=sample_section dbname="imcn_sample.sample_section" dbalias=".sample_section" )
 column=(type=char(20) updatewhereclause=yes name=sample_grade dbname="imcn_sample.sample_grade" dbalias=".sample_grade" )
 column=(type=datetime updatewhereclause=yes name=sample_apply_date dbname="imcn_sample.sample_apply_date" dbalias=".sample_apply_date" )
 column=(type=number updatewhereclause=yes name=valid_months dbname="imcn_sample.valid_months" dbalias=".valid_months" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="imcn_sample.line_code" dbalias=".line_code" )
 column=(type=char(10) updatewhereclause=yes name=workstage_code dbname="imcn_sample.workstage_code" dbalias=".workstage_code" )
 column=(type=char(100) updatewhereclause=yes name=model_name dbname="imcn_sample.model_name" dbalias=".model_name" )
 column=(type=char(1) updatewhereclause=yes name=use_status dbname="imcn_sample.use_status" dbalias=".use_status" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="imcn_sample.enter_by" dbalias=".enter_by" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="imcn_sample.enter_date" dbalias=".enter_date" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="imcn_sample.last_modify_by" dbalias=".last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="imcn_sample.last_modify_date" dbalias=".last_modify_date" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="imcn_sample.organization_id" dbalias=".organization_id" )
 column=(type=char(37) updatewhereclause=yes name=rowid dbname="imcn_sample.rowid" dbalias=".rowid" )
 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	 /	 " )
 column=(type=number updatewhereclause=yes name=remain_days dbname="remain_days" )
 column=(type=datetime updatewhereclause=yes name=sample_valid_date dbname="sample_valid_date" )
 column=(type=char(30) updatewhereclause=yes name=location_address dbname="imcn_sample.location_address" dbalias=".location_address" )
 retrieve="  select  sample_type, 
            sample_code, 
            sample_name, 
            sample_spec, 
            sample_lot_no, 
            sample_status, 
            sample_section, 
            sample_grade, 
            sample_apply_date, 
            valid_months, 
            line_code, 
            workstage_code, 
            model_name, 
            use_status, 
            enter_by, 
            enter_date, 
            last_modify_by, 
            last_modify_date, 
            organization_id,
            ROWID,
            'N' CHECK_YN,
            NVL(trunc(add_months(sample_apply_date, valid_months) - sysdate), 0)  remain_days,
            add_months( sample_apply_date,  NVL(valid_months, 0) ) sample_valid_date,
            location_address
    from IMCN_SAMPLE 
WHERE SAMPLE_CODE                   like :arg_sample_code 
     AND SAMPLE_TYPE                   like :arg_sample_type
     AND NVL(SAMPLE_STATUS,'*')  like :arg_sample_status 
     AND NVL(USE_STATUS,'*')       like :arg_use_status 
     AND NVL(round(add_months(sample_apply_date, valid_months) - sysdate), 0) <= NVL(:arg_remain_days, 10000)
     AND ORGANIZATION_ID             =   :arg_org 
     AND sample_name                   like  :arg_sample_name
     AND location_address               like  :arg_location_address
        
" arguments=(("arg_sample_code", string),("arg_sample_type", string),("arg_sample_status", string),("arg_use_status", string),("arg_remain_days", string),("arg_org", number),("arg_sample_name", string),("arg_location_address", string))  sort="sample_type A sample_code A sample_lot_no A " )
