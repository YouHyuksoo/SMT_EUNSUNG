 retrieve="  SELECT ~"IP_PRODUCT_DELIVERY_PLAN~".~"LINE_CODE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_DATE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_SEQUENCE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"WORK_ORDER_NO~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"MFS~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_PRIORITY~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PARENT_ITEM_CODE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_QTY~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"ACTUAL_QTY~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME1~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME2~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME3~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME4~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME5~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME6~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME7~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME8~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME9~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME10~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"COMMENTS~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"ENTER_BY~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"MODEL_COLOR~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_STATUS~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"CUSTOMER_CODE~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TRANSFER_YN~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"LOT_DIVIDE_YN~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"A_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"B_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"C_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"D_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"E_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"F_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"G_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"H_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"I_TIME_ACTUAL~",   
         ~"IP_PRODUCT_DELIVERY_TIME_V~".~"J_TIME_ACTUAL~",

         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME1~" +  
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME2~"+   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME3~"+  
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME4~"+   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME5~"+     
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME6~"+     
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME7~"+     
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME8~"+     
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME9~"+     
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_TIME10~" PLAN_QTY_CALC   ,
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_QTY_D1~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_QTY_D2~",   
         ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_QTY_D3~",
		~"IP_PRODUCT_DELIVERY_TIME_V~".~"WORKSTAGE_CODE~" WORKSTAGE_CODE



    FROM ~"IP_PRODUCT_DELIVERY_PLAN~",   
              ~"ID_ITEM~",   
              ~"IP_PRODUCT_DELIVERY_TIME_V~" 
   WHERE ( ip_product_delivery_plan.item_code = id_item.item_code (+)) and  
         ( ip_product_delivery_plan.organization_id = id_item.organization_id (+)) and  
         ( ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_DATE~" = ~"IP_PRODUCT_DELIVERY_TIME_V~".~"ACTUAL_DATE~"(+) ) and  
         ( ~"IP_PRODUCT_DELIVERY_PLAN~".~"MODEL_NAME~" = ~"IP_PRODUCT_DELIVERY_TIME_V~".~"MODEL_NAME~"(+) ) and  
         ( ~"IP_PRODUCT_DELIVERY_PLAN~".~"MODEL_SUFFIX~" = ~"IP_PRODUCT_DELIVERY_TIME_V~".~"MODEL_SUFFIX~"(+) ) and  
         ( ( ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_DATE~" >= :arg_dateset ) AND  
         ( ~"IP_PRODUCT_DELIVERY_PLAN~".~"PLAN_DATE~" <= :arg_dateend ) AND  
         ( ~"IP_PRODUCT_DELIVERY_PLAN~".~"MODEL_NAME~" like :arg_model_name) AND  
         ( ~"IP_PRODUCT_DELIVERY_PLAN~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_model_name", string),("arg_org_id", number))  sort="organization_id A line_code A plan_date A plan_priority A model_name A item_code A " )
