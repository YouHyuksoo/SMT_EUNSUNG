 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"isys_privilege~" )  TABLE(NAME=~"isys_users~" )  TABLE(NAME=~"isys_window~" ) COLUMN(NAME=~"isys_privilege.user_id~") COLUMN(NAME=~"isys_privilege.window_name~") COLUMN(NAME=~"isys_privilege.organization_id~") COLUMN(NAME=~"isys_privilege.dateset~") COLUMN(NAME=~"isys_privilege.dateend~") COLUMN(NAME=~"isys_privilege.role_code~") COLUMN(NAME=~"isys_privilege.enter_by~") COLUMN(NAME=~"isys_privilege.enter_date~") COLUMN(NAME=~"isys_privilege.last_modify_by~") COLUMN(NAME=~"isys_privilege.last_modify_date~") COLUMN(NAME=~"isys_users.user_name~") COLUMN(NAME=~"isys_users.user_level~") COLUMN(NAME=~"isys_users.department_code~") COLUMN(NAME=~"isys_privilege.role_type~") COMPUTE(NAME=~"DECODE( :ARG_LANGUAGE , 'K' , ~~~"ISYS_WINDOW~~~".~~~"WINDOW_GROUP_KOR~~~" , 'E' , ~~~"ISYS_WINDOW~~~".~~~"WINDOW_GROUP_ENG~~~" , 'C' , ~~~"ISYS_WINDOW~~~".~~~"WINDOW_GROUP_LOCAL~~~" ) WINDOW_GROUP~") COLUMN(NAME=~"isys_window.window_type~") COLUMN(NAME=~"isys_privilege.application_name~")    JOIN (LEFT=~"isys_privilege.user_id~"    OP =~"=~"RIGHT=~"isys_users.user_id~"    OUTER1 =~"isys_privilege.user_id~" )    JOIN (LEFT=~"isys_privilege.organization_id~"    OP =~"=~"RIGHT=~"isys_users.organization_id~"    OUTER1 =~"isys_privilege.organization_id~" )    JOIN (LEFT=~"isys_privilege.window_name~"    OP =~"=~"RIGHT=~"isys_window.window_name~" )    JOIN (LEFT=~"isys_privilege.organization_id~"    OP =~"=~"RIGHT=~"isys_window.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"ISYS_PRIVILEGE~~~".~~~"USER_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_USER_ID )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"ISYS_PRIVILEGE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORGANIZATION_ID ) )~" ) ) ARG(NAME = ~"ARG_USER_ID~" TYPE = string)  ARG(NAME = ~"ARG_LANGUAGE~" TYPE = string)  ARG(NAME = ~"ARG_ORGANIZATION_ID~" TYPE = number) " update="ISYS_PRIVILEGE" updatewhere=0 updatekeyinplace=no arguments=(("ARG_USER_ID", string),("ARG_LANGUAGE", string),("ARG_ORGANIZATION_ID", number))  sort="user_id A window_group A window_type A window_name A role_code A " )
