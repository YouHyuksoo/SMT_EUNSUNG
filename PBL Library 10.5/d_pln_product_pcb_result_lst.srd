 column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_workstage_io.run_no" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="ip_product_workstage_io.line_code" )
 column=(type=char(20) updatewhereclause=yes name=workstage_code dbname="ip_product_workstage_io.workstage_code" )
 column=(type=number updatewhereclause=yes name=lot_qty dbname="lot_qty" )
