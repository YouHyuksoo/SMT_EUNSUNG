 retrieve="SELECT MODEL_NAME, 
            RUN_NO, 
            LINE_CODE, 
            WORKSTAGE_CODE, 
            F_GET_RUN_LOT_QTY( RUN_NO )  LOT_QTY,
            SUM(IO_QTY) RESULT,
            MIN(IO_DATE) FIRST_DATE,
            MAX(IO_DATE) LAST_DADTE            
  FROM IP_PRODUCT_WORKSTAGE_IO
 WHERE ACTUAL_DATE                >= (TRUNC( :ARG_DATESET )) 
   AND ACTUAL_DATE                  <   (TRUNC( :ARG_DATEEND ) +1) 
   AND MODEL_NAME           LIKE :ARG_MODEL_NAME
   AND RUN_NO                   LIKE :ARG_RUN_NO
   AND LINE_CODE               LIKE :ARG_LINE_CODE
   AND WORKSTAGE_CODE  LIKE :ARG_WORKSTAGE_CODE
 GROUP BY MODEL_NAME, RUN_NO, LINE_CODE, WORKSTAGE_CODE
 ORDER BY MODEL_NAME, RUN_NO, LINE_CODE, WORKSTAGE_CODE" arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_MODEL_NAME", string),("ARG_RUN_NO", string),("ARG_LINE_CODE", string),("ARG_WORKSTAGE_CODE", string)) )
