 retrieve="select LINE_CODE, 
       MACHINE_CODE, 
       ACTUAL_DATE, 
       C1 as PRODUCT_ID, 
       C2 as SPI_RESULT, 
       C3 as PCB_INDEX, 
       C4 as INSPECT_VALUE1, 
       C5 as INSPECT_VALUE2, 
       C6 as INSPECT_VALUE3, 
       C7 as INSPECT_VALUE4, 
       ENTER_DATE 
       
  from iq_machine_inspect_spi  
where RUN_NO >= :arg_sdate
    and RUN_NO <= :arg_edate
    and c1  like :arg_pid
    and line_code like :arg_line_code
  " arguments=(("arg_pid", string),("arg_sDate", string),("arg_eDate", string),("arg_line_code", string)) )
