if as_free_receipt_type = 'N' then

	if  lvs_line_type = 'M' then 			
		//===========================
		// bom $$HEX8$$44c7200004c81cac200058d5ecc52000$$ENDHEX$$
		// $$HEX11$$acc009ae98cc2000acc7e0ac7cb9200010ac8cc12000$$ENDHEX$$/ $$HEX7$$9dc900ac2000dcc2a8d0e4b22000$$ENDHEX$$
		//===========================
