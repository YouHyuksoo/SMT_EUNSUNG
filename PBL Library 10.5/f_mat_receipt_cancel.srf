global function integer f_mat_receipt_cancel (datetime adt_date, double ad_seq, datetime adt_cancel_date, string as_free_receipt_type);long lvl_cnt, LVF_RETURN , lvl_receipt_qty
double lvl_receipt_seq
string  lvs_supplier_code,lvs_item_code , lvs_line_type , lvs_order_no , lvs_material_mfs

SELECT supplier_code , item_code , line_type  , order_no , receipt_qty , material_mfs
   into  :lvs_supplier_code,:lvs_item_code , :lvs_line_type , :lvs_order_no , :lvl_receipt_qty , :lvs_material_mfs
  from im_item_receipt
 WHERE receipt_date = :adt_date
   AND receipt_sequence = :ad_seq
   AND organization_id = :gvi_organization_id;
	if f_sql_check() < 0 then 
		return -1 
	end if 

