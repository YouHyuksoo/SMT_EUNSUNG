 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_receipt~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"im_item_receipt.receipt_date~") COLUMN(NAME=~"im_item_receipt.receipt_sequence~") COLUMN(NAME=~"im_item_receipt.organization_id~") COLUMN(NAME=~"im_item_receipt.mfs~") COLUMN(NAME=~"im_item_receipt.item_code~") COLUMN(NAME=~"im_item_receipt.line_type~") COLUMN(NAME=~"im_item_receipt.unit_price~") COLUMN(NAME=~"im_item_receipt.receipt_qty~") COLUMN(NAME=~"im_item_receipt.receipt_amt~") COLUMN(NAME=~"im_item_receipt.receipt_deficit~") COLUMN(NAME=~"im_item_receipt.receipt_type~") COLUMN(NAME=~"im_item_receipt.receipt_status~") COLUMN(NAME=~"im_item_receipt.comments~") COLUMN(NAME=~"im_item_receipt.enter_date~") COLUMN(NAME=~"im_item_receipt.enter_by~") COLUMN(NAME=~"im_item_receipt.last_modify_date~") COLUMN(NAME=~"im_item_receipt.last_modify_by~") COLUMN(NAME=~"im_item_receipt.confirm_yn~") COLUMN(NAME=~"im_item_receipt.confirm_date~") COLUMN(NAME=~"im_item_receipt.confirm_by~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"id_item.item_name~") COMPUTE(NAME=~"' ' check_yn~") COLUMN(NAME=~"im_item_receipt.invoice_no~") COLUMN(NAME=~"im_item_receipt.supplier_code~") COLUMN(NAME=~"im_item_receipt.currency~") COLUMN(NAME=~"im_item_receipt.material_mfs~") COLUMN(NAME=~"im_item_receipt.order_type~") COLUMN(NAME=~"im_item_receipt.location_code~")    JOIN (LEFT=~"im_item_receipt.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~" )    JOIN (LEFT=~"id_item.item_code~"    OP =~"=~"RIGHT=~"im_item_receipt.item_code~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_RECEIPT~~~".~~~"RECEIPT_DATE~~~"~"   OP =~"between~"    EXP2 =~":arg_dateset and :arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"nvl(~~~"IM_ITEM_RECEIPT~~~".~~~"INVOICE_NO~~~",'*')~"   OP =~"like~"    EXP2 =~":arg_invoice_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT~~~".~~~"LOCATION_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_location_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT~~~".~~~"RECEIPT_STATUS~~~"~"   OP =~"<>~"    EXP2 =~"'C'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"CONFIRM_YN~~~"~"   OP =~"=~"    EXP2 =~"'N' ) )~" ) ) ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_invoice_no~" TYPE = string)  ARG(NAME = ~"arg_location_code~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " update="IM_ITEM_RECEIPT" updatewhere=0 updatekeyinplace=yes arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_invoice_no", string),("arg_location_code", string),("arg_org_id", number))  sort="organization_id A order_type A receipt_date A receipt_sequence A " )
