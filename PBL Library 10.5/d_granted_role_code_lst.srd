footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_id dbname="isys_privilege.user_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=role_code dbname="isys_privilege.role_code" )
 column=(type=char(0) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(20) updatewhereclause=yes name=user_name dbname="isys_users.user_name" )
 retrieve="  SELECT ~"ISYS_PRIVILEGE~".~"USER_ID~",   
         ~"ISYS_PRIVILEGE~".~"ROLE_CODE~",   
         '' check_yn,   
         ~"ISYS_USERS~".~"USER_NAME~"  
    FROM ~"ISYS_PRIVILEGE~",   
         ~"ISYS_USERS~"  
   WHERE ( ~"ISYS_PRIVILEGE~".~"USER_ID~" = ~"ISYS_USERS~".~"USER_ID~" ) and  
         ( ~"ISYS_PRIVILEGE~".~"ORGANIZATION_ID~" = ~"ISYS_USERS~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"ISYS_PRIVILEGE~".~"USER_ID~" = :ARG_USER_ID ) AND  
         ( ~"ISYS_PRIVILEGE~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID ) )   
GROUP BY ~"ISYS_PRIVILEGE~".~"USER_ID~",   
         ~"ISYS_PRIVILEGE~".~"ROLE_CODE~",   
         ~"ISYS_PRIVILEGE~".~"ORGANIZATION_ID~",   
         ~"ISYS_USERS~".~"USER_ID~",   ~"ISYS_USERS~".~"USER_NAME~"  ,
         ~"ISYS_USERS~".~"ORGANIZATION_ID~"   
" arguments=(("ARG_USER_ID", string),("ARG_ORGANIZATION_ID", number))  sort="role_code A " )
