t.organization_id~" )WHERE(    EXP1 =~"~~~"IMAN_CARRYING_OUT~~~".~~~"CARRYING_OUT_ITEM~~~"~"   OP =~"like~"    EXP2 =~":arg_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMAN_CARRYING_OUT~~~".~~~"CARRYING_OUT_RECEIPTOR~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"TRUNC(~~~"IMAN_CARRYING_OUT~~~".~~~"CARRYING_OUT_DATE~~~")~"   OP =~">=~"    EXP2 =~":arg_dateset~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"TRUNC(~~~"IMAN_CARRYING_OUT~~~".~~~"CARRYING_OUT_DATE~~~")~"   OP =~"<=~"    EXP2 =~":arg_dateend~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"nvl(~~~"IMAN_CARRYING_OUT~~~".~~~"COMPLETE_YN~~~",'*')~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMAN_CARRYING_OUT~~~".~~~"CARRYING_OUT_TYPE~~~"~"   OP =~"like~"    EXP2 =~":arg_carrying_out_type~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMAN_CARRYING_OUT~~~".~~~"GATE_GUARD_CONFIRM_YN~~~"~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"ISYS_USERS~~~".~~~"DEPARTMENT_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_dept_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMAN_CARRYING_OUT~~~".~~~"CARRYING_OUT_GROUP_NO~~~"~"   OP =~"like~"    EXP2 =~":arg_carrying_out_group_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMAN_CARRYING_OUT~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_item~" TYPE = string)  ARG(NAME = ~"arg_supplier~" TYPE = string)  ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_carrying_out_type~" TYPE = string)  ARG(NAME = ~"arg_dept_code~" TYPE = string)  ARG(NAME = ~"arg_carrying_out_group_no~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IMAN_CARRYING_OUT" updatewhere=0 updatekeyinplace=no arguments=(("arg_item", string),("arg_supplier", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_carrying_out_type", string),("arg_dept_code", string),("arg_carrying_out_group_no", string),("arg_org", number))