public subroutine wf_ok_slip_receipt ();
long   lvl_solder_day_seq
string lvs_solder_day_yymmdd, lvs_solder_type

//===================================
//$$HEX22$$15c8c1c001c878c7200004c85cd45cb8200098ccacb958d594b22000bdacb0c6ccb92000e4b4b4c534c62000$$ENDHEX$$
//$$HEX24$$39d6dcc2200004c85cd488bc38d6d0c5200088d4a9ba44c72000a4c294ce200088d544c74cae10bd2000b4cc6cd02000$$ENDHEX$$
//===================================
lvl_check_Pos =  pos( sle_slip_no.text , "+" , 1 ) 

if lvl_check_Pos > 0 then 
	
	sle_slip_no.setfocus( )
	sle_slip_no.text = ''
	sle_supplier_lot_no.text =''
	sle_origin_supplier_code.text = ''
	st_status.text = F_MSG( "$$HEX16$$04c85cd4200088bc38d6200000ac200098c7bbba200018b4c8c5b5c2c8b2e4b2$$ENDHEX$$" , 'S')
	ivi_error = -1 
	return 
end if 
	
lvl_check_Pos =  pos( sle_slip_no.text , "," , 1 ) 

//	//==================================================
//	// $$HEX12$$d8c5c0c920009ccde0ac200074c725b8200070c88cd62000$$ENDHEX$$
//	//==================================================
//	
//	dw_3.retrieve( sle_slip_no.text )
//	if dw_3.rowcount() < 1 then 
//		F_PLAY_SOUND("scanfailed.wav")
//	end if 
	
	//==================================================
	//
	//==================================================
	
	if f_check_slip_exists( sle_slip_no.text)  > 0 then
		st_status.text = "NG"
		f_play_sound( "Eixst.wav")
		f_msgbox1(813 , sle_slip_no.text) 
		sle_lot_no.text = ''
		sle_supplier_lot_no.text =''
		sle_origin_supplier_code.text = ''
		sle_lot_no.setfocus()
		ivi_error = -1 
		return 
	end if 
	
//=================================================
// $$HEX10$$94c154b388d4a9ba200078c7c0c9200055d678c7$$ENDHEX$$
//=================================================

    lvs_solder_type = '*'
	 
    select solder_type
	   into :lvs_solder_type
       from id_item
    where item_class = 'SOLDER'
       and item_code = :lvs_item_code;
		 
    IF ( lvs_solder_type = '*' OR ISNULL(lvs_solder_type) OR lvs_solder_type = '' ) THEN
		
		st_status.text = F_MSG('$$HEX17$$85c725b820005cd5200088d4a9ba74c7200094c154b300ac200044c5d9b2c8b2e4b2$$ENDHEX$$, $$HEX8$$55d678c7200014bc8db7c8b2e4b22000$$ENDHEX$$: ' + lvs_item_code , 'S') 		
		sle_slip_no.text = ''
		sle_lot_no.text = ''
		sle_slip_no.setfocus()		
		
   ELSE
		
		IF ( lvs_solder_type = 'F' ) THEN
			  lvs_solder_type = 'S'
		END IF
		
    END IF	
	
//========================================================================
// $$HEX20$$94c154b3200014bc54cfdcb42000ddc031c144c7200004c75cd520001cc288bc200055d678c72000$$ENDHEX$$: S/P(1) + YYMMDD(6) + 000(3) : $$HEX15$$58d5e8b8d0c5200058d598b058c7200088d488bcd0c5200000b374d52000$$ENDHEX$$999$$HEX9$$1cac7cb9200018b1c0c920004ac594b2e4b2$$ENDHEX$$
//========================================================================

    select nvl(to_number(substr(max(item_barcode),8,3)),0), to_char(sysdate,'YYMMDD')
       into :lvl_solder_day_seq, :lvs_solder_day_yymmdd
     from im_item_receipt_barcode
   where item_barcode like:lvs_solder_type||to_char(sysdate,'YYMMDD')||'%'
       and organization_id = 1;
	
	if (lvl_solder_day_seq + LVL_LOOP > 999) then
		
		st_status.text = F_MSG('$$HEX18$$7cc77cc72000c8d5a9c620001cbc89d5200018c2c9b744c7200018b1c8c5b5c2c8b2e4b2$$ENDHEX$$' , 'S') 		
		sle_slip_no.text = ''
		sle_lot_no.text = ''
		sle_lot_no.setfocus()
		
	end if
	
	//==================================================
	// $$HEX13$$acc2bdb9200015c8f4bc7cb92000ddc031c120005cd5e4b22000$$ENDHEX$$.
	//==================================================
	LVL_ROW = 0 
	f_insert()
	
	LVDB_SLIP_RCV_SEQ  = F_GET_SEQUENCE('SEQ_RECEIPT_SLIP')
	
	dw_1.object.receipt_date[LVL_ROW]         = f_t_sysdate()
	dw_1.object.receipt_sequence[LVL_ROW] = LVDB_SLIP_RCV_SEQ
	dw_1.object.item_code[LVL_ROW]            = sle_item_code.text
	dw_1.object.reel_qty[LVL_ROW]               = long(sle_reel_qty.text)
	dw_1.object.receipt_unit_qty[LVL_ROW]    = long(sle_unit_qty.text)
	dw_1.object.receipt_sum_qty[LVL_ROW]   = long(sle_total_qty.text)
	dw_1.object.receipt_barcode[LVL_ROW]    = sle_lot_no.text  //$$HEX15$$acc2bdb9d0c51cc12000a4c294ce5cd5200015c8f4bc200088d4a9ba2000$$ENDHEX$$+ $$HEX2$$b4b92000$$ENDHEX$$+ $$HEX4$$1dcd18c2c9b72000$$ENDHEX$$
	dw_1.object.receipt_slip_no[LVL_ROW]     = sle_slip_no.text
	dw_1.object.receipt_status[LVL_ROW]       = 'N'
	dw_1.object.supplier_code[LVL_ROW]         = ddlb_supplier_code.getcode()
	dw_1.object.from_supplier_code[LVL_ROW] = ddlb_supplier_code.getcode()
	//=================================================
	//
	//=================================================
	
	lvs_receipt_type = 'N'
	dw_1.object.receipt_type[LVL_ROW]       = lvs_receipt_type
	lvs_eco_item_yn = 'N'
	dw_1.object.eco_item_yn[lvl_row] = lvs_eco_item_yn
	
//	//==================================================
//	// $$HEX9$$d8c5c0c920009ccde0ac200070c88cd62000$$ENDHEX$$
//	//==================================================
//	dw_3.retrieve( sle_slip_no.text )
	
	if cbx_manual_slip.checked = true then 
		LVL_LOOP = UPPERBOUND(ivl_divide_qty)  
	ELSE
		LVL_LOOP = long(sle_reel_qty.text)
	END IF 
	
	//=================================================
	//
	//=================================================
	if cbx_manual_slip.checked =false and ( sle_unit_qty.text = '' or isnull(sle_unit_qty.text)) then
		st_status.text = F_MSG( "$$HEX15$$e8b204c7200018c2c9b774c7200098c7bbba200018b4c8c5b5c2c8b2e4b2$$ENDHEX$$" ,'S')
		sle_slip_no.text = ''
		sle_supplier_lot_no.text =''
		sle_origin_supplier_code.text = ''
		ivi_error = -1 
		return 
	end if 
	
	//==================================================
	// $$HEX20$$acc2bdb9200014bc54cfdcb42000c8b9a4c230d1200015c8f4bc7cb92000ddc031c120005cd5e4b2$$ENDHEX$$
	//==================================================
	lvl_row = 0 
	i  = 0 
	do
			 i++
			LVL_ROW = DW_2.INSERTROW(1)
			DW_2.SCROLLTOROW(LVL_ROW)
			F_SET_SECURITY_ROW(DW_2 , LVL_ROW ,'ALL')
			
			lvdb_receipt_lot_no = F_GET_SEQUENCE('SEQ_MATERIAL_BARCODE')
			lvs_receipt_lot_no = F_YMD_SYSDATE()+STRING(lvdb_receipt_lot_no)
			
			dw_2.object.scan_date[LVL_ROW]            =  f_sysdate()
			dw_2.object.item_code[LVL_ROW]            = sle_item_code.text //$$HEX5$$fcd3a9ba54cfdcb42000$$ENDHEX$$
			dw_2.object.lot_no[LVL_ROW]                  = lvs_receipt_lot_no  //$$HEX5$$6fb8b8d288bc38d62000$$ENDHEX$$
			
			dw_2.object.origin_lot_no[LVL_ROW]         = lvs_receipt_lot_no  //$$HEX5$$6fb8b8d288bc38d62000$$ENDHEX$$
	
			dw_2.object.receipt_slip_no[LVL_ROW]     = sle_slip_no.text
			dw_2.object.receipt_compare_yn[lvl_row] = 'N' //$$HEX5$$44be50ad44c6ccb82000$$ENDHEX$$
			dw_2.object.barcode_status[lvl_row] = 'N' //$$HEX7$$44be50ad44c6ccb8200009000900$$ENDHEX$$
			dw_2.object.holding_yn[lvl_row] = 'N' //$$HEX6$$40d629b544c6ccb820000900$$ENDHEX$$
			dw_2.object.lot_divide_yn[lvl_row] = 'N' //$$HEX5$$6fb8b8d284bd60d52000$$ENDHEX$$
			
			if cbx_manual_slip.checked = true  and long(sle_unit_qty.text) > 0  and  (long(sle_total_qty.text) > long(sle_unit_qty.text)) then 
				
				dw_2.object.scan_qty[LVL_ROW]              = ivl_divide_qty[i]
		  	    //	dw_2.object.item_barcode[LVL_ROW]       = sle_item_code.text+"+"+lvs_receipt_lot_no+"+"+string( ivl_divide_qty[i])// $$HEX7$$5ccd85c814bc54cfdcb420000900$$ENDHEX$$
					
			    dw_2.object.item_barcode[LVL_ROW]       = lvs_solder_type+lvs_solder_day_yymmdd+string(lvl_solder_day_seq+i,'000')// $$HEX5$$5ccd85c814bc54cfdcb4$$ENDHEX$$
		
			else
				
				dw_2.object.scan_qty[LVL_ROW]              = long(sle_unit_qty.text)
				// dw_2.object.item_barcode[LVL_ROW]       = sle_item_code.text+"+"+lvs_receipt_lot_no+"+"+sle_unit_qty.text // $$HEX7$$5ccd85c814bc54cfdcb420000900$$ENDHEX$$
				
				dw_2.object.item_barcode[LVL_ROW]       = lvs_solder_type+lvs_solder_day_yymmdd+string(lvl_solder_day_seq+i,'000')// $$HEX5$$5ccd85c814bc54cfdcb4$$ENDHEX$$
			
			end if 
			
			  dw_2.object.receipt_type[lvl_row]             = lvs_receipt_type //$$HEX5$$85c7e0ac20c715d62000$$ENDHEX$$
			  dw_2.object.supplier_code[LVL_ROW]       =  ddlb_supplier_code.getcode()
			  
			  dw_2.object.return_yn[LVL_ROW]       =  'N'
   	           dw_2.object.label_type[LVL_ROW]       =  'N'
			  
	loop until i = LVL_LOOP 
	
	//===================================================
	//
	//===================================================
	IF dw_1.UPDATE() < 0   or  dw_2.UPDATE() < 0   THEN
		
		ROLLBACK;
		
		dw_1.reset()
	    dw_2.reset()
	
		SLE_LOT_NO.TEXT = ''
		SLE_LOT_NO.SETFOCus( )
		f_play_sound("$$HEX4$$00c8a5c7e4c228d3$$ENDHEX$$.wav")
		sle_slip_no.text = ''
		sle_supplier_lot_no.text =''
		sle_origin_supplier_code.text = ''
		ivi_error = -1 
		RETURN					
	ELSE
		COMMIT;
		F_MSG_MDI_HELP( "Update Complete" )//$$HEX14$$31c1f5ac01c83cc75cb8200000c8a5c7200018b4c8c5b5c2c8b2e4b2$$ENDHEX$$"
		f_play_sound("$$HEX4$$00c8a5c731c1f5ac$$ENDHEX$$.wav")
	END IF 
	
	st_status.text = "OK"
	
if cbx_auto_print.checked = true then 
	pb_print.triggerevent(clicked!)
end if 
	
sle_lot_no.text = ''
sle_slip_no.text = ''
sle_item_code.text = ''
sle_reel_qty.text = ''
sle_total_qty.text = ''
sle_unit_qty.text = ''
sle_supplier_lot_no.text =''
sle_origin_supplier_code.text = ''
sle_lot_no.setfocus( )
end subroutine

public function integer wf_set_material_qty ();
//=====================================================
// $$HEX14$$30ae00c918c2c9b7200080bd69d52000ecc580bd2000b4cc6cd02000$$ENDHEX$$
//=====================================================
lvl_material_qty = 0 ; lvl_material_qty2 = 0 ; lvl_material_qty3 = 0 ;

select nvl(material_qty,0) , nvl(material_qty2 ,0) , nvl(material_qty3 ,0) 
   into :lvl_material_qty , :lvl_material_qty2 , :lvl_material_qty3
  from id_item 
where item_code        =  :lvs_item_code
    and organization_id = :gvi_organization_id  ;

if f_sql_check() < 0 then 
	ivi_error = -1 
	return -1
end if 


if lvl_material_qty <> 0 and lvl_material_qty2 = 0  and lvl_material_qty3 = 0 then 
	return lvl_material_qty
elseif lvl_material_qty <> 0 and lvl_material_qty2 <>  0  then 
	return -1 
else
	return 0 
end if 

end function

private subroutine wf_no_slip_receipt ();
long         lvl_solder_day_seq
string       lvs_solder_day_yymmdd, lvs_prod_yymmdd, lvs_solder_type

//==================================================
//  $$HEX12$$5ccd85c8200094cd9ccd1cb4200088d4a9ba54cfdcb42000$$ENDHEX$$
//==================================================
sle_item_code.text = lvs_item_code

//=================================================
//
//=================================================
if cbx_dual_pcb_slip.checked = true then 
	
	
else	
		if cbx_manual_slip.checked =false and ( sle_unit_qty.text = '' or isnull(sle_unit_qty.text)) then
			st_status.text = F_MSG( "$$HEX15$$e8b204c7200018c2c9b774c7200098c7bbba200018b4c8c5b5c2c8b2e4b2$$ENDHEX$$", 'S')
			sle_supplier_lot_no.text =''
			sle_origin_supplier_code.text = ''
			em_creator_qty.text = ''
			ivi_error = -1 
			return 
		end if 
end if 
//==================================================
//  SLIP INSERT 
//  $$HEX14$$acc2bdb974c725b844c7200090c7d9b33cc75cb82000ddc031c12000$$ENDHEX$$
//==================================================
LVL_ROW = 0 
f_insert()
LVDB_SLIP_RCV_SEQ  = F_GET_SEQUENCE('SEQ_RECEIPT_SLIP')
dw_1.object.receipt_date[LVL_ROW]         = f_t_sysdate()
dw_1.object.receipt_sequence[LVL_ROW] = LVDB_SLIP_RCV_SEQ
dw_1.object.item_code[LVL_ROW]            = sle_item_code.text
dw_1.object.reel_qty[LVL_ROW]               = LVL_LOOP
dw_1.object.receipt_unit_qty[LVL_ROW]    = long(sle_unit_qty.text)
dw_1.object.receipt_sum_qty[LVL_ROW]   = long(sle_total_qty.text)
dw_1.object.receipt_barcode[LVL_ROW]    = lvs_supplier_barcode // sle_lot_no.text
dw_1.object.receipt_slip_no[LVL_ROW]     =  STRING(f_t_sysdate(),'YYMMDD')+STRING(LVDB_SLIP_RCV_SEQ)
dw_1.object.receipt_status[LVL_ROW]       = 'N'
dw_1.object.supplier_code[LVL_ROW]         = ddlb_supplier_code.getcode()
dw_1.object.from_supplier_code[LVL_ROW] = ddlb_supplier_code.getcode()
//=================================================
//
//=================================================
lvs_receipt_type = 'N'
dw_1.object.receipt_type[LVL_ROW]       = lvs_receipt_type
//=================================================

//=================================================
// $$HEX6$$14bc54cfdcb4200055d678c7$$ENDHEX$$
//=================================================

    lvs_solder_type = '*'
	 
    select solder_type
	   into :lvs_solder_type
       from id_item
    where item_class = 'SOLDER'
       and item_code = :lvs_item_code;
		 
    IF ( lvs_solder_type = '*' OR ISNULL(lvs_solder_type) OR lvs_solder_type = '' ) THEN
		
		st_status.text = F_MSG('$$HEX17$$85c725b820005cd5200088d4a9ba74c7200094c154b300ac200044c5d9b2c8b2e4b2$$ENDHEX$$, $$HEX8$$55d678c7200014bc8db7c8b2e4b22000$$ENDHEX$$: ' + lvs_item_code , 'S') 		
		sle_slip_no.text = ''
		sle_lot_no.text = ''
		sle_slip_no.setfocus()		
		
   ELSE
		
		IF ( lvs_solder_type = 'F' ) THEN
			  lvs_solder_type = 'S'
		END IF
		
    END IF
		  
//========================================================================
// $$HEX20$$94c154b3200014bc54cfdcb42000ddc031c144c7200004c75cd520001cc288bc200055d678c72000$$ENDHEX$$:S/P(6) + YYMMDD(6) + 000(3) : $$HEX15$$58d5e8b8d0c5200058d598b058c7200088d488bcd0c5200000b374d52000$$ENDHEX$$999$$HEX9$$1cac7cb9200018b1c0c920004ac594b2e4b2$$ENDHEX$$
//========================================================================

    lvs_prod_yymmdd = trim( sle_proddate.text )

     select nvl(to_number(substr(max(item_barcode),8,3)),0), to_char(sysdate,'YYMMDD')
        into :lvl_solder_day_seq, :lvs_solder_day_yymmdd
      from im_item_receipt_barcode
    where item_barcode like :lvs_solder_type||to_char(sysdate,'YYMMDD')||'%'
        and organization_id = 1;	 

	if (lvl_solder_day_seq + LVL_LOOP > 999) then
		
		st_status.text = F_MSG('$$HEX18$$7cc77cc72000c8d5a9c620001cbc89d5200018c2c9b744c7200018b1c8c5b5c2c8b2e4b2$$ENDHEX$$' , 'S') 		
		sle_slip_no.text = ''
		sle_lot_no.text = ''
		sle_proddate.text = ''
		sle_slip_no.setfocus()
		
	end if
	
//==================================================
//
//==================================================

lvl_row = 0 
i = 0 
do
	 i++
	LVL_ROW = DW_2.INSERTROW(1)
	DW_2.SCROLLTOROW(LVL_ROW)
	F_SET_SECURITY_ROW(DW_2 , LVL_ROW ,'ALL')
	
	lvdb_receipt_lot_no = F_GET_SEQUENCE('SEQ_MATERIAL_BARCODE')
	lvs_receipt_lot_no   =F_YMD_SYSDATE()+STRING(lvdb_receipt_lot_no)// STRING(F_T_SYSDATE(),'YYMMDD')+STRING(lvdb_receipt_lot_no)
	
	dw_2.object.scan_date[LVL_ROW]            =  f_sysdate()
	dw_2.object.item_code[LVL_ROW]            = sle_item_code.text //$$HEX5$$fcd3a9ba54cfdcb42000$$ENDHEX$$
	dw_2.object.lot_no[LVL_ROW]                  = lvs_receipt_lot_no  //$$HEX5$$6fb8b8d288bc38d62000$$ENDHEX$$
	dw_2.object.lot_divide_yn[LVL_ROW]                  = 'N'  //$$HEX5$$6fb8b8d288bc38d62000$$ENDHEX$$
	
	dw_2.object.origin_lot_no[LVL_ROW]        = lvs_receipt_lot_no  //$$HEX5$$6fb8b8d288bc38d62000$$ENDHEX$$

	dw_2.object.receipt_slip_no[LVL_ROW]     = STRING(f_t_sysdate(),'YYMMDD')+STRING(LVDB_SLIP_RCV_SEQ)
	dw_2.object.receipt_compare_yn[lvl_row] = 'N' //$$HEX5$$44be50ad44c6ccb82000$$ENDHEX$$
	dw_2.object.barcode_status[lvl_row] = 'N' //$$HEX7$$44be50ad44c6ccb8200009000900$$ENDHEX$$
	dw_2.object.holding_yn[lvl_row] = 'N' //$$HEX7$$40d629b544c6ccb8200009000900$$ENDHEX$$
	
	if cbx_manual_slip.checked = true and long(sle_unit_qty.text) > 0  and  (long(sle_total_qty.text) > long(sle_unit_qty.text))  then 
		
		dw_2.object.scan_qty[LVL_ROW]              = ivl_divide_qty[i]
		//dw_2.object.item_barcode[LVL_ROW]       = sle_item_code.text+"+"+lvs_receipt_lot_no+"+"+string( ivl_divide_qty[i])// $$HEX8$$5ccd85c814bc54cfdcb4200009000900$$ENDHEX$$
		//lvs_our_barcode = sle_item_code.text+"+"+lvs_receipt_lot_no+"+"+string( ivl_divide_qty[i])// $$HEX6$$5ccd85c814bc54cfdcb42000$$ENDHEX$$
		
		dw_2.object.item_barcode[LVL_ROW]       = lvs_solder_type+lvs_solder_day_yymmdd+string(lvl_solder_day_seq+i,'000')// $$HEX5$$5ccd85c814bc54cfdcb4$$ENDHEX$$
		lvs_our_barcode = dw_2.object.item_barcode[LVL_ROW]
		
	else
		
		dw_2.object.scan_qty[LVL_ROW]              = long(sle_unit_qty.text)
		//dw_2.object.item_barcode[LVL_ROW]       = sle_item_code.text+"+"+lvs_receipt_lot_no+"+"+sle_unit_qty.text // $$HEX9$$5ccd85c814bc54cfdcb42000090009000900$$ENDHEX$$
		//lvs_our_barcode = sle_item_code.text+"+"+lvs_receipt_lot_no+"+"+sle_unit_qty.text
		
		dw_2.object.item_barcode[LVL_ROW]       = lvs_solder_type+lvs_solder_day_yymmdd+string(lvl_solder_day_seq+i,'000')// $$HEX5$$5ccd85c814bc54cfdcb4$$ENDHEX$$
		lvs_our_barcode = dw_2.object.item_barcode[LVL_ROW]
		
	end if 
	
	  dw_2.object.receipt_type[lvl_row]             = lvs_receipt_type //$$HEX5$$85c7e0ac20c715d62000$$ENDHEX$$
	  dw_2.object.supplier_code[LVL_ROW]       =  ddlb_supplier_code.getcode()
	  
	  dw_2.object.return_yn[LVL_ROW]       =  'N'
	  dw_2.object.label_type[LVL_ROW]      =  'N'
	 
      dw_2.object.valid_date[LVL_ROW]       = uo_valid_date.text() 
	  
loop until  i = lvl_loop 

//===================================================
//
//===================================================
IF dw_1.UPDATE() < 0   or  dw_2.UPDATE() < 0   THEN
	
	ROLLBACK;
	
//	dw_1.reset()
//	dw_2.reset()
				
	sle_slip_no.TEXT   = ''
	sle_item_code.text = ''
	sle_supplier_lot_no.text =''
	sle_origin_supplier_code.text = ''
	sle_slip_no.SETFOCus( )
	f_play_sound("$$HEX4$$00c8a5c7e4c228d3$$ENDHEX$$.wav")
	ivi_error = -1 
	RETURN					
ELSE
	COMMIT;
	F_MSG_MDI_HELP( "Update Complete" )//$$HEX14$$31c1f5ac01c83cc75cb8200000c8a5c7200018b4c8c5b5c2c8b2e4b2$$ENDHEX$$"
	f_play_sound("$$HEX4$$00c8a5c731c1f5ac$$ENDHEX$$.wav")
	//================================
	// $$HEX5$$90c7d9b39ccd25b82000$$ENDHEX$$
	//================================
	if cbx_auto_print.checked = true then
	   pb_print.triggerevent(clicked!)
	end if 
END IF 

//========================================
// direct $$HEX4$$85c7e0ac74ba2000$$ENDHEX$$
// $$HEX16$$30b55cb82000a4c294ce44c720001bbcc0c920004ac5e0ac200098ccacb92000$$ENDHEX$$
//========================================
if  rb_no_slip_auto_receipt.checked = true then 
		//====================================
		//  $$HEX8$$90c7d9b385c7e0ac200098ccacb92000$$ENDHEX$$
		//====================================
		sle_supplier_barcode.setfocus()
		sle_supplier_barcode.text = lvs_our_barcode + 'S'
		sle_our_barcode.text        = lvs_our_barcode 
		
		//=====================================
		// $$HEX10$$e4b274c709b8b8d2200085c7e0ac200074ba2000$$ENDHEX$$
		//=====================================
		wf_receipt_barcode('N')
		
		st_status.text = "OK"
		sle_item_code.text = ''
		sle_reel_qty.text = '0'
		sle_total_qty.text = ''
		sle_unit_qty.text = ''
		em_creator_qty.text = ''
		sle_slip_no.text = '' 
		sle_supplier_lot_no.text =''
		sle_origin_supplier_code.text = ''
		sle_slip_no.setfocus( )

elseif rb_no_slip_manual_receipt.checked  = true then 
		//$$HEX15$$54d674bad0c51cc12000a4c294ce20001bbc44c51cc1200098ccacb92000$$ENDHEX$$
     	sle_supplier_barcode.setfocus( )
			
else
	
	st_status.text = "OK"
     if cbx_dual_pcb_slip.checked = true then 
		
				if lvi_dual_loop = upperbound(lvs_dual_item_code) then 
						sle_item_code.text = ''
						sle_reel_qty.text = '0'
						sle_total_qty.text = ''
						sle_unit_qty.text = ''
						em_creator_qty.text = ''
						sle_slip_no.text = '' 
						sle_supplier_lot_no.text =''
						sle_origin_supplier_code.text = ''
						sle_slip_no.setfocus( )
				else
					
				end if 
		
	else
		sle_item_code.text = ''
		sle_reel_qty.text = '0'
		sle_total_qty.text = ''
		sle_unit_qty.text = ''
		em_creator_qty.text = ''
		sle_slip_no.text = '' 
		sle_supplier_lot_no.text =''
		sle_origin_supplier_code.text = ''
		sle_slip_no.setfocus( )
	end if 

end if 



end subroutine

