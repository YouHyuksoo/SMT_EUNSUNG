event ue_data_control;call super::ue_data_control;string lvs_date
double lvd_seq
Decimal  lvd_qty, lvd_packing_qty, lvd_request_qty, lvd_issue_qty
choose case gvs_ue_data_control
		
	case 'RETRIEVE'
		
			dw_1.reset()
			dw_2.reset()
			dw_1.retrieve( uo_dateset.text() , uo_dateend.text(),    ddlb_item_code.text() + '%',  sle_slip_no_condition.text+'%' , ddlb_receipt_type.getcode()+'%'  , ddlb_barcode_status.GETCODE()+'%' ,  gvi_organization_id)
			
			sle_lot_no.text = ''
			sle_lot_no.setfocus()
			st_status.text = 'Waitting'
	 
     case 'INSERT'
		
					LVL_ROW = DW_1.INSERTROW(1)
					DW_1.SCROLLTOROW(LVL_ROW)
					F_SET_SECURITY_ROW(DW_1 , LVL_ROW ,'ALL')
	
	case 'UPDATE'
		
			IF dw_1.UPDATE() < 0   or dw_2.update()  < 0 THEN 
				ROLLBACK;
				
				dw_1.reset()
			    dw_2.reset()
			
				RETURN					
			ELSE
				COMMIT;
				F_MSG_MDI_HELP( "Update Complete" )//$$HEX14$$31c1f5ac01c83cc75cb8200000c8a5c7200018b4c8c5b5c2c8b2e4b2$$ENDHEX$$"
				sle_lot_no.setfocus()		 
			END IF

	case else
end choose

end event

event clicked;call super::clicked;sle_lot_no.setfocus()
end event

event resize;call super::resize;st_status.width = dw_1.width + dw_2.width
end event

