//							  COMMENTS,   
//							  WORK_ORDER_NO,   
//							  CURRENCY,   
//							  BARCODE,   
//							  RECEIPT_STATUS,   
//							  ITEM_CODE,   
//							  MATERIAL_MFS,   
//							  INTERFACE_YN,   
//							  INTERFACE_DATE,   
//							  RECEIPT_LOT_NO,   
//							  RECEIPT_EXPENSE_COST,   
//							  INCIDENTAL_EXPENSE_CODE,   
//							  INTERFACE_WORK_NO,   
//							  TARIFF_RATE,   
//							  TARIFF_AMT,   
//							  ORDER_NO,   
//							  ORIGIN_MFS,   
