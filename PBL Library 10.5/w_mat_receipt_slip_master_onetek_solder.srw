event dw_2::buttonclicked;call super::buttonclicked;String lvs_msl_level, lvs_itemcode

if dwo.name = 'b_print' then 
	
//	if cbx_zebra_print.checked = true then 
//	   wf_print_comport( this.object.lot_no[row] ,  this.object.receipt_slip_no[row], this.object.item_code[row] ,  gvi_organization_id )
//	else
		 
		lvs_itemcode = this.object.item_code[row]
   	     dw_5.retrieve( this.object.item_code[row] , this.object.receipt_slip_no[row] , this.object.lot_no[row] , gvi_organization_id )
			  
		if dw_5.rowcount() > 0 then 
			
	  	     dw_5.Object.DataWindow.Print.Page.Range= '1'
			dw_5.print( )
			
			//$$HEX7$$68d5b5c27cb7a8bc20009ccd25b8$$ENDHEX$$
			If cbx_msl.checked = true Then			  	 
				// MSL$$HEX6$$90c7acc7ecc580bdb4cc6cd0$$ENDHEX$$
				  SELECT NVL(msl_level, '0')
					  INTO :lvs_msl_level
					FROM  id_item
				  WHERE item_code = :lvs_itemcode
					  AND organization_id = :gvi_organization_id  ;
				  
				  IF F_SQL_CHECK() < 0 THEN 
				  Else
					 IF  lvs_msl_level > '2'  THEN
						 dw_7.retrieve( this.object.item_code[row] , this.object.receipt_slip_no[row] , this.object.lot_no[row] , gvi_organization_id )
						 if dw_7.rowcount() > 0 then 	
							dw_7.print( )
						 end if
					  End if	
				  END IF 		
			End if	
		else
			f_msgbox(117)
		end if 
		
	
//	end if 

end if 

end event

