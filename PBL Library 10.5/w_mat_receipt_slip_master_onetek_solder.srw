event modified;call super::modified;int lvi_Pos
long lvl_return_qty, lvl_supplier_index, lvl_supplier_count, lvl_unit_qty
string lvs_supplier_name, lvs_parsing_pn

string     lvs_valid_stat
datetime lvdt_valid_date

lvdt_valid_date =  uo_valid_date.text() 

lvs_valid_stat = 'N'

select 'Y'
  into :lvs_valid_stat
  from dual
where :lvdt_valid_date > trunc(sysdate) + 30;

if lvs_valid_stat = 'N' then

   messagebox('NG', '$$HEX13$$94c154b3200020c7a8d67cc744c7200055d678c758d524b194c6$$ENDHEX$$. ($$HEX7$$04d6acc77cc7200030ae00c92000$$ENDHEX$$30$$HEX4$$7cc7200074c7c1c0$$ENDHEX$$)' )
   uo_valid_date.setfocus( )	
	
  this.text = ''	
  return

end if


lvi_dual_loop = 0 

if this.text = '' or isnull(this.text) then 
		sle_slip_no.setfocus( )
		ivi_error = -1 
		return 
else
	
	  lvs_slip_no_origin = this.text
	  lvs_supplier = ddlb_supplier_code.getcode()
	  
	  
     //================================================
     // $$HEX3$$94c154b32000$$ENDHEX$$item $$HEX7$$85c725b8ecc580bd200055d678c7$$ENDHEX$$
     //================================================	
//	  if not (lvs_slip_no_origin = 'M951X9' or lvs_slip_no_origin = 'TLF204' or lvs_slip_no_origin = 'GRN360' or lvs_slip_no_origin = 'RMA202') then 
//	
//   	     st_status.text = F_MSG( "$$HEX13$$94c154b3200088d4a9ba44c7200085c725b8200058d538c194c6$$ENDHEX$$." , 'S')
//	     f_play_sound("$$HEX6$$98c7bbba1cb414bc54cfdcb4$$ENDHEX$$.wav")	
//	
//	     this.selecttext(1,100)
//	     this.setfocus()
//	     return;
//
//      end if 
		
		
	  
	     //================================================
         // $$HEX11$$70ac98b798cc200085c725b8ecc580bd200055d678c7$$ENDHEX$$
         //================================================	
	  if lvs_supplier = '' or lvs_supplier = '%' then 
	
   	     st_status.text = F_MSG( "$$HEX11$$70ac98b798cc7cb9200020c1ddd0200058d538c194c6$$ENDHEX$$." , 'S')
	     f_play_sound("$$HEX9$$70ac98b798cc7cb920c1ddd058d538c194c6$$ENDHEX$$.wav")
	
	     this.text = ''	
	     ddlb_supplier_code.setfocus()
	      return;

      end if 
	
end if 

//================================================
//$$HEX12$$15c8c1c001c878c72000acc2bdb9200078c785acb0c62000$$ENDHEX$$
//================================================
if rb_normal_slip.checked = true then 
		wf_ok_slip_receipt()		
		return 
end if 
	
//==================================================
// $$HEX18$$04c85cd4c6c574c7200098ccacb9200058d594b2bdacb0c6ccb92000e4b4b4c534c62000$$ENDHEX$$
//==================================================
if cbx_dual_pcb_slip.checked = true then 
	
		lvi_dual_pos =   pos( this.text , '/' , 1 )
		lvi_dual_pos2 =   pos( this.text , '-' , 1 )
		
		if 	lvi_dual_pos > 0 and lvi_dual_pos2 > 0 then 
			
				if em_pcb_qty1.text = '' or em_pcb_qty2.text = '' then 
					st_status.text = F_MSG('PCB Qty Check' ,'S') 
					this.text = ''
					em_pcb_qty1.setfocus()
					ivi_error = -1 
					return 
				end if 
			
			lvs_dual_item_bottom =   trim(mid( this.text  ,pos( this.text , '/' , 1 ) + 1 , 30 ))
			
			lvs_dual_item_code[1] =   mid( this.text  , 1 , pos( this.text , '/' , 1 ) -1 ) 
			lvs_dual_item_code[2] =   mid( this.text  , 1 , lvi_dual_pos2 ) + lvs_dual_item_bottom
			
		else
			
			lvs_dual_item_code[1] = this.text
			
		end if 
else 
 		    lvs_dual_item_code[1] = this.text
end if 
//=================================================
//
//=================================================
   do
				lvi_dual_loop++
		
		
				lvs_slip_no = lvs_slip_no_origin
				lvs_supplier = ddlb_supplier_code.getcode()
				lvs_supplier_barcode = ''
			     lvs_supplier_barcode = trim(lvs_slip_no_origin )
				
				lvs_item_code = ''
				lvl_material_qty = 0 
				lvl_material_qty2 = 0  
				lvl_material_qty3 = 0 
	
				sle_material_qty1.text = ''
				sle_material_qty2.text = ''
				sle_material_qty3.text = '' 				
				
				//==================================================
				// $$HEX7$$f5ac09aec1c02000b4cc6cd02000$$ENDHEX$$
				//==================================================
				
				if lvs_supplier = '%' then
					st_status.text = F_MSG('Supplier Code Check' ,'S') 
					ddlb_supplier_code.setfocus()
					this.text = ''
					sle_supplier_lot_no.text =''
					sle_origin_supplier_code.text = ''
					ivi_error = -1 
					return 
				end if 
				
				//==================================================
				
				if  len(lvs_slip_no_origin) < 5 then 
					this.text = '' 
					sle_supplier_lot_no.text =''
					sle_origin_supplier_code.text = ''
					st_status.text = F_MSG(  "Barcode Invalid" , 'P' )
					return 
				end if 

				//=======================================
				// $$HEX16$$14bc54cfdcb47cb9200084bd74d5200074d51cc1200088d4a9ba98ccacb92000$$ENDHEX$$
				//=======================================
				
				lvs_supplier_barcode   = lvs_dual_item_code[lvi_dual_loop ]
				
			    lvs_supplier_item_code = lvs_supplier_barcode
				 
					//===============================================
					// $$HEX25$$f5ac09aec1c0200088d488bc20003cc75cb8200070c88cd6200074d51cc120005ccd85c8200088d488bc2000e8cd9ccd2000$$ENDHEX$$
					//===============================================

						SELECT ITEM_CODE, material_qty 
						   INTO :lvs_item_code, :lvl_unit_qty
					 	 FROM ID_ITEM 
						WHERE ( ITEM_CODE = :lvs_supplier_item_code or  PART_NO = :lvs_supplier_item_code )
						     AND ORGANIZATION_ID = :GVI_ORGANIZATION_ID
							 AND ROWNUM = 1;	
				
						IF F_SQL_CHECK() < 0 THEN 
								sle_lot_no.text = ''	
								sle_item_code.text = ''
								this.text = ''
								sle_supplier_lot_no.text =''
								sle_origin_supplier_code.text = ''
								sle_slip_no.setfocus()
								ivi_error = -1 
								return  
						END IF 		

						//===============================================
						// $$HEX25$$f5ac09aec1c0200088d488bc20003cc75cb8200070c88cd6200074d51cc120005ccd85c8200088d488bc2000e8cd9ccd2000$$ENDHEX$$
						//===============================================
						sle_item_code.text = lvs_item_code
						sle_unit_qty.text = string(lvl_unit_qty)
									
						//================================================
						if f_check_item_exists( lvs_item_code , f_t_sysdate())  < 1 then 
							f_play_sound("$$HEX6$$98c7bbba1cb414bc54cfdcb4$$ENDHEX$$.wav")		
							f_msgbox(9041)	
							sle_lot_no.text = ''	
							this.text = ''
							sle_item_code.text = ''
							sle_supplier_lot_no.text =''
							sle_origin_supplier_code.text = ''
							sle_slip_no.setfocus()
							ivi_error = -1 
							return 
						end if 
						
					//======================================
					//  $$HEX10$$f5ac09aec5c5b4cc200090c7d9b3c0c915c82000$$ENDHEX$$(id_item $$HEX2$$30ae00c9$$ENDHEX$$)
					//======================================		
					
//					SELECT s.supplier_code
//	                     INTO :lvs_supplier_name
//                        FROM id_item        i,
//                                  icom_supplier  s
//                     WHERE i.supplier_code = s.supplier_code
//                          AND i.item_code = : lvs_item_code
//                          AND rownum = 1;
								  
					//======================================
					//  $$HEX10$$f5ac09aec5c5b4cc200090c7d9b3c0c915c82000$$ENDHEX$$(im_item_unit_price $$HEX2$$30ae00c9$$ENDHEX$$)
					//======================================	
					
					lvs_supplier = ddlb_supplier_code.getcode()
								  
                     SELECT count(*)
  					  INTO :lvl_supplier_count
	                   FROM im_item_unit_price
                      WHERE item_code        =  :lvs_item_code
						AND supplier_code   =  :lvs_supplier
						AND dateset            <= trunc(sysdate)
						AND dateend           >= trunc(sysdate)
                           AND organization_id = 1;							  
								  
                      IF F_SQL_CHECK() < 0 THEN 
								sle_lot_no.text = ''	
								sle_item_code.text = ''
								this.text = ''
								sle_supplier_lot_no.text =''
								sle_origin_supplier_code.text = ''
								ddlb_supplier_code.setfocus()
								ivi_error = -1 
								return  
				   END IF				
					
//					//======================================
//					// $$HEX4$$70c88cd61cb42000$$ENDHEX$$supplier$$HEX4$$7cb9200020c1ddd0$$ENDHEX$$
//					//======================================		
//					
// //				   lvl_supplier_index = ddlb_supplier_code.finditem(lvs_supplier_name,0)
// //	  
// //	                if lvl_supplier_index <> -1  then
// //		              ddlb_supplier_code.selectitem(lvl_supplier_index)
// //	                end if
//								
//				   IF 	lvl_supplier_count  = 0 THEN
//						messagebox("* $$HEX4$$4cc52000bcb92000$$ENDHEX$$*", "$$HEX23$$e8b200ac2000f8bbf1b45db8200010b694b2200088d4a9bad0c5200000b35cd52000f5ac09ae98cc200074c7c1c0$$ENDHEX$$,  $$HEX7$$55d678c7200014bc8db7c8b2e4b2$$ENDHEX$$")
//                           st_status.text = F_MSG('Supplier Code Check' ,'S') 
//				   	    ddlb_supplier_code.setfocus()
//					    this.text = ''
//					    sle_supplier_lot_no.text =''
//					    sle_origin_supplier_code.text = ''
//					    ivi_error = -1 
//					    return 						
//				   END IF;	
					                    
					//======================================
					//  $$HEX3$$c0b4bcc52000$$ENDHEX$$pcb  $$HEX12$$90c7d9b33cc75cb8200024c115c858d594b2bdacb0c62000$$ENDHEX$$
					//======================================
					 if cbx_dual_pcb_slip.checked = true then 
						
						        if lvi_dual_loop = 1 then 
										sle_material_qty1.text = em_pcb_qty1.text
										sle_material_qty2.text = em_pcb_qty1.text
										sle_material_qty3.text = em_pcb_qty1.text
										em_creator_qty.text =em_pcb_qty1.text
										sle_total_qty.text =em_pcb_qty1.text
										sle_unit_qty.text  =em_pcb_qty1.text
										sle_reel_qty.text = string(1)
										wf_no_slip_receipt()
										sle_slip_no.setfocus( )
										continue 		
							else
											sle_material_qty1.text = em_pcb_qty2.text
											sle_material_qty2.text = em_pcb_qty2.text
											sle_material_qty3.text = em_pcb_qty2.text		
											em_creator_qty.text =em_pcb_qty2.text
											sle_total_qty.text =em_pcb_qty1.text
											sle_unit_qty.text  =em_pcb_qty1.text
											sle_reel_qty.text = string(1)
											wf_no_slip_receipt()
											sle_slip_no.setfocus( )
											continue 										
							end if 
							
					end if 
					//======================================
					// $$HEX18$$85c7e0ac18c2c9b744c7200090c7d9b33cc75cb8200024c115c858d594b2bdacb0c62000$$ENDHEX$$
					//======================================					
					if cbx_check_material_qty.checked = true then 	
						
									SELECT  material_qty , material_qty2 , material_qty3 
									INTO :lvl_material_qty , :lvl_material_qty2  ,:lvl_material_qty3
									FROM ID_ITEM 
									WHERE   ( ITEM_CODE = :lvs_supplier_item_code or  PART_NO = :lvs_supplier_item_code )
									   AND ORGANIZATION_ID = :GVI_ORGANIZATION_ID ;	
							
									IF F_SQL_CHECK() < 0 THEN 
											sle_lot_no.text = ''	
											sle_item_code.text = ''
											this.text = ''
											sle_supplier_lot_no.text =''
											sle_origin_supplier_code.text = ''
											sle_slip_no.setfocus()
											ivi_error = -1 
											return  
									END IF 		
												
										sle_material_qty1.text =string( lvl_material_qty)
										sle_material_qty2.text =string( lvl_material_qty2)
										sle_material_qty3.text =string( lvl_material_qty3)	
			
										if lvl_material_qty <> 0 and  lvl_material_qty2 = 0 and lvl_material_qty3 = 0  then 
											
											em_creator_qty.setfocus( )
											em_creator_qty.text = string(lvl_material_qty) 
											wf_no_slip_receipt()
											sle_slip_no.setfocus( )
											return 

										//=====================================
										// $$HEX23$$18c2c9b774c7200050b41cac74c7c1c0200088c73cc774ba200020c1ddd02000200058d58cac20005cd5e4b22000$$ENDHEX$$
										//=====================================
										elseif  lvl_material_qty <> 0 and  lvl_material_qty2 <> 0 then 
			
												openwithparm( w_mat_new_item_set_msl_location_popup ,  lvs_item_code ) 
												if long(message.stringparm) > 0  then 
													em_creator_qty.setfocus( )
													em_creator_qty.text =message.stringparm
													//===================================
													//
													//===================================
													wf_no_slip_receipt()
													sle_slip_no.setfocus( )
													return 
												end if 
										end if 
					end if 
					em_creator_qty.setfocus( )
 
loop until lvi_dual_loop = upperbound(lvs_dual_item_code) 

end event

event getfocus;call super::getfocus;string     lvs_valid_stat
datetime lvdt_valid_date

lvdt_valid_date =  uo_valid_date.text() 

lvs_valid_stat = 'N'

select 'Y'
  into :lvs_valid_stat
  from dual
where :lvdt_valid_date > trunc(sysdate) + 30;

if lvs_valid_stat = 'N' then

   messagebox('NG', '$$HEX13$$94c154b3200020c7a8d67cc744c7200055d678c758d538c194c6$$ENDHEX$$. ($$HEX7$$04d6acc77cc7200030ae00c92000$$ENDHEX$$30$$HEX4$$7cc7200074c7c1c0$$ENDHEX$$)' )
   uo_valid_date.setfocus( )	
	
   return

else
	
   st_status.text = f_msg("$$HEX12$$acc2bdb988bc38d67cb92000a4c294ce200058d538c194c6$$ENDHEX$$" , 'S' )
   f_play_sound("$$HEX6$$acc2bdb988bc38d6a4c294ce$$ENDHEX$$.wav")

end if


end event

