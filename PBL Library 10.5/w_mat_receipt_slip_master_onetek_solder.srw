//							  RECEIPT_DEFICIT,   
//							  LINE_TYPE,   
//							  RECEIPT_QTY,   
//							  MATERIAL_COST,   
//							  UNIT_PRICE,   
//							  MATERIAL_COST_AMT,   
//							  ENTER_DATE,   
//							  INVOICE_NO,   
//							  RECEIPT_AMT,   
//							  ENTER_BY,   
//							  EXCHANGE_RATE,   
//							  FOREIGN_RECEIPT_AMT,   
//							  SUPPLIER_CODE,   
//							  LAST_MODIFY_DATE,   
//							  LAST_MODIFY_BY,   
//							  CONFIRM_YN,   
//							  CONFIRM_DATE,   
//							  RECEIPT_TYPE,   
//							  MFS,   
//							  ARRIVAL_DATE,   
//							  ARRIVAL_SEQ_NO,   
