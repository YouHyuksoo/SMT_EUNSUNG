event clicked;call super::clicked;STRING lvs_msl_check, lvs_itemcode, lvs_msl_level
 i =0

if sle_item_code.text = '' or lvs_slip_no_origin  = '' then 
   st_status.text = "$$HEX20$$88d4a9ba54cfdcb400ac2000c6c570ac98b02000acc2bdb988bc38d600ac2000c6c5b5c2c8b2e4b2$$ENDHEX$$"
   f_msgbox(117)
   sle_lot_no.setfocus()
   return 
end if 

//=========================================
//
//=========================================

if dw_1.getrow() < 1 then return 

    //  dw_5.reset()
    //  dw_6.reset()
	//  dw_7.reset()
	  
     // f_set_column_dddw(dw_5)
      
//===========================================   
// $$HEX5$$94c154b37cb7a8bc2000$$ENDHEX$$or $$HEX4$$7cc718bc7cb7a8bc$$ENDHEX$$
//===========================================

         dw_5.retrieve( dw_1.object.item_code[dw_1.getrow()] ,  dw_1.object.receipt_slip_no[dw_1.getrow()]  ,  '%' , gvi_organization_id )
			
         if dw_5.rowcount() > 0 then 
         ELSE
            f_msgbox(117)
            RETURN 
         END IF   
			
    
   //=====================================
   // LG$$HEX9$$7cb7a8bc2000d9b3dcc220009ccd25b82000$$ENDHEX$$
   //=====================================
   if cbx_lg.checked = true then
      
      dw_6.retrieve(dw_1.object.item_code[dw_1.getrow()] ,  dw_1.object.receipt_slip_no[dw_1.getrow()]  ,  '%' , gvi_organization_id )
      if dw_6.rowcount() > 0 then
      else
         f_msgbox(117)
         return 
      end if
      
   end if

//===========================================   
//$$HEX7$$68d5b5c27cb7a8bc20009ccd25b8$$ENDHEX$$
// MSL$$HEX6$$90c7acc7ecc580bdb4cc6cd0$$ENDHEX$$
//===========================================
If cbx_msl.checked = true Then          

		lvs_itemcode = dw_1.object.item_code[dw_1.getrow()]

		SELECT NVL(msl_level, '0')
		INTO :lvs_msl_level
		FROM  id_item
		WHERE item_code = :lvs_itemcode
		AND organization_id = :gvi_organization_id  ;
		
		IF F_SQL_CHECK() < 0 THEN 
			RETURN 
		END IF 

		IF  lvs_msl_level > '2'  THEN
			dw_7.retrieve( dw_1.object.item_code[dw_1.getrow()] ,  dw_1.object.receipt_slip_no[dw_1.getrow()]  ,  '%' , gvi_organization_id )
			if dw_7.rowcount() > 0 then
			else
				f_msgbox(117)
				return
			end if			
			
		End if   
		
End if      
			
			
//=========================================================
// $$HEX8$$c0c9f8ad1cc8f8ad20009ccd25b82000$$ENDHEX$$
//=========================================================
    DO
      
      i++
      
	 dw_5.Object.DataWindow.Print.Page.Range= STRING(i)
      dw_5.print(false )
		
      if cbx_lg.checked = true then
			
         dw_6.Object.DataWindow.Print.Page.Range= STRING(i)
         dw_6.print(false )      
			
      end if 

     If cbx_msl.checked = true and  lvs_msl_level > '2'  THEN           
		dw_7.Object.DataWindow.Print.Page.Range= STRING(i)
		dw_7.print( false)
      end if 
		
   LOOP UNTIL i = dw_5.rowcount( )               
               
   sle_lot_no.setfocus()
end event

event rbuttondown;call super::rbuttondown;dw_3.retrieve( dw_1.object.item_code[dw_1.getrow()] ,  dw_1.object.receipt_slip_no[dw_1.getrow()]  ,  '%' , gvi_organization_id )
end event

