//f_play_sound("$$HEX4$$00c8a5c731c1f5ac$$ENDHEX$$.wav")
//st_status.text = '$$HEX10$$15c8c1c098ccacb9200018b4c8c5b5c2c8b2e4b2$$ENDHEX$$'
