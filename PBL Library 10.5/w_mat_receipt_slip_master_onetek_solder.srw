event modified;call super::modified;string  lvs_item_code_barcode  ,  lvs_reel_qty , lvs_totla_qty , lvs_mark, lvs_supplier_name
integer lvi_supplier_index
datetime lvdt_receipt_date
long lvl_supplier_count		

ivi_error =  0 
cbx_manual_slip.CHecked = true

dw_2.reset()
//=========================================================================
//
//=========================================================================
	  
if ddlb_supplier_code.getcode() = '' or ddlb_supplier_code.getcode() = '*' or ddlb_supplier_code.getcode() = '%' then 
	
   	    st_status.text = F_MSG( "$$HEX11$$70ac98b798cc7cb9200020c1ddd0200058d538c194c6$$ENDHEX$$." , 'S')
	    f_play_sound("$$HEX9$$70ac98b798cc7cb920c1ddd058d538c194c6$$ENDHEX$$.wav")
	
	    this.text = ''	
	    ddlb_supplier_code.setfocus()
	    ivi_error = -1 
	    return -1

end if 

lvl_receipt_sequence =    LONG(f_get_any_no( 'SEQ_RECEIPT_SLIP') )
	 
lvs_item_code_barcode = sle_lot_no.text
lvdt_receipt_date         = f_sysdate()

if len(this.text) <0 or isnull(this.text) or sle_lot_no.text ='' then
	ivi_error = -1 
	return -1
	sle_lot_no.setfocus()
end if
//======================================================
//  $$HEX25$$6dd5a9ba6cad84bd90c77cb920000cd345c574d51cc1200018c2d9b378c7c0c9200090c7d9b378c7c0c920006cad84bd2000$$ENDHEX$$
//  $$HEX21$$18c2d9b37cc72000bdacb0c62000200084bd60d5200018c2c9b744c7200018c2d9b32000f1b45db82000$$ENDHEX$$
//======================================================
	int lvl_pos2  

     lvl_check_Pos =  pos(lvs_item_code_barcode , "+" , 7 ) 
	  
	 if lvl_check_Pos > 0 then 
		lvs_mark = "+"
		cbx_manual_slip.checked = false
	else
		lvl_check_Pos =  pos(lvs_item_code_barcode , "," , 1 ) 
		 if lvl_check_Pos > 0 then 
			lvs_mark = ","
			cbx_manual_slip.checked = true
		end if 
	 end if 

//if rb_normal.checked = false and 	 lvs_mark = "+" then 
//		f_play_sound("$$HEX6$$85c7e0ac20c715d624c658b9$$ENDHEX$$.wav")	    
//		sle_lot_no.setfocus()
//		sle_lot_no.selecttext( 1,100)	
//		return 
//end if 
	 
//====================================================	 
//	 
//====================================================
     lvl_pos1 =  pos(lvs_item_code_barcode , lvs_mark , 7 ) 
	  
	if  lvl_pos1 <= 0 then 
		f_play_sound("$$HEX6$$98c7bbba1cb414bc54cfdcb4$$ENDHEX$$.wav")			
		f_msgbox1(1175 ,lvs_item_code_barcode )
		sle_lot_no.text = ''	
		sle_lot_no.setfocus()
		sle_lot_no.selecttext( 1,100)
	    ivi_error = -1 
		return -1
	end if 
	  
	lvs_item_code =   trim( mid( lvs_item_code_barcode , 1 ,   lvl_pos1  -1 ))
		
	if f_check_item_exists( lvs_item_code , f_t_sysdate())  < 1 then 
		
   	   f_play_sound("$$HEX6$$98c7bbba1cb414bc54cfdcb4$$ENDHEX$$.wav")		
	   f_msgbox(9041)	
	   sle_lot_no.text = ''	
	   sle_lot_no.setfocus()
	   sle_lot_no.selecttext( 1,100)		
	   ivi_error = -1 
	   return -1
	end if 
	
//=========================================================================
//  $$HEX3$$94c154b32000$$ENDHEX$$item $$HEX5$$78c7c0c9200055d678c7$$ENDHEX$$
//=========================================================================
  
	  if not (lvs_item_code = 'M951X9' or lvs_item_code = 'TLF204' or lvs_item_code = 'GRN360' or lvs_slip_no_origin = 'RMA202') then 
	
   	     st_status.text = F_MSG( "$$HEX13$$94c154b3200088d4a9ba44c7200085c725b8200058d538c194c6$$ENDHEX$$." , 'S')
	     f_play_sound("$$HEX6$$98c7bbba1cb414bc54cfdcb4$$ENDHEX$$.wav")	
	
	     sle_lot_no.text = ''	
	     sle_lot_no.setfocus()
	     sle_lot_no.selecttext( 1,100)		
	     ivi_error = -1 
	     return -1

      end if 
		

     sle_item_code.text = lvs_item_code
 
	lvl_pos2 =  pos(lvs_item_code_barcode , lvs_mark, lvl_pos1+1 ) 
	
	if  lvl_pos2 <= 0 then 
		f_play_sound("$$HEX6$$98c7bbba1cb414bc54cfdcb4$$ENDHEX$$.wav")
		f_msgbox1(1175 ,lvs_item_code_barcode )
		
		sle_item_code.text  = ''
		sle_lot_no.text = ''	
		sle_lot_no.setfocus()
		sle_lot_no.selecttext( 1,100)		
		ivi_error = -1 
		return -1
	end if 	
	
	lvs_reel_qty =    trim(mid( lvs_item_code_barcode ,  lvl_pos1+1   ,  lvl_pos2 -lvl_pos1 -1 ))
	sle_reel_qty.text = lvs_reel_qty
	
	//===================================================
	// $$HEX4$$1dcd18c2c9b72000$$ENDHEX$$
	//===================================================
	lvs_totla_qty =   trim( mid( lvs_item_code_barcode ,  lvl_pos2+1   ,  len(lvs_item_code_barcode) - lvl_pos2 ))
	
	if  long(lvs_totla_qty) <= 0 then 
		f_play_sound("$$HEX6$$98c7bbba1cb414bc54cfdcb4$$ENDHEX$$.wav")
		f_msgbox1(1175 ,lvs_item_code_barcode )
		sle_item_code.text  = ''
		sle_reel_qty.text = ''
		 sle_lot_no.text = ''	
		sle_lot_no.setfocus()		
		sle_lot_no.selecttext( 1,100)
		ivi_error = -1 
		return -1
	end if 	
	
	sle_total_qty.text = lvs_totla_qty	
	
	//======================================
	// $$HEX4$$20c1ddd01cb42000$$ENDHEX$$supplier$$HEX4$$7cb9200020c1ddd0$$ENDHEX$$
	//======================================		
	
    lvs_supplier = ddlb_supplier_code.getcode()
	
	                 SELECT count(*)
  					  INTO :lvl_supplier_count
	                   FROM im_item_unit_price
                      WHERE item_code        =  :lvs_item_code
						AND supplier_code   =  :lvs_supplier
						AND dateset            <= trunc(sysdate)
						AND dateend           >= trunc(sysdate)
                           AND organization_id = 1;							  
								  
                      IF F_SQL_CHECK() < 0 THEN 
								sle_lot_no.text = ''	
								sle_item_code.text = ''
								this.text = ''
								sle_supplier_lot_no.text =''
								sle_origin_supplier_code.text = ''
								ddlb_supplier_code.setfocus()
								ivi_error = -1 
								return  
				   END IF				
													
				   IF 	lvl_supplier_count  = 0 THEN
						messagebox("* $$HEX4$$4cc52000bcb92000$$ENDHEX$$*", "$$HEX23$$e8b200ac2000f8bbf1b45db8200010b694b2200088d4a9bad0c5200000b35cd52000f5ac09ae98cc200074c7c1c0$$ENDHEX$$,  $$HEX7$$55d678c7200014bc8db7c8b2e4b2$$ENDHEX$$")
                           st_status.text = F_MSG('Supplier Code Check' ,'S') 
				   	    ddlb_supplier_code.setfocus()
					    this.text = ''
					    sle_supplier_lot_no.text =''
					    sle_origin_supplier_code.text = ''
					    ivi_error = -1 
					    return 						
				   END IF;	
					

//=====================================================
// $$HEX14$$30ae00c918c2c9b7200080bd69d52000ecc580bd2000b4cc6cd02000$$ENDHEX$$
//=====================================================
// long lvl_material_qty , lvl_material_qty2 , lvl_material_qty3
 
//select nvl(material_qty,0) , nvl(material_qty2 ,0) , nvl(material_qty3 ,0) 
//   into :lvl_material_qty , :lvl_material_qty2 , :lvl_material_qty3
// from id_item 
//where item_code =  :lvs_item_code
//    and organization_id = :gvi_organization_id  ;
//
//if f_sql_check() < 0 then 
//	ivi_error = -1 
//	return -1
//end if 

wf_set_material_qty() 

//======================================================
//  $$HEX9$$15c818c22000ecc580bd2000b4cc6cd02000$$ENDHEX$$
//  $$HEX22$$15c818c200ac200044c5c8b274ba200090c7d9b33cc75cb8200018c2d9b385c7e0ac20003dcc1dd3c5c52000$$ENDHEX$$
//======================================================
 if mod(  Long(lvs_totla_qty) , long(lvs_reel_qty) ) > 0 then 
	cbx_manual_slip.checked = true 		
ELSE
	//===========================================
	// $$HEX5$$e8b204c718c2c9b72000$$ENDHEX$$
	//===========================================
	sle_unit_qty.text = string( Long(lvs_totla_qty) / long(lvs_reel_qty) )
	cbx_manual_slip.CHecked = false
end if 

sle_material_qty1.text =string( lvl_material_qty)
sle_material_qty2.text =string( lvl_material_qty2)
sle_material_qty3.text =string( lvl_material_qty3)	
//======================================================
//  $$HEX23$$30ae00c9200018c2c9b7fcac2000c0d2b4b9bdacb0c6200018c2d9b3200085c725b820003dcc200024c608d52000$$ENDHEX$$
//  $$HEX10$$ecc5ecb71cac2000b4b9200074c774ba1cc12000$$ENDHEX$$
//======================================================
if cbx_check_material_qty.checked = true then 
	if long(sle_unit_qty.text) <> lvl_material_qty and  long(sle_unit_qty.text) <> lvl_material_qty2 and long(sle_unit_qty.text) <> lvl_material_qty3 and  long(lvs_reel_qty) <> 1  then 
		cbx_manual_slip.checked = true
	end if 
end if 
//====================================================	 
//	 $$HEX19$$18c2d9b37cc7bdacb0c6200084bd60d518c2c9b7200085c725b820003dcc20001dd3c5c52000$$ENDHEX$$
//====================================================	 
if cbx_manual_slip.checked = true then 

		 ivl_divide_qty = {0}
		 openwithparm (w_mat_slip_manual_qty_popup_onetek_solder ,lvs_totla_qty )   
		 
		 if  Upperbound(ivl_divide_qty) = 0  then		
			st_status.text = F_MSG( "Divide Qty Invalid" ,'S')
			sle_lot_no.text = ''
			sle_lot_no.setfocus()
			sle_lot_no.selecttext( 1,100)		
			sle_slip_no.text = ''
			ivi_error = -1 
			return -1
		elseif Upperbound(ivl_divide_qty) = 1 and ivl_divide_qty[1] = 0 then 
			st_status.text = F_MSG( "Divide Qty Invalid" , 'S')
			sle_lot_no.text = ''
			sle_lot_no.setfocus()
			sle_lot_no.selecttext( 1,100)		
			sle_slip_no.text = ''
			ivi_error = -1 
			return -1			
		end if 
		
end if 

sle_slip_no.text = ''
sle_slip_no.setfocus()

end event

type sle_slip_no from so_singlelineedit within w_mat_receipt_slip_master_onetek_solder
integer x = 594
