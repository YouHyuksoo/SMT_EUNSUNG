event selectionchanged;call super::selectionchanged;
       lvs_supplier = ddlb_supplier_code.getcode()
		 
     //================================================
     // $$HEX11$$70ac98b798cc200085c725b8ecc580bd200055d678c7$$ENDHEX$$
     //================================================	
	  
	  if  (lvs_supplier = '%' ) then 
	
   	     st_status.text = F_MSG( "$$HEX14$$94c154b3200070ac98b798cc7cb9200020c1ddd0200058d538c194c6$$ENDHEX$$." , 'S')
	     f_play_sound("$$HEX9$$70ac98b798cc7cb920c1ddd058d538c194c6$$ENDHEX$$.wav")
	
	     ddlb_supplier_code.setfocus()
	
      else

	     st_status.text  = ''
   	     sle_slip_no.setfocus()

      end if 
end event

