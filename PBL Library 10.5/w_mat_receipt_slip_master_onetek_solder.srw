event modified;call super::modified;sle_week.text = ''
STRING LVS_WEEK , LVS_SYS_WEEK
//PCB $$HEX13$$78c7bdacb0c62000d0c5ccb92000fcc828cc200000adacb92000$$ENDHEX$$
IF MID( THIS.TEXT , 1,3) = 'EAX' THEN 

	SELECT F_GET_LOT_NO_FROM_BARCODE( :THIS.TEXT)  , TO_CHAR( SYSDATE , 'YYWW')
	    INTO :LVS_WEEK , :LVS_SYS_WEEK 
	   FROM DUAL ;
	  
	IF  LEN(LVS_WEEK) = 4 THEN 
		sle_week.text = lvs_week
	ELSE
		sle_week.text = lvs_sys_week
	END IF 
	
END IF 	

sle_our_barcode.setfocus()
end event

