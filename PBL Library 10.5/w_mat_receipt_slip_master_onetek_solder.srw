type em_creator_qty from editmask within w_mat_receipt_slip_master_onetek_solder
integer x = 1842
integer y = 616
integer width = 357
integer height = 112
integer taborder = 30
boolean bringtotop = true
integer textsize = -10
integer weight = 400
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Tahoma"
long textcolor = 33554432
long backcolor = 16777215
boolean enabled = false
alignment alignment = right!
textcase textcase = upper!
borderstyle borderstyle = stylelowered!
maskdatatype maskdatatype = stringmask!
end type

event modified;int lvi_Pos
string lvs_qty , lvs_total_qty


				
				//==================================================
				// $$HEX7$$f5ac09aec1c02000b4cc6cd02000$$ENDHEX$$
				//==================================================
				
				if ddlb_supplier_code.getcode( ) = '%' then
					st_status.text = F_MSG('Supplier Code Check' ,'S') 
					ddlb_supplier_code.setfocus()
					this.text = ''
					sle_supplier_lot_no.text =''
					sle_origin_supplier_code.text = ''
					ivi_error = -1 
					return 
				end if 
				
				//==================================================
				
				if  len(sle_slip_no.text) < 5 then 
					this.text = '' 
					sle_supplier_lot_no.text =''
					sle_origin_supplier_code.text = ''
					st_status.text = F_MSG(  "Barcode Invalid" , 'S' )
					sle_slip_no.setfocus()
					return 
				end if 
				

//========================================
//  
//========================================
sle_reel_qty.text = string(1)
lvs_qty = this.text

//=========================================
//$$HEX11$$e4b2dcc25cd588bc200018c2c9b7d0c51cc120000900$$ENDHEX$$Q $$HEX5$$7cb920001cc870ac2000$$ENDHEX$$
//=========================================
if mid( upper(lvs_qty) , 1,1 ) = 'Q' then 

	sle_total_qty.text = string(long(trim(mid(lvs_qty , 2, 10))))
	sle_unit_qty.text  = string(long(trim(mid( lvs_qty , 2, 10))))
	
elseif lvs_qty ='' or  isnull(lvs_qty) or not isnumber(lvs_qty) then 
	
		st_status.text = F_MSG('$$HEX11$$18c2c9b744c7200055d678c7200058d538c194c62000$$ENDHEX$$CHECK QTY' , 'S') 		
		this.text = ''
		em_creator_qty.setfocus()
		ivi_error = -1 
		return 	
else
	
//	LVL_LOOP = 1
//
//	sle_reel_qty.text  = string(1)		
//	sle_total_qty.text = string(long( this.text))
//	sle_unit_qty.text  = string(long(this.text ))
	
end if 

//====================================================	 
//	 $$HEX19$$18c2d9b37cc7bdacb0c6200084bd60d518c2c9b7200085c725b820003dcc20001dd3c5c52000$$ENDHEX$$
//====================================================	 

 sle_total_qty.text = string(long(this.text))
 lvs_total_qty = sle_total_qty.text
		  
if  cbx_manual_slip.checked = true and long(sle_total_qty.text) > 0 and long(sle_unit_qty.text) > 0  and  (long(sle_total_qty.text) > long(sle_unit_qty.text))  then 	    
 	      	  
		 if ( mod( long(sle_total_qty.text) ,  long(sle_unit_qty.text)) > 0 ) then	  
              sle_reel_qty.text  = string(( long(sle_total_qty.text) /  long(sle_unit_qty.text))  +1)		
		else
			sle_reel_qty.text  = string(( long(sle_total_qty.text) /  long(sle_unit_qty.text)) )
		 end if
			
		 ivl_divide_qty = {0}
		 GST_RETURN.GVS_RETURN[1] = sle_unit_qty.text
		 openwithparm (w_mat_slip_manual_qty_popup_onetek_solder ,lvs_total_qty )   
		 
		 if  Upperbound(ivl_divide_qty) = 0  then		
			st_status.text = F_MSG( "Divide Qty Invalid" ,'S')
			sle_lot_no.text = ''
			sle_lot_no.setfocus()
			sle_lot_no.selecttext( 1,100)		
			sle_slip_no.text = ''
			ivi_error = -1 
			return -1
		elseif Upperbound(ivl_divide_qty) = 1 and ivl_divide_qty[1] = 0 then 
			st_status.text = F_MSG( "Divide Qty Invalid" , 'S')
			sle_lot_no.text = ''
			sle_lot_no.setfocus()
			sle_lot_no.selecttext( 1,100)		
			sle_slip_no.text = ''
			ivi_error = -1 
			return -1		
		else
			LVL_LOOP = UPPERBOUND(ivl_divide_qty)  
		end if         
			
else
	
	LVL_LOOP = 1

	sle_reel_qty.text  = string(1)		
	sle_unit_qty.text  = string(long(this.text ))
	
end if 


wf_no_slip_receipt()







end event

