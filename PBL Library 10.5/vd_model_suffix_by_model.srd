   WHERE ~"ID_ITEM~".~"MODEL_NAME~" = :ARG_MODEL_NAME
       AND ORGANIZATION_ID = :ARG_ORG   
" arguments=(("ARG_MODEL_NAME", string),("ARG_ORG", number))  sort="model_suffix A " )
