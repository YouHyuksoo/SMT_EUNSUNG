 retrieve=" select  a.item_code , b.item_name, b.item_spec, b.item_uom,b.virtual_receipt_yn, a.organization_id,
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'01', a.issue_qty, 0 ))  qty1, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'02', a.issue_qty, 0 ))   qty2, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'03', a.issue_qty, 0 ))   qty3, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'04', a.issue_qty, 0 ))   qty4, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'05', a.issue_qty, 0 ))    qty5, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'06', a.issue_qty, 0 ))    qty6, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'07', a.issue_qty, 0 ))    qty7, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'08', a.issue_qty, 0 ))    qty8, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'09', a.issue_qty, 0 ))    qty9, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'10', a.issue_qty, 0 ))  qty10, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'11', a.issue_qty, 0 ))  qty11, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'12', a.issue_qty, 0 ))  qty12, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'01', a.issue_amt, 0 ))    amt1, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'02', a.issue_amt, 0 ))    amt2, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'03', a.issue_amt, 0 ))    amt3, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'04', a.issue_amt, 0 ))    amt4, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'05', a.issue_amt, 0 ))    amt5, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'06', a.issue_amt, 0 ))    amt6, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'07', a.issue_amt, 0 ))    amt7, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'08', a.issue_amt, 0 ))    amt8, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'09', a.issue_amt, 0 ))    amt9, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'10', a.issue_amt, 0 ))    amt10, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'11', a.issue_amt, 0 ))    amt11, 
          sum(decode(to_char(a.issue_date,'yyyymm'), :arg_yyyy||'12', a.issue_amt, 0 ))    amt12
 from   im_item_issue a ,       
          id_item      b          
 where a.item_code = b.item_code 
 and    a.organization_id = b.organization_id 
 and    a.issue_date between to_date(:arg_yyyy||'0101', 'yyyymmdd')  and  to_date(:arg_yyyy||'1231', 'yyyymmdd') 
 and    a.item_code like :arg_item_code 
 and    a.organization_id = :arg_org_id 
 and    a.issue_status <> 'C'
group by a.item_code , b.item_name, b.item_spec, b.item_uom, b.virtual_receipt_yn,  a.organization_id
         

" arguments=(("arg_yyyy", string),("arg_item_code", string),("arg_org_id", number)) )
