 retrieve="  SELECT ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"RUN_NO~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"LINE_CODE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"MACHINE_CODE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"SCAN_DATE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"SCAN_BY~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"PCB_BARCODE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"ENTER_BY~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"WORKSTAGE_CODE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"LOT_QTY~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"SUPPLIER_CODE~",   
         ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"RECEIPT_STATUS~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_BARCODE~"  ,
         ~"IM_ITEM_RECEIPT_BARCODE~" .~"ITEM_BARCODE~",
          ~"ID_ITEM~".pcb_coating_type, 
          ~"ID_ITEM~".pcb_coating_max_day,
          ~"IM_ITEM_RECEIPT_BARCODE~".pcb_coating_date,
          ~"IM_ITEM_RECEIPT_BARCODE~".manufacture_week
    FROM ~"IP_PRODUCT_PCB_SCAN_MASTER~",   
         ~"ID_ITEM~",   
         ~"IM_ITEM_RECEIPT_BARCODE~"  
   WHERE ( ip_product_pcb_scan_master.item_code = id_item.item_code (+)) and  
         ( ip_product_pcb_scan_master.organization_id = id_item.organization_id (+)) and  
         ( ip_product_pcb_scan_master.pcb_barcode = im_item_receipt_barcode.item_barcode (+)) and  
         ( ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"PCB_BARCODE~" like :arg_pcb_barcode ) AND  
         ( ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"SCAN_DATE~" >= TRUNC(:arg_dateset) ) AND  
         ( ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"SCAN_DATE~" <  TRUNC(:arg_dateend) +1 )  AND 
         ( ~"IP_PRODUCT_PCB_SCAN_MASTER~".~"ORGANIZATION_ID~" = :arg_org )     
" arguments=(("arg_item_code", string),("arg_pcb_barcode", string),("arg_line_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number))  sort="scan_date A line_code A item_code A " )
