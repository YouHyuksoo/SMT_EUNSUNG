 column=(type=char(1) updatewhereclause=yes name=item_division dbname="id_item.item_division" dbalias=".item_division" )
 column=(type=char(6) updatewhereclause=yes name=close_yyyymm dbname="im_item_inventory_check.close_yyyymm" dbalias=".close_yyyymm" )
 retrieve="  SELECT ~"IM_ITEM_INVENTORY_CHECK~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"INVENTORY_AMT~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"LOCATION_CODE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"CHECK_INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"COMMENTS~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"ENTER_DATE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"ENTER_BY~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"CLOSE_YYYYMM~"  
    FROM ~"IM_ITEM_INVENTORY_CHECK~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY_CHECK~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY_CHECK~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_INVENTORY_CHECK~".~"CLOSE_YYYYMM~" = :arg_yyyymm ) AND  
         ( ( ~"IM_ITEM_INVENTORY_CHECK~".~"ITEM_CODE~" like :arg_item_code ) AND  
		 ( NVL(~"IM_ITEM_INVENTORY_CHECK~".~"LOCATION_CODE~",'*') like :arg_location_code ) AND  
         ( ~"IM_ITEM_INVENTORY_CHECK~".~"ORGANIZATION_ID~" = :arg_org_id ) ) )    
" arguments=(("arg_yyyymm", string),("arg_item_code", string),("arg_location_code", string),("arg_org_id", number)) )
