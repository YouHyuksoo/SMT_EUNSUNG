table(column=(type=char(30) updatewhereclause=yes name=serial_no dbname="ip_product_2d_barcode.serial_no" )
 column=(type=char(20) updatewhereclause=yes name=equipmentid dbname="iq_machine_inspect_data_mk.equipmentid" )
 column=(type=char(20) updatewhereclause=yes name=dateset dbname="iq_machine_inspect_data_mk.dateset" )
 column=(type=char(30) updatewhereclause=yes name=iq_machine_inspect_data_aoi_equipmentid dbname="iq_machine_inspect_data_aoi.equipmentid" )
 column=(type=char(30) updatewhereclause=yes name=iq_machine_inspect_data_aoi_inspect_date dbname="iq_machine_inspect_data_aoi.inspect_date" )
 column=(type=char(10) updatewhereclause=yes name=iq_machine_inspect_data_aoi_result dbname="iq_machine_inspect_data_aoi.result" )
 column=(type=char(1000) updatewhereclause=yes name=iq_machine_inspect_data_aoi_defect_code dbname="iq_machine_inspect_data_aoi.defect_code" )
 column=(type=char(30) updatewhereclause=yes name=iq_machine_inspect_data_spi_equipmentid dbname="iq_machine_inspect_data_spi.equipmentid" )
 column=(type=char(30) updatewhereclause=yes name=iq_machine_inspect_data_spi_inspect_date dbname="iq_machine_inspect_data_spi.inspect_date" )
 column=(type=char(10) updatewhereclause=yes name=iq_machine_inspect_data_spi_result dbname="iq_machine_inspect_data_spi.result" )
