 column=(type=number updatewhereclause=yes name=lot_qty dbname="ip_product_2d_barcode.lot_qty" )
 column=(type=datetime updatewhereclause=yes name=shipping_date dbname="ip_product_2d_barcode.shipping_date" )
 column=(type=datetime updatewhereclause=yes name=box_scan_date dbname="ip_product_pack_serial.box_scan_date" )
 column=(type=datetime updatewhereclause=yes name=imcn_jig_input_hist_input_date dbname="ip_product_2d_barcode.input_date" )
 column=(type=char(30) updatewhereclause=yes name=imcn_jig_input_hist_jig_lot_no dbname="ip_product_2d_barcode.jig_lot_no" )
 column=(type=number updatewhereclause=yes name=imcn_jig_input_hist_current_hit_value dbname="ip_product_2d_barcode.current_hit_value" )
 column=(type=datetime updatewhereclause=yes name=input_date dbname="ip_product_2d_barcode.input_date" )
 column=(type=char(61) updatewhereclause=yes name=jig_lot_no dbname="ip_product_2d_barcode.jig_lot_no" )
 column=(type=number updatewhereclause=yes name=current_hit_value dbname="ip_product_2d_barcode.current_hit_value" )
 column=(type=char(4000) updatewhereclause=yes name=solder_lot_no dbname="solder_lot_no" )
 column=(type=char(4000) updatewhereclause=yes name=mk_shipping_time dbname="mk_shipping_time" )
 column=(type=char(4000) updatewhereclause=yes name=repair_yn dbname="repair_yn" )
 column=(type=char(20) updatewhereclause=yes name=first_marking_date dbname="first_marking_date" )
 column=(type=char(20) updatewhereclause=yes name=last_marking_date dbname="last_marking_date" )
 column=(type=char(30) updatewhereclause=yes name=min_spi_inspect_date dbname="min_spi_inspect_date" )
 column=(type=char(30) updatewhereclause=yes name=max_spi_inspect_date dbname="max_spi_inspect_date" )
 column=(type=char(30) updatewhereclause=yes name=min_aoi_inspect_date dbname="min_aoi_inspect_date" )
 column=(type=char(30) updatewhereclause=yes name=max_aoi_inspect_date dbname="max_aoi_inspect_date" )
 column=(type=char(4000) updatewhereclause=yes name=spi_aoi_pass_time dbname="spi_aoi_pass_time" )
 column=(type=char(4000) updatewhereclause=yes name=mk_aoi_pass_time dbname="mk_aoi_pass_time" )
