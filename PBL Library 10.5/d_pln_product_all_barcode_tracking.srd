 column=(type=datetime updatewhereclause=yes name=ccs_end_date dbname="ccs_end_date" )
 retrieve="  SELECT ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"EQUIPMENTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"EQUIPMENTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"INSPECT_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"DEFECT_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"EQUIPMENTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"DEFECT_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LINE_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BOX_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"PALLETE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_QTY~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"SHIPPING_DATE~",   

		~"IP_PRODUCT_PACK_SERIAL~".~"SCAN_DATE~"  BOX_SCAN_DATE ,
         ~"A~".~"INPUT_DATE~" ,
         ~"A~".~"JIG_LOT_NO~",   
         ~"A~".~"CURRENT_HIT_VALUE~",   

         ~"B~".~"INPUT_DATE~",   
         ~"B~".~"JIG_LOT_NO~",   
         ~"B~".~"CURRENT_HIT_VALUE~",   

	  (	SELECT LISTAGG(SOLDER_LOT_NO, ',') WITHIN GROUP(ORDER BY SOLDER_LOT_NO) AS SOLDER_LOT_NO
		  FROM IM_ITEM_SOLDER_INPUT_HIST 
          WHERE RUN_NO = :ARG_RUN_NO
         )  AS SOLDER_LOT_NO , 
	
   		F_GET_TIME_TERM_HHHMISS(TO_DATE(~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~" ,'YYYY/MM/DD HH24:MI:SS') , NVL(~"IP_PRODUCT_2D_BARCODE~".~"SHIPPING_DATE~" ,SYSDATE) )  MK_SHIPPING_TIME,
		F_GET_PCB_REPAIR_YN( ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~"  , :arg_org ) REPAIR_YN,
         ( SELECT MIN( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~") FROM IQ_MACHINE_INSPECT_DATA_MK WHERE RUN_NO = :ARG_RUN_NO ) FIRST_MARKING_DATE ,
         ( SELECT MAX( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~") FROM IQ_MACHINE_INSPECT_DATA_MK WHERE RUN_NO = :ARG_RUN_NO ) LAST_MARKING_DATE ,

         ( SELECT MIN( ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~") FROM IQ_MACHINE_INSPECT_DATA_SPI WHERE RUN_NO = :ARG_RUN_NO ) MIN_SPI_INSPECT_DATE ,
         ( SELECT MAX( ~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~") FROM IQ_MACHINE_INSPECT_DATA_SPI WHERE RUN_NO = :ARG_RUN_NO ) MAX_SPI_INSPECT_DATE,
  
         ( SELECT MIN( ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"INSPECT_DATE~") FROM IQ_MACHINE_INSPECT_DATA_AOI WHERE RUN_NO = :ARG_RUN_NO ) MIN_AOI_INSPECT_DATE ,
         ( SELECT MAX( ~"IQ_MACHINE_INSPECT_DATA_AOI~".~"INSPECT_DATE~") FROM IQ_MACHINE_INSPECT_DATA_AOI WHERE RUN_NO = :ARG_RUN_NO ) MAX_AOI_INSPECT_DATE ,


   		F_GET_TIME_TERM_HHHMISS(TO_DATE(~"IQ_MACHINE_INSPECT_DATA_SPI~".~"INSPECT_DATE~",'YYYY/MM/DD HH24:MI:SS')  ,  TO_DATE(~"IQ_MACHINE_INSPECT_DATA_AOI~".~"INSPECT_DATE~",'YYYY/MM/DD HH24:MI:SS') )   SPI_AOI_PASS_TIME,
   		F_GET_TIME_TERM_HHHMISS( TO_DATE(~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~",'YYYY/MM/DD HH24:MI:SS') ,  TO_DATE(~"IQ_MACHINE_INSPECT_DATA_AOI~".~"INSPECT_DATE~",'YYYY/MM/DD HH24:MI:SS') )   MK_AOI_PASS_TIME,

		( SELECT MIN(INPUT_DATE) FROM IMCN_SAMPLE_INPUT_HIST WHERE RUN_NO = :ARG_RUN_NO ) SAMPLE_INPUT_DATE ,
		( SELECT MIN(CHECK_DATE) FROM IB_SMT_CHECKHIST WHERE RUN_NO = :ARG_RUN_NO AND CHECK_TYPE = '1' ) CCS_START_DATE,
		( SELECT MAX(CHECK_DATE) FROM IB_SMT_CHECKHIST WHERE RUN_NO = :ARG_RUN_NO AND CHECK_TYPE = '1' ) CCS_END_DATE

    FROM ~"IP_PRODUCT_2D_BARCODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~",   
         ~"IQ_MACHINE_INSPECT_DATA_AOI~",   
         ~"IQ_MACHINE_INSPECT_DATA_SPI~",   
         ~"IP_PRODUCT_PACK_SERIAL~" , 
         ( SELECT ~"IMCN_JIG_INPUT_HIST~".~"RUN_NO~",
					 MIN(~"IMCN_JIG_INPUT_HIST~".~"INPUT_DATE~") AS INPUT_DATE,   
					MAX(~"IMCN_JIG_INPUT_HIST~".~"JIG_LOT_NO~") AS JIG_LOT_NO,   
					MAX(~"IMCN_JIG_INPUT_HIST~".~"CURRENT_HIT_VALUE~")  AS CURRENT_HIT_VALUE
             FROM     ~"IMCN_JIG_INPUT_HIST~"  
           WHERE RUN_NO = :ARG_RUN_NO
                AND JIG_TYPE = 'M'
       GROUP BY ~"IMCN_JIG_INPUT_HIST~".~"RUN_NO~"  ) A ,

         ( SELECT ~"IMCN_JIG_INPUT_HIST~".~"RUN_NO~",
					 MIN(~"IMCN_JIG_INPUT_HIST~".~"INPUT_DATE~") AS INPUT_DATE,   
					 MIN(~"IMCN_JIG_INPUT_HIST~".~"JIG_LOT_NO~")||','|| MAX(~"IMCN_JIG_INPUT_HIST~".~"JIG_LOT_NO~") AS JIG_LOT_NO ,   
					 MAX(~"IMCN_JIG_INPUT_HIST~".~"CURRENT_HIT_VALUE~") AS CURRENT_HIT_VALUE
             FROM     ~"IMCN_JIG_INPUT_HIST~"  
           WHERE  RUN_NO = :ARG_RUN_NO
               AND  JIG_TYPE = 'S' 
          GROUP BY ~"IMCN_JIG_INPUT_HIST~".~"RUN_NO~" ) B 



		
   WHERE ( ip_product_2d_barcode.serial_no = iq_machine_inspect_data_mk.pid (+)) and  
         ( ip_product_2d_barcode.serial_no = iq_machine_inspect_data_aoi.pid (+)) and  
         ( ip_product_2d_barcode.serial_no = iq_machine_inspect_data_spi.pid (+)) and  
         ( ip_product_2d_barcode.serial_no = IP_PRODUCT_PACK_SERIAL.barcode (+)) and  
         ( ip_product_2d_barcode.run_no = A.run_no (+)) and  	
         ( ip_product_2d_barcode.run_no = B.run_no (+)) and  	
         ( ( ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~" = :arg_run_no ) AND  
         ( ~"IP_PRODUCT_2D_BARCODE~".~"ORGANIZATION_ID~" = :arg_org ) )    
" arguments=(("ARG_RUN_NO", string),("ARG_ORG", number))  sort="dateset A serial_no A " )
