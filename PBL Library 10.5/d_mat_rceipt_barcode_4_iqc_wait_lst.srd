 retrieve="  SELECT ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_BARCODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_NO~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_QTY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_BARCODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_ITEM_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_SLIP_NO~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ENTER_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ENTER_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"BARCODE_STATUS~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_TYPE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"FROM_SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_DIVIDE_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ORIGIN_ITEM_BARCODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LABEL_TYPE~",   
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",   
         ~"ID_ITEM~".~"MSL_LEVEL~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"INSPECT_RESULT~" ,
		F_GET_ESD_CHECK_CYCLE_VALUE(~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_CODE~",   ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_CODE~", ~"IM_ITEM_RECEIPT_BARCODE~".~"ORGANIZATION_ID~"  ) ESD_CHECK_CYCLE_VALUE ,
         ID_ITEM.ITEM_NAME , ID_ITEM.ITEM_SPEC , ID_ITEM.ITEM_CLASS ,
		 ~"IM_ITEM_RECEIPT_BARCODE~".~"MANUFACTURE_WEEK~",
		 ~"IM_ITEM_RECEIPT_BARCODE~".~"MANUFACTURE_DATE~" ,
	       IM_ITEM_RECEIPT_BARCODE.PCB_COATING_DATE

    FROM ~"IM_ITEM_RECEIPT_BARCODE~",   
              ~"ID_ITEM~"  
   WHERE ( im_item_receipt_barcode.item_code = id_item.item_code (+)) and  
         ( ( ~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_DATE~" < :arg_dateend + 1 ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_SLIP_NO~" like :arg_receipt_slip_no ) AND  
         ( nvl(~"IM_ITEM_RECEIPT_BARCODE~".~"INSPECT_RESULT~" , 'N') not in ( 'P' , 'R' ) ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"BARCODE_STATUS~" <> 'C' ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_BARCODE~" like :arg_item_barcode ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_YN~" = :arg_receipt_compare_yn ) AND  
	     ( ~"ID_ITEM~".~"ITEM_NAME~" LIKE :arg_item_name ) AND
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"ORGANIZATION_ID~" = :arg_org ) )    
" update="IM_ITEM_RECEIPT_BARCODE" updatewhere=0 updatekeyinplace=no arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_receipt_slip_no", string),("arg_receipt_compare_yn", string),("arg_item_name", string),("arg_item_barcode", string),("arg_org", number))  sort="receipt_slip_no A " )
