 retrieve="SELECT  ~"ISYS_REPORT_WHERE_CONDITION~".~"WINDOW_NAME~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"DATAWINDOW_NAME~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"COLUMN_NAME~" ,
           DECODE( '0' ,
 'K' ,
 WORD_KOR ,
 'E' ,
 WORD_ENG ,
 WORD_LOCAL ) COLUMN_DESC,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"DATA_TYPE~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"OPERATION~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"DEFAULT_VALUE~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"ENTER_BY~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"ENTER_DATE~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"LAST_MODIFY_BY~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"LAST_MODIFY_DATE~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"ORGANIZATION_ID~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"COLUMN_ORDER~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"RELATION~" ,
           ~"ISYS_REPORT_WHERE_CONDITION~".~"COLUMN_DESC~"     
        FROM ~"ISYS_REPORT_WHERE_CONDITION~" ,
           ~"ISYS_WORD_DICTIONARY~"     
        WHERE ( ~"ISYS_REPORT_WHERE_CONDITION~".~"COLUMN_NAME~" = ~"ISYS_WORD_DICTIONARY~".~"COLUMN_NAME~" ) and          ( ( ~"ISYS_REPORT_WHERE_CONDITION~".~"WINDOW_NAME~" = :ARG_WINDOW_NAME ) and          ( ~"ISYS_REPORT_WHERE_CONDITION~".~"DATAWINDOW_NAME~" = :ARG_DATAWINDOW_NAME ) and          ( ~"ISYS_REPORT_WHERE_CONDITION~".~"ORGANIZATION_ID~" = :ARG_ORG ) )  " arguments=(("ARG_WINDOW_NAME", string),("ARG_DATAWINDOW_NAME", string),("ARG_LANGUAGE", string),("ARG_ORG", number)) )
