 column=(type=char(1000) updatewhereclause=yes name=nsnp_error_message dbname="iq_machine_inspect_nsnp.nsnp_error_message" dbalias=".nsnp_error_message" )
 column=(type=char(10) updatewhereclause=yes name=action_code dbname="iq_machine_inspect_nsnp.action_code" dbalias=".action_code" )
 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_NSNP~".~"LINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"MACHINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"MODEL_NAME~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"MODEL_SUFFIX~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"ORGANIZATION_ID~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"NSNP_REASON~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"NSNP_ERROR_MESSAGE~",   
         ~"IQ_MACHINE_INSPECT_NSNP~".~"ACTION_CODE~"  
    FROM ~"IQ_MACHINE_INSPECT_NSNP~"  
   WHERE ( ~"IQ_MACHINE_INSPECT_NSNP~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IQ_MACHINE_INSPECT_NSNP~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( ~"IQ_MACHINE_INSPECT_NSNP~".~"ENTER_DATE~" >= :arg_dateset ) AND  
         ( ~"IQ_MACHINE_INSPECT_NSNP~".~"ENTER_DATE~" < :arg_dateend+1 ) AND  
         ( ~"IQ_MACHINE_INSPECT_NSNP~".~"ORGANIZATION_ID~" = :arg_org )    

union all


  SELECT ~"IB_SMT_LINE_ONOFF_HISTORY~".~"LINE_CODE~",   
         '*' MACHINE_CODE,   
          IB_SMT_LINE_ONOFF_HISTORY.MODEL_NAME,   
         '' MODEL_SUFFIX,   
         TO_CHAR(~"IB_SMT_LINE_ONOFF_HISTORY~".~"ORGANIZATION_ID~") ,   
         ~"IB_SMT_LINE_ONOFF_HISTORY~".~"ENTER_DATE~",   
         ~"IB_SMT_LINE_ONOFF_HISTORY~".~"LAST_MODIFY_DATE~",   
         ~"IB_SMT_LINE_ONOFF_HISTORY~".~"ENTER_BY~",   
         ~"IB_SMT_LINE_ONOFF_HISTORY~".~"LAST_MODIFY_BY~",   
         LINE_ONOFF  ~"NSNP_REASON~",   
         '' ~"NSNP_ERROR_MESSAGE~",   
         NULL ACTION_CODE  
    FROM ~"IB_SMT_LINE_ONOFF_HISTORY~"  
   WHERE ( ~"IB_SMT_LINE_ONOFF_HISTORY~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IB_SMT_LINE_ONOFF_HISTORY~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( ~"IB_SMT_LINE_ONOFF_HISTORY~".~"ENTER_DATE~" >= :arg_dateset ) AND  
         ( ~"IB_SMT_LINE_ONOFF_HISTORY~".~"ENTER_DATE~" < :arg_dateend+1 ) AND  
         ( ~"IB_SMT_LINE_ONOFF_HISTORY~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_line_code", string),("arg_model_name", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number))  sort="enter_date D " )
