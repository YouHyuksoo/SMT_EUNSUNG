 retrieve="  SELECT  TO_CHAR(~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"RECEIPT_DATE~",   'YYYY-MM-DD') RECEIPT_DATE ,
         ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"LINE_CODE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"PRODUCT_ACTUAL_QTY~"    PRODUCT_ACTUAL_QTY ,
         ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"TIME_DIVISION~"||' '||F_GET_WORKTIME_SMT_ZONE_DESC( ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"TIME_DIVISION~")  TIME_DIVISION ,   
         ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"PCB_ITEM~"  
    FROM ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~"  
   WHERE ( ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"LINE_CODE~" like :ARG_LINE_CODE ) AND  
         ( ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"MODEL_NAME~" like :ARG_MODEL_NAME ) AND  
         ( ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"RECEIPT_DATE~" >= :ARG_DATESET ) AND  
         ( ~"IP_PRODUCT_SENSOR_ACTUAL_HOUR~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" arguments=(("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_DATESET", datetime),("ARG_ORG", number))  sort="line_code A model_name A pcb_item A " )
