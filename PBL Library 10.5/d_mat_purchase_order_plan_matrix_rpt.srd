table(column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) updatewhereclause=yes name=model_suffix dbname="model_suffix" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="supplier_code" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=number updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 retrieve="  SELECT ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORDER_NO~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"PURCHASE_ORDER_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ITEM_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"DELIVERY_DATE~" DELIVERY_DATE ,   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"DELIVERY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"LINE_TYPE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORDER_TYPE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORDER_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"UNIT_PRICE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"CURRENCY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ARRIVAL_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"PRE_ORDER_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"MFS~",   
         ~"B~".~"MODEL_NAME~",   
         ~"B~".~"MODEL_SUFFIX~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ENTER_BY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ENTER_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"LAST_MODIFY_DATE~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~"  
    FROM ~"IM_ITEM_PURCHASE_ORDER_PLAN~",   
         ~"ICOM_SUPPLIER~",   
         ~"ID_ITEM~"  , ID_ITEM B
   WHERE ( im_item_purchase_order_plan.supplier_code = icom_supplier.supplier_code (+)) and  
         ( im_item_purchase_order_plan.organization_id = icom_supplier.organization_id (+)) and  
         ( im_item_purchase_order_plan.item_code = id_item.item_code (+)) and  
         ( im_item_purchase_order_plan.organization_id = id_item.organization_id (+)) and  
         ( im_item_purchase_order_plan.set_item_code = b.item_code (+)) and  
         ( im_item_purchase_order_plan.organization_id = b.organization_id (+)) and  			
         ( ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"SUPPLIER_CODE~" like :ARG_SUPPLIER_CODE ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ITEM_CODE~" like :ARG_ITEM_CODE ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"DELIVERY_DATE~" >= :ARG_DATESET ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"DELIVERY_DATE~" <= :ARG_DATEEND ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORGANIZATION_ID~" = :ARG_ORG ) )    
 ORDER BY im_item_purchase_order_plan.DELIVERY_DATE, B.MODEL_NAME, B.MODEL_SUFFIX, im_item_purchase_order_plan.ITEM_CODE 
" arguments=(("ARG_SUPPLIER_CODE", string),("ARG_ITEM_CODE", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_ORG", number))  sort="model_name A model_suffix A supplier_code A item_code A item_name A item_spec A " )
