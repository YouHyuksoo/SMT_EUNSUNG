 column=(type=char(100) updatewhereclause=yes name=detail dbname="detail" )
 retrieve="  SELECT ~"ISYS_AUDIT_MESSAGE_FILTER~".~"USER_ID~",   
         ~"ISYS_AUDIT_MESSAGE_FILTER~".~"MSG_ID~",   
         ~"ISYS_AUDIT_MESSAGE_FILTER~".~"ORGANIZATION_ID~",   
         ~"ISYS_AUDIT_MESSAGE_FILTER~".~"VISIBLE_YN~",   
         ~"ISYS_AUDIT_MESSAGE_FILTER~".~"ENTER_DATE~",   
         ~"ISYS_AUDIT_MESSAGE_FILTER~".~"ENTER_BY~",   
         ~"ISYS_AUDIT_MESSAGE_FILTER~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_AUDIT_MESSAGE_FILTER~".~"LAST_MODIFY_BY~",   
         ~"ISYS_USERS~".~"USER_NAME~",   
         DECODE( :ARG_LANGUAGE , 'E' , ~"ISYS_AUDIT_MESSAGE_CODE~".~"DETAIL_ENG~",   'K' ,  ~"ISYS_AUDIT_MESSAGE_CODE~".~"DETAIL_KOR~",   'C' ,  ~"ISYS_AUDIT_MESSAGE_CODE~".~"DETAIL_LOC~"  ) DETAIL
    FROM ~"ISYS_AUDIT_MESSAGE_FILTER~",   
         ~"ISYS_USERS~",   
         ~"ISYS_AUDIT_MESSAGE_CODE~"  
   WHERE ( ~"ISYS_USERS~".~"USER_ID~" = ~"ISYS_AUDIT_MESSAGE_FILTER~".~"USER_ID~" ) and  
         ( ~"ISYS_USERS~".~"ORGANIZATION_ID~" = ~"ISYS_AUDIT_MESSAGE_FILTER~".~"ORGANIZATION_ID~" ) and  
         ( ~"ISYS_AUDIT_MESSAGE_FILTER~".~"MSG_ID~" = ~"ISYS_AUDIT_MESSAGE_CODE~".~"MSG_ID~" ) and  
         ( ~"ISYS_AUDIT_MESSAGE_FILTER~".~"ORGANIZATION_ID~" = ~"ISYS_AUDIT_MESSAGE_CODE~".~"ORGANIZATION_ID~" )   and
	    ( ~"ISYS_AUDIT_MESSAGE_FILTER~".~"USER_ID~" like :ARG_USER_ID ) and
	    ( ~"ISYS_AUDIT_MESSAGE_FILTER~".~"ORGANIZATION_ID~" = :ARG_ORG )
" update="ISYS_AUDIT_MESSAGE_FILTER" updatewhere=0 updatekeyinplace=no arguments=(("ARG_LANGUAGE", string),("ARG_USER_ID", string),("ARG_ORG", number))  sort="organization_id A user_id A msg_id A " )
