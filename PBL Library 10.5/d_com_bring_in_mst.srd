 column=(type=char(30) updatewhereclause=yes name=carrying_out_item dbname="iman_carrying_out.carrying_out_item" )
 column=(type=char(200) updatewhereclause=yes name=carrying_out_item_spec dbname="iman_carrying_out.carrying_out_item_spec" )
