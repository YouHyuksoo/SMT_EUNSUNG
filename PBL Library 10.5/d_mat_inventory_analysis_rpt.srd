 retrieve="SELECT 'MATERIAL' DIV , IM_ITEM_INVENTORY_CLOSE.CLOSE_YYYYMM ,
           IM_ITEM_INVENTORY_CLOSE.ITEM_CODE ,
           IM_ITEM_INVENTORY_CLOSE.LINE_TYPE ,
           IM_ITEM_INVENTORY_CLOSE.ORGANIZATION_ID ,
           IM_ITEM_INVENTORY_CLOSE.LAST_AVG_PRICE ,
           IM_ITEM_INVENTORY_CLOSE.LAST_INVENTORY_AMT ,
           IM_ITEM_INVENTORY_CLOSE.LAST_INVENTORY_QTY ,
           IM_ITEM_INVENTORY_CLOSE.MM_MASS_QTY ,
           IM_ITEM_INVENTORY_CLOSE.MM_MASS_AMT ,
           IM_ITEM_INVENTORY_CLOSE.MM_ISSUE_QTY ,
           IM_ITEM_INVENTORY_CLOSE.MM_ISSUE_AMT ,
           IM_ITEM_INVENTORY_CLOSE.MM_RECEIPT_QTY ,
           IM_ITEM_INVENTORY_CLOSE.MM_RECEIPT_AMT ,
           IM_ITEM_INVENTORY_CLOSE.MM_AVG_PRICE ,
           IM_ITEM_INVENTORY_CLOSE.MM_INVENTORY_QTY ,
           IM_ITEM_INVENTORY_CLOSE.MM_INVENTORY_AMT ,
           ID_ITEM.ITEM_SPEC ,
           ID_ITEM.ITEM_NAME ,
           ID_ITEM.ITEM_UOM ,
           ID_ITEM.ITEM_DIVISION ,
           ID_ITEM.ITEM_CLASS
        FROM IM_ITEM_INVENTORY_CLOSE ,
           ID_ITEM     
        WHERE ( IM_ITEM_INVENTORY_CLOSE.ITEM_CODE = ID_ITEM.ITEM_CODE ) and 
				( IM_ITEM_INVENTORY_CLOSE.ORGANIZATION_ID = ID_ITEM.ORGANIZATION_ID  ) and     
				( ( IM_ITEM_INVENTORY_CLOSE.CLOSE_YYYYMM = :arg_yyyymm ) And      
				( IM_ITEM_INVENTORY_CLOSE.ITEM_CODE like :arg_item_code ) and   
				( ID_ITEM.ITEM_CLASS LIKE :arg_item_class ) and
				( IM_ITEM_INVENTORY_CLOSE.ORGANIZATION_ID = :arg_org_id ) )  and
    ID_ITEM.ITEM_DIVISION LIKE :arg_item_division

UNION ALL

SELECT 'PRODUCT' DIV , IS_PRODUCT_INVENTORY_CLOSE.CLOSE_YYYYMM ,
           IS_PRODUCT_INVENTORY_CLOSE.ITEM_CODE ,
           IS_PRODUCT_INVENTORY_CLOSE.PRODUCT_LINE_TYPE ,
           IS_PRODUCT_INVENTORY_CLOSE.ORGANIZATION_ID ,
