           IS_PRODUCT_INVENTORY_CLOSE.MM_AVG_PRICE ,
           IS_PRODUCT_INVENTORY_CLOSE.MM_INVENTORY_QTY ,
           IS_PRODUCT_INVENTORY_CLOSE.MM_INVENTORY_AMT ,
           ID_ITEM.ITEM_SPEC ,
           ID_ITEM.ITEM_NAME ,
           ID_ITEM.ITEM_UOM,
           ID_ITEM.ITEM_DIVISION ,
           ID_ITEM.ITEM_CLASS
        FROM IS_PRODUCT_INVENTORY_CLOSE ,
           ID_ITEM     
        WHERE ( IS_PRODUCT_INVENTORY_CLOSE.ITEM_CODE = ID_ITEM.ITEM_CODE ) and   
				( IS_PRODUCT_INVENTORY_CLOSE.ORGANIZATION_ID = ID_ITEM.ORGANIZATION_ID ) and     
				( ( IS_PRODUCT_INVENTORY_CLOSE.CLOSE_YYYYMM = :arg_yyyymm ) And    
