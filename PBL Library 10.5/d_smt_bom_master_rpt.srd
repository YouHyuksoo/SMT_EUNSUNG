 retrieve="  SELECT ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"CHILD_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"DATESET~",   
         ~"ID_ENG_BOM_SMT~".~"SORT_SEQUENCE~",   
         ~"ID_ENG_BOM_SMT~".~"ITEM_UNIT_QTY~",   
         ~"ID_ENG_BOM_SMT~".~"WORKSTAGE_CODE~",   
         ~"ID_ENG_BOM_SMT~".~"DATEEND~",   
         ~"ID_ENG_BOM_SMT~".~"BOM_WORK_NO~",   
         ~"ID_ENG_BOM_SMT~".~"ENTER_BY~",   
         ~"ID_ENG_BOM_SMT~".~"ENTER_DATE~",   
         ~"ID_ENG_BOM_SMT~".~"LAST_MODIFY_BY~",   
         ~"ID_ENG_BOM_SMT~".~"LAST_MODIFY_DATE~",   
         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   
         ~"ID_ITEM_A~".~"ITEM_UOM~",   
         ~"ID_ENG_BOM_SMT~".~"ITEM_TYPE~",   
         ~"ID_ENG_BOM_SMT~".~"LINE_TYPE~",   
         ~"ID_ENG_BOM_SMT~".~"BOM_LEVEL~",   
         ~"ID_ENG_BOM_SMT~".~"ORGANIZATION_ID~",   
         ~"ID_ENG_BOM_SMT~".~"LOCATION_CODE~" ,
         ~"ID_ENG_BOM_SMT~".~"LINE_CODE~"  ,
         ~"ID_ENG_BOM_SMT~".~"MACHINE~"   ,
         ~"ID_ENG_BOM_SMT~".~"TABLE_ID~"

    FROM ~"ID_ENG_BOM_SMT~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~"
   WHERE ( id_eng_bom_smt.child_item_code = ID_ITEM_A.item_code (+)) and  
         ( id_eng_bom_smt.organization_id = ID_ITEM_A.organization_id (+)) and  
         ( ~"ID_ENG_BOM_SMT~".~"PARENT_ITEM_CODE~" LIKE :ARG_PARENT_ITEM ) and
         ( ~"ID_ENG_BOM_SMT~".~"LINE_CODE~" LIKE :ARG_LINE_CODE ) and
         ( ~"ID_ENG_BOM_SMT~".~"MACHINE~" LIKE :ARG_MACHINE ) and
         ( ~"ID_ENG_BOM_SMT~".~"DATESET~" <= :ARG_DATESET ) and
         ( ~"ID_ENG_BOM_SMT~".~"DATEEND~" >= :ARG_DATESET ) and
         ( ~"ID_ENG_BOM_SMT~".~"ORGANIZATION_ID~" = :ARG_ORG ) 
" arguments=(("ARG_PARENT_ITEM", string),("ARG_DATESET", datetime),("ARG_LINE_CODE", string),("ARG_MACHINE", string),("ARG_ORG", number))  sort="line_code A machine A parent_item_code A table_id A location_code A sort_sequence A " )
