table(column=(type=char(10) updatewhereclause=yes name=workstage_code dbname="im_item_workstage_inventory.workstage_code" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="im_item_workstage_inventory.item_code" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_workstage_inventory.organization_id" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(1) updatewhereclause=yes name=item_division dbname="id_item.item_division" )
 column=(type=char(10) updatewhereclause=yes name=msl_level dbname="id_item.msl_level" )
 column=(type=number updatewhereclause=yes name=unit_price dbname="unit_price" )
 retrieve="  SELECT 
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"WORKSTAGE_CODE~",   
 
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~",   
         SUM(~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_QTY~") INVENTORY_QTY,   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"ID_ITEM~".~"MSL_LEVEL~"  ,
		
		f_get_mat_max_unit_price_cfm( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~",   'F' , SYSDATE ,  :ARG_ORG ) UNIT_PRICE

    FROM ~"IM_ITEM_WORKSTAGE_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"MFS~" like :ARG_MFS ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"LINE_CODE~" like :ARG_LINE_CODE ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"WORKSTAGE_CODE~" like :ARG_WORKSTAGE_CODE ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~" like :ARG_ITEM_CODE ) AND  
         ( ~"ID_ITEM~".~"ITEM_DIVISION~" like :ARG_ITEM_DIVISION ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"MATERIAL_MFS~" like :ARG_MATERIAL_MFS ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~" = :ARG_ORG ) )    


GROUP BY 
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"WORKSTAGE_CODE~",   

         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~",   

         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"ID_ITEM~".~"MSL_LEVEL~"  " arguments=(("ARG_MFS", string),("ARG_LINE_CODE", string),("ARG_WORKSTAGE_CODE", string),("ARG_ITEM_CODE", string),("ARG_ITEM_DIVISION", string),("ARG_MATERIAL_MFS", string),("ARG_ORG", number))  sort="item_division A workstage_code A item_code A " )
group(level=1 header.height=0 trailer.height=68 by=("item_division" ) header.color="536870912" trailer.color="12639424" )
