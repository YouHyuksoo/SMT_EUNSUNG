 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="im_item_workstage_inventory.organization_id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=line_type dbname="im_item_workstage_inventory.line_type" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_price dbname="inventory_price" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_amt dbname="inventory_amt" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(100) updatewhereclause=yes name=id_item_item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=id_item_item_uom dbname="id_item.item_uom" )
 column=(type=char(1) updatewhereclause=yes name=item_division dbname="id_item.item_division" )
 retrieve="  SELECT ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"LINE_TYPE~",   
         AVG(~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_PRICE~") INVENTORY_PRICE,   
         SUM(~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_QTY~") INVENTORY_QTY,   
         SUM(~"IM_ITEM_WORKSTAGE_INVENTORY~".~"INVENTORY_AMT~") INVENTORY_AMT,   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~"  
    FROM ~"IM_ITEM_WORKSTAGE_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org ) )    
GROUP BY  ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_WORKSTAGE_INVENTORY~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~"  " arguments=(("arg_workstage_code", string),("arg_item_code", string),("arg_org", number))  sort="organization_id A item_division A item_code A " )
