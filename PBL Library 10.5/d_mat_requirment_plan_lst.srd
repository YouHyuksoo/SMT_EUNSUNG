 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_requirment_plan~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"im_item_requirment_plan.item_code~") COLUMN(NAME=~"im_item_requirment_plan.supplier_code~") COLUMN(NAME=~"im_item_requirment_plan.plan_date~") COLUMN(NAME=~"im_item_requirment_plan.organization_id~") COLUMN(NAME=~"im_item_requirment_plan.requirment_qty~") COLUMN(NAME=~"im_item_requirment_plan.enter_by~") COLUMN(NAME=~"im_item_requirment_plan.enter_date~") COLUMN(NAME=~"im_item_requirment_plan.last_modify_by~") COLUMN(NAME=~"im_item_requirment_plan.last_modify_date~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"im_item_requirment_plan.requirment_plan_date~") COLUMN(NAME=~"im_item_requirment_plan.line_type~")    JOIN (LEFT=~"im_item_requirment_plan.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~"    OUTER1 =~"im_item_requirment_plan.item_code~" )    JOIN (LEFT=~"im_item_requirment_plan.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~"    OUTER1 =~"im_item_requirment_plan.organization_id~" )    JOIN (LEFT=~"im_item_requirment_plan.supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier.supplier_code~"    OUTER1 =~"im_item_requirment_plan.supplier_code~" )    JOIN (LEFT=~"im_item_requirment_plan.organization_id~"    OP =~"=~"RIGHT=~"icom_supplier.organization_id~"    OUTER1 =~"im_item_requirment_plan.organization_id~" )WHERE(    EXP1 =~"~~~"IM_ITEM_REQUIRMENT_PLAN~~~".~~~"REQUIRMENT_PLAN_DATE~~~"~"   OP =~">=~"    EXP2 =~":ARG_REQUIRMENT_DATE~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_REQUIRMENT_PLAN~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":ARG_SUPPLIER_CODE~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_REQUIRMENT_PLAN~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":ARG_ITEM_CODE~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_REQUIRMENT_PLAN~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG~" ) ) ARG(NAME = ~"ARG_REQUIRMENT_DATE~" TYPE = datetime)  ARG(NAME = ~"ARG_SUPPLIER_CODE~" TYPE = string)  ARG(NAME = ~"ARG_ITEM_CODE~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " update="IM_ITEM_REQUIRMENT_PLAN" updatewhere=0 updatekeyinplace=no arguments=(("ARG_REQUIRMENT_DATE", datetime),("ARG_SUPPLIER_CODE", string),("ARG_ITEM_CODE", string),("ARG_ORG", number))  sort="organization_id A requirment_plan_date A item_code A plan_date A " )
