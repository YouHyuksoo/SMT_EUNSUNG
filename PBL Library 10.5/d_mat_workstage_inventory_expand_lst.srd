arg_yyyymm )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_WORKSTAGE_INV_EXPAND~~~".~~~"MFS~~~"~"   OP =~"=~"    EXP2 =~":arg_mfs~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_WORKSTAGE_INV_EXPAND~~~".~~~"SET_ITEM_CODE~~~"~"   OP =~"=~"    EXP2 =~":arg_set_item_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_WORKSTAGE_INV_EXPAND~~~".~~~"LINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_line_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_WORKSTAGE_INV_EXPAND~~~".~~~"WORKSTAGE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_workstage_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_WORKSTAGE_INV_EXPAND~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) ~" ) ) ARG(NAME = ~"arg_yyyymm~" TYPE = string)  ARG(NAME = ~"arg_mfs~" TYPE = string)  ARG(NAME = ~"arg_set_item_code~" TYPE = string)  ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_workstage_code~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_yyyymm", string),("arg_mfs", string),("arg_set_item_code", string),("arg_line_code", string),("arg_workstage_code", string),("arg_org_id", number))  sort="organization_id A close_yyyymm A item_code A " )
