 column=(type=char(200) updatewhereclause=yes name=im_item_purchase_order_shipment_comment dbname="shipment_comment" )
 column=(type=char(40) updatewhereclause=yes name=icom_supplier_tel_no dbname="tel_no" )
 column=(type=char(20) updatewhereclause=yes name=icom_supplier_fax_no dbname="fax_no" )
 column=(type=char(1) updatewhereclause=yes name=order_type dbname="order_type" )
 column=(type=char(100) updatewhereclause=yes name=supplier_name dbname="supplier_name" )
 column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_GROUP_NO~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~",   
         SUM(~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_QTY~") ORDER_QTY,   
         ~"IM_ITEM_PURCHASE_ORDER~".~"UNIT_PRICE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"CURRENCY~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~",   
         MAX(~"ID_ITEM~".~"ITEM_UOM~") ITEM_UOM,   
         MAX(~"ID_ITEM~".~"ITEM_SPEC~") ITEM_SPEC,   
         MAX(~"ID_ITEM~".~"ITEM_NAME~") ITEM_NAME,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"LAST_MODIFY_BY~")  LAST_MODIFY_BY ,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"INCIDENTAL_EXPENSE_CODE~") INCIDENTAL_EXPENSE_CODE,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"ORIGIN_NATION_CODE~") ORIGIN_NATION_CODE,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_METHOD~") DELIVERY_METHOD,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_PLACE~") DELIVERY_PLACE,   
         MAX(~"ICOM_SUPPLIER~".~"PAYMENT_TYPE~") PAYMENT_TYPE ,   
         TRUNC(~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~")  DELIVERY_DATE ,   
         MAX(~"ISYS_ORGANIZATION~".~"ORGANIZATION_FULL_NAME_ENG~") ORGANIZATION_FULL_NAME_ENG,   
         MAX(~"ISYS_ORGANIZATION~".~"TEL_NO~") TEL_NO,   
         MAX(~"ISYS_ORGANIZATION~".~"FAX_NO~") FAX_NO,   
         MAX(~"ICOM_SUPPLIER~".~"SUPPLIER_CHARGE_NAME~") SUPPLIER_CHARGE_NAME,   
         MAX(~"ICOM_SUPPLIER~".~"SUPPLIER_NAME_ENG~") SUPPLIER_NAME_ENG,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"ATTN_NAME~") ATTN_NAME,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"CC_NAME~") CC_NAME,   
         MAX(~"ISYS_ORGANIZATION~".~"ADDRESS_ENG~") ADDRESS_ENG,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"SHIPMENT_COMMENT~") SHIPMENT_COMMENT,   
         MAX(~"ICOM_SUPPLIER~".~"TEL_NO~") TEL_NO,   
         MAX(~"ICOM_SUPPLIER~".~"FAX_NO~") FAX_NO,   
         MAX(~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_TYPE~") ORDER_TYPE,
         MAX(~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~") SUPPLIER_NAME,   
         MAX(~"ISYS_USERS~".~"USER_NAME~")  USER_NAME
    FROM ~"IM_ITEM_PURCHASE_ORDER~",   
         ~"ID_ITEM~",   
         ~"ICOM_SUPPLIER~",   
         ~"ISYS_ORGANIZATION~",   
         ~"ISYS_USERS~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" ) and  
         ( ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" = ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~" ) and  
         ( ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" = ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" = ~"ISYS_ORGANIZATION~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"ENTER_BY~" = ~"ISYS_USERS~".~"USER_ID~" ) and  
         ( ~"ISYS_USERS~".~"ORGANIZATION_ID~" = ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_GROUP_NO~" = :arg_order_group_no ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
GROUP BY 

		~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_GROUP_NO~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"UNIT_PRICE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"CURRENCY~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~",   
         TRUNC(~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~") 


" arguments=(("arg_order_group_no", string),("arg_supplier_code", string),("arg_org_id", number))  sort="item_code A " )
