 column=(type=char(20) updatewhereclause=yes name=supplier_charge_name dbname="supplier_charge_name" )
 column=(type=char(100) updatewhereclause=yes name=supplier_name_eng dbname="supplier_name_eng" )
 column=(type=char(20) updatewhereclause=yes name=attn_name dbname="attn_name" )
 column=(type=char(20) updatewhereclause=yes name=cc_name dbname="cc_name" )
