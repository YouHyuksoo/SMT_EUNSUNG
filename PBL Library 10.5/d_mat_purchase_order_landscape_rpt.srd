 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="last_modify_by" )
 column=(type=char(3) updatewhereclause=yes name=incidental_expense_code dbname="incidental_expense_code" )
 column=(type=char(3) updatewhereclause=yes name=origin_nation_code dbname="origin_nation_code" )
 column=(type=char(20) updatewhereclause=yes name=delivery_method dbname="delivery_method" )
 column=(type=char(3) updatewhereclause=yes name=delivery_place dbname="delivery_place" )
 column=(type=char(20) updatewhereclause=yes name=payment_type dbname="payment_type" )
 column=(type=datetime updatewhereclause=yes name=delivery_date dbname="delivery_date" )
 column=(type=char(100) updatewhereclause=yes name=organization_full_name_eng dbname="organization_full_name_eng" )
 column=(type=char(20) updatewhereclause=yes name=tel_no dbname="tel_no" )
