 retrieve="  SELECT ~"ID_ITEM~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"SET_ITEM_YN~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"ID_ITEM~".~"ENTER_DATE~",   
         ~"ID_ITEM~".~"LAST_MODIFY_DATE~",   
         ~"ID_ITEM~".~"ENTER_BY~",   
         ~"ID_ITEM~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"BARCODE~",   
         ~"ID_ITEM~".~"HEIGHT~",   
         ~"ID_ITEM~".~"WEIGHT~",   
         ~"ID_ITEM~".~"INNER_DIAMETER~",   
         ~"ID_ITEM~".~"OUTER_DIAMETER~",   
         ~"ID_ITEM~".~"DATESET~",   
         ~"ID_ITEM~".~"DATEEND~",   
         ~"ID_ITEM~".~"DRAWING_NO~",    
         ~"ID_ITEM~".~"PART_NO~",   
         DECODE( SIGN( ID_ITEM.DATEEND - TRUNC(SYSDATE) ) , 1 , DECODE( SIGN( ID_ITEM.DATESET - TRUNC(SYSDATE) ) , 1 , 'FUTURE' , 'RUNNING' ) , 'EXPIRED') STATUS,   
         ~"ID_ITEM~".~"WIDTH~",   
         ~"ID_ITEM~".~"ABC_GRADE~",   
         ~"ID_ITEM~".~"HS_CODE~",   
         ~"ID_ITEM~".~"HS_NAME~",   
         ~"ID_ITEM~".~"HS_NAME_SALE~",   
         ~"ID_ITEM~".~"HS_SPEC~",   
         ~"ID_ITEM~".~"ROUTE_NO~",   
         ~"ID_ITEM~".~"SAFETY_INVENTORY~",   
         ~"ID_ITEM~".~"MANUFACTURE_LEADTIME~",   
         ~"ID_ITEM~".~"HS_CODE_SCRAP~",   
         ~"ID_ITEM~".~"HS_NAME_SCRAP~",   
         ~"ID_ITEM~".~"HS_SPEC_SCRAP~",   
         'N' CHECK_YN,   
         ~"ID_ITEM~".~"SUPPLIER_CODE~",   
         ~"ID_ITEM~".~"CUSTOMER_CODE~",   
         ~"ID_ITEM~".~"BUY_PRICE~",   
         ~"ID_ITEM~".~"SALE_PRICE~",   
         ~"ID_ITEM~".~"ORDER_RULE~",   
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",   
         ~"ID_ITEM~".~"CHECK_SUPPLIER_BARCODE~",   
         ~"ID_ITEM~".~"IS_NEW_YN~",   
         ~"ID_ITEM~".~"MSL_LEVEL~",   
         ~"ID_ITEM~".~"MSL_MAX_TIME~",   
         ~"ID_ITEM~".~"MODEL_NAME~",   
         ~"ID_ITEM~".~"MODEL_SUFFIX~",   
         ~"ID_ITEM~".~"LIFE_CYCLE~",   
         ~"ID_ITEM~".~"KEYITEM_YN~",   
         ~"ID_ITEM~".~"VIRTUAL_RECEIPT_YN~",   
         ~"ID_ITEM~".~"RAW_MATERIAL~",   
         ~"ID_ITEM~".~"WORK_BAD_RATE~",   
         ~"ID_ITEM~".~"TRANSFER_UOM~",   
         ~"ID_ITEM~".~"ORDER_CYCLE~",   
         ~"ID_ITEM~".~"SVC_CODE~",   
         ~"ID_ITEM~".~"CAPACITY~",   
         ~"ID_ITEM~".~"LENGTH~",   
         ~"ID_ITEM~".~"SPECIAL_PROPERTY~",   
         ~"ID_ITEM~".~"LAYER~",   
         ~"ID_ITEM~".~"GRADIENT~",   
         ~"ID_ITEM~".~"DENSITY~",   
         ~"ID_ITEM~".~"ISSUE_PACKING_QTY~",   
         ~"ID_ITEM~".~"TRANSFER_YN~",   
         ~"ID_ITEM~".~"LINE_CODE~",   
         ~"ID_ITEM~".~"TARIFF_RATE~",   
         ~"ID_ITEM~".~"AUTO_ISSUE_YN~",   
         ~"ID_ITEM~".~"AUTO_RECEIPT_YN~",   
         ~"ID_ITEM~".~"AUTO_ISSUE_PLAN_YN~",   
         ~"ID_ITEM~".~"SALE_PRICE_APPLY_TYPE~",   
         ~"ID_ITEM~".~"GROSS_WEIGHT~",   
         ~"ID_ITEM~".~"CBM~",   
         ~"ID_ITEM~".~"BARCODE2~",   
         ~"ID_ITEM~".~"EHMS_YN~",   
         ~"ID_ITEM~".~"EHMS_STATUS~",   
         ~"ID_ITEM~".~"MATERIAL_TYPE~",   
         ~"ID_ITEM~".~"PURCHASE_GROUP~",   
         ~"ID_ITEM~".~"PHANTOM_CODE~",   
         ~"ID_ITEM~".~"SUPPLY_TYPE~",   
         ~"ID_ITEM~".~"MES_DISPLAY_YN~",   
         ~"ID_ITEM~".~"MATERIAL_QTY~",   
         ~"ID_ITEM~".~"MATERIAL_QTY2~",   
         ~"ID_ITEM~".~"FEEDER_LAYOUT_COMMENTS~",   
         ~"ID_ITEM~".~"ECO_CHECK_YN~",   
         ~"ID_ITEM~".~"ECO_CHECK_COMMENTS~",   
         ~"ID_ITEM~".~"CARRIER_SIZE~",   
         ~"ID_ITEM~".~"FEEDER_SIZE~",   
         ~"ID_ITEM~".~"SOLDER_TYPE~",   
         ~"ID_ITEM~".~"SOLDER_OPEN_LIMIT_TIME~",   
         ~"ID_ITEM~".~"SOLDER_AGITATION_TIME~",   
         ~"ID_ITEM~".~"CUSTOMER_MODEL_NAME~",   
         ~"ID_ITEM~".~"RECEIPT_LOT_CHECK_YN~",   
         ~"ID_ITEM~".~"MATERIAL_QTY3~",   
         ~"ID_ITEM~".~"COMMENTS~",   
         ~"ID_ITEM~".~"VENDOR_CODE1~",   
         ~"ID_ITEM~".~"VENDOR_CODE2~",   
         ~"ID_ITEM~".~"VENDOR_CODE3~",   
         ~"ID_ITEM~".~"NO_CHECK_ORIGIN_SUPPLIER~"  ,
         ~"ID_ITEM~".~"CUSTOMER_PART_NO~"  

    FROM ~"ID_ITEM~"  
   WHERE ( ( ~"ID_ITEM~".~"ITEM_CODE~" like :ARG_ITEM_CODE ) AND  
         ( upper(NVL(~"ID_ITEM~".~"MODEL_NAME~",'*')) like :ARG_MODEL_NAME ) AND  
         ( NVL(~"ID_ITEM~".~"SET_ITEM_YN~",'N') like :ARG_SETYN ) AND  
         ~"ID_ITEM~".~"ITEM_DIVISION~" like :ARG_ITEM_DIVISION AND  
         ~"ID_ITEM~".~"LINE_TYPE~" like :ARG_LINE_TYPE AND  
         NVL(~"ID_ITEM~".~"IS_NEW_YN~",'*') like :ARG_IS_NEW_YN AND  
         NVL(~"ID_ITEM~".~"SUPPLIER_CODE~" , '*') like :ARG_SUPPLIER_CODE AND  
         NVL(~"ID_ITEM~".~"CUSTOMER_CODE~" ,'*') like :ARG_CUSTOMER_CODE AND  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID ) ) AND  
         NVL(~"ID_ITEM~".~"PART_NO~",'*') like :ARG_PART_NO   AND 
         NVL(~"ID_ITEM~".~"ITEM_SPEC~",'*') like :ARG_ITEM_SPEC

" update="ID_ITEM" updatewhere=0 updatekeyinplace=yes arguments=(("ARG_ITEM_CODE", string),("ARG_MODEL_NAME", string),("ARG_SETYN", string),("ARG_LINE_TYPE", string),("ARG_ITEM_DIVISION", string),("ARG_IS_NEW_YN", string),("ARG_SUPPLIER_CODE", string),("ARG_CUSTOMER_CODE", string),("ARG_ORGANIZATION_ID", number),("ARG_PART_NO", string),("ARG_ITEM_SPEC", string))  sort="organization_id A status D item_division A item_class A item_code A " )
