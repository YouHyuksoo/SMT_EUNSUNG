table(column=(type=char(100) updatewhereclause=yes key=yes name=pid dbname="iq_machine_inspect_data_spi.pid" )
 column=(type=char(10) updatewhereclause=yes name=result dbname="iq_machine_inspect_data_spi.result" )
 column=(type=char(1000) updatewhereclause=yes name=defect_code dbname="iq_machine_inspect_data_spi.defect_code" )
 column=(type=char(30) updatewhereclause=yes key=yes name=inspect_date dbname="iq_machine_inspect_data_spi.inspect_date" )
 column=(type=char(4000) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(30) updatewhereclause=yes name=equipmentid dbname="iq_machine_inspect_data_spi.equipmentid" )
 column=(type=char(50) updatewhereclause=yes name=run_no dbname="iq_machine_inspect_data_spi.run_no" )
 column=(type=char(50) updatewhereclause=yes name=cstid dbname="iq_machine_inspect_data_spi.cstid" )
 column=(type=char(10) updatewhereclause=yes name=seq_no dbname="iq_machine_inspect_data_spi.seq_no" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="iq_machine_inspect_data_spi.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="iq_machine_inspect_data_spi.enter_by" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="iq_machine_inspect_data_spi.organization_id" )
 retrieve="select pid, 
         result, 
         defect_code, 
         inspect_date, 
         f_get_line_name( line_code, organization_id) line_code, 
         equipmentid, 
         run_no, 
         cstid, 
         seq_no,  
         enter_date, 
         enter_by, 
         organization_id  
  from iq_machine_inspect_data_spi     
 where PID like :ARG_SERIAL_NO 
   AND ORGANIZATION_ID = :ARG_ORG
" update="iq_machine_inspect_data_spi" updatewhere=0 updatekeyinplace=no arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="pid A inspect_date A " )
