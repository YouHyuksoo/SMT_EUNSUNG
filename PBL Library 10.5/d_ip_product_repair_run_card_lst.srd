 retrieve="  SELECT ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~",   
         ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_NO~",   
         ~"IP_PRODUCT_RUN_CARD~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"MARKING_NO~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_SIZE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"PCB_SUPPLIER_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"CHARGER~",   
         ~"IP_PRODUCT_RUN_CARD~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_RUN_CARD~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"ENTER_BY~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"RUN_STATUS~",   
         ~"IP_PRODUCT_RUN_CARD~".~"CARRIER_SIZE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"PRODUCT_RUN_TYPE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"ARRAY_TYPE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"METALMASK_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_TRUNC_QTY~",   
         ~"IP_PRODUCT_RUN_CARD~".~"KITTING_DATE~"  ,
         ~"IP_PRODUCT_RUN_CARD~".~"REPAIR_WORKSTAGE_CODE~"  ,
		( select max(a.serial_no) from IP_PRODUCT_PCB_BARCODE a where a.run_no =  IP_PRODUCT_RUN_CARD.run_no ) max_serial_no
    FROM ~"IP_PRODUCT_RUN_CARD~"  
   WHERE ( ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~" like :ARG_MODEL_NAME ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~" like :ARG_RUN_NO ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~" >= :ARG_DATESET ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~" <= :ARG_DATEEND ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"PRODUCT_RUN_TYPE~" like :ARG_PRODUCT_TYPE ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" update="IP_PRODUCT_RUN_CARD" updatewhere=0 updatekeyinplace=no arguments=(("ARG_MODEL_NAME", string),("ARG_RUN_NO", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_PRODUCT_TYPE", string),("ARG_ORG", number))  sort="run_date A run_no A " )
