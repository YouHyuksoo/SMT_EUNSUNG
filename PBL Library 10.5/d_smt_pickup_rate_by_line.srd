HA$PBExportHeader$d_smt_pickup_rate_by_line.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no )
header(height=212 color="536870912" )
summary(height=0 color="536870912" )
footer(height=92 color="65535" )
detail(height=116 color="536870912" )
table(column=(type=char(5) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=number updatewhereclause=yes name=amt_total dbname="amt_total" )
 column=(type=number updatewhereclause=yes name=takea dbname="takea" )
 column=(type=number updatewhereclause=yes name=missa dbname="missa" )
 column=(type=number updatewhereclause=yes name=recoa dbname="recoa" )
 column=(type=number updatewhereclause=yes name=takeb dbname="takeb" )
 column=(type=number updatewhereclause=yes name=missb dbname="missb" )
 column=(type=number updatewhereclause=yes name=recob dbname="recob" )
 column=(type=number updatewhereclause=yes name=takec dbname="takec" )
 column=(type=number updatewhereclause=yes name=missc dbname="missc" )
 column=(type=number updatewhereclause=yes name=recoc dbname="recoc" )
 column=(type=number updatewhereclause=yes name=taked dbname="taked" )
 column=(type=number updatewhereclause=yes name=missd dbname="missd" )
 column=(type=number updatewhereclause=yes name=recod dbname="recod" )
 column=(type=number updatewhereclause=yes name=takee dbname="takee" )
 column=(type=number updatewhereclause=yes name=misse dbname="misse" )
 column=(type=number updatewhereclause=yes name=recoe dbname="recoe" )
 column=(type=number updatewhereclause=yes name=takef dbname="takef" )
 column=(type=number updatewhereclause=yes name=missf dbname="missf" )
 column=(type=number updatewhereclause=yes name=recof dbname="recof" )
 column=(type=number updatewhereclause=yes name=takeg dbname="takeg" )
 column=(type=number updatewhereclause=yes name=missg dbname="missg" )
 column=(type=number updatewhereclause=yes name=recog dbname="recog" )
 column=(type=number updatewhereclause=yes name=takeh dbname="takeh" )
 column=(type=number updatewhereclause=yes name=missh dbname="missh" )
 column=(type=number updatewhereclause=yes name=recoh dbname="recoh" )
 column=(type=number updatewhereclause=yes name=takei dbname="takei" )
 column=(type=number updatewhereclause=yes name=missi dbname="missi" )
 column=(type=number updatewhereclause=yes name=recoi dbname="recoi" )
 column=(type=number updatewhereclause=yes name=takej dbname="takej" )
 column=(type=number updatewhereclause=yes name=missj dbname="missj" )
 column=(type=number updatewhereclause=yes name=recoj dbname="recoj" )
 column=(type=number updatewhereclause=yes name=takesum dbname="takesum" )
 column=(type=number updatewhereclause=yes name=misssum dbname="misssum" )
 column=(type=number updatewhereclause=yes name=recosum dbname="recosum" )
 column=(type=number updatewhereclause=yes name=taskeam dbname="taskeam" )
 column=(type=number updatewhereclause=yes name=missam dbname="missam" )
 column=(type=number updatewhereclause=yes name=recoam dbname="recoam" )
 column=(type=number updatewhereclause=yes name=amt_am dbname="amt_am" )
 column=(type=number updatewhereclause=yes name=takepm dbname="takepm" )
 column=(type=number updatewhereclause=yes name=misspm dbname="misspm" )
 column=(type=number updatewhereclause=yes name=recopm dbname="recopm" )
 column=(type=number updatewhereclause=yes name=amt_pm dbname="amt_pm" )
 retrieve="SELECT  LINE_CODE, 
  
	    (
		amtA +                       
		amtB +                       
		amtC +                       
		amtD +                       
		amtE +                       
		amtF +                       
		amtG +                       
		amtH +                       
		amtI +                       
		amtJ  ) as amt_total ,       


	
		TakeA, MissA, RecoA, 
		TakeB, MissB, RecoB, 
		TakeC, MissC, RecoC, 
		TakeD, MissD, RecoD, 
		TakeE, MissE, RecoE, 
		TakeF, MissF, RecoF, 
		TakeG, MissG, RecoG, 
		TakeH, MissH, RecoH, 
		TakeI, MissI, RecoI, 
		TakeJ, MissJ, RecoJ, 
		
		TakeA +                       
		TakeB +                       
		TakeC +                       
		TakeD +                       
		TakeE +                       
		TakeF +                       
		TakeG +                       
		TakeH +                       
		TakeI +                       
		TakeJ as TakeSUM,             
		
		MissA +                       
		MissB +                       
		MissC +                       
		MissD +                       
		MissE +                       
		MissF +                       
		MissG +                       
		MissH +                       
		MissI +                       
		MissJ as MissSUM,             
		
		RecoA+                        
		RecoB+                        
		RecoC+                        
		RecoD+                        
		RecoE+                        
		RecoF+                        
		RecoG+                        
		RecoH+                        
		RecoI+                        
		RecoJ as RecoSUM,             
		
		
		
		TakeA +                       
		TakeB +                       
		TakeC +                       
		TakeD +                       
		TakeE as TaskeAM,             
		


		MissA +                       
		MissB +                       
		MissC +                       
		MissD +                       
		MissE as MissAM,              
		
		RecoA+                        
		RecoB+                        
		RecoC+                        
		RecoD+                        
		RecoE as RecoAM,              
		

         ( AmtA +                       
		AmtB +                       
		AmtC +                       
		AmtD +                       
		AmtE ) as amt_am, 

		
		TakeF +                       
		TakeG +                       
		TakeH +                       
		TakeI +                       
		TakeJ as TakePM,              
		
		MissF +                       
		MissG +                       
		MissH +                       
		MissI +                       
		MissJ as MissPM,              
		
		RecoF+                        
		RecoG+                        
		RecoH+                        
		RecoI+                        
		RecoJ as RecoPM, 

         ( AmtF +                       
		AmtG +                       
		AmtH +                       
		AmtI  +                       
		AmtJ ) as  amt_pm 
                      



   
  FROM ( 

SELECT LINE_CODE, 
       SUM(DECODE(ACTUAL_TIME,'A', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeA, 
       SUM(DECODE(ACTUAL_TIME,'A', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissA, 
       SUM(DECODE(ACTUAL_TIME,'A', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoA,
       SUM(DECODE(ACTUAL_TIME,'A', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'A', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtA,
       

       SUM(DECODE(ACTUAL_TIME,'B', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeB, 
       SUM(DECODE(ACTUAL_TIME,'B', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissB, 
       SUM(DECODE(ACTUAL_TIME,'B', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoB,
       SUM(DECODE(ACTUAL_TIME,'B', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'B', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtB,
       
       SUM(DECODE(ACTUAL_TIME,'C', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeC, 
       SUM(DECODE(ACTUAL_TIME,'C', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissC, 
       SUM(DECODE(ACTUAL_TIME,'C', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoC,
       SUM(DECODE(ACTUAL_TIME,'C', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'C', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtC,      

       SUM(DECODE(ACTUAL_TIME,'D', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeD, 
       SUM(DECODE(ACTUAL_TIME,'D', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissD, 
       SUM(DECODE(ACTUAL_TIME,'D', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoD,
       SUM(DECODE(ACTUAL_TIME,'D', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'D', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtD,       

       SUM(DECODE(ACTUAL_TIME,'E', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeE, 
       SUM(DECODE(ACTUAL_TIME,'E', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissE, 
       SUM(DECODE(ACTUAL_TIME,'E', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoE,
       SUM(DECODE(ACTUAL_TIME,'E', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'E', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtE,

       SUM(DECODE(ACTUAL_TIME,'F', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeF, 
       SUM(DECODE(ACTUAL_TIME,'F', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissF, 
       SUM(DECODE(ACTUAL_TIME,'F', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoF,
       SUM(DECODE(ACTUAL_TIME,'F', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'F', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtF,
       
       SUM(DECODE(ACTUAL_TIME,'G', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeG, 
       SUM(DECODE(ACTUAL_TIME,'G', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissG, 
       SUM(DECODE(ACTUAL_TIME,'G', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoG,
       SUM(DECODE(ACTUAL_TIME,'G', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'G', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtG,
       
       SUM(DECODE(ACTUAL_TIME,'H', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeH, 
       SUM(DECODE(ACTUAL_TIME,'H', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissH, 
       SUM(DECODE(ACTUAL_TIME,'H', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoH,
       SUM(DECODE(ACTUAL_TIME,'H', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'H', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtH,
       
       SUM(DECODE(ACTUAL_TIME,'I', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeI, 
       SUM(DECODE(ACTUAL_TIME,'I', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissI, 
       SUM(DECODE(ACTUAL_TIME,'I', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoI,
       SUM(DECODE(ACTUAL_TIME,'I', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'I', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtI,

       SUM(DECODE(ACTUAL_TIME,'J', DECODE(DATA_TYPE,'T',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) TakeJ, 
       SUM(DECODE(ACTUAL_TIME,'J', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) MissJ, 
       SUM(DECODE(ACTUAL_TIME,'J', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM,NVL(SIM_COUNT,HEAD_SUM)),0),0)) RecoJ,
       SUM(DECODE(ACTUAL_TIME,'J', DECODE(DATA_TYPE,'M',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) + 
       SUM(DECODE(ACTUAL_TIME,'J', DECODE(DATA_TYPE,'R',DECODE(SIGN(SIM_COUNT),-1,HEAD_SUM_AMT,NVL(SIM_AMT,HEAD_SUM_AMT)),0),0)) amtJ

  FROM ( 
          
     SELECT LINE_CODE, 
                 ACTUAL_TIME, 
                 ACTUAL_DATE,
                 DATA_TYPE, 
                 HEAD_SUM,
                 HEAD_SUM * INVENTORY_PRICE  AS HEAD_SUM_AMT,   
                 SIM_COUNT, 
                 SIM_COUNT * INVENTORY_PRICE AS SIM_AMT 
                 
        FROM ( 
						  SELECT T.LINE_CODE  , 
										  T.DATA_TYPE  ,
										  T.ACTUAL_TIME,
								
										  T.MODEL_NAME, 
										  T.MODEL_SUFFIX, 
										  T.PARENT_ITEM_CODE,
										  T.PCB_ITEM, 
										  T.ACTUAL_DATE, 
										 // NVL(f_get_mat_max_unit_price_cfm(substr(t.item_code, 1, decode(instr(t.item_code,'-'),0,length(t.item_code), instr(t.item_code,'-') - 1 )),'F',sysdate,1),0)  INVENTORY_PRICE,
									       NVL(f_get_mat_max_unit_price_cfm(t.item_code,'*',sysdate,1),0)  INVENTORY_PRICE,
										  
										  T.HEAD_SUM   ,
										  DECODE(NVL(MACHINE_TYPE,'CM'), 'NPM' , T.HEAD_SUM, 
										  HEAD_SUM - 
										  LAG( HEAD_SUM) OVER ( PARTITION BY LINE_CODE  , 
																						 MACHINE_CODE, 
																						 PROGRAM_NAME,
																						 ADDRESS    , 
																						 SUB_ADDRESS,
																						 ITEM_CODE  ,
																						 DATA_TYPE  
																		 ORDER BY LINE_CODE  , 
																							 MACHINE_CODE,
																							 PROGRAM_NAME,
																							 ADDRESS    , 
																							 SUB_ADDRESS, 
																							 ITEM_CODE  ,
																							 DATA_TYPE  ,
																							 ACTUAL_DATE, 
																							 ACTUAL_TIME
																	  )
										  ) SIM_COUNT  
										  
										
																						 
											
									FROM IQ_MACHINE_INSPECT_PICKUP_RATE t
								  WHERE  ( ACTUAL_DATE = :arg_date or ( ACTUAL_DATE = TRUNC(:arg_date -1) and ACTUAL_TIME = 'J' ) )   
									 AND LINE_CODE like  :arg_line
								 AND MACHINE_CODE like :arg_machine
									 AND PROGRAM_NAME like :arg_program
								 AND item_code like :arg_item 
								 AND TABLE_NO like :arg_table 
								 AND FEEDER_ZAXIS  like :arg_feeder 
								 AND FEEDER_LRAXIS like :arg_lr
                ) 
     )  
WHERE ACTUAL_DATE = TRUNC(:arg_date) 
   
GROUP BY LINE_CODE
) 

ORDER BY LINE_CODE" arguments=(("arg_date", datetime),("arg_line", string),("arg_machine", string),("arg_program", string),("arg_item", string),("arg_table", string),("arg_feeder", string),("arg_lr", string)) )
