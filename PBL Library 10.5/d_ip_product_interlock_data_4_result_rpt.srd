table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="iq_interlock_check_result_line_code" )
 column=(type=char(20) updatewhereclause=yes name=model_name dbname="iq_interlock_check_result_model_name" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="iq_interlock_check_result_item_code" )
 column=(type=char(20) updatewhereclause=yes name=workstage_code dbname="iq_interlock_check_result_workstage_code" )
 column=(type=number updatewhereclause=yes name=iq_interlock_check_result_item_code_1 dbname="iq_interlock_check_result_item_code_1" )
 retrieve="  SELECT /*+ index ( IQ_INTERLOCK_CHECK_RESULT XPKIQ_INTERLOCK_CHECK_RESULT ) */ TO_CHAR(  ~"IQ_INTERLOCK_CHECK_RESULT~".~"RECEIPT_DATE~" , 'MMDD' )  RECEIPT_DATE ,   
		TO_CHAR(~"IQ_INTERLOCK_CHECK_RESULT~".~"RECEIPT_DATE~",   'HH24' ) RECEIPT_TIME ,
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"LINE_CODE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"MODEL_NAME~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"ITEM_CODE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"WORKSTAGE_CODE~"  
    FROM ~"IQ_INTERLOCK_CHECK_RESULT~"   , IP_PRODUCT_LINE 
   WHERE  IQ_INTERLOCK_CHECK_RESULT.LINE_CODE = IP_PRODUCT_LINE.LINE_CODE AND 

         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"RECEIPT_DATE~" >=   TO_DATE(  to_char( :arg_dateset  , 'yyyymmdd ') || '0800'  , 'yyyymmdd hh24mi')  ) AND  
        ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"RECEIPT_DATE~" <      TO_DATE(  to_char( :arg_dateset +1  , 'yyyymmdd ') || '0800', 'yyyymmdd hh24mi')    ) AND  

         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"IS_LAST_YN~" = 'Y' ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"CHECK_RESULT~" <> 'NG' ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"MAGAZINE_NO~" IS NOT NULL  ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_dateset", datetime),("arg_line_code", string),("arg_model_name", string),("arg_workstage_code", string),("arg_org", number))  sort="line_code A model_name A " )
group(level=1 header.height=0 trailer.height=48 by=("line_code" ) header.color="536870912" trailer.color="12639424" )
