 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_model_master.item_code" )
 column=(type=number updatewhereclause=yes name=magazine_qty dbname="magazine_qty" )
 retrieve="  SELECT A.MODEL_NAME MODEL_NAME  ,
			0 LOT_QTY ,
			0 OK_QTY ,
			0 NG_QTY ,
              0 OK_INCLUDE_QTY ,
			0 DESTROY_QTY , 
			0 REPAIR_QTY ,
             A.ITEM_CODE AS ITEM_CODE ,
	        NVL( F_GET_MAGAZINE_QTY_BY_RUN_NO( :ARG_RUN_NO  ,  ORGANIZATION_ID ) ,0 )  AS  MAGAZINE_QTY
    FROM IP_PRODUCT_MODEL_MASTER    A
  WHERE A.MASTER_MODEL_NAME = :ARG_MODEL_NAME
      AND A.ORGANIZATION_ID = :ARG_ORG" arguments=(("ARG_MODEL_NAME", string),("ARG_RUN_NO", string),("ARG_ORG", number)) )
