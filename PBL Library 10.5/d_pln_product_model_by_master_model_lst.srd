table(column=(type=char(30) updatewhereclause=yes name=model_name dbname="ip_product_model_master.model_name" )
 column=(type=number updatewhereclause=yes name=lot_qty dbname="lot_qty" )
 column=(type=number updatewhereclause=yes name=ok_qty dbname="ok_qty" )
 column=(type=number updatewhereclause=yes name=ng_qty dbname="ng_qty" )
