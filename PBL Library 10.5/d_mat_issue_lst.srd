 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_issue~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"im_item_issue.issue_date~") COLUMN(NAME=~"im_item_issue.issue_sequence~") COLUMN(NAME=~"im_item_issue.organization_id~") COLUMN(NAME=~"im_item_issue.mfs~") COLUMN(NAME=~"im_item_issue.location_code~") COLUMN(NAME=~"im_item_issue.item_type~") COLUMN(NAME=~"im_item_issue.line_code~") COLUMN(NAME=~"im_item_issue.workstage_code~") COLUMN(NAME=~"im_item_issue.issue_deficit~") COLUMN(NAME=~"im_item_issue.issue_qty~") COLUMN(NAME=~"im_item_issue.issue_status~") COLUMN(NAME=~"im_item_issue.issue_amt~") COLUMN(NAME=~"im_item_issue.issue_account~") COLUMN(NAME=~"im_item_issue.line_type~") COLUMN(NAME=~"im_item_issue.comments~") COLUMN(NAME=~"im_item_issue.issue_price~") COLUMN(NAME=~"im_item_issue.enter_date~") COLUMN(NAME=~"im_item_issue.enter_by~") COLUMN(NAME=~"im_item_issue.last_modify_date~") COLUMN(NAME=~"im_item_issue.last_modify_by~") COLUMN(NAME=~"im_item_issue.item_code~") COLUMN(NAME=~"im_item_issue.supplier_code~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"im_item_issue.issue_type~") COLUMN(NAME=~"im_item_issue.machine_code~") COLUMN(NAME=~"im_item_issue.work_order_no~") COLUMN(NAME=~"im_item_issue.invoice_no~") COLUMN(NAME=~"im_item_issue.material_mfs~") COLUMN(NAME=~"im_item_issue.parent_item_code~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"im_item_issue.demand_qty~")    JOIN (LEFT=~"icom_supplier.supplier_code~"    OP =~"=~"RIGHT=~"im_item_issue.supplier_code~"    OUTER2 =~"im_item_issue.supplier_code~" )    JOIN (LEFT=~"icom_supplier.organization_id~"    OP =~"=~"RIGHT=~"im_item_issue.organization_id~"    OUTER2 =~"im_item_issue.organization_id~" )    JOIN (LEFT=~"id_item.item_code~"    OP =~"=~"RIGHT=~"im_item_issue.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_issue.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_ISSUE~~~".~~~"ISSUE_DATE~~~"~"   OP =~"between~"    EXP2 =~":arg_dateset and :arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ISSUE~~~".~~~"MFS~~~"~"   OP =~"like~"    EXP2 =~":arg_mfs~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ISSUE~~~".~~~"LINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_line_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ISSUE~~~".~~~"WORKSTAGE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_workstage_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ISSUE~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ISSUE~~~".~~~"INVOICE_NO~~~"~"   OP =~"like~"    EXP2 =~":arg_invoice_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ISSUE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_mfs~" TYPE = string)  ARG(NAME = ~"arg_workstage_code~" TYPE = string)  ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_invoice_no~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_mfs", string),("arg_workstage_code", string),("arg_item_code", string),("arg_invoice_no", string),("arg_org_id", number))  sort="organization_id A issue_status D issue_date A invoice_no A parent_item_code A mfs A item_code A issue_sequence A " )
