 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_RT~".~"CSTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"SEQ_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"PID~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"MACHINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"INSPECT_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"DEFECT_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"ORGANIZATION_ID~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"ARRAY_NO~"  ,
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"RUN_NO~",
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"LINE_CODE~",
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"RPM_VALUE~",
         ~"IQ_MACHINE_INSPECT_DATA_RT~".~"BIT_VALUE~",
         F_GET_RUN_MODEL_NAME(RUN_NO) MODEL_NAME
    FROM ~"IQ_MACHINE_INSPECT_DATA_RT~"  
   WHERE ( ~"IQ_MACHINE_INSPECT_DATA_RT~".~"INSPECT_DATE~" >= TO_CHAR(TRUNC(:ARG_DATESET),'YYYY/MM/DD HH24:MI:SS' ) ) AND  
              ( ~"IQ_MACHINE_INSPECT_DATA_RT~".~"INSPECT_DATE~" <   TO_CHAR(TRUNC(:ARG_DATEEND)+1 ,'YYYY/MM/DD HH24:MI:SS' )) AND  
              (~"IQ_MACHINE_INSPECT_DATA_RT~".~"PID~" like :ARG_PID  )   AND 
	     	 (NVL(~"IQ_MACHINE_INSPECT_DATA_RT~".~"LINE_CODE~",'*') LIKE :ARG_LINE_CODE ) AND
		     F_GET_RUN_MODEL_NAME( RUN_NO) LIKE :ARG_MODEL_NAME  AND
              RUN_NO  LIKE :ARG_RUN_NO " update="IQ_MACHINE_INSPECT_DATA_RT" updatewhere=0 updatekeyinplace=no arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_PID", string),("ARG_MODEL_NAME", string),("ARG_RUN_NO", string))  sort="inspect_date A line_code A pid A " )
