 retrieve="SELECT   ~"IP_PRODUCT_RUN_CARD_INV~".~"ITEM_CODE~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"MODEL_NAME~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"LINE_CODE~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"WORKSTAGE_CODE~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"INVENTORY_QTY~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"ORGANIZATION_ID~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"ENTER_DATE~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"ENTER_BY~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"LAST_MODIFY_DATE~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"LAST_MODIFY_BY~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"MODEL_SUFFIX~",
         ~"IP_PRODUCT_RUN_CARD_INV~".~"PCB_ITEM~"
  FROM   ~"IP_PRODUCT_RUN_CARD_INV~"
 WHERE   (~"IP_PRODUCT_RUN_CARD_INV~".~"LINE_CODE~" LIKE :arg_line_code)
     AND (~"IP_PRODUCT_RUN_CARD_INV~".~"WORKSTAGE_CODE~" LIKE :arg_workstage_code)
     AND (~"IP_PRODUCT_RUN_CARD_INV~".~"MODEL_NAME~" LIKE :arg_model_name)
     AND (~"IP_PRODUCT_RUN_CARD_INV~".~"PCB_ITEM~" LIKE :arg_pcb_item)
     AND (~"IP_PRODUCT_RUN_CARD_INV~".~"INVENTORY_QTY~" <> 0 )
     AND (~"IP_PRODUCT_RUN_CARD_INV~".~"ORGANIZATION_ID~" = :arg_org)" update="IP_PRODUCT_RUN_CARD_INV" updatewhere=1 updatekeyinplace=no arguments=(("ARG_LINE_CODE", string),("ARG_WORKSTAGE_CODE", string),("ARG_MODEL_NAME", string),("ARG_PCB_ITEM", string),("ARG_ORG", number))  sort="model_name A workstage_code A line_code A " )
