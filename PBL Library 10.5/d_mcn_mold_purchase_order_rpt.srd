 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_mold_purchase_order~" )  TABLE(NAME=~"imcn_mold~" )  TABLE(NAME=~"icom_supplier~" )  TABLE(NAME=~"isys_organization~" ) COLUMN(NAME=~"imcn_mold_purchase_order.order_group_no~") COLUMN(NAME=~"imcn_mold_purchase_order.organization_id~") COLUMN(NAME=~"imcn_mold_purchase_order.order_qty~") COLUMN(NAME=~"imcn_mold_purchase_order.unit_price~") COLUMN(NAME=~"imcn_mold_purchase_order.supplier_code~") COLUMN(NAME=~"imcn_mold_purchase_order.currency~") COLUMN(NAME=~"imcn_mold_purchase_order.mold_code~") COLUMN(NAME=~"imcn_mold.mold_spec~") COLUMN(NAME=~"imcn_mold.mold_name~") COLUMN(NAME=~"imcn_mold_purchase_order.last_modify_by~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"imcn_mold_purchase_order.incidental_expense_code~") COLUMN(NAME=~"imcn_mold_purchase_order.delivery_method~") COLUMN(NAME=~"imcn_mold_purchase_order.delivery_place~") COLUMN(NAME=~"icom_supplier.payment_type~") COLUMN(NAME=~"imcn_mold_purchase_order.delivery_date~") COLUMN(NAME=~"isys_organization.organization_full_name_eng~") COLUMN(NAME=~"isys_organization.tel_no~") COLUMN(NAME=~"isys_organization.fax_no~") COLUMN(NAME=~"icom_supplier.supplier_charge_name~") COLUMN(NAME=~"icom_supplier.supplier_name_eng~") COLUMN(NAME=~"imcn_mold_purchase_order.attn_name~") COLUMN(NAME=~"imcn_mold_purchase_order.cc_name~") COLUMN(NAME=~"isys_organization.address_eng~") COMPUTE(NAME=~"'' REMARKS~")    JOIN (LEFT=~"imcn_mold.mold_code~"    OP =~"=~"RIGHT=~"imcn_mold_purchase_order.mold_code~" )    JOIN (LEFT=~"imcn_mold.organization_id~"    OP =~"=~"RIGHT=~"imcn_mold_purchase_order.organization_id~" )    JOIN (LEFT=~"icom_supplier.supplier_code~"    OP =~"=~"RIGHT=~"imcn_mold_purchase_order.supplier_code~" )    JOIN (LEFT=~"icom_supplier.organization_id~"    OP =~"=~"RIGHT=~"imcn_mold_purchase_order.organization_id~" )    JOIN (LEFT=~"imcn_mold_purchase_order.organization_id~"    OP =~"=~"RIGHT=~"isys_organization.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"ORDER_GROUP_NO~~~"~"   OP =~"=~"    EXP2 =~":arg_order_group_no )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD_PURCHASE_ORDER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_order_group_no~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_order_group_no", string),("arg_supplier_code", string),("arg_org_id", number)) )
