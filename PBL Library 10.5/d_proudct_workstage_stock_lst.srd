 retrieve="  SELECT ~"IP_PRODUCT_WORKSTAGE_INV~".~"RUN_NO~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"INVENTORY_QTY~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"LAST_RECEIPT_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"LAST_ISSUE_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"LINE_CODE~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"WORKSTAGE_CODE~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"ENTER_BY~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"INVENTORY_TYPE~"  
    FROM ~"IP_PRODUCT_WORKSTAGE_INV~"  
   WHERE ( ~"IP_PRODUCT_WORKSTAGE_INV~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( SIGN(~"IP_PRODUCT_WORKSTAGE_INV~".~"INVENTORY_QTY~") >= :arg_sign ) and   
         ( ~"IP_PRODUCT_WORKSTAGE_INV~".~"ORGANIZATION_ID~" = :arg_org )    
" update="IP_PRODUCT_WORKSTAGE_INV" updatewhere=1 updatekeyinplace=no arguments=(("arg_model_name", string),("arg_workstage_code", string),("arg_sign", number),("arg_org", number))  sort="run_no A workstage_code A " )
