w_progress_popup.f_set_message("140")
//=============================================
//
//=============================================
phase = 130
update im_item_inventory set inventory_amt = inventory_qty * inventory_price
where organization_id = :gvi_organization_id 
   AND ITEM_CODE IN ( SELECT ITEM_CODE FROM ID_ITEM WHERE CUSTOMER_CODE = :AS_CUSTOMER_CODE );
	 
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -130
end if 
w_progress_popup.f_stepit()  // 1-15
close(w_progress_popup)		
return 1
 



end function

