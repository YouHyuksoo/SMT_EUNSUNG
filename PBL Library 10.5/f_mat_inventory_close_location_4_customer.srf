phase = 90
update im_item_issue a
set      (issue_price, issue_amt ) =
          (select   b.mm_avg_price,    a.issue_qty *  abs(b.mm_avg_price)
		   from   im_item_inventory_close_mfs  b
		   where  b.close_yyyymm = :as_yyyymm
		       and a.material_mfs = b.material_mfs 	
			  and  a.item_code = b.item_code
			  and a.line_type = b.line_type
		       and b.organization_id  = :gvi_organization_id
		       and a.organization_id = b.organization_id
		       and a.location_code = b.location_code
			   AND A.ITEM_CODE IN ( SELECT ITEM_CODE FROM ID_ITEM WHERE CUSTOMER_CODE = :AS_CUSTOMER_CODE )
		)
where issue_date >= :LVDT_START_date AND issue_date  <= :LVDT_END_date
    and  a.organization_id = :gvi_organization_id
	AND A.ITEM_CODE IN ( SELECT ITEM_CODE FROM ID_ITEM WHERE CUSTOMER_CODE = :AS_CUSTOMER_CODE )
;
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -90
end if 
phase = 100
