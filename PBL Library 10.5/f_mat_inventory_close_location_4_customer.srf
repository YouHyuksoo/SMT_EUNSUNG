UPDATE im_item_inventory a
   SET (a.inventory_price) =
          (SELECT b.mm_avg_price
           FROM   im_item_inventory_close_mfs b
           WHERE  a.material_mfs = b.material_mfs
			    AND a.item_code = b.item_code
                  AND a.line_type = b.line_type
                  AND a.location_code = b.location_code
                  AND a.organization_id = b.organization_id
                  AND b.close_yyyymm = :as_yyyymm
                  AND b.organization_id = :gvi_organization_id
				AND B.ITEM_CODE IN ( SELECT ITEM_CODE FROM ID_ITEM WHERE CUSTOMER_CODE = :AS_CUSTOMER_CODE ))
 WHERE     ( a.material_mfs, a.item_code, a.line_type,a.location_code, a.organization_id) IN
             (SELECT
                     b.item_code,
                     b.line_type,
				   b.material_mfs ,
				   b.location_code ,	
                     b.organization_id
              FROM   im_item_inventory_close_mfs b
              WHERE   a.material_mfs = b.material_mfs   
				   AND a.item_code = b.item_code
                     AND a.line_type = b.line_type
                     AND a.location_code = b.location_code
                     AND a.organization_id = b.organization_id
                     AND b.close_yyyymm = :as_yyyymm
                     AND b.organization_id = :gvi_organization_id
				   AND B.ITEM_CODE IN ( SELECT ITEM_CODE FROM ID_ITEM WHERE CUSTOMER_CODE = :AS_CUSTOMER_CODE )			
			   )
       AND organization_id = :gvi_organization_id;
		
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -100
end if 
