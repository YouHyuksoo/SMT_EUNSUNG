UPDATE is_material_shipping SET CLOSE_YN = 'Y' , CLOSE_DATE = SYSDATE 
WHERE shipping_date 
BETWEEN :LVDT_start_date
        AND :LVDT_end_date
	   AND ENTER_DATE <= :lvdt_last_date
        AND organization_id = :gvi_organization_id
	   AND ITEM_CODE IN ( SELECT ITEM_CODE FROM ID_ITEM WHERE CUSTOMER_CODE = :AS_CUSTOMER_CODE );
if f_sql_check_with_msg(string(phase)) < 0 then 
