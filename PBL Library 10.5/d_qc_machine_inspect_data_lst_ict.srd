 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"CSTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"SEQ_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"PID~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"MACHINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"INSPECT_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"DEFECT_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"ORGANIZATION_ID~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"ARRAY_NO~"  ,
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"RUN_NO~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"LINE_CODE~",
         F_GET_RUN_MODEL_NAME(RUN_NO) MODEL_NAME,

         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"FILE_PATH~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"STEP_NO~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"PARTS_NAME~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"OP_MODE~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"C0R0~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"C0R0_UNIT~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"ACTUAL~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"ACTUAL_UNIT~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"STANDARD~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"STANDARD_UNIT~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"MEASURE~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"MEASURE_UNIT~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"HI_LIMIT~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"HI_LIMIT_UNIT~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"LO_LIMIT~",
         ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"LO_LIMIT_UNIT~"
         
    FROM ~"IQ_MACHINE_INSPECT_DATA_ICT~"  
   WHERE ( ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"INSPECT_DATE~" >= TO_CHAR(TRUNC(:ARG_DATESET),'YYYY/MM/DD HH24:MI:SS' ) ) AND  
              ( ~"IQ_MACHINE_INSPECT_DATA_ICT~".~"INSPECT_DATE~" <   TO_CHAR(TRUNC(:ARG_DATEEND)+1 ,'YYYY/MM/DD HH24:MI:SS' )) AND  
              (~"IQ_MACHINE_INSPECT_DATA_ICT~".~"PID~" like :ARG_PID  )   AND 
	     	 (NVL(~"IQ_MACHINE_INSPECT_DATA_ICT~".~"LINE_CODE~",'*') LIKE :ARG_LINE_CODE ) AND
              F_GET_RUN_MODEL_NAME( RUN_NO) LIKE :ARG_MODEL_NAME  AND
             RUN_NO  LIKE :ARG_RUN_NO " update="IQ_MACHINE_INSPECT_DATA_ICT" updatewhere=0 updatekeyinplace=no arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_PID", string),("ARG_MODEL_NAME", string),("ARG_RUN_NO", string))  sort="inspect_date A line_code A pid A " )
