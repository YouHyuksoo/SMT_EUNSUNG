 retrieve="  SELECT ~"IM_ITEM_UNIT_PRICE~".~"DATESET~",   
         ~"IM_ITEM_UNIT_PRICE~".~"CURRENCY~",   
         ~"IM_ITEM_UNIT_PRICE~".~"UNIT_PRICE~",   
         ~"IM_ITEM_UNIT_PRICE~".~"DELIVERY~",   
         ~"IM_ITEM_UNIT_PRICE~".~"DATEEND~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         DECODE( SIGN( IM_ITEM_UNIT_PRICE.DATEEND - TRUNC(SYSDATE)) , 1 , DECODE( SIGN( IM_ITEM_UNIT_PRICE.DATESET - TRUNC(SYSDATE) ) , 1 , 'FUTURE' , 'RUNNING' ) , 'EXPIRED') STATUS,   
         ~"IM_ITEM_UNIT_PRICE~".~"LINE_TYPE~"  ,
          PRICE_CHANGE_CONFIRM_YN
    FROM ~"IM_ITEM_UNIT_PRICE~",   
         ~"ID_ITEM~",   
         ~"ICOM_SUPPLIER~"  
   WHERE ( ~"IM_ITEM_UNIT_PRICE~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_UNIT_PRICE~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" = ~"IM_ITEM_UNIT_PRICE~".~"SUPPLIER_CODE~" ) and  
         ( ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" = ~"IM_ITEM_UNIT_PRICE~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_UNIT_PRICE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_UNIT_PRICE~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" arguments=(("arg_item_code", string),("arg_org_id", number))  sort="dateset A " )
