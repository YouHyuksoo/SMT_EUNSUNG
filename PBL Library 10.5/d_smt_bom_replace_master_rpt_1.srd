 retrieve="  SELECT ~"ID_ENG_BOM_SMT_REPLACE~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"CHILD_ITEM_CODE~",   
		~"ID_ENG_BOM_SMT_REPLACE~".~"REPLACE_ITEM_CODE~" ,
         ~"ID_ENG_BOM_SMT_REPLACE~".~"DATESET~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"SORT_SEQUENCE~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"ITEM_UNIT_QTY~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"WORKSTAGE_CODE~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"DATEEND~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"BOM_WORK_NO~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"ENTER_BY~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"ENTER_DATE~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"LAST_MODIFY_BY~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"LAST_MODIFY_DATE~",   
         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   
         ~"ID_ITEM_A~".~"ITEM_UOM~",   
         ~"ID_ITEM_B~".~"ITEM_NAME~",   
         ~"ID_ITEM_B~".~"ITEM_SPEC~",   

         ~"ID_ITEM_C~".~"ITEM_NAME~"    REPLACE_ITEM_NAME ,
         ~"ID_ITEM_C~".~"ITEM_SPEC~"     REPLACE_ITEM_SPEC,   


         ~"ID_ENG_BOM_SMT_REPLACE~".~"ITEM_TYPE~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"LINE_TYPE~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"BOM_LEVEL~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"ORGANIZATION_ID~",   
         ~"ID_ENG_BOM_SMT_REPLACE~".~"LOCATION_CODE~" ,
         ~"ID_ENG_BOM_SMT_REPLACE~".~"LINE_CODE~"  ,
         ~"ID_ENG_BOM_SMT_REPLACE~".~"MACHINE~"   

    FROM ~"ID_ENG_BOM_SMT_REPLACE~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~",   
         ~"ID_ITEM~" ~"ID_ITEM_B~" ,
         ~"ID_ITEM~" ~"ID_ITEM_C~"    
   WHERE ( id_eng_bom_smt_replace.child_item_code = ID_ITEM_A.item_code (+)) and  
         ( id_eng_bom_smt_replace.organization_id = ID_ITEM_A.organization_id (+)) and  
         ( id_eng_bom_smt_replace.parent_item_code = ID_ITEM_B.item_code (+)) and  
         ( id_eng_bom_smt_replace.organization_id = ID_ITEM_B.organization_id (+)) and  

		( id_eng_bom_smt_replace.replace_item_code = ID_ITEM_C.item_code (+)) and  
         ( id_eng_bom_smt_replace.organization_id = ID_ITEM_C.organization_id (+)) and  


         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"PARENT_ITEM_CODE~" LIKE :ARG_PARENT_ITEM ) and
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"LINE_CODE~" LIKE :ARG_LINE_CODE ) and
      /*   ( ~"ID_ENG_BOM_SMT_REPLACE~".~"MACHINE~" LIKE :ARG_MACHINE ) and*/
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"DATESET~" <= :ARG_DATESET ) and
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"DATEEND~" >= :ARG_DATESET ) and
         ( ~"ID_ENG_BOM_SMT_REPLACE~".~"ORGANIZATION_ID~" = :ARG_ORG ) 
" arguments=(("ARG_PARENT_ITEM", string),("ARG_DATESET", datetime),("ARG_LINE_CODE", string),("ARG_MACHINE", string),("ARG_ORG", number))  sort="line_code A machine A parent_item_code A sort_sequence A " )
