table(column=(type=char(20) update=yes updatewhereclause=yes name=item_type dbname="im_item_inventory_barcode.item_type" )
 column=(type=char(20) update=yes updatewhereclause=yes name=line_type dbname="im_item_inventory_barcode.line_type" )
 column=(type=char(20) update=yes updatewhereclause=yes name=location_code dbname="im_item_inventory_barcode.location_code" )
 column=(type=char(2) update=yes updatewhereclause=yes name=barcode_status dbname="im_item_inventory_barcode.barcode_status" )
 column=(type=number updatewhereclause=yes name=item_qty dbname="item_qty" )
 column=(type=char(20) update=yes updatewhereclause=yes name=supplier_code dbname="im_item_inventory_barcode.supplier_code" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="enter_by" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="enter_date" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="last_modify_date" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="last_modify_by" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="organization_id" )
 column=(type=datetime updatewhereclause=yes name=print_date dbname="print_date" )
 column=(type=char(50) update=yes updatewhereclause=yes name=item_code dbname="im_item_inventory_barcode.item_code" )
 column=(type=char(50) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(100) updatewhereclause=yes name=supplier_name dbname="supplier_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=bin_code dbname="im_item_inventory_barcode.bin_code" )
 column=(type=char(50) update=yes updatewhereclause=yes name=invoice_no dbname="im_item_inventory_barcode.invoice_no" )
 retrieve="  SELECT
         ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_TYPE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"LOCATION_CODE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"BARCODE_STATUS~",   
         sum(~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_QTY~") ITEM_QTY,   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"SUPPLIER_CODE~",      
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"ENTER_BY~") ENTER_BY,   
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"ENTER_DATE~") ENTER_DATE,   
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"LAST_MODIFY_DATE~") LAST_MODIFY_DATE,   
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"LAST_MODIFY_BY~") LAST_MODIFY_BY,   
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"ORGANIZATION_ID~") ORGANIZATION_ID,    
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"PRINT_DATE~") PRINT_DATE,   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_CODE~",   
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_NAME~") ITEM_NAME,   
         max(~"IM_ITEM_INVENTORY_BARCODE~".~"SUPPLIER_NAME~") SUPPLIER_NAME,   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"BIN_CODE~",   
         ~"IM_ITEM_INVENTORY_BARCODE~".~"INVOICE_NO~"  
    FROM ~"IM_ITEM_INVENTORY_BARCODE~"  
   WHERE ( ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_CODE_BARCODE~" like :arg_item_code_barcode ) AND  
         ( ~"IM_ITEM_INVENTORY_BARCODE~".~"SERIAL_NO~" like :arg_serial_no ) AND  
         ( ~"IM_ITEM_INVENTORY_BARCODE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( trunc(~"IM_ITEM_INVENTORY_BARCODE~".~"PRINT_DATE~") >= :arg_datestart ) AND  
         ( trunc(~"IM_ITEM_INVENTORY_BARCODE~".~"PRINT_DATE~") <= :arg_dateend ) AND  
         ( ~"IM_ITEM_INVENTORY_BARCODE~".~"ORGANIZATION_ID~" = :arg_org ) 
group by   item_code,supplier_code,item_type,line_type,location_code,invoice_no,barcode_status,bin_code
" arguments=(("arg_item_code", string),("arg_serial_no", string),("arg_item_code_barcode", string),("arg_datestart", datetime),("arg_dateend", datetime),("arg_org", number)) )
