export.xhtml( template=(comment="" name="d" xhtml="$$HEX1$$fffe$$ENDHEX$$<form name=~"webDW_dataForm~"><div class=~"webDW_band_0~"><div class=~"webDW_t_1~">t_1</div><div class=~"webDW_item_status_t~">item_status_t</div><div class=~"webDW_vr1~"/><div class=~"webDW_mfs_t~">mfs_t</div><div class=~"webDW_vr2~"/><div class=~"webDW_line_type_t~">line_type_t</div><div class=~"webDW_vr3~"/><div class=~"webDW_inventory_hold_t~">inventory_hold_t</div><div class=~"webDW_vr4~"/><div class=~"webDW_inventory_price_t~">inventory_price_t</div><div class=~"webDW_vr5~"/><div class=~"webDW_inventory_qty_t~">inventory_qty_t</div><div class=~"webDW_vr6~"/><div class=~"webDW_check_inventory_qty_t~">check_inventory_qty_t</div><div class=~"webDW_vr7~"/><div class=~"webDW_inventory_amt_t~">inventory_amt_t</div><div class=~"webDW_vr8~"/><div class=~"webDW_inventory_division_t~">inventory_division_t</div><div class=~"webDW_vr9~"/><div class=~"webDW_location_code_t~">location_code_t</div><div class=~"webDW_vr10~"/><div class=~"webDW_comments_t~">comments_t</div><div class=~"webDW_vr11~"/><div class=~"webDW_enter_date_t~">enter_date_t</div><div class=~"webDW_vr12~"/><div class=~"webDW_enter_by_t~">enter_by_t</div><div class=~"webDW_vr13~"/><div class=~"webDW_last_modify_date_t~">last_modify_date_t</div><div class=~"webDW_vr14~"/><div class=~"webDW_line_code_t~">line_code_t</div><div class=~"webDW_vr15~"/><div class=~"webDW_last_modify_by_t~">last_modify_by_t</div><div class=~"webDW_vr16~"/><div class=~"webDW_item_spec_t~">item_spec_t</div><div class=~"webDW_vr17~"/><div class=~"webDW_item_name_t~">item_name_t</div><div class=~"webDW_vr18~"/><div class=~"webDW_item_code_t~">item_code_t</div><div class=~"webDW_vr19~"/><div class=~"webDW_close_yyyymm_t~">close_yyyymm_t</div><div class=~"webDW_vr20~"/><div class=~"webDW_difference_qty_t~">difference_qty_t</div><div class=~"webDW_vr21~"/><div class=~"webDW_organization_id_t~">organization_id_t</div><div class=~"webDW_vr22~"/><div class=~"webDW_virtu