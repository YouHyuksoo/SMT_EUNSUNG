detail(height=64 color="536870912" )
table(column=(type=char(6) updatewhereclause=yes key=yes name=close_yyyymm dbname="close_yyyymm" )
 column=(type=char(20) updatewhereclause=yes key=yes name=item_code dbname="item_code" )
 column=(type=number updatewhereclause=yes key=yes name=organization_id dbname="organization_id" )
 column=(type=char(30) updatewhereclause=yes key=yes name=material_mfs dbname="material_mfs" )
 column=(type=char(10) updatewhereclause=yes key=yes name=line_type dbname="line_type" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number update=yes updatewhereclause=yes name=check_inventory_qty dbname="check_inventory_qty" )
 column=(type=char(20) updatewhereclause=yes key=yes name=location_code dbname="location_code" )
 column=(type=number updatewhereclause=yes name=difference_qty dbname="difference_qty" )
 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=number updatewhereclause=yes name=excel_check_inventory_qty dbname="excel_check_inventory_qty" )
 retrieve="SELECT * FROM 
(
  SELECT ~"IM_ITEM_INVENTORY_CHECK~".~"CLOSE_YYYYMM~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"CHECK_INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY_CHECK~".~"LOCATION_CODE~",   
         nvl(im_item_inventory_check.inventory_qty,0) - nvl(im_item_inventory_check.check_inventory_qty,0) difference_qty,   
         'N' CHECK_YN,   
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"CHECK_INVENTORY_QTY~"  EXCEL_CHECK_INVENTORY_QTY
    FROM ~"IM_ITEM_INVENTORY_CHECK~",  
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~"  
   WHERE ( im_item_inventory_check.close_yyyymm = im_item_inventory_check_excel.close_yyyymm (+)) and  
         ( im_item_inventory_check.item_code = im_item_inventory_check_excel.item_code (+)) and  
         ( im_item_inventory_check.line_type = im_item_inventory_check_excel.line_type (+)) and  
         ( im_item_inventory_check.organization_id = im_item_inventory_check_excel.organization_id (+)) and  
         ( im_item_inventory_check.location_code = im_item_inventory_check_excel.location_code (+)) and  
         ( im_item_inventory_check.material_mfs = im_item_inventory_check_excel.material_mfs (+)) and  
         ( ( ~"IM_ITEM_INVENTORY_CHECK~".~"CLOSE_YYYYMM~" = :arg_yyyymm ) AND  
         ( ~"IM_ITEM_INVENTORY_CHECK~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_INVENTORY_CHECK~".~"MATERIAL_MFS~" like :arg_material_mfs ) AND  
         ( NVL(~"IM_ITEM_INVENTORY_CHECK~".~"LOCATION_CODE~",'*') like :arg_location_code ) AND  
		( NVL(~"IM_ITEM_INVENTORY_CHECK~".~"LOCATION_CODE~",'*') in ( 'M01' , 'M05' , 'M06')) AND  
		
         ( ~"IM_ITEM_INVENTORY_CHECK~".~"ORGANIZATION_ID~" = :arg_org_id ) )    

UNION ALL

  SELECT ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"CLOSE_YYYYMM~",   
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"LINE_TYPE~",   
         0 INVENTORY_QTY,   
         0 CHECK_INVENTORY_QTY,   
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"LOCATION_CODE~",   
         nvl(IM_ITEM_INVENTORY_CHECK_EXCEL.CHECK_INVENTORY_QTY,0) difference_qty,   
         'N' CHECK_YN,   
         ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"CHECK_INVENTORY_QTY~"   EXCEL_CHECK_INVENTORY_QTY
    FROM  ~"IM_ITEM_INVENTORY_CHECK_EXCEL~"  
   WHERE  ( ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"CLOSE_YYYYMM~" = :arg_yyyymm )  
       AND   ( CLOSE_YYYYMM , ITEM_CODE  , MATERIAL_MFS , LINE_TYPE , LOCATION_CODE , ORGANIZATION_ID )
       NOT IN ( SELECT CLOSE_YYYYMM , ITEM_CODE  , MATERIAL_MFS , LINE_TYPE , LOCATION_CODE , ORGANIZATION_ID
                       FROM IM_ITEM_INVENTORY_CHECK
                      WHERE ~"IM_ITEM_INVENTORY_CHECK~".~"CLOSE_YYYYMM~" = :arg_yyyymm AND
                      ( ~"IM_ITEM_INVENTORY_CHECK~".~"MATERIAL_MFS~" like :arg_material_mfs )   
                    )
       AND  ( NVL(~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"LOCATION_CODE~",'*') like :arg_location_code )  
	  AND   ( NVL(~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"LOCATION_CODE~",'*') in ( 'M01' , 'M05' , 'M06')   )
       AND  ( ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"ITEM_CODE~" like :arg_item_code ) 
       AND   ( ~"IM_ITEM_INVENTORY_CHECK_EXCEL~".~"MATERIAL_MFS~" like :arg_material_mfs ) 
 ) " update="IM_ITEM_INVENTORY_CHECK" updatewhere=0 updatekeyinplace=no arguments=(("arg_yyyymm", string),("arg_item_code", string),("arg_location_code", string),("arg_material_mfs", string),("arg_org_id", number)) )
