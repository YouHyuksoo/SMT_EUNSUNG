 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_baking_master~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"imcn_machine~" ) COLUMN(NAME=~"im_item_baking_master.chamber_code~") COLUMN(NAME=~"im_item_baking_master.input_scan_date~") COLUMN(NAME=~"im_item_baking_master.output_scan_date~") COLUMN(NAME=~"im_item_baking_master.scan_by~") COLUMN(NAME=~"im_item_baking_master.item_code~") COLUMN(NAME=~"im_item_baking_master.item_barcode~") COLUMN(NAME=~"im_item_baking_master.lot_no~") COLUMN(NAME=~"im_item_baking_master.lot_qty~") COLUMN(NAME=~"im_item_baking_master.organization_id~") COLUMN(NAME=~"im_item_baking_master.enter_date~") COLUMN(NAME=~"im_item_baking_master.enter_by~") COLUMN(NAME=~"im_item_baking_master.last_modify_date~") COLUMN(NAME=~"im_item_baking_master.last_modify_by~") COLUMN(NAME=~"im_item_baking_master.chamber_type~") COLUMN(NAME=~"im_item_baking_master.chamber_location~") COMPUTE(NAME=~"( SYSDATE - INPUT_SCAN_DATE) * 24 AS INPUT_LAPSE_TIME~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_class~") COLUMN(NAME=~"id_item.height~") COLUMN(NAME=~"id_item.life_cycle~") COLUMN(NAME=~"id_item.baking_time~") COLUMN(NAME=~"id_item.msl_level~") COLUMN(NAME=~"id_item.supplier_code~") COLUMN(NAME=~"imcn_machine.min_temp_value~") COLUMN(NAME=~"imcn_machine.max_temp_value~") COLUMN(NAME=~"imcn_machine.std_temp_value~")    JOIN (LEFT=~"im_item_baking_master.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~"    OUTER1 =~"im_item_baking_master.item_code~" )    JOIN (LEFT=~"im_item_baking_master.chamber_code~"    OP =~"=~"RIGHT=~"imcn_machine.machine_code~"    OUTER1 =~"im_item_baking_master.chamber_code~" )WHERE(    EXP1 =~"( ~~~"IM_ITEM_BAKING_MASTER~~~".~~~"ITEM_CODE~~~"~"   OP =~"=~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_BAKING_MASTER~~~".~~~"INPUT_SCAN_DATE~~~"~"   OP =~"IS NOT~"    EXP2 =~"NULL )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_BAKING_MASTER~~~".~~~"OUTPUT_SCAN_DATE~~~"~"   OP =~"IS~"    EXP2 =~"NULL )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_BAKING_MASTER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_BAKING_MASTER~~~".~~~"CHAMBER_TYPE~~~"~"   OP =~"=~"    EXP2 =~":arg_type )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_BAKING_MASTER~~~".~~~"CHAMBER_CODE~~~"~"   OP =~"=~"    EXP2 =~":arg_code )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number)  ARG(NAME = ~"arg_type~" TYPE = string)  ARG(NAME = ~"arg_code~" TYPE = string) " arguments=(("arg_item_code", string),("arg_org", number),("arg_type", string),("arg_code", string))  sort="item_code A lot_no A " )
