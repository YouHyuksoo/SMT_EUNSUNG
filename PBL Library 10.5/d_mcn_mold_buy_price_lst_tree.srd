 retrieve="  SELECT ~"IMCN_MOLD_UNIT_PRICE~".~"MOLD_CODE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"SUPPLIER_CODE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"DATESET~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"ORGANIZATION_ID~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"CURRENCY~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"UNIT_PRICE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"LINE_TYPE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"DELIVERY~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"PRICE_TYPE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"STANDARD_UNIT_PRICE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"DATEEND~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"APPROVAL_NO~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"PRICE_CHANGE_REASON~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"PRICE_CHANGE_CONFIRM_YN~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"ENTER_BY~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"ENTER_DATE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"LAST_MODIFY_DATE~",   
         ~"IMCN_MOLD_UNIT_PRICE~".~"LAST_MODIFY_BY~",   
         ~"IMCN_MOLD~".~"MOLD_SPEC~",   
         ~"IMCN_MOLD~".~"MOLD_NAME~",   
         ~"IMCN_MOLD~".~"MOLD_UOM~",   

         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",
         DECODE(  SIGN( IMCN_MOLD_UNIT_PRICE.DATEEND - TRUNC(SYSDATE)) , 1 , DECODE( SIGN( IMCN_MOLD_UNIT_PRICE.DATESET - TRUNC(SYSDATE) ) , 1 , 'FUTURE' , 'RUNNING' )    , 'EXPIRED') STATUS ,
          imcn_mold_unit_price.rowid  
    FROM ~"IMCN_MOLD_UNIT_PRICE~",   
         ~"IMCN_MOLD~",   
         ~"ICOM_SUPPLIER~"  
   WHERE ( ~"IMCN_MOLD_UNIT_PRICE~".~"MOLD_CODE~" = ~"IMCN_MOLD~".~"MOLD_CODE~"(+) ) and  
         ( ~"IMCN_MOLD_UNIT_PRICE~".~"ORGANIZATION_ID~" =~"IMCN_MOLD~".~"ORGANIZATION_ID~"(+)) and  
         ( ~"IMCN_MOLD_UNIT_PRICE~".~"SUPPLIER_CODE~" = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~"(+)) and  
         ( ~"IMCN_MOLD_UNIT_PRICE~".~"ORGANIZATION_ID~"= ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~"(+) ) and  
         ( ( ~"IMCN_MOLD_UNIT_PRICE~".~"MOLD_CODE~" like :arg_mold_code ) AND  
         ( ~"IMCN_MOLD_UNIT_PRICE~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IMCN_MOLD_UNIT_PRICE~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" arguments=(("arg_mold_code", string),("arg_supplier_code", string),("arg_org_id", number))  sort="organization_id A status D supplier_code A mold_code A dateset A " )
