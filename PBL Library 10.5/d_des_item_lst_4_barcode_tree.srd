 retrieve="  SELECT ‾"ID_ITEM‾".‾"ITEM_CODE‾",   
         ‾"ID_ITEM‾".‾"ORGANIZATION_ID‾",   
         ‾"ID_ITEM‾".‾"SET_ITEM_YN‾",   
         ‾"ID_ITEM‾".‾"ITEM_NAME‾",   
         ‾"ID_ITEM‾".‾"ITEM_SPEC‾",   
         ‾"ID_ITEM‾".‾"ITEM_UOM‾",   
         ‾"ID_ITEM‾".‾"ITEM_TYPE‾",   
         ‾"ID_ITEM‾".‾"LINE_TYPE‾",   
         ‾"ID_ITEM‾".‾"ITEM_DIVISION‾",   
         ‾"ID_ITEM‾".‾"ENTER_DATE‾",   
         ‾"ID_ITEM‾".‾"LAST_MODIFY_DATE‾",   
         ‾"ID_ITEM‾".‾"ENTER_BY‾",   
         ‾"ID_ITEM‾".‾"LAST_MODIFY_BY‾",   
         ‾"ID_ITEM‾".‾"ITEM_CLASS‾",   
         ‾"ID_ITEM‾".‾"BARCODE‾",   
         ‾"ID_ITEM‾".‾"PART_NO‾",   
         'N' CHECK_YN,   
         ‾"ID_ITEM‾".‾"SUPPLIER_CODE‾",   
         ‾"ID_ITEM‾".‾"CUSTOMER_CODE‾",   
		0 QTY,
         ROWID
    FROM ‾"ID_ITEM‾"  
   WHERE ( ( ‾"ID_ITEM‾".‾"ITEM_CODE‾" like :ARG_ITEM_CODE ) AND  
          ( ‾"ID_ITEM‾".‾"ORGANIZATION_ID‾" = :ARG_ORGANIZATION_ID ) )    
" arguments=(("ARG_ITEM_CODE", string),("ARG_ORGANIZATION_ID", number))  sort="organization_id A item_division A set_item_yn D item_code A " )
