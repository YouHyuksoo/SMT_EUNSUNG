 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_SP~".~"CSTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"SEQ_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"PID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"MACHINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"INSPECT_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"RESULT~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"DEFECT_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"ORGANIZATION_ID~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"ARRAY_NO~"  ,
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"RUN_NO~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"LINE_CODE~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"SSO_DIST_TABLE~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"SSO_TABLE_SPEED~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"PRESSURE1~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"SPEED1~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"PRESSURE2~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"SPEED2~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"FREQUENCY~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"TEMPRATURE~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"FRONT_SQG~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"REAR_SQG~",
         ~"IQ_MACHINE_INSPECT_DATA_SP~".~"MATAL_MASK~",
         F_GET_RUN_MODEL_NAME(RUN_NO)   MODEL_NAME,
         paste_id         ,
         Stencil_Id       ,
         Squeegee_Id      ,
         Product_Count    ,
         squeegee_count   ,
         Mask_Count       ,
         paste_count ,
		WORK_SEPARATION_SPEED,
         WORK_SEPARATION_DISTANCE,
         job_file,

         position                        HIT_POSITION,
         double_printing_option  SJ_OPTION,
         printing_direction          SJ_DIRECTION
    FROM ~"IQ_MACHINE_INSPECT_DATA_SP~"  
   WHERE ( ~"IQ_MACHINE_INSPECT_DATA_SP~".~"INSPECT_DATE~" >= TO_CHAR(TRUNC(:ARG_DATESET),'YYYY/MM/DD HH24:MI:SS' ) ) AND  
              ( ~"IQ_MACHINE_INSPECT_DATA_SP~".~"INSPECT_DATE~" <   TO_CHAR(TRUNC(:ARG_DATEEND)+1 ,'YYYY/MM/DD HH24:MI:SS' )) AND  
              (~"IQ_MACHINE_INSPECT_DATA_SP~".~"PID~" like :ARG_PID  )   AND 
	     	 (NVL(~"IQ_MACHINE_INSPECT_DATA_SP~".~"LINE_CODE~",'*') LIKE :ARG_LINE_CODE ) AND
			  F_GET_RUN_MODEL_NAME( RUN_NO) LIKE :ARG_MODEL_NAME  AND
               RUN_NO  LIKE :ARG_RUN_NO " arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_PID", string),("ARG_MODEL_NAME", string),("ARG_RUN_NO", string))  sort="inspect_date A line_code A pid A " )
