 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"isys_company~" ) COLUMN(NAME=~"isys_company.company_code~") COLUMN(NAME=~"isys_company.company_address~") COLUMN(NAME=~"isys_company.company_fax_no~") COLUMN(NAME=~"isys_company.company_name~") COLUMN(NAME=~"isys_company.company_tel_no~") COLUMN(NAME=~"isys_company.enter_date~") COLUMN(NAME=~"isys_company.enter_by~") COLUMN(NAME=~"isys_company.last_modify_date~") COLUMN(NAME=~"isys_company.last_modify_by~") COLUMN(NAME=~"isys_company.trade_type~") COLUMN(NAME=~"isys_company.trade_code~") COMPUTE(NAME=~"ROWID~")WHERE(    EXP1 =~"~~~"ISYS_COMPANY~~~".~~~"COMPANY_CODE~~~"~"   OP =~"LIKE~"    EXP2 =~":ARG_COMPANY_CODE~" ) ) ARG(NAME = ~"ARG_COMPANY_CODE~" TYPE = string) " update="ISYS_COMPANY" updatewhere=1 updatekeyinplace=no arguments=(("ARG_COMPANY_CODE", string)) )
