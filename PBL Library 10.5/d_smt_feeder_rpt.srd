datawindow(units=0 timer_interval=60000 color=16777215 processing=0 HTMLDW=no print.printername="" print.documentname="" print.orientation = 1 print.margin.left = 220 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 9 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no )
header(height=768 color="536870912" )
summary(height=0 color="536870912" )
footer(height=84 color="536870912" )
detail(height=76 color="536870912" height.autosize=yes )
table(column=(type=char(30) updatewhereclause=yes name=line_code dbname="ib_product_plandata.line_code" dbalias="A.line_code" )
 column=(type=char(10) updatewhereclause=yes name=table_id dbname="ib_product_plandata.table_id" dbalias="A.table_id" )
 column=(type=number updatewhereclause=yes name=sort_order dbname="sort_order" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="ib_product_plandata.model_name" dbalias="A.model_name" )
 column=(type=char(30) updatewhereclause=yes name=machine dbname="ib_product_plandata.machine" dbalias="A.machine" )
 column=(type=char(100) updatewhereclause=yes name=item_code dbname="ib_product_plandata.item_code" dbalias="A.item_code" )
 column=(type=char(1) updatewhereclause=yes name=feeder_shaft dbname="ib_product_plandata.feeder_shaft" dbalias="A.feeder_shaft" )
 column=(type=char(2) updatewhereclause=yes name=loc dbname="loc" )
 column=(type=char(1) updatewhereclause=yes name=loc2 dbname="loc2" )
 column=(type=char(40) updatewhereclause=yes name=loc_b dbname="loc_b" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="ib_product_plandata.location_code" dbalias="A.location_code" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias="B.item_spec" )
 column=(type=char(10) updatewhereclause=yes name=msl dbname="id_item.msl" dbalias="B.msl" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="id_eng_bom_smt.item_unit_qty" dbalias="C.item_unit_qty" )
 column=(type=char(1201) updatewhereclause=yes name=location_info dbname="location_info" )
 column=(type=char(10) updatewhereclause=yes name=revision dbname="id_eng_bom_smt.revision" dbalias="C.revision" )
 column=(type=datetime updatewhereclause=yes name=dateset dbname="id_eng_bom_smt.dateset" dbalias="C.dateset" )
 column=(type=datetime updatewhereclause=yes name=dateend dbname="id_eng_bom_smt.dateend" dbalias="C.dateend" )
 column=(type=char(10) updatewhereclause=yes name=feeder_type dbname="id_item.feeder_type" dbalias="B.feeder_type" )
 column=(type=char(100) updatewhereclause=yes name=item_name_desc dbname="id_item.item_name_desc" dbalias="B.item_name_desc" )
 column=(type=char(1) updatewhereclause=yes name=replace_yn dbname="ib_product_plandata.replace_yn" dbalias="A.replace_yn" )
 retrieve="    SELECT A.LINE_CODE, 
                A.TABLE_ID,

           CASE WHEN    SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 )  = 1 THEN 1 
					WHEN   SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) = 2 THEN 2
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) = 5 THEN 3
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) = 6 THEN 4
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) = 9 THEN 5
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) = 10 THEN 6
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) = 13 THEN 7
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) = 14 THEN 8

					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  3  THEN 1 
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  4 THEN 2
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  7 THEN 3
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  8 THEN 4
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  11 THEN 5
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  12 THEN 6
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  15 THEN 7
					WHEN  SUBSTR ( A.TABLE_ID , 1, INSTR(A.TABLE_ID, 'T' , 1) -1 ) =  16 THEN 8

            END  SORT_ORDER ,

				A.MODEL_NAME, 
				A.MACHINE, 
				A.ITEM_CODE, 
				A.FEEDER_SHAFT,

			    
				DECODE(LENGTH(A.LOCATION_CODE),5, SUBSTR(A.LOCATION_CODE, 3,2), SUBSTR(A.LOCATION_CODE, 4,2))  LOC,
		
				DECODE(LENGTH(A.LOCATION_CODE),5, SUBSTR(A.LOCATION_CODE, 5,1), SUBSTR(A.LOCATION_CODE, 6,1)) LOC2,

				DECODE (  SUBSTR(A.ITEM_CODE ,1,3) , 'EAX' , '01' ,TO_CHAR(TO_NUMBER(DECODE(LENGTH(A.LOCATION_CODE),5, SUBSTR(A.LOCATION_CODE, 3,2), SUBSTR(A.LOCATION_CODE, 4,2))) + 10))  LOC_B,
				A.LOCATION_CODE,
				B.ITEM_SPEC,
				B.MSL_LEVEL AS MSL,
				C.ITEM_UNIT_QTY,
				SUBSTR( C.LOCATION_INFO, 1, INSTR(  C.LOCATION_INFO , ',' , 1, 8 ) -1 )||' '||SUBSTR( C.LOCATION_INFO , INSTR(  C.LOCATION_INFO , ',' , 1, 8 ) , 200 )  AS LOCATION_INFO ,
				C.REVISION,
				C.DATESET,
				C.DATEEND ,
				B.FEEDER_TYPE ,
				B.ITEM_NAME_DESC,
				A.REPLACE_YN REPLACE_YN
        FROM IB_PRODUCT_PLANDATA A ,
				ID_ENG_BOM_SMT       C,
				ID_ITEM               B
				
     WHERE  A.ITEM_CODE        = B.ITEM_CODE

      AND  A.MODEL_NAME         = C.PARENT_ITEM_CODE
      AND A.LINE_CODE              = C.LINE_CODE
      AND A.FEEDER_SHAFT        = C.FEEDER_SHAFT 
      AND A.ITEM_CODE             = C.CHILD_ITEM_CODE
      AND A.LOCATION_CODE     = C.LOCATION_CODE
      AND A.REVISION                = C.REVISION		

      AND A.LINE_CODE              = :arg_line_code
      AND A.MODEL_NAME          = :arg_model_name
      AND A.PCB_ITEM                = :arg_pcb_item
      AND A.REVISION                = :arg_revision
      AND A.FEEDER_SHAFT       = :arg_shaft
      AND A.ORGANIZATION_ID   = :arg_org
 " arguments=(("arg_line_code", string),("arg_model_name", string),("arg_pcb_item", string),("arg_shaft", string),("arg_revision", string),("arg_org", number))  sort="sort_order A MOD(   INTEGER( MID( TABLE_ID , 1,   pos( table_id , 'T' , 1 ) -1 ) ) , 2 ) D INTEGER( MID( TABLE_ID , 1,   pos( table_id , 'T' , 1 ) -1 )) A loc A loc2 A replace_yn A " )
