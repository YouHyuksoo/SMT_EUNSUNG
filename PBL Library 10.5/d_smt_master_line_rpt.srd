table(column=(type=char(100) updatewhereclause=yes name=item_code dbname="ib_product_plandata.item_code" )
 column=(type=char(20) updatewhereclause=yes name=lot_no dbname="ib_product_plandata.lot_no" )
 column=(type=char(30) updatewhereclause=yes name=line_code dbname="ib_product_plandata.line_code" )
 column=(type=char(10) updatewhereclause=yes name=revision dbname="ib_product_plandata.revision" )
 column=(type=datetime updatewhereclause=yes name=issue_date dbname="ib_product_plandata.issue_date" )
 column=(type=number updatewhereclause=yes name=product_qty dbname="product_qty" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" )
 column=(type=char(4000) updatewhereclause=yes name=select_lot_no dbname="select_lot_no" )
 column=(type=char(30) updatewhereclause=yes name=plan_date dbname="ib_product_plandata.plan_date" )
 retrieve="SELECT   A.ITEM_CODE,   
              A.LOT_NO,            
              A.LINE_CODE, 
              A.REVISION,      
              SYSDATE  AS ISSUE_DATE,
             CASE WHEN NVL( A.ITEM_UNIT_QTY, 0 ) = 0 THEN 1
                      ELSE ROUND(( NVL( A.FEEDING_QTY , 0)  - ( NVL(A.PRODUCT_ACTUAL_QTY,0) ) + F_GET_LINE_SCAN_QTY(A.ITEM_CODE, A.LINE_CODE, A.ORGANIZATION_ID) ) / NVL( A.ITEM_UNIT_QTY, 0 )) END  PRODUCT_QTY,
		    (SELECT SUM(D.INVENTORY_QTY)  FROM IM_ITEM_INVENTORY  D WHERE D.ITEM_CODE =  A.ITEM_CODE AND D.INVENTORY_QTY > 0 AND LOCATION_CODE IN ('M01' , 'M05' , 'M06' ) )  INVENTORY_QTY,
		    B.ITEM_SPEC ITEM_SPEC ,
     		B.LOCATION_ADDRESS,
             F_GET_LOT_NO_FIFO(A.ITEM_CODE, A.ORGANIZATION_ID) AS SELECT_LOT_NO,
             A.PLAN_DATE
   FROM IB_PRODUCT_PLANDATA  A , 
             ID_ITEM                         B , 
             IP_PRODUCT_LINE          C
   WHERE A.ITEM_CODE = B.ITEM_CODE(+) 
	   AND A.ORGANIZATION_ID = B.ORGANIZATION_ID(+) 
        AND A.LINE_CODE = C.LINE_CODE(+)
  	   AND A.ORGANIZATION_ID = C.ORGANIZATION_ID(+) 
	   AND A.LINE_CODE  = :arg_line_code
	   AND A.MODEL_NAME  LIKE :arg_model_name
       AND  A.ACTIVE_YN LIKE :ARG_ACTIVE 
       AND A.ITEM_UNIT_QTY > 0 
       AND A.PRODUCT_ACTUAL_QTY > 0 
	  AND A.ITEM_UNIT_QTY <= :arg_item_unit_qty
      AND A.ORGANIZATION_ID = :arg_org
	  AND A.LOCATION_CODE NOT LIKE 'TRAY%'
	  AND (  DECODE( NVL(A.item_unit_qty * C.REAL_ST,0) , 0 , 0 ,TRUNC(  (NVL( A.FEEDING_QTY , 0)- NVL(A.PRODUCT_ACTUAL_QTY,0) ) / A.item_unit_qty * C.REAL_ST / 60 , 0 ) )  < :ARG_LIMIT_TIME  OR FEEDING_QTY - PRODUCT_ACTUAL_QTY <= :ARG_LIMIT_QTY ) 
" arguments=(("arg_line_code", string),("arg_model_name", string),("arg_limit_time", number),("arg_active", string),("arg_item_unit_qty", number),("arg_limit_qty", number),("arg_org", number))  sort="product_qty A " )
