 retrieve="select   f_get_basecode( 'OPERATIONNAME' ,  operationname ,  'K'  , 1 )  operationname , count(*) ACTUAL_QTY , model , buyer ,  max(last_txn_date )  last_txn_date
 from TB_VIS_PID_ISSUE_HIST
 where operationname is not null  
   and operationname not in ( 'FNL1000' , 'PCB8100') 
group by operationname , model , buyer  
"  sort="model A buyer A " )
