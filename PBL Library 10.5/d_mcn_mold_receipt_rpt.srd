_MOLD_RECEIPT~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_RECEIPT~~~".~~~"MOLD_CODE~~~"~"   OP =~"<>~"    EXP2 =~"'*'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_RECEIPT~~~".~~~"RECEIPT_STATUS~~~"~"   OP =~"=~"    EXP2 =~"'N'~" ) ) ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_mold_code~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_mold_code", string),("arg_supplier_code", string),("arg_org", number)) )
