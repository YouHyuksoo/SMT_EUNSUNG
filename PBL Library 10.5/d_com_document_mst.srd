 retrieve="  SELECT ~"ICOM_DOCUMENT~".~"DOC_KEYWORD~",   
               ~"ICOM_DOCUMENT~".~"DOC_COMMENT~", 
               organization_ID, 
               DOC_ID, 
               ENTER_BY, ENTER_DATE, LAST_MODIFY_BY, LAST_MODIFY_DATE
    FROM ~"ICOM_DOCUMENT~"  
   WHERE rowid = :arg_rowid    
" update="ICOM_DOCUMENT" updatewhere=0 updatekeyinplace=yes arguments=(("arg_rowid", string)) )
