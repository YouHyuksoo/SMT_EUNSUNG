table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=number updatewhereclause=yes name=receipt_qty dbname="receipt_qty" )
 column=(type=number updatewhereclause=yes name=receipt_amt dbname="receipt_amt" )
 retrieve="  SELECT ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~",   
         ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_QTY~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_AMT~",   
         F_GET_BASECODE( 'ORDER TYPE' ,  ~"IM_ITEM_RECEIPT~".~"ORDER_TYPE~",   :ARG_LANG  ,~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" ) ORDER_TPYE ,
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~"  
    FROM ~"IM_ITEM_RECEIPT~",   
         ~"ICOM_SUPPLIER~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~" = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" ) and  
         ( ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" = ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~" <= :arg_dateend ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_lang", string),("arg_org", number))  sort="item_code A item_name A item_spec A " )
