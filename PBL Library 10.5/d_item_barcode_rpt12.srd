table(column=(type=char(30) updatewhereclause=yes name=model_name dbname="ip_product_model_master.model_name" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_model_master.item_code" )
 column=(type=char(10) updatewhereclause=yes name=company_code dbname="ip_product_model_master.company_code" )
 column=(type=char(50) updatewhereclause=yes name=item_barcode dbname="item_barcode" )
 column=(type=char(46) updatewhereclause=yes name=barcode_no dbname="barcode_no" )
 retrieve=" SELECT  MODEL_NAME,
              ITEM_CODE,
             COMPANY_CODE,
            ITEM_CODE||COMPANY_CODE||TO_CHAR(:ARG_DATESET,'YYMMDD')||'.BMP'   ITEM_BARCODE,
            ITEM_CODE||COMPANY_CODE||TO_CHAR(:ARG_DATESET,'YYMMDD')   BARCODE_NO    
           
FROM    IP_PRODUCT_MODEL_MASTER
WHERE     MODEL_NAME   LIKE  :ARG_MODEL_NAME
AND     ITEM_CODE   LIKE  :ARG_ITEM_CODE
AND       ORGANIZATION_ID = :ARG_ORG" arguments=(("arg_model_name", string),("arg_item_code", string),("arg_dateset", datetime),("arg_org", number)) )
