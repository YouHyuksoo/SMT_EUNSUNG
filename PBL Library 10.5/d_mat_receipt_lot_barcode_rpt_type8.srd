 column=(type=char(42) updatewhereclause=yes name=scan_qty_barcode dbname="scan_qty_barcode" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" dbalias=".item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias=".item_spec" )
 column=(type=char(10) updatewhereclause=yes name=msl_level dbname="id_item.msl_level" dbalias=".msl_level" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" dbalias=".location_address" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="im_item_receipt_barcode.supplier_code" dbalias=".supplier_code" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_receipt_barcode.organization_id" dbalias=".organization_id" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="im_item_receipt_barcode.enter_date" dbalias=".enter_date" )
 column=(type=char(1) updatewhereclause=yes name=label_type dbname="im_item_receipt_barcode.label_type" dbalias=".label_type" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="im_item_receipt_barcode.enter_by" dbalias=".enter_by" )
 column=(type=char(1) updatewhereclause=yes name=receipt_type dbname="im_item_receipt_barcode.receipt_type" dbalias=".receipt_type" )
 column=(type=char(100) updatewhereclause=yes name=organization_id dbname="isys_organization.organization_id" dbalias="O.organization_id" )
 retrieve="  SELECT 
        
		~"ID_ITEM~".~"ITEM_CODE~", 
    		F_BACODE_CODE128( 'B' ,~"ID_ITEM~".~"ITEM_CODE~") ITEM_BARCODE_BARCODE,   
         '*' LOT_NO, 
		--F_BACODE_CODE128( 'B' ,~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_BARCODE~") ITEM_BARCODE_BARCODE,   
		--~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_NO~" LOT_NO,   
		--F_BACODE_CODE128( 'B' , ~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_NO~") LOT_NO_BARCODE,   
          F_BACODE_CODE128( 'B' , '*' ) LOT_NO_BARCODE,   
		
		~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_BARCODE~",   
         '*'||~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_QTY~"||'*' SCAN_QTY_BARCODE,   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"MSL_LEVEL~",   
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_CODE~"  ,
		~"IM_ITEM_RECEIPT_BARCODE~".~"ORGANIZATION_ID~" ,
		SYSDATE ENTER_DATE , 
          IM_ITEM_RECEIPT_BARCODE.LABEL_TYPE ,
         IM_ITEM_RECEIPT_BARCODE.ENTER_BY ,
		IM_ITEM_RECEIPT_BARCODE.RECEIPT_TYPE ,
		O.ORGANIZATION_FULL_NAME_ENG ORGANIZATION_ID
		
    FROM ~"IM_ITEM_RECEIPT_BARCODE~",   
         ~"ID_ITEM~"  ,
		ISYS_ORGANIZATION O
   WHERE ( im_item_receipt_barcode.item_code = id_item.item_code (+)) and  
         ( im_item_receipt_barcode.organization_id = id_item.organization_id (+)) and  
         ( im_item_receipt_barcode.organization_id = o.organization_id (+)) and  

         ( ( ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_CODE~" = :arg_item_code ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"BARCODE_STATUS~" <> 'C' ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"ORGANIZATION_ID~" = :arg_org ) )   AND
         rownum = 1" arguments=(("arg_item_code", string),("arg_org", number)) )
