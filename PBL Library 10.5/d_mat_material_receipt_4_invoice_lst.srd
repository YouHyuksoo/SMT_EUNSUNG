 retrieve="SELECT  ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~" ,    
~"IM_ITEM_RECEIPT~".~"RECEIPT_SEQUENCE~" ,  
~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" ,  
~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~" ,  
~"IM_ITEM_RECEIPT~".~"ORDER_NO~" , 
~"IM_ITEM_RECEIPT~".~"MFS~" ,  
~"IM_ITEM_RECEIPT~".~"ITEM_CODE~" ,  
~"IM_ITEM_RECEIPT~".~"RECEIPT_LOT_NO~" ,  
~"IM_ITEM_RECEIPT~".~"RECEIPT_DEFICIT~" ,     
~"IM_ITEM_RECEIPT~".~"RECEIPT_TYPE~" ,    
~"IM_ITEM_RECEIPT~".~"UNIT_PRICE~" ,     
~"IM_ITEM_RECEIPT~".~"CURRENCY~" ,    
~"IM_ITEM_RECEIPT~".~"RECEIPT_QTY~" ,   
~"IM_ITEM_RECEIPT~".~"INVOICE_NO~" ,     
~"IM_ITEM_RECEIPT~".~"RECEIPT_STATUS~" ,     
~"IM_ITEM_RECEIPT~".~"BARCODE~" ,      
~"IM_ITEM_RECEIPT~".~"COMMENTS~" ,     
~"IM_ITEM_RECEIPT~".~"ENTER_DATE~" ,  
~"IM_ITEM_RECEIPT~".~"ENTER_BY~" ,     
~"IM_ITEM_RECEIPT~".~"LAST_MODIFY_DATE~" ,   
~"IM_ITEM_RECEIPT~".~"LAST_MODIFY_BY~" ,   
~"ID_ITEM~".~"ITEM_NAME~" ,           ~"ID_ITEM~".~"ITEM_SPEC~" ,   
~"ID_ITEM~".~"ITEM_UOM~" ,           ~"IM_ITEM_RECEIPT~".~"RECEIPT_AMT~" ,  
~"IM_ITEM_RECEIPT~".~"CONFIRM_YN~" ,           ~"IM_ITEM_RECEIPT~".~"CONFIRM_DATE~" ,      
~"IM_ITEM_RECEIPT~".~"CONFIRM_BY~" ,      
'N' CHECK_YN,           
~"IM_ITEM_RECEIPT~".~"LINE_TYPE~" ,           
~"IM_ITEM_RECEIPT~".~"INVOICE_OPEN_YN~" ,     
~"IM_ITEM_RECEIPT~".~"INVOICE_OPEN_SEQUENCE~" ,       
~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~" ,   
~"IM_ITEM_RECEIPT~".~"EXCHANGE_RATE~" ,  
~"IM_ITEM_RECEIPT~".~"FOREIGN_RECEIPT_AMT~" ,  
F_GET_BILL_DISBURSE_DATE( im_item_receipt.supplier_code , im_item_receipt.receipt_date , im_item_receipt.organization_id ) BILL_COLLECT_DATE  
FROM ~"IM_ITEM_RECEIPT~" ,           ~"ID_ITEM~" ,           ~"ICOM_SUPPLIER~"     WHERE ( ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and     
( ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and   
( ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~" = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" ) and    
( ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" = ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" ) and 
( ( ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~" >= :arg_dateset ) and  
( ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~" <= :arg_dateend ) and     
( ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~" like :arg_supplier_code ) And 
( ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~" like :arg_item_code ) And  
( NVL(~"IM_ITEM_RECEIPT~".~"INVOICE_OPEN_YN~",'N') like :arg_invoice_open_yn ) and  
( ~"IM_ITEM_RECEIPT~".~"CONFIRM_YN~" = 'Y' ) and          
( ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" = :arg_org ) and
( ~"IM_ITEM_RECEIPT~".~"RECEIPT_STATUS~" <> 'C' ) )  " update="IM_ITEM_RECEIPT" updatewhere=0 updatekeyinplace=yes arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_invoice_open_yn", string),("arg_org", number))  sort="organization_id A supplier_code A invoice_open_yn A receipt_date A receipt_sequence A " )
group(level=1 header.height=0 trailer.height=64 by=("organization_id" , "supplier_code" ) header.color="536870912" trailer.color="65535" )
group(level=2 header.height=0 trailer.height=64 by=("organization_id" , "supplier_code" , "invoice_open_yn" ) header.color="65535" trailer.color="536870912" )
