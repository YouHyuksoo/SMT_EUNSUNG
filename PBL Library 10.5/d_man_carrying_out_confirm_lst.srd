 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"iman_carrying_out~" )  TABLE(NAME=~"isys_users~" ) COLUMN(NAME=~"iman_carrying_out.carrying_out_date~") COLUMN(NAME=~"iman_carrying_out.carrying_out_seq~") COLUMN(NAME=~"iman_carrying_out.organization_id~") COLUMN(NAME=~"iman_carrying_out.carrying_out_item~") COLUMN(NAME=~"iman_carrying_out.carrying_out_item_spec~") COLUMN(NAME=~"iman_carrying_out.carrying_out_receiptor~") COLUMN(NAME=~"iman_carrying_out.carrying_out_qty~") COLUMN(NAME=~"iman_carrying_out.carrying_out_type~") COLUMN(NAME=~"iman_carrying_out.carrying_out_division~") COLUMN(NAME=~"iman_carrying_out.carrying_out_by~") COLUMN(NAME=~"iman_carrying_out.comments~") COLUMN(NAME=~"iman_carrying_out.car_no~") COLUMN(NAME=~"iman_carrying_out.invoice_no~") COLUMN(NAME=~"iman_carrying_out.confirm_by~") COLUMN(NAME=~"iman_carrying_out.confirm_date~") COLUMN(NAME=~"iman_carrying_out.confirm_yn~") COLUMN(NAME=~"iman_carrying_out.confirm_by2~") COLUMN(NAME=~"iman_carrying_out.confirm_date2~") COLUMN(NAME=~"iman_carrying_out.confirm_yn2~") COLUMN(NAME=~"iman_carrying_out.complete_yn~") COLUMN(NAME=~"iman_carrying_out.gate_guard_id~") COLUMN(NAME=~"iman_carrying_out.gate_guard_confirm_yn~") COLUMN(NAME=~"iman_carrying_out.bring_in_plan_date~") COLUMN(NAME=~"iman_carrying_out.bring_in_yn~") COLUMN(NAME=~"iman_carrying_out.enter_date~") COLUMN(NAME=~"iman_carrying_out.enter_by~") COLUMN(NAME=~"iman_carrying_out.last_modify_date~") COLUMN(NAME=~"iman_carrying_out.last_modify_by~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"iman_carrying_out.carrying_out_group_no~") COLUMN(NAME=~"isys_users.department_code~") COLUMN(NAME=~"iman_carrying_out.request_status~")WHERE(    EXP1 =~"IMAN_CARRYING_OUT.ENTER_BY~"   OP =~"=~"    EXP2 =~"ISYS_USERS.USER_ID(+)~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"IMAN_CARRYING_OUT.ORGANIZATION_ID~"   OP =~"=~"    EXP2 =~"ISYS_USERS.ORGANIZATION_ID(+)~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"ISYS_USERS.DEPARTMENT_CODE~"   OP =~"LIKE~"    EXP2 =~":ARG_DEPT_CODE~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( IMAN_CARRYING_OUT.CARRYING_OUT_ITEM~"   OP =~"like~"    EXP2 =~":arg_item )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( IMAN_CARRYING_OUT.REQUEST_STATUS~"   OP =~"=~"    EXP2 =~"'C' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( IMAN_CARRYING_OUT.CARRYING_OUT_RECEIPTOR~"   OP =~"like~"    EXP2 =~":arg_supplier )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(IMAN_CARRYING_OUT.CONFIRM_YN , 'N')~"   OP =~"=~"    EXP2 =~":arg_confirm_yn )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"(NVL(IMAN_CARRYING_OUT.CONFIRM_BY ,'*')~"   OP =~"like~"    EXP2 =~":arg_confirm_by )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( IMAN_CARRYING_OUT.ORGANIZATION_ID~"   OP =~"=~"    EXP2 =~":arg_org )~" ) ) ARG(NAME = ~"arg_item~" TYPE = string)  ARG(NAME = ~"arg_supplier~" TYPE = string)  ARG(NAME = ~"arg_confirm_yn~" TYPE = string)  ARG(NAME = ~"arg_confirm_by~" TYPE = string)  ARG(NAME = ~"arg_dept_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IMAN_CARRYING_OUT" updatewhere=0 updatekeyinplace=no arguments=(("arg_item", string),("arg_supplier", string),("arg_confirm_yn", string),("arg_confirm_by", string),("arg_dept_code", string),("arg_org", number))  sort="organization_id A carrying_out_group_no A carrying_out_date D carrying_out_seq D " )
