detail(height=72 color="536870912" )
table(column=(type=char(7) updatewhereclause=yes name=div dbname="div" )
 column=(type=char(30) updatewhereclause=yes name=child_item_code dbname="child_item_code" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="location_code" )
 column=(type=char(1000) updatewhereclause=yes name=location_info dbname="location_info" )
 column=(type=char(30) updatewhereclause=yes name=pcb_item dbname="pcb_item" )
 retrieve="( SELECT 'RETURN ' DIV ,
~"ID_ENG_BOM_SMT~".~"CHILD_ITEM_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_INFO~",   

~"ID_ENG_BOM_SMT~".~"PCB_ITEM~"
FROM ~"ID_ENG_BOM_SMT~"   
WHERE LINE_CODE = :ARG_LINE_CODE 
AND PARENT_ITEM_CODE = :ARG_MODEL_NAME
AND PCB_ITEM = :ARG_PCB_ITEM
AND NVL(FEEDER_SHAFT,'*') =  NVL(:ARG_SHAFT,'*')
AND ORGANIZATION_ID = :ARG_ORG

MINUS 

SELECT  'RETURN ' DIV ,
~"ID_ENG_BOM_SMT~".~"CHILD_ITEM_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_INFO~",   
~"ID_ENG_BOM_SMT~".~"PCB_ITEM~"

FROM ~"ID_ENG_BOM_SMT~"   
WHERE LINE_CODE = :ARG_LINE_CODE_NEW
AND PARENT_ITEM_CODE = :ARG_MODEL_NAME_NEW
AND PCB_ITEM = :ARG_PCB_ITEM_NEW
AND NVL(FEEDER_SHAFT,'*') = NVL(:ARG_SHAFT_NEW,'*')
AND ORGANIZATION_ID = :ARG_ORG_NEW
)

UNION ALL

(
SELECT  'ISSUE ' DIV ,
~"ID_ENG_BOM_SMT~".~"CHILD_ITEM_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_INFO~",   
~"ID_ENG_BOM_SMT~".~"PCB_ITEM~"
FROM ~"ID_ENG_BOM_SMT~"   
WHERE LINE_CODE = :ARG_LINE_CODE_NEW
AND PARENT_ITEM_CODE = :ARG_MODEL_NAME_NEW
AND PCB_ITEM = :ARG_PCB_ITEM_NEW
AND NVL(FEEDER_SHAFT,'*') = NVL(:ARG_SHAFT_NEW,'*')
AND ORGANIZATION_ID = :ARG_ORG_NEW

MINUS 

SELECT  'ISSUE ' DIV ,
~"ID_ENG_BOM_SMT~".~"CHILD_ITEM_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_CODE~",   
~"ID_ENG_BOM_SMT~".~"LOCATION_INFO~",   
~"ID_ENG_BOM_SMT~".~"PCB_ITEM~"
FROM ~"ID_ENG_BOM_SMT~"   
WHERE LINE_CODE = :ARG_LINE_CODE 
AND PARENT_ITEM_CODE = :ARG_MODEL_NAME
AND PCB_ITEM = :ARG_PCB_ITEM
AND NVL(FEEDER_SHAFT,'*') = NVL(:ARG_SHAFT ,'*')
AND ORGANIZATION_ID = :ARG_ORG

)
