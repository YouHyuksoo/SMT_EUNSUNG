 column=(type=char(20) update=yes updatewhereclause=yes name=enter_by dbname="imcn_weekly_pm_result.enter_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="imcn_weekly_pm_result.enter_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="imcn_weekly_pm_result.last_modify_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="imcn_weekly_pm_result.last_modify_date" )
 column=(type=char(100) updatewhereclause=yes name=code_mean dbname="code_mean" )
 retrieve="  SELECT ~"IMCN_WEEKLY_PM_RESULT~".~"PLAN_YYYY~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"PLAN_WEEKS~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"MACHINE_CODE~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"TPM_SEQUENCE~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"ORGANIZATION_ID~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_TYPE~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_GROUP~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_GROUP_SECOND~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_GROUP_THIRD~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_NAME~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"TPM_RESULT~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"TPM_COMMENTS~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"TPM_DATE~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"ENTER_BY~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"ENTER_DATE~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"LAST_MODIFY_BY~",   
         ~"IMCN_WEEKLY_PM_RESULT~".~"LAST_MODIFY_DATE~",   
         DECODE( :ARG_LANG , 'K' , ~"ISYS_CODE_MASTER~".~"CODE_MEAN_KOR~"   , 'C' , ~"ISYS_CODE_MASTER~".~"CODE_MEAN_LOCAL~" , ~"ISYS_CODE_MASTER~".~"CODE_MEAN_ENG~" ) CODE_MEAN
    FROM ~"IMCN_WEEKLY_PM_RESULT~",   
         ~"ISYS_CODE_MASTER~"  
   WHERE ( ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_TYPE~" = ~"ISYS_CODE_MASTER~".~"CODE_TYPE~" ) and  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_GROUP~" = ~"ISYS_CODE_MASTER~".~"CODE_GROUP~" ) and  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_GROUP_SECOND~" = ~"ISYS_CODE_MASTER~".~"CODE_GROUP_SECOND~" ) and  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_GROUP_THIRD~" = ~"ISYS_CODE_MASTER~".~"CODE_GROUP_THIRD~" ) and  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"CODE_NAME~" = ~"ISYS_CODE_MASTER~".~"CODE_NAME~" ) and  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"ORGANIZATION_ID~" = ~"ISYS_CODE_MASTER~".~"ORGANIZATION_ID~" ) and  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"MACHINE_CODE~" = :arg_machine_code ) AND  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"PLAN_YYYY~"||trim(to_char(~"IMCN_WEEKLY_PM_RESULT~".~"PLAN_WEEKS~", '00')) = :arg_yyyymmweek ) AND  
         ( ~"IMCN_WEEKLY_PM_RESULT~".~"ORGANIZATION_ID~" = :arg_org )    
" update="IMCN_WEEKLY_PM_RESULT" updatewhere=0 updatekeyinplace=no arguments=(("arg_machine_code", string),("arg_yyyymmweek", string),("arg_lang", string),("arg_org", number))  sort="plan_yyyy A plan_weeks A machine_code A tpm_sequence A " )
