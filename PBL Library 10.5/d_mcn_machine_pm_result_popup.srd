table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=plan_yyyy dbname="imcn_weekly_pm_result.plan_yyyy" )
 column=(type=number update=yes updatewhereclause=yes key=yes name=plan_weeks dbname="imcn_weekly_pm_result.plan_weeks" )
