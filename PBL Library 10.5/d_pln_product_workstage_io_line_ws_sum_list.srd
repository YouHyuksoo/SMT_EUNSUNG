table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=datetime updatewhereclause=yes name=workstage_code dbname="workstage_code" )
 column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=number updatewhereclause=yes name=actual_date dbname="actual_date" )
 retrieve="  SELECT ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~",   
         f_get_workstage_name ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_CODE~" )  as WORKSTAGE_CODE ,
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"ACTUAL_DATE~"  
    FROM ~"IP_PRODUCT_WORKSTAGE_IO~"  
   WHERE ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ACTUAL_DATE~" >= :arg_dateset ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ACTUAL_DATE~" <= :arg_dateend ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_workstage_code", string),("arg_model_name", string),("arg_org", number))  sort="line_code A workstage_code A model_name A " )
