 column=(type=number updatewhereclause=yes name=amt7 dbname="amt7" )
 column=(type=number updatewhereclause=yes name=amt8 dbname="amt8" )
 column=(type=number updatewhereclause=yes name=amt9 dbname="amt9" )
 column=(type=number updatewhereclause=yes name=amt10 dbname="amt10" )
 column=(type=number updatewhereclause=yes name=amt11 dbname="amt11" )
