 retrieve=" select  a.item_code , b.item_name, b.item_spec, b.item_uom,a.supplier_code, c.supplier_name , a.organization_id,
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'01', a.receipt_qty, 0 ))  qty1, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'02', a.receipt_qty, 0 ))   qty2, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'03', a.receipt_qty, 0 ))   qty3, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'04', a.receipt_qty, 0 ))   qty4, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'05', a.receipt_qty, 0 ))    qty5, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'06', a.receipt_qty, 0 ))    qty6, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'07', a.receipt_qty, 0 ))    qty7, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'08', a.receipt_qty, 0 ))    qty8, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'09', a.receipt_qty, 0 ))    qty9, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'10', a.receipt_qty, 0 ))  qty10, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'11', a.receipt_qty, 0 ))  qty11, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'12', a.receipt_qty, 0 ))  qty12, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'01', a.receipt_amt, 0 ))    amt1, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'02', a.receipt_amt, 0 ))    amt2, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'03', a.receipt_amt, 0 ))    amt3, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'04', a.receipt_amt, 0 ))    amt4, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'05', a.receipt_amt, 0 ))    amt5, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'06', a.receipt_amt, 0 ))    amt6, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'07', a.receipt_amt, 0 ))    amt7, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'08', a.receipt_amt, 0 ))    amt8, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'09', a.receipt_amt, 0 ))    amt9, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'10', a.receipt_amt, 0 ))    amt10, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'11', a.receipt_amt, 0 ))    amt11, 
          sum(decode(to_char(a.receipt_date,'yyyymm'), :arg_yyyy||'12', a.receipt_amt, 0 ))    amt12
 from   im_item_receipt a ,       
          id_item      b, 
          icom_supplier c 
 where a.item_code = b.item_code 
 and    a.organization_id = b.organization_id 
 and    a.supplier_code = c.supplier_code 
 and    a.organization_id = c.organization_id 
 and    a.receipt_date between to_date(:arg_yyyy||'0101', 'yyyymmdd')  and  to_date(:arg_yyyy||'1231', 'yyyymmdd')
 and    a.supplier_code like :arg_supplier_code 
 and    a.item_code like :arg_item_code 
 and    a.organization_id = :arg_org_id 
 and    a.receipt_status <> 'C'
group by a.item_code , b.item_name, b.item_spec, b.item_uom, a.supplier_code, c.supplier_name, a.organization_id
         
" arguments=(("arg_yyyy", string),("arg_supplier_code", string),("arg_item_code", string),("arg_org_id", number)) )
