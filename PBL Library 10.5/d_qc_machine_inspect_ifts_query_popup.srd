 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"INSPECT_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"INSPECT_TIME~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"EQUIPMENT_NUMBER~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"CHANNEL~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"START_MODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"BARCODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"TOTAL_JUDGMENT~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"NG_ITEM~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"WORKER~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"ORGANIZATION_ID~",   
         UPPER(~"IQ_MACHINE_INSPECT_DATA_IFTS~".~"FILE_NAME~") FILE_NAME,   
		MODEL_NAME , RUN_NO 
    FROM ~"IQ_MACHINE_INSPECT_DATA_IFTS~"  
   WHERE 	RUN_NO LIKE :ARG_RUN_NO 
    " update="IQ_MACHINE_INSPECT_DATA_IFTS" updatewhere=0 updatekeyinplace=no arguments=(("ARG_RUN_NO", string))  sort="inspect_date A model_name A run_no A inspect_time A " )
