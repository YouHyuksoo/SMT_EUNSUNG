footer(height=0 color="536870912" )
detail(height=80 color="553648127" )
table(column=(type=datetime updatewhereclause=yes name=move_date dbname="im_item_location_move_hist.move_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="im_item_location_move_hist.item_code" )
 column=(type=char(30) updatewhereclause=yes name=material_mfs dbname="im_item_location_move_hist.material_mfs" )
 column=(type=char(20) updatewhereclause=yes name=from_rack dbname="im_item_location_move_hist.from_rack" )
 column=(type=char(20) updatewhereclause=yes name=to_rack dbname="im_item_location_move_hist.to_rack" )
 retrieve="SELECT MOVE_DATE, 
            ITEM_CODE, 
            MATERIAL_MFS, 
            FROM_RACK, 
            TO_RACK 
  FROM IM_ITEM_LOCATION_MOVE_HIST
 WHERE MOVE_DATE >= :arg_fdate
     AND MOVE_DATE <  :arg_tdate + 1
     AND ITEM_CODE LIKE :arg_item_code
     AND MATERIAL_MFS LIKE :arg_material_mfs
     AND ORGANIZATION_ID = :arg_org    " arguments=(("arg_fdate", datetime),("arg_tdate", datetime),("arg_item_code", string),("arg_material_mfs", string),("arg_org", number))  sort="move_date A item_code A material_mfs A " )
