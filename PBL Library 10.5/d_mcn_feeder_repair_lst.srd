 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_jig_repair~" )  TABLE(NAME=~"imcn_jig~" ) COLUMN(NAME=~"imcn_jig_repair.jig_code~") COLUMN(NAME=~"imcn_jig_repair.repair_sequence~") COLUMN(NAME=~"imcn_jig_repair.organization_id~") COLUMN(NAME=~"imcn_jig_repair.repair_request_date~") COLUMN(NAME=~"imcn_jig_repair.repair_reason_code~") COLUMN(NAME=~"imcn_jig_repair.repair_vendor_code~") COLUMN(NAME=~"imcn_jig_repair.repair_status~") COLUMN(NAME=~"imcn_jig_repair.repair_by~") COLUMN(NAME=~"imcn_jig_repair.repair_date~") COLUMN(NAME=~"imcn_jig_repair.repair_amt~") COLUMN(NAME=~"imcn_jig_repair.currency~") COLUMN(NAME=~"imcn_jig_repair.comments~") COLUMN(NAME=~"imcn_jig_repair.enter_by~") COLUMN(NAME=~"imcn_jig_repair.enter_date~") COLUMN(NAME=~"imcn_jig_repair.last_modify_by~") COLUMN(NAME=~"imcn_jig_repair.last_modify_date~") COLUMN(NAME=~"imcn_jig_repair.repair_time~") COLUMN(NAME=~"imcn_jig_repair.repair_comments~") COLUMN(NAME=~"imcn_jig_repair.jig_lot_no~") COLUMN(NAME=~"imcn_jig.jig_spec~") COLUMN(NAME=~"imcn_jig.jig_name~")    JOIN (LEFT=~"imcn_jig_repair.jig_code~"    OP =~"=~"RIGHT=~"imcn_jig.jig_code~" )    JOIN (LEFT=~"imcn_jig_repair.organization_id~"    OP =~"=~"RIGHT=~"imcn_jig.organization_id~" )WHERE(    EXP1 =~"( IMCN_JIG_REPAIR.rowid~"   OP =~"=~"    EXP2 =~":arg_rowid )~" ) ) ARG(NAME = ~"arg_rowid~" TYPE = string) " update="IMCN_JIG_REPAIR" updatewhere=0 updatekeyinplace=no arguments=(("arg_rowid", string)) )
