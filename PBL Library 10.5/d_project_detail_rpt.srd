table(column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_run_card.run_no" dbalias=".run_no" )
 column=(type=char(32) updatewhereclause=yes name=run_no_label dbname="run_no_label" )
 column=(type=datetime updatewhereclause=yes name=run_date dbname="run_date" )
 column=(type=char(50) updatewhereclause=yes name=model_name dbname="ip_product_run_card.model_name" dbalias=".model_name" )
 column=(type=char(10) updatewhereclause=yes name=line_code dbname="ip_product_run_card.line_code" dbalias=".line_code" )
 column=(type=char(30) updatewhereclause=yes name=pcb_supplier_code dbname="ip_product_run_card.pcb_supplier_code" dbalias=".pcb_supplier_code" )
 column=(type=number updatewhereclause=yes name=lot_size dbname="ip_product_run_card.lot_size" dbalias=".lot_size" )
 retrieve="  SELECT ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~", 
           '*'||UPPER(~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~")||'*' RUN_NO_LABEL,   
         TRUNC(~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~") RUN_DATE,   
         ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~",   
        ~"IP_PRODUCT_RUN_CARD~".~"PCB_SUPPLIER_CODE~",   
		~"IP_PRODUCT_RUN_CARD~".~"LOT_SIZE~" 
    FROM ~"IP_PRODUCT_RUN_CARD~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~"  
   WHERE ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~" = ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"RUN_NO~"(+) ) 
			AND    ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~" = :arg_run_no) 
			AND    (~"IP_PRODUCT_RUN_CARD~".~"ORGANIZATION_ID~" = :arg_organization_id)
" arguments=(("arg_run_no", string),("arg_organization_id", number)) )
