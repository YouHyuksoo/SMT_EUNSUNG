 retrieve="  SELECT ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"CLOSE_YYYYMM~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"LINE_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"INVENTORY_HOLD~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"CHECK_INVENTORY_QTY~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"INVENTORY_AMT~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"LOCATION_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"COMMENTS~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ENTER_DATE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ENTER_BY~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"LINE_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"LAST_MODIFY_BY~",   
         nvl( IM_ITEM_WORKSTAGE_INV_CHECK.inventory_qty,0) - nvl(IM_ITEM_WORKSTAGE_INV_CHECK.check_inventory_qty,0) difference_qty,   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"WORKSTAGE_CODE~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"MACHINE_CODE~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"MFS~",   
         'N' CHECK_YN,   
         IM_ITEM_WORKSTAGE_INV_CHECK.ROWID,   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         nvl(~"IM_ITEM_WS_INVE_CHECK_EXCEL~".~"EXCEL_CHECK_INVENTORY_QTY~" ,0) EXCEL_CHECK_INVENTORY_QTY
    FROM ~"IM_ITEM_WORKSTAGE_INV_CHECK~",   
         ~"ID_ITEM~",   
         ~"IM_ITEM_WS_INVE_CHECK_EXCEL~"  
   WHERE ( im_item_workstage_inv_check.close_yyyymm = im_item_ws_inve_check_excel.close_yyyymm (+)) and  
         ( im_item_workstage_inv_check.item_code = im_item_ws_inve_check_excel.item_code (+)) and  
         ( im_item_workstage_inv_check.line_type = im_item_ws_inve_check_excel.line_type (+)) and  
         ( im_item_workstage_inv_check.mfs = im_item_ws_inve_check_excel.mfs (+)) and  
         ( im_item_workstage_inv_check.line_code = im_item_ws_inve_check_excel.line_code (+)) and  
         ( im_item_workstage_inv_check.workstage_code = im_item_ws_inve_check_excel.workstage_code (+)) and  
         ( im_item_workstage_inv_check.location_code = im_item_ws_inve_check_excel.location_code (+)) and  
         ( im_item_workstage_inv_check.organization_id = im_item_ws_inve_check_excel.organization_id (+)) and  
         ( ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"CLOSE_YYYYMM~" = :arg_yyyymm ) AND  
         ( ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"LINE_CODE~" like :arg_line_code AND  
         ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"WORKSTAGE_CODE~" like :arg_workstage_code AND  
         ~"ID_ITEM~".~"ITEM_DIVISION~" like :arg_item_division AND  
         ( ~"IM_ITEM_WORKSTAGE_INV_CHECK~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" update="IM_ITEM_WORKSTAGE_INV_CHECK" updatewhere=0 updatekeyinplace=yes arguments=(("arg_yyyymm", string),("arg_item_code", string),("arg_line_code", string),("arg_workstage_code", string),("arg_item_division", string),("arg_org_id", number))  sort="organization_id A close_yyyymm A item_code A " )
