 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="im_item_workstage_inv_check.last_modify_date" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=line_code dbname="im_item_workstage_inv_check.line_code" )
