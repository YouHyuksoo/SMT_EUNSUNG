 retrieve="  SELECT ~"ID_ITEM~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM~".~"SET_ITEM_YN~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"ID_ITEM~".~"ENTER_DATE~",   
         ~"ID_ITEM~".~"LAST_MODIFY_DATE~",   
         ~"ID_ITEM~".~"ENTER_BY~",   
         ~"ID_ITEM~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"BARCODE~",   
         ~"ID_ITEM~".~"SPECIAL_PROPERTY~",   
         ~"ID_ITEM~".~"HEIGHT~",   
         ~"ID_ITEM~".~"WEIGHT~",   
         ~"ID_ITEM~".~"INNER_DIAMETER~",   
         ~"ID_ITEM~".~"OUTER_DIAMETER~",   
         ~"ID_ITEM~".~"DATESET~",   
         ~"ID_ITEM~".~"DATEEND~",   
         ~"ID_ITEM~".~"DRAWING_NO~",   
         ~"ID_ITEM~".~"PART_NO~",   
         DECODE( SIGN( ID_ITEM.DATEEND - TRUNC(SYSDATE) ) , 1 , DECODE( SIGN( ID_ITEM.DATESET - TRUNC(SYSDATE) ) , 1 , 'FUTURE' , 'RUNNING' ) , 'EXPIRED') STATUS,   
         ~"ID_ITEM~".~"WIDTH~",   
         ~"ID_ITEM~".~"ABC_GRADE~",   
         ~"ID_ITEM~".~"HS_CODE~",   
         ~"ID_ITEM~".~"HS_NAME~",   
         ~"ID_ITEM~".~"HS_SPEC~",   
         ID_ITEM.ROWID  
    FROM ~"ID_ITEM~"
   WHERE ( ( ~"ID_ITEM~".~"ITEM_CODE~" like :ARG_ITEM_CODE ) AND  
         ( NVL(~"ID_ITEM~".~"ITEM_NAME~",'*') like :ARG_ITEM_NAME ) AND  
         ( NVL(~"ID_ITEM~".~"SET_ITEM_YN~",'N') like :ARG_SETYN ) AND  
         ( NVL(~"ID_ITEM~".~"DATEEND~" , :ARG_DATESET ) >= :ARG_DATESET ) AND  
         ( NVL(~"ID_ITEM~".~"DRAWING_NO~",'*') like :ARG_DRAWING_NO ) AND  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID ) )    
" update="ID_ITEM" updatewhere=0 updatekeyinplace=no arguments=(("ARG_ITEM_CODE", string),("ARG_ITEM_NAME", string),("ARG_SETYN", string),("ARG_DATESET", datetime),("ARG_DRAWING_NO", string),("ARG_ORGANIZATION_ID", number))  sort="organization_id A status D item_class A item_code A " )
