 column=(type=char(2) updatewhereclause=yes name=inspect_result dbname="iq_machine_inspect_manual.inspect_result" )
 column=(type=char(20) updatewhereclause=yes name=inspect_type dbname="iq_machine_inspect_manual.inspect_type" )
