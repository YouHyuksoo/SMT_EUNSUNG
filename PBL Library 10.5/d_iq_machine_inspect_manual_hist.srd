 retrieve="   select f_get_line_name( line_code, organization_id) as line_code,   
          f_get_workstage_name(  workstage_code) as workstage_code, 
          f_get_machine_name(  machine_code ) as machine_code , 
         inspect_date,
		run_no        , 
		inspect_result,  
	     inspect_type,
		defect_code, 
		inspector  , 
		inspector_name 
       
 from IQ_MACHINE_INSPECT_MANUAL 
where product_id = :arg_product_id 
order by inspect_date" arguments=(("arg_product_id", string)) )
