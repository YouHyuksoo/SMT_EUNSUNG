 column=(type=char(20) updatewhereclause=yes name=workstage_code dbname="iq_interlock_request_log.workstage_code" dbalias=".workstage_code" )
 column=(type=char(100) updatewhereclause=yes name=interlock_type dbname="iq_interlock_request_log.interlock_type" dbalias=".interlock_type" )
 column=(type=char(10) updatewhereclause=yes name=return_value dbname="iq_interlock_request_log.return_value" dbalias=".return_value" )
 retrieve="  SELECT ~"IQ_INTERLOCK_REQUEST_LOG~".~"LINE_CODE~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"MACHINE_CODE~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"SERIAL_NO~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"REQUEST_DATE~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"COMMENTS~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"LOG_SEQUENCE~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"WORKSTAGE_CODE~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"INTERLOCK_TYPE~",   
         ~"IQ_INTERLOCK_REQUEST_LOG~".~"RETURN_VALUE~"  
    FROM ~"IQ_INTERLOCK_REQUEST_LOG~"  
   WHERE ( ~"IQ_INTERLOCK_REQUEST_LOG~".~"SERIAL_NO~" like :ARG_SERIAL_NO ) AND  
         ( ~"IQ_INTERLOCK_REQUEST_LOG~".~"LINE_CODE~" like :ARG_LINE_CODE )    AND
(   ~"IQ_INTERLOCK_REQUEST_LOG~".~"REQUEST_DATE~" >= :ARG_DATESET) AND
(   ~"IQ_INTERLOCK_REQUEST_LOG~".~"REQUEST_DATE~" <   :ARG_DATEEND+  (1/24) ) AND
(   ~"IQ_INTERLOCK_REQUEST_LOG~".~"ORGANIZATION_ID~" = 1 )
ORDER BY  ~"IQ_INTERLOCK_REQUEST_LOG~".~"REQUEST_DATE~" ,  ~"IQ_INTERLOCK_REQUEST_LOG~".~"LINE_CODE~" 
" arguments=(("ARG_SERIAL_NO", string),("ARG_LINE_CODE", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime)) )
