 retrieve="  SELECT IM_ITEM_RECEIPT_SLIP_EXCEL.TXN_DATE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ITEM,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ITEM_TYPE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.SUBINVENTORY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.LOCATOR,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_QTY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.DERIVED_ONHAND_QTY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ARRIVAL_DEPARTMENT,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSFER_SUBINVENTORY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSFER_LOCATOR,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_TYPE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.REASON_CODE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.REASON,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.SUPPLIER_CODE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.SUPPLIER_NAME,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.WORK_ORDER,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.SALES_ORDER,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ASSEMBLY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.LINE_CODE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSFER_ORG_CODE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ITEM_DESC,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ITEM_SPEC,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.MARKET,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.CURRENCY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.UNIT_PRICE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ARRIVAL_NO,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.MPC,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.SUPPLIER_REF_NO,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ORDER_NO,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.INVOICE_NO,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.EXCHANGE_RATE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.SHIPMENT_NUM,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ITEM_COST,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.CREATION_DATE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.CREATED_BY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ARRIVED_BY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.RECEIVED_BY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ACCOUNT,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.ACCOUNT_DESCRIPTION,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TAKEOVER_USER,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TAKEOVER_DATE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_ID,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.REFERENCE_REASON_DETAIL,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.CONTENT_LPN,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.UIT,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.DELIVERY_TYPE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.WH_KEEPER,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.PACK_QTY,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.BL_NO,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.LOCATION,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_DATE,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.DROPSHIP_OSP,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.NOTA_NO,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.REASON_CODE2,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.REASON_DESC,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.MODEL_SUFFIX,   
         IM_ITEM_RECEIPT_SLIP_EXCEL.SLIP_GROUP_NO,   
         NVL(IM_ITEM_RECEIPT_SLIP_EXCEL.SCAN_YN   , 'N' ) SCAN_YN ,
		IM_ITEM_RECEIPT_SLIP.RECEIPT_DATE 
    FROM IM_ITEM_RECEIPT_SLIP_EXCEL    , IM_ITEM_RECEIPT_SLIP 
WHERE IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_ID = IM_ITEM_RECEIPT_SLIP.RECEIPT_SLIP_NO(+)
     AND IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_DATE >= :ARG_DATESET
     AND IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_DATE <= :ARG_DATEEND
     AND IM_ITEM_RECEIPT_SLIP_EXCEL.ITEM LIKE :ARG_ITEM_CODE
     AND IM_ITEM_RECEIPT_SLIP_EXCEL.TRANSACTION_ID LIKE :ARG_SLIP_NO
     AND IM_ITEM_RECEIPT_SLIP_EXCEL.SLIP_GROUP_NO LIKE :ARG_SLIP_GROUP_NO
     AND IM_ITEM_RECEIPT_SLIP.RECEIPT_STATUS(+) <> 'C' 
" update="IM_ITEM_RECEIPT_SLIP_EXCEL" updatewhere=0 updatekeyinplace=no arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_slip_no", string),("arg_slip_group_no", string))  sort="slip_group_no A txn_date A item A " )
