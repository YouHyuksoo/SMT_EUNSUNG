 column=(type=char(20) updatewhereclause=yes name=line_code dbname="iq_machine_inspect_data_mk.line_code" )
 column=(type=char(30) updatewhereclause=yes name=machine_code dbname="iq_machine_inspect_data_mk.machine_code" )
 column=(type=char(18) updatewhereclause=yes name=row_pos dbname="row_pos" )
 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LOTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"CSTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"SEQ~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"PID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"EQUIPMENTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RESULT_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"ORGANIZATION_ID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RUN_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"MACHINE_CODE~"  ,
         ROWIDTOCHAR(rowid)   row_pos
    FROM ~"IQ_MACHINE_INSPECT_DATA_MK~"  
   WHERE ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RUN_NO~" like :ARG_RUN_NO ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"PID~" like :ARG_SERIAL_NO ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~" >= TO_CHAR(:ARG_DATESET , 'YYYY/MM/DD HH24:MI:SS') ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~" < TO_CHAR(:ARG_DATEEND +1  , 'YYYY/MM/DD HH24:MI:SS') ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" arguments=(("ARG_RUN_NO", string),("ARG_SERIAL_NO", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_ORG", number))  sort="lotid A pid A " )
