 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_sale_inventory~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"im_item_sale_inventory.supplier_code~") COLUMN(NAME=~"im_item_sale_inventory.item_code~") COLUMN(NAME=~"im_item_sale_inventory.organization_id~") COLUMN(NAME=~"im_item_sale_inventory.line_type~") COLUMN(NAME=~"im_item_sale_inventory.inventory_qty~") COLUMN(NAME=~"im_item_sale_inventory.inventory_price~") COLUMN(NAME=~"im_item_sale_inventory.inventory_amt~") COLUMN(NAME=~"im_item_sale_inventory.last_receipt_date~") COLUMN(NAME=~"im_item_sale_inventory.last_issue_date~") COLUMN(NAME=~"im_item_sale_inventory.enter_by~") COLUMN(NAME=~"im_item_sale_inventory.enter_date~") COLUMN(NAME=~"im_item_sale_inventory.last_modify_by~") COLUMN(NAME=~"im_item_sale_inventory.last_modify_date~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"icom_supplier.supplier_name~")    JOIN (LEFT=~"im_item_sale_inventory.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"im_item_sale_inventory.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~" )    JOIN (LEFT=~"im_item_sale_inventory.supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier.supplier_code~" )    JOIN (LEFT=~"im_item_sale_inventory.organization_id~"    OP =~"=~"RIGHT=~"icom_supplier.organization_id~" )WHERE(    EXP1 =~"~~~"IM_ITEM_SALE_INVENTORY~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_SALE_INVENTORY~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_SALE_INVENTORY~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_org_id", number))  sort="organization_id A supplier_code A item_code A " )
