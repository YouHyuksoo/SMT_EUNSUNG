 column=(type=char(30) updatewhereclause=yes key=yes name=pcb_item dbname="ib_product_plandata.pcb_item" dbalias="A.pcb_item" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="ib_product_plandata.item_unit_qty" dbalias="A.item_unit_qty" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="ib_product_plandata.parent_item_code" dbalias="A.parent_item_code" )
 column=(type=datetime updatewhereclause=yes name=last_actual_date dbname="ib_product_plandata.last_actual_date" dbalias="A.last_actual_date" )
