 column=(type=number updatewhereclause=yes name=remain_qty dbname="remain_qty" )
 column=(type=number updatewhereclause=yes name=return_qty dbname="ib_product_plandata.return_qty" dbalias="A.return_qty" )
 column=(type=number updatewhereclause=yes name=feeding_count dbname="ib_product_plandata.feeding_count" dbalias="A.feeding_count" )
 column=(type=number updatewhereclause=yes name=product_acceptable_qty dbname="product_acceptable_qty" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" dbalias="B.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias="B.item_spec" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" dbalias="B.location_address" )
 column=(type=number updatewhereclause=yes name=real_st dbname="ip_product_line.real_st" dbalias="C.real_st" )
 column=(type=char(10) updatewhereclause=yes name=line_status dbname="ip_product_line.line_status" dbalias="C.line_status" )
 column=(type=number updatewhereclause=yes name=remain_time dbname="remain_time" )
 column=(type=number updatewhereclause=yes name=st_value dbname="st_value" )
 column=(type=char(4000) updatewhereclause=yes name=use_status dbname="use_status" )
 column=(type=char(10) updatewhereclause=yes name=nsnp_status dbname="ip_product_line.nsnp_status" dbalias="C.nsnp_status" )
 column=(type=number updatewhereclause=yes name=unfeeding_qty dbname="unfeeding_qty" )
 column=(type=number updatewhereclause=yes name=new_scan_qty dbname="new_scan_qty" )
 column=(type=char(10) updatewhereclause=yes name=feeder_clamp_status dbname="ib_product_plandata.feeder_clamp_status" dbalias="A.feeder_clamp_status" )
 retrieve="  SELECT A.PLAN_DATE,   
         A.MODEL_NAME,   
         A.MODEL_SUFFIX AS MODEL_SUFFIX,   
         A.ITEM_CODE,   
         A.LOT_NO,   
         A.CHIPNAME,   
         A.CHECK_YN,   
         A.SELECTED_DATE,   
         A.MACHINE,   
         A.LINE_CODE,   
         A.CHECK_STATUS,   
         A.ORGANIZATION_ID,   
         A.LOCATION_CODE,   
         A.ITEM_BARCODE,   
         A.TABLE_ID,   
         A.FEEDING_DATE,   
         A.RECYCLE_DATE,   
         A.FEEDING_QTY,   
         A.CHANGE_DATE,   
		0 PLAN_QTY ,
         NVL(A.PRODUCT_ACTUAL_QTY,0) PRODUCT_ACTUAL_QTY,   
         A.PCB_ITEM  ,
		A.ITEM_UNIT_QTY  ,
		A.PARENT_ITEM_CODE  AS PARENT_ITEM_CODE,
		A.LAST_ACTUAL_DATE  AS LAST_ACTUAL_DATE,
		( SYSDATE  - A.LAST_ACTUAL_DATE ) * 24 * 60 * 60 AS PASSED_TIME ,
		NVL( A.FEEDING_QTY , 0)  - ( NVL(A.PRODUCT_ACTUAL_QTY,0) )  REMAIN_QTY ,
		RETURN_QTY ,
		FEEDING_COUNT ,
	    0  Product_Acceptable_Qty,
		B.ITEM_NAME ITEM_NAME , 
		B.ITEM_SPEC ITEM_SPEC ,
		B.LOCATION_ADDRESS ,
         C.REAL_ST AS REAL_ST,
		C.LINE_STATUS  LINE_STATUS ,

		DECODE( NVL(A.item_unit_qty * f_get_model_st(  A.MODEL_NAME,    A.LINE_CODE,  A.PCB_ITEM , A.ORGANIZATION_ID ),0) , 0 , 0 ,TRUNC(  (NVL( A.FEEDING_QTY , 0)- NVL(A.PRODUCT_ACTUAL_QTY,0) ) / A.item_unit_qty * f_get_model_st(  A.MODEL_NAME,    A.LINE_CODE,   A.PCB_ITEM , A.ORGANIZATION_ID ) / 60 , 0 ) ) REMAIN_TIME ,

		f_get_model_st(  A.MODEL_NAME,    A.LINE_CODE,  A.PCB_ITEM  , A.ORGANIZATION_ID ) ST_VALUE  ,

		f_get_nsnp_use_status( A.LINE_CODE , A.ORGANIZATION_ID ) USE_STATUS ,
		C.NSNP_STATUS NSNP_STATUS ,

		F_GET_UNFEEDING_QTY(  A.LINE_CODE , A.MODEL_NAME , A.ITEM_CODE , A.LOCATION_CODE  ,A.FEEDER_SHAFT ) UNFEEDING_QTY ,

		(SELECT E.NEW_SCAN_QTY FROM IM_ITEM_RECEIPT_BARCODE E WHERE E.ITEM_CODE = A.ITEM_CODE AND E.LOT_NO = A.LOT_NO ) NEW_SCAN_QTY ,

		FEEDER_CLAMP_STATUS

    FROM IB_PRODUCT_PLANDATA  A , ID_ITEM B , IP_PRODUCT_LINE  C
   WHERE  A.ITEM_CODE = B.ITEM_CODE(+) 
	    AND A.ORGANIZATION_ID = B.ORGANIZATION_ID(+) 
        AND A.LINE_CODE = C.LINE_CODE(+)
 		 AND A.ORGANIZATION_ID = C.ORGANIZATION_ID(+) 
		AND A.LINE_CODE  IN (:arg_line_code )
		AND A.MODEL_NAME  LIKE :arg_model_name
         AND A.ITEM_CODE LIKE :ARG_ITEM_CODE
         AND  A.ACTIVE_YN ='Y' 
         AND A.ORGANIZATION_ID = :arg_org
" update="IB_PRODUCT_PLANDATA" updatewhere=0 updatekeyinplace=yes arguments=(("arg_line_code", stringlist),("arg_model_name", string),("ARG_ITEM_CODE", string),("arg_limit_time", number),("arg_active", string),("arg_item_unit_qty", number),("arg_limit_qty", number),("arg_org", number))  sort="line_code A model_name A remain_time A location_code A " )
