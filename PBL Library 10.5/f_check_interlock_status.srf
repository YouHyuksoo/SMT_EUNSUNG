ELSEIF  arg_check_type = 'WAVESOLDER' THEN 		
	
		 SELECT COUNT(*) INTO :LVI_COUNT 
	   FROM IQ_INTERLOCK_CHECK_RESULT 
      WHERE SERIAL_NO = :ARG_SERIAL_NO 
		  AND WORKSTAGE_CODE = 'W160' 
		  AND IS_LAST_YN = 'Y'
		  AND CHECK_RESULT NOT IN ( 'OK' , 'PASS')  ;
		  
		IF F_SQL_CHECK() < 0 THEN 
			RETURN 'ERROR' 
		END IF 
	
		if LVI_COUNT > 0 then 
			return 'NG'
		ELSE
			return 'OK'
		end if 					
		
ELSEIF  arg_check_type = 'REPAIR' THEN 	
	
	 //===================================
	// $$HEX15$$18c2acb9e4c2200085c7e0ac2000c1c0dcd05cb8200088c794b283ac2000$$ENDHEX$$
	//===================================
	 SELECT COUNT(*) INTO :LVI_COUNT 
	   FROM IP_PRODUCT_WORK_QC 
      WHERE SERIAL_NO = :ARG_SERIAL_NO 
	      AND RECEIPT_DEFICIT = '1'  ;
		  
		IF F_SQL_CHECK() < 0 THEN 
			RETURN 'ERROR' 
		END IF 
	
		if LVI_COUNT > 0 then 
			return 'NG'
		ELSE
			return 'OK'
		end if 		
	
END IF 

end function

