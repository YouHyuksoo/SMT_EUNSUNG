		IF F_SQL_CHECK() < 0 THEN 
			RETURN 'ERROR' 
		END IF 
	
		if LVI_COUNT > 0 then 
			return 'NG'
		ELSE
			return 'OK'
		end if 		
		
ELSEIF  arg_check_type = 'ICT' THEN 
	
	 SELECT COUNT(*) INTO :LVI_COUNT 
	   FROM IQ_INTERLOCK_CHECK_RESULT 
      WHERE SERIAL_NO = :ARG_SERIAL_NO 
		  AND WORKSTAGE_CODE = 'W070' 
		  AND IS_LAST_YN = 'Y'
		  AND CHECK_RESULT NOT IN ( 'OK' , 'PASS')  ;
		  
		IF F_SQL_CHECK() < 0 THEN 
			RETURN 'ERROR' 
		END IF 
	
		if LVI_COUNT > 0 then 
			return 'NG'
		ELSE
			return 'OK'
		end if 		
ELSEIF  arg_check_type = 'FUNCTION' THEN 
	
ELSEIF  arg_check_type = 'PRESSFIT' THEN 	
	
ELSEIF  arg_check_type = 'COATING' THEN 		
	
		 SELECT COUNT(*) INTO :LVI_COUNT 
	   FROM IQ_INTERLOCK_CHECK_RESULT 
      WHERE SERIAL_NO = :ARG_SERIAL_NO 
		  AND WORKSTAGE_CODE = 'W090' 
		  AND IS_LAST_YN = 'Y'
		  AND CHECK_RESULT NOT IN ( 'OK' , 'PASS')  ;
		  
		IF F_SQL_CHECK() < 0 THEN 
			RETURN 'ERROR' 
		END IF 
	
		if LVI_COUNT > 0 then 
			return 'NG'
		ELSE
			return 'OK'
		end if 		
ELSEIF  arg_check_type = 'SELECTIVE' THEN 		
	
		 SELECT COUNT(*) INTO :LVI_COUNT 
	   FROM IQ_INTERLOCK_CHECK_RESULT 
      WHERE SERIAL_NO = :ARG_SERIAL_NO 
		  AND WORKSTAGE_CODE = 'W150' 
		  AND IS_LAST_YN = 'Y'
		  AND CHECK_RESULT NOT IN ( 'OK' , 'PASS')  ;
		  
		IF F_SQL_CHECK() < 0 THEN 
			RETURN 'ERROR' 
		END IF 
	
		if LVI_COUNT > 0 then 
			return 'NG'
