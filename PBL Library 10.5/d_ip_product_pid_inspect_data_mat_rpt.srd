table(column=(type=char(4000) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="ib_smt_checkhist.location_code" dbalias="c.location_code" )
 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="ib_smt_checkhist.pcb_item" dbalias="c.pcb_item" )
 column=(type=char(10) updatewhereclause=yes name=check_type dbname="check_type" )
 column=(type=char(500) updatewhereclause=yes name=scan_partname dbname="ib_smt_checkhist.scan_partname" dbalias="c.scan_partname" )
 column=(type=char(500) updatewhereclause=yes name=scan_supplier_partname dbname="ib_smt_checkhist.scan_supplier_partname" dbalias="c.scan_supplier_partname" )
 column=(type=decimal(0) updatewhereclause=yes name=scan_qty dbname="ib_smt_checkhist.scan_qty" dbalias="c.scan_qty" )
 column=(type=datetime updatewhereclause=yes name=ib_smt_checkhist_feeding_date dbname="ib_smt_checkhist.feeding_date" dbalias="c.feeding_date" )
 column=(type=datetime updatewhereclause=yes name=reel_destroy_date dbname="im_item_receipt_barcode.reel_destroy_date" dbalias="b.reel_destroy_date" )
 column=(type=char(10) updatewhereclause=yes name=msl_level dbname="id_item.msl_level" dbalias="i.msl_level" )
 column=(type=number updatewhereclause=yes name=msl_max_time dbname="id_item.msl_max_time" dbalias="i.msl_max_time" )
 column=(type=number updatewhereclause=yes name=msl_passed_time dbname="im_item_receipt_barcode.msl_passed_time" dbalias="b.msl_passed_time" )
 retrieve="select  f_get_line_name( c.line_code, 1)  line_code, 
         c.location_code,
         c.pcb_item, 
         decode(c.check_type,'1','CCS','2','REEL',c.check_type) check_type,
         c.scan_partname,
         c.scan_supplier_partname, 
         c.scan_qty, 
         c.check_date         feeding_date,
         b.reel_destroy_date,
         i.msl_level,
         i.msl_max_time,
        F_GET_MSL_PASSED_TIME(b.item_barcode)  msl_passed_time
  from ib_smt_checkhist c,
          im_item_receipt_barcode b,
          id_item i 
 where c.scan_partname = b.item_barcode
   and c.item_code     = i.item_code
   and c.run_no = (
                            select run_no   
                             from ip_product_2d_barcode  
                           where SERIAL_NO like :ARG_SERIAL_NO 
                              AND ORGANIZATION_ID = :ARG_ORG 
                              AND ROWNUM = 1
                         )

" arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="ib_smt_checkhist_feeding_date A location_code A " )
