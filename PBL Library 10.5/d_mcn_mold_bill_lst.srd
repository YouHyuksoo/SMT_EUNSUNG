 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_mold_bill~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"imcn_mold~" ) COLUMN(NAME=~"imcn_mold_bill.item_code~") COLUMN(NAME=~"imcn_mold_bill.mold_code~") COLUMN(NAME=~"imcn_mold_bill.sequence~") COLUMN(NAME=~"imcn_mold_bill.organization_id~") COLUMN(NAME=~"imcn_mold_bill.break_value~") COLUMN(NAME=~"imcn_mold_bill.unit_qty~") COLUMN(NAME=~"imcn_mold_bill.enter_by~") COLUMN(NAME=~"imcn_mold_bill.enter_date~") COLUMN(NAME=~"imcn_mold_bill.last_modify_by~") COLUMN(NAME=~"imcn_mold_bill.last_modify_date~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"imcn_mold.mold_name~") COLUMN(NAME=~"imcn_mold.mold_spec~") COMPUTE(NAME=~"F_CHECK_BOM_EXISTS( IMCN_MOLD_BILL.ITEM_CODE , IMCN_MOLD_BILL.ORGANIZATION_ID ) BOM_CHECK~")    JOIN (LEFT=~"imcn_mold_bill.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~"    OUTER1 =~"imcn_mold_bill.item_code~" )    JOIN (LEFT=~"imcn_mold_bill.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~"    OUTER1 =~"imcn_mold_bill.organization_id~" )    JOIN (LEFT=~"imcn_mold_bill.mold_code~"    OP =~"=~"RIGHT=~"imcn_mold.mold_code~" )    JOIN (LEFT=~"imcn_mold_bill.organization_id~"    OP =~"=~"RIGHT=~"imcn_mold.organization_id~" )WHERE(    EXP1 =~"~~~"IMCN_MOLD_BILL~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_BILL~~~".~~~"MOLD_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_mold_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"ID_ITEM~~~".~~~"DATESET~~~"(+)~"   OP =~"<=~"    EXP2 =~"trunc(sysdate)~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"ID_ITEM~~~".~~~"DATEEND~~~"(+)~"   OP =~">=~"    EXP2 =~"trunc(sysdate)~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_BILL~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_mold_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_item_code", string),("arg_mold_code", string),("arg_org", number))  sort="organization_id A item_code A sequence A " )
