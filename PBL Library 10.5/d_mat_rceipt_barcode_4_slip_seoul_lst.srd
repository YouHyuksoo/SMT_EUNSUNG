 retrieve="  SELECT ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_BARCODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_NO~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_QTY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_BARCODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_ITEM_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_SLIP_NO~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ENTER_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ENTER_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"BARCODE_STATUS~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_TYPE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"FROM_SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_DIVIDE_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ORIGIN_ITEM_BARCODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LABEL_TYPE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"HOLDING_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ISSUE_RETURN_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ISSUE_COMPARE_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_DIVIDE_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ORIGIN_LOT_NO~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_DIVIDE_SEQUENCE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LINE_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"WORKSTAGE_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LAST_ISSUE_COMPARE_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"FEEDING_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"FEEDING_MODEL~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"MSL_REMAIN_TIME~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"MSL_PASSED_TIME~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"REAL_DIVIDE_REASON~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"VENDOR_LOTNO~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"VENDOR_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LOCATION_CODE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"FEEDER_SHAFT~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ISSUE_DIVISION~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"MANUFACTURE_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ISSUE_COMPARE_DATE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ISSUE_COMPARE_BY~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"NEW_SCAN_QTY~", 
         ~"IM_ITEM_RECEIPT_BARCODE~".~"MANUFACTURE_WEEK~" ,
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LED_RANK_INFO~" 
    FROM ~"IM_ITEM_RECEIPT_BARCODE~"  
   WHERE ( ~"IM_ITEM_RECEIPT_BARCODE~".~"ITEM_CODE~" = :arg_item_code ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_SLIP_NO~" = :arg_slip_no ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"BARCODE_STATUS~" <> 'C' ) AND  
         ( ~"IM_ITEM_RECEIPT_BARCODE~".~"ORGANIZATION_ID~" = :arg_org )    
" update="IM_ITEM_RECEIPT_BARCODE" updatewhere=0 updatekeyinplace=yes arguments=(("arg_item_code", string),("arg_slip_no", string),("arg_org", number)) )
