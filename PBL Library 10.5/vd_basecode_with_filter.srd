table(column=(type=char(30) updatewhereclause=yes name=code_type dbname="isys_basecode.code_type" dbalias=".code_type" )
 column=(type=char(100) updatewhereclause=yes name=code_name dbname="isys_basecode.code_name" dbalias=".code_name" )
 column=(type=char(100) updatewhereclause=yes name=code_mean dbname="code_mean" )
 retrieve="SELECT CODE_TYPE , CODE_NAME ,
		 DECODE(:ARG_LANG, 'K', CODE_MEAN_KOR, 'E', CODE_MEAN_ENG ,CODE_MEAN_LOCAL ) AS CODE_MEAN     
FROM  ISYS_BASECODE      
WHERE  CODE_TYPE       LIKE :ARG_CODE_TYPE
AND    ORGANIZATION_ID = TO_NUMBER(:ARG_ORG)" arguments=(("ARG_LANG", string),("ARG_ORG", string),("ARG_CODE_TYPE", string))  sort="code_name A " )
