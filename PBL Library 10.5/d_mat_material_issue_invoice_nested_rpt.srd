 column=(type=char(20) updatewhereclause=yes name=ip_product_master_plan_item_code dbname="im_item_issue.item_code" dbalias=".item_code" )
 column=(type=char(100) updatewhereclause=yes name=item_name_1 dbname="id_item.item_name" dbalias="ID_ITEM_B.item_name" )
 column=(type=char(100) updatewhereclause=yes name=item_spec_1 dbname="id_item.item_spec" dbalias="ID_ITEM_B.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=id_item_item_uom dbname="id_item.item_uom" dbalias="ID_ITEM_B.item_uom" )
 retrieve="  SELECT ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_SEQUENCE~",   
         ~"IM_ITEM_ISSUE~".~"INVOICE_NO~",   
         ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_ISSUE~".~"MFS~",   
         ~"IM_ITEM_ISSUE~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_ISSUE~".~"WORK_ORDER_NO~",   
         ~"IM_ITEM_ISSUE~".~"ITEM_CODE~",   
         ~"IM_ITEM_ISSUE~".~"ITEM_TYPE~",   
         ~"IM_ITEM_ISSUE~".~"LINE_TYPE~",   
         ~"IM_ITEM_ISSUE~".~"LINE_CODE~",   
         'WH'  WORKSTAGE_CODE,   
         DECODE( :ARG_NORMAL_SCRAP , 'N' , ~"IM_ITEM_ISSUE~".~"WORKSTAGE_CODE~", 'WH' ) DEST_WORKSTAGE_CODE,   
         ~"IM_ITEM_ISSUE~".~"MACHINE_CODE~",   
         DECODE( :ARG_NORMAL_SCRAP , 'N' , ~"IM_ITEM_ISSUE~".~"ISSUE_QTY~", 0 ) ISSUE_QTY,   
         ~"IM_ITEM_ISSUE~".~"MADE_BY~",   
         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   
         ~"ID_ITEM_A~".~"ITEM_UOM~",   
         ~"ID_ITEM_A~".~"DRAWING_NO~",   
         DECODE( :ARG_NORMAL_SCRAP , 'N' ,~"IM_ITEM_ISSUE~".~"MADE_BY~", '' ) TAKEOVER_BY,   
         ~"IM_ITEM_ISSUE~".~"COMMENTS~",   
         ~"IP_PRODUCT_MASTER_PLAN~".~"ORIGIN_MFS~",   
         ~"IP_PRODUCT_MASTER_PLAN~".~"CUSTOMER_ORDER_NO~",   
         ~"IP_PRODUCT_MASTER_PLAN~".~"CUSTOMER_CODE~",   
         ~"IP_PRODUCT_MASTER_PLAN~".~"ITEM_CODE~",   
         ~"ID_ITEM_B~".~"ITEM_NAME~",   
         ~"ID_ITEM_B~".~"ITEM_SPEC~",   
         ~"ID_ITEM_B~".~"ITEM_UOM~"  
    FROM ~"IM_ITEM_ISSUE~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~",   
         ( SELECT MFS , ORIGIN_MFS ,CUSTOMER_ORDER_NO , CUSTOMER_CODE ,  ITEM_CODE  ,ORGANIZATION_ID
              FROM IP_PRODUCT_MASTER_PLAN
            WHERE MFS=  :arg_mfs 
                 AND ORGANIZATION_ID = :ARG_ORG 
           UNION ALL 
		SELECT MFS , ORIGIN_MFS ,CUSTOMER_ORDER_NO , CUSTOMER_CODE ,  ITEM_CODE ,ORGANIZATION_ID
              FROM IP_ASSEMBLY_MASTER_PLAN
            WHERE MFS=  :arg_mfs 
                 AND ORGANIZATION_ID = :ARG_ORG 
        ) IP_PRODUCT_MASTER_PLAN ,
         ~"ID_ITEM~" ~"ID_ITEM_B~"  
   WHERE ( ~"IM_ITEM_ISSUE~".~"ITEM_CODE~" = ~"ID_ITEM_A~".~"ITEM_CODE~"(+) ) and  
         ( ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" = ~"ID_ITEM_A~".~"ORGANIZATION_ID~"(+) ) and  
         ( ~"IM_ITEM_ISSUE~".~"MFS~" = ~"IP_PRODUCT_MASTER_PLAN~".~"MFS~"(+) ) and  
         ( ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" = ~"IP_PRODUCT_MASTER_PLAN~".~"ORGANIZATION_ID~"(+) ) and  
         ( ~"IP_PRODUCT_MASTER_PLAN~".~"ITEM_CODE~" = ~"ID_ITEM_B~".~"ITEM_CODE~"(+) ) and  
         ( ~"IP_PRODUCT_MASTER_PLAN~".~"ORGANIZATION_ID~" = ~"ID_ITEM_B~".~"ORGANIZATION_ID~"(+) ) and  
         ( ( ~"IM_ITEM_ISSUE~".~"MFS~" = :arg_mfs ) AND  
         ( NVL(~"IM_ITEM_ISSUE~".~"INVOICE_NO~",'*')  like :arg_invoice_no ) AND  
         ( ~"IM_ITEM_ISSUE~".~"ISSUE_STATUS~" = 'N' ) AND  
         ( ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" = :arg_org ) )    
" arguments=(("arg_mfs", string),("arg_invoice_no", string),("arg_normal_scrap", string),("arg_org", number)) )
