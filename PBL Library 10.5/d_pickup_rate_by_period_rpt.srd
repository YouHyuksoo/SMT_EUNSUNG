HA$PBExportHeader$d_pickup_rate_by_period_rpt.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes row.resize=1 grid.lines=0 )
header[1](height=0 color="536870912" )
header[2](height=60 color="536870912" )
header[3](height=108 color="536870912" )
summary(height=92 color="65535" )
footer(height=0 color="536870912" )
detail(height=96 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(20) updatewhereclause=yes name=machine_code dbname="machine_code" )
 column=(type=char(20) updatewhereclause=yes name=program_name dbname="program_name" )
 column=(type=char(20) updatewhereclause=yes name=table_no dbname="table_no" )
 column=(type=char(20) updatewhereclause=yes name=feeder_zaxis dbname="feeder_zaxis" )
 column=(type=char(20) updatewhereclause=yes name=feeder_lraxis dbname="feeder_lraxis" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=abc_grade dbname="abc_grade" )
 column=(type=number updatewhereclause=yes name=pur_unit_price dbname="pur_unit_price" )
 column=(type=number updatewhereclause=yes name=takeup_qty dbname="takeup_qty" )
 column=(type=number updatewhereclause=yes name=miss_qty dbname="miss_qty" )
 column=(type=number updatewhereclause=yes name=recog_qty dbname="recog_qty" )
 column=(type=number updatewhereclause=yes name=miss_amount dbname="miss_amount" )
 retrieve="select line_code, 
      machine_code, 
      program_name, 
      address, 
      sub_address, 
      item_code, 
      abc_grade, 
      item_name, 
      pur_unit_price, 
      to_char(actual_date,'yy/mm/dd') as actual_date, 
      table_no, 
      feeder_zaxis, 
      feeder_lraxis, 
      takeup_qty, 
      miss_qty, 
      ( nvl(miss_qty,0) + nvl(recog_qty,0)) * pur_unit_price as miss_amount, 
      recog_qty, 
      created_date, 
      create_by
  from IQ_MACHINE_INSPECT_PICKUP_QRY t
 WHERE line_code       like :arg_line
   AND ITEM_CODE LIKE :arg_item_code
   AND ACTUAL_DATE >= TRUNC(:arg_sdate)
   AND ACTUAL_DATE <   TRUNC(:arg_edate)  + 1 
   AND nvl(pur_unit_price,0)  >=  to_number(:arg_price)" arguments=(("arg_line", string),("arg_sdate", datetime),("arg_edate", datetime),("arg_price", string),("arg_item_code", string))  sort="line_code A machine_code A program_name A table_no A feeder_zaxis A feeder_lraxis A item_code A item_name A abc_grade A pur_unit_price A " )
