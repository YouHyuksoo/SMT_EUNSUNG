HA$PBExportHeader$vd_window_name.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=12632256 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=132 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=64 color="536870912" )
table(column=(type=char(100) updatewhereclause=yes name=window_name dbname="isys_window.window_name" )
 column=(type=char(100) updatewhereclause=yes name=window_group dbname="window_group" )
 column=(type=char(100) updatewhereclause=yes name=window_description dbname="window_description" )
 retrieve="  SELECT ~"ISYS_WINDOW~".~"WINDOW_NAME~",   
         DECODE( :ARG_LANGUAGE , 'K' ,~"ISYS_WINDOW~".~"WINDOW_GROUP_KOR~",   'E' , ~"ISYS_WINDOW~".~"WINDOW_GROUP_ENG~" , 'C' , ~"ISYS_WINDOW~".~"WINDOW_GROUP_LOCAL~" ) WINDOW_GROUP ,
         DECODE( :ARG_LANGUAGE , 'K' , ~"ISYS_WINDOW~".~"WINDOW_DESCRIPTION_KOR~", 'E' , ~"ISYS_WINDOW~".~"WINDOW_DESCRIPTION_ENG~", ~"ISYS_WINDOW~".~"WINDOW_DESCRIPTION_LOCAL~" ) WINDOW_DESCRIPTION
    FROM ~"ISYS_WINDOW~"  
   WHERE ORGANIZATION_ID = TO_NUMBER(:ARG_ORGANIZATION_ID)    
" arguments=(("ARG_LANGUAGE", string),("ARG_ORGANIZATION_ID", string))  sort="window_group A window_description A " )
group(level=1 header.height=0 trailer.height=48 by=("window_group" ) header.color="536870912" trailer.color="65535" )
