 column=(type=char(4000) updatewhereclause=yes name=array_type dbname="array_type" )
 column=(type=char(1) updatewhereclause=yes name=pcb_item dbname="ip_product_smd_plan.pcb_item" )
 column=(type=char(20) updatewhereclause=yes name=mfs_group_no dbname="ip_product_smd_plan.mfs_group_no" )
 column=(type=char(20) updatewhereclause=yes name=shift_code dbname="ip_product_smd_plan.shift_code" )
 column=(type=char(1) updatewhereclause=yes name=production_type dbname="ip_product_smd_plan.production_type" )
 retrieve="  SELECT IP_PRODUCT_SMD_PLAN.MFS,   
			IP_PRODUCT_SMD_PLAN.PLAN_DATE,   
			IP_PRODUCT_SMD_PLAN.ORGANIZATION_ID,   
			IP_PRODUCT_SMD_PLAN.LINE_CODE,   
			IP_PRODUCT_SMD_PLAN.PLAN_PRIORITY,   
			IP_PRODUCT_SMD_PLAN.PLAN_QTY,   
			IP_PRODUCT_SMD_PLAN.CUSTOMER_CODE,   
			IP_PRODUCT_SMD_PLAN.WORK_ORDER_NO,   
			IP_PRODUCT_SMD_PLAN.ITEM_CODE,   
			IP_PRODUCT_SMD_PLAN.PLAN_TRANSFER_YN,   
			'N' CHECK_YN,   
			IP_PRODUCT_SMD_PLAN.ACTUAL_QTY,   
			NVL( IP_PRODUCT_SMD_PLAN.PLAN_STATUS,   'W') PLAN_STATUS ,
			ID_ITEM.ITEM_NAME,   
			ID_ITEM.ITEM_SPEC,   
			ID_ITEM.ITEM_UOM,   
			IP_PRODUCT_SMD_PLAN.PLAN_SEQUENCE,   
			IP_PRODUCT_SMD_PLAN.MASTER_MODEL_NAME AS MASTER_MODEL_NAME ,   
			IP_PRODUCT_SMD_PLAN.MODEL_NAME AS MODEL_NAME ,   
			IP_PRODUCT_SMD_PLAN.PARENT_ITEM_CODE ,
			(SELECT SUM(LOT_SIZE) FROM IP_PRODUCT_RUN_CARD WHERE LOT_NO = IP_PRODUCT_SMD_PLAN.MFS )  LOT_QTY ,
            
			IP_PRODUCT_SMD_PLAN.PLAN_QTY - NVL((SELECT SUM(LOT_SIZE) FROM IP_PRODUCT_RUN_CARD WHERE LOT_NO = IP_PRODUCT_SMD_PLAN.MFS ),0)  REMAIN_QTY ,
						F_GET_PCB_ARRAY_TYPE( IP_PRODUCT_SMD_PLAN.MODEL_NAME , IP_PRODUCT_SMD_PLAN.ORGANIZATION_ID ) ARRAY_TYPE  ,
			IP_PRODUCT_SMD_PLAN.PCB_ITEM AS PCB_ITEM ,
	     	IP_PRODUCT_SMD_PLAN.MFS_GROUP_NO	,
		    IP_PRODUCT_SMD_PLAN.SHIFT_CODE AS SHIFT_CODE ,
		    IP_PRODUCT_SMD_PLAN.PRODUCTION_TYPE AS PRODUCTION_TYPE 
    FROM IP_PRODUCT_SMD_PLAN,   
             ID_ITEM  
   WHERE  IP_PRODUCT_SMD_PLAN.ITEM_CODE = ID_ITEM.ITEM_CODE(+)  and  
				IP_PRODUCT_SMD_PLAN.ORGANIZATION_ID = ID_ITEM.ORGANIZATION_ID(+)  and  
				IP_PRODUCT_SMD_PLAN.PLAN_DATE >= :ARG_DATESET  AND  
				IP_PRODUCT_SMD_PLAN.PLAN_DATE <= :ARG_DATEEND  AND  
				IP_PRODUCT_SMD_PLAN.LINE_CODE like :ARG_LINE_CODE AND  
				IP_PRODUCT_SMD_PLAN.ORGANIZATION_ID = :ARG_ORG AND
				IP_PRODUCT_SMD_PLAN.MODEL_NAME LIKE :ARG_MODEL_NAME AND 
                  IP_PRODUCT_SMD_PLAN.PLAN_QTY > 0 AND
                  NVL(IP_PRODUCT_SMD_PLAN.PLAN_STATUS  , 'W' ) <> 'X' AND 
				IP_PRODUCT_SMD_PLAN.PLAN_QTY - NVL((SELECT SUM(LOT_SIZE) FROM IP_PRODUCT_RUN_CARD WHERE LOT_NO = IP_PRODUCT_SMD_PLAN.MFS ),0)  > 0 


			
" arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_ORG", number))  sort="line_code A plan_date D plan_priority A master_model_name A mfs_group_no A model_name A mfs A " )
