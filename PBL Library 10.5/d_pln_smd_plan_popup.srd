 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=number updatewhereclause=yes name=actual_qty dbname="ip_product_smd_plan.actual_qty" )
 column=(type=char(1) updatewhereclause=yes name=plan_status dbname="plan_status" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 column=(type=number updatewhereclause=yes name=plan_sequence dbname="ip_product_smd_plan.plan_sequence" )
 column=(type=char(50) updatewhereclause=yes name=master_model_name dbname="ip_product_smd_plan.master_model_name" )
 column=(type=char(50) updatewhereclause=yes name=model_name dbname="ip_product_smd_plan.model_name" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="ip_product_smd_plan.parent_item_code" )
 column=(type=number updatewhereclause=yes name=lot_qty dbname="lot_qty" )
