HA$PBExportHeader$f_append.srf
$PBExportComments$Re Retrieve
global type f_append from function_object
end type

forward prototypes
global function integer f_append ()
end prototypes

global function integer f_append ();window activesheet
string mtext
activesheet = w_main_frame.GetActiveSheet( )
IF IsValid(activesheet) THEN
	Gvs_ue_data_control = 'APPEND'
	activesheet.TRIGGEREVENT('UE_DATA_CONTROL')
ELSE 
   RETURN -1
   
END IF

RETURN 0 
end function

