compute(band=summary alignment="1" expression="sum(inventory_qty for all )"border="0" color="65280" x="1504" y="4" height="72" width="229" format="###,##0" html.valueishtml="0"  name=compute_6 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="553648127" )
compute(band=summary alignment="1" expression="sum(sum_inventory_qty for all )"border="0" color="65280" x="1742" y="4" height="72" width="261" format="###,##0" html.valueishtml="0"  name=compute_7 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="553648127" )
compute(band=summary alignment="1" expression="sum(grand_sum_inventory_qty for all )"border="0" color="65280" x="2011" y="4" height="72" width="274" format="###,##0" html.valueishtml="0"  name=compute_8 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="0" )
 crosstab(band = foreground  crosstabonly = yes 
 columns = "div, location_code" rows = "item_code, item_name" values = "sum(inventory_qty for crosstab)" sourcenames = "div, location_code, item_code, item_name, inventory_qty")
