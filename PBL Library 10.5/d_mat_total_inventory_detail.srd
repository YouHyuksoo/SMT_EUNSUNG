HA$PBExportHeader$d_mat_total_inventory_detail.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=68 color="536870912" )
header[3](height=112 color="536870912" )
summary(height=84 color="0" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 retrieve="SELECT A.DIV , 
			A.LOCATION_CODE,
			A.ITEM_CODE,
			B.ITEM_NAME,
			A.INVENTORY_QTY
  FROM (

			 SELECT  'WAREHOUSE' DIV ,	
						f_get_basecode ('MATERIAL LOCATION CODE',location_code,:ARG_LANG,:ARG_ORG) LOCATION_CODE,
						ITEM_CODE,
						INVENTORY_QTY
				FROM IM_ITEM_INVENTORY
	
		    UNION ALL
	
			SELECT  'WORKSTAGE' DIV ,
						F_GET_LINE_NAME( LINE_CODE , ORGANIZATION_ID )  LOCATION_CODE,
						ITEM_CODE,
						INVENTORY_QTY
			    FROM IM_ITEM_WORKSTAGE_INVENTORY
         ) A,
		
		ID_ITEM B
		WHERE A.ITEM_CODE = B.ITEM_CODE
		AND A.ITEM_CODE LIKE :ARG_ITEM 
		AND A.INVENTORY_QTY <> 0 " arguments=(("arg_item", string),("arg_org", number),("arg_lang", string))  sort="item_code A item_name A " )
text(band=header[2] alignment="2" text="@div" border="0" color="0" x="1504" y="4" height="60" width="229" html.valueishtml="0"  name=t_4 visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65280" )
