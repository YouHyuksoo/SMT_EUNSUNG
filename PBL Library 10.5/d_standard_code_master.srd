 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="isys_code_master.enter_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="isys_code_master.last_modify_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="isys_code_master.last_modify_date" )
 retrieve="  SELECT  ~"ISYS_CODE_MASTER~".~"CODE_TYPE~",   
         ~"ISYS_CODE_MASTER~".~"CODE_NAME~",   
         ~"ISYS_CODE_MASTER~".~"ORGANIZATION_ID~",   
         ~"ISYS_CODE_MASTER~".~"CODE_MEAN_ENG~",   
         ~"ISYS_CODE_MASTER~".~"CODE_MEAN_KOR~",   
         ~"ISYS_CODE_MASTER~".~"CODE_MEAN_LOCAL~",   
         ~"ISYS_CODE_MASTER~".~"CODE_NAME_DESCRIPTION_ENG~",   
         ~"ISYS_CODE_MASTER~".~"CODE_NAME_DESCRIPTION_KOR~",   
         ~"ISYS_CODE_MASTER~".~"CODE_NAME_DESCRIPTION_LOCAL~",   
         ~"ISYS_CODE_MASTER~".~"CODE_GROUP~",   
         ~"ISYS_CODE_MASTER~".~"CODE_GROUP_SECOND~",   
         ~"ISYS_CODE_MASTER~".~"CODE_GROUP_THIRD~",   
         ~"ISYS_CODE_MASTER~".~"ENTER_BY~",   
         ~"ISYS_CODE_MASTER~".~"ENTER_DATE~",   
         ~"ISYS_CODE_MASTER~".~"LAST_MODIFY_BY~",   
         ~"ISYS_CODE_MASTER~".~"LAST_MODIFY_DATE~"  
    FROM ~"ISYS_CODE_MASTER~"   
   WHERE   (NVL( ~"ISYS_CODE_MASTER~".~"CODE_GROUP~",'*')  like :ARG_CODE_GROUP ) AND  
         ( NVL(~"ISYS_CODE_MASTER~".~"CODE_TYPE~" , '*') like :ARG_CODE_TYPE ) AND  
         ( NVL(~"ISYS_CODE_MASTER~".~"CODE_NAME~",'*')  like :ARG_CODE_NAME ) AND  
         ( ~"ISYS_CODE_MASTER~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID )    
" update="ISYS_CODE_MASTER" updatewhere=0 updatekeyinplace=no arguments=(("ARG_CODE_GROUP", string),("ARG_CODE_TYPE", string),("ARG_CODE_NAME", string),("ARG_ORGANIZATION_ID", number))  sort="organization_id A code_type A code_group A code_group_second A code_group_third A code_name A " )
