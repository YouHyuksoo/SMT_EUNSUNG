 retrieve="  SELECT  ~"IB_PRODUCT_PLANDATA~".~"PLAN_DATE~" ,           ~"IB_PRODUCT_PLANDATA~".~"MODEL_NAME~" ,      
     ~"IB_PRODUCT_PLANDATA~".~"ITEM_CODE~" ,           ~"IB_PRODUCT_PLANDATA~".~"CHIPNAME~" ,           ~"IB_PRODUCT_PLANDATA~".~"CHECK_YN~" ,  
        ~"IB_PRODUCT_PLANDATA~".~"SELECTED_DATE~" ,           ~"IB_PRODUCT_PLANDATA~".~"MACHINE~" ,           ~"IB_PRODUCT_PLANDATA~".~"LINE_CODE~" ,    
       ~"IB_PRODUCT_PLANDATA~".~"PLAN_DATE_SEQUENCE~" ,           ~"IB_PRODUCT_PLANDATA~".~"CHECK_STATUS~" ,   
        ~"IB_PRODUCT_PLANDATA~".~"ITEM_BARCODE~" ,           
      ~"IB_PRODUCT_PLANDATA~".~"LOCATION_CODE~"     FROM ~"IB_PRODUCT_PLANDATA~"  
    WHERE
      ( ~"IB_PRODUCT_PLANDATA~".~"MODEL_NAME~" like :arg_item_code ) and       
   ( NVL(~"IB_PRODUCT_PLANDATA~".~"LINE_CODE~" , '*') like :arg_line_code ) and    
      ( NVL(~"IB_PRODUCT_PLANDATA~".~"MACHINE~",'*') like :arg_machine ) and     
     ( nvl(~"IB_PRODUCT_PLANDATA~".~"CHECK_STATUS~" , '*') like :arg_check_status )   " arguments=(("arg_line_code", string),("arg_machine", string),("arg_item_code", string),("arg_check_status", string))  sort="selected_date A line_code A machine A plan_date A plan_date_sequence A model_name A " )
