arcode.lot_divide_date~") COLUMN(NAME=~"id_item.location_address~") COLUMN(NAME=~"im_item_receipt_barcode.return_yn~") COLUMN(NAME=~"im_item_receipt_barcode.return_date~") COLUMN(NAME=~"im_item_receipt_barcode.feeder_shaft~") COLUMN(NAME=~"im_item_receipt_barcode.location_code~") COLUMN(NAME=~"im_item_receipt_barcode.feeding_group_no~") COLUMN(NAME=~"im_item_receipt_barcode.line_code~")    JOIN (LEFT=~"im_item_receipt_barcode.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~"    OUTER1 =~"im_item_receipt_barcode.item_code~" )WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"ITEM_CODE~~~"~"   OP =~"=~"    EXP2 =~":arg_item_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"LINE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_line_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"FEEDER_SHAFT~~~"~"   OP =~"like~"    EXP2 =~":arg_feeder_shaft~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"LOCATION_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_location_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"NVL(~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"ISSUE_COMPARE_YN~~~" , 'N')~"   OP =~"like~"    EXP2 =~"'Y'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"BARCODE_STATUS~~~"~"   OP =~"<>~"    EXP2 =~"'C'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"RETURN_YN~~~"~"   OP =~"<>~"    EXP2 =~"'Y'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_BARCODE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_line_code~" TYPE = string)  ARG(NAME = ~"arg_feeder_shaft~" TYPE = string)  ARG(NAME = ~"arg_location_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_item_code", string),("arg_line_code", string),("arg_feeder_shaft", string),("arg_location_code", string),("arg_org", number))  sort="issue_compare_date D receipt_compare_date D " )
