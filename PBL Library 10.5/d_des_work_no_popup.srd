detail(height=80 color="536870912" )
table(column=(type=number updatewhereclause=yes name=bom_work_no dbname="bom_work_no" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="enter_by" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="enter_date" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="last_modify_date" )
 retrieve="  SELECT MAX(~"ID_ENG_BOM_WORKSPACE~".~"BOM_WORK_NO~")BOM_WORK_NO,   
         MIN(~"ID_ENG_BOM_WORKSPACE~".~"ITEM_CODE~") ITEM_CODE,   
         MAX(~"ID_ENG_BOM_WORKSPACE~".~"ENTER_BY~") ENTER_BY,   
         MAX(~"ID_ENG_BOM_WORKSPACE~".~"LAST_MODIFY_BY~")LAST_MODIFY_BY ,   
         MAX(~"ID_ENG_BOM_WORKSPACE~".~"ENTER_DATE~") ENTER_DATE,   
         MAX(~"ID_ENG_BOM_WORKSPACE~".~"LAST_MODIFY_DATE~") LAST_MODIFY_DATE  
    FROM ~"ID_ENG_BOM_WORKSPACE~"  
   WHERE ( LAST_MODIFY_BY LIKE :ARG_USER_ID ) AND  
         ( ORGANIZATION_ID = :ARG_ORG ) AND  
         ( ~"ID_ENG_BOM_WORKSPACE~".~"PARENT_ITEM_CODE~" <> '*' )   
GROUP BY ~"ID_ENG_BOM_WORKSPACE~".~"BOM_WORK_NO~"   
" arguments=(("ARG_USER_ID", string),("ARG_ORG", number)) )
