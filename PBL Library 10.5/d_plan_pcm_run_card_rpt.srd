 column=(type=char(2000) updatewhereclause=yes name=comments dbname="ip_product_run_card.comments" dbalias=".comments" )
 column=(type=char(4000) updatewhereclause=yes name=metalmask_code dbname="metalmask_code" )
 column=(type=char(4000) updatewhereclause=yes name=metalmask_code_label dbname="metalmask_code_label" )
 column=(type=char(4000) updatewhereclause=yes name=sample_code dbname="sample_code" )
 column=(type=char(4000) updatewhereclause=yes name=sample_code_label dbname="sample_code_label" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_run_card.item_code" dbalias=".item_code" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="ip_product_run_card.parent_item_code" dbalias=".parent_item_code" )
 column=(type=char(104) updatewhereclause=yes name=model_part_image dbname="model_part_image" )
 column=(type=char(30) updatewhereclause=yes name=lot_no dbname="ip_product_run_card.lot_no" dbalias=".lot_no" )
 column=(type=char(30) updatewhereclause=yes name=marking_no dbname="ip_product_run_card.marking_no" dbalias=".marking_no" )
 column=(type=char(50) updatewhereclause=yes name=master_model_name dbname="ip_product_run_card.master_model_name" dbalias=".master_model_name" )
 column=(type=char(20) updatewhereclause=yes name=mfs_group_no dbname="ip_product_run_card.mfs_group_no" dbalias=".mfs_group_no" )
 column=(type=char(22) updatewhereclause=yes name=mfs_group_no_barcode dbname="mfs_group_no_barcode" )
 column=(type=char(20) updatewhereclause=yes name=customer_code dbname="ip_product_model_master.customer_code" dbalias="B.customer_code" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_model_master.item_code" dbalias="B.item_code" )
 column=(type=char(100) updatewhereclause=yes name=model_spec dbname="ip_product_model_master.model_spec" dbalias="B.model_spec" )
 column=(type=char(61) updatewhereclause=yes name=serial_no dbname="serial_no" )
 column=(type=char(20) updatewhereclause=yes name=pcb_week dbname="ip_product_run_card.pcb_week" dbalias=".pcb_week" )
 column=(type=char(4000) updatewhereclause=yes name=pcb_item dbname="pcb_item" )
 retrieve="  SELECT IP_PRODUCT_RUN_CARD.RUN_NO,   
			'*'||UPPER(IP_PRODUCT_RUN_CARD.RUN_NO)||'*' RUN_NO_LABEL,   
			TRUNC(IP_PRODUCT_RUN_CARD.RUN_DATE) RUN_DATE,   

			IP_PRODUCT_RUN_CARD.MODEL_NAME AS MODEL_NAME,   
			// '*'||IP_PRODUCT_RUN_CARD.MODEL_NAME||'*' MODEL_NAME_LABEL,   
              F_BACODE_CODE128( 'B' , ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~") MODEL_NAME_LABEL,   

			B.MODEL_NAME AS B_MODEL_NAME, 
			
			IP_PRODUCT_RUN_CARD.LINE_CODE,   
			'*'||IP_PRODUCT_RUN_CARD.LINE_CODE||'*' LINE_CODE_LABEL ,   
			IP_PRODUCT_RUN_CARD.LOT_SIZE,   
			IP_PRODUCT_RUN_CARD.PRODUCT_RUN_TYPE,   
			IP_PRODUCT_RUN_CARD.COMMENTS,

			// IP_PRODUCT_RUN_CARD.METALMASK_CODE,   
			// '*'||IP_PRODUCT_RUN_CARD.METALMASK_CODE||'*' METALMASK_CODE_LABEL,   

			(
                 select listagg(jig_lot_no,', ') within group ( order by jig_lot_no )
                  from imcn_jig
                where jig_lot_no in (
                                              select jig_lot_no
                                                from imcn_jig_apply_model
                                              where item_code = IP_PRODUCT_RUN_CARD.MODEL_NAME
                                            )
                   and jig_type = 'M'
                   and pcb_item = IP_PRODUCT_RUN_CARD.pcb_item
                 group by jig_type
              )  METALMASK_CODE,
              
              (
                select listagg(location_address,', ') within group ( order by location_address )
                 from imcn_jig
                where jig_lot_no in (
                                              select jig_lot_no
                                                from imcn_jig_apply_model
                                              where item_code = IP_PRODUCT_RUN_CARD.MODEL_NAME
                                            )
                   and jig_type = 'M'
                 group by jig_type
              ) METALMASK_CODE_LABEL,

             (
                 select listagg(sample_lot_no,', ') within group ( order by sample_lot_no )
                  from imcn_sample
                where sample_lot_no in (
                                              select sample_lot_no
                                                from imcn_sample_apply_model
                                              where item_code = IP_PRODUCT_RUN_CARD.MODEL_NAME
                                            )
                   and sample_type = 'S'
                 group by sample_type
              )  SAMPLE_CODE,
              
              (
                select listagg(location_address,', ') within group ( order by location_address )
                 from imcn_sample
                where sample_lot_no in (
                                              select sample_lot_no
                                                from imcn_sample_apply_model
                                              where item_code = IP_PRODUCT_RUN_CARD.MODEL_NAME
                                            )
                   and sample_type = 'S'
                 group by sample_type
              ) SAMPLE_CODE_LABEL,
			
			IP_PRODUCT_RUN_CARD.ITEM_CODE,   
			IP_PRODUCT_RUN_CARD.PARENT_ITEM_CODE,   
			IP_PRODUCT_RUN_CARD.MODEL_NAME||'.JPG' MODEL_PART_IMAGE ,
			IP_PRODUCT_RUN_CARD.LOT_NO ,
			IP_PRODUCT_RUN_CARD.MARKING_NO AS MARKING_NO ,
			IP_PRODUCT_RUN_CARD.MASTER_MODEL_NAME MASTER_MODEL_NAME ,
			IP_PRODUCT_RUN_CARD.MFS_GROUP_NO MFS_GROUP_NO ,
			'*'||IP_PRODUCT_RUN_CARD.MFS_GROUP_NO||'*' MFS_GROUP_NO_BARCODE ,
			B.CUSTOMER_CODE CUSTOMER_CODE ,
			B.ITEM_CODE , 
			B.MODEL_SPEC ,
			( SELECT MIN(A.SERIAL_NO) ||'-'||MAX(A.SERIAL_NO) FROM IP_PRODUCT_2D_BARCODE A WHERE A.RUN_NO = IP_PRODUCT_RUN_CARD.RUN_NO ) SERIAL_NO  ,
			IP_PRODUCT_RUN_CARD.PCB_WEEK AS PCB_WEEK,
              F_GET_BASECODE('PCB ITEM', pcb_item, 'K', 1) pcb_item

    FROM IP_PRODUCT_RUN_CARD, IP_PRODUCT_MODEL_MASTER B   
  
   WHERE  IP_PRODUCT_RUN_CARD.MASTER_MODEL_NAME = B.MASTER_MODEL_NAME(+) AND 
         IP_PRODUCT_RUN_CARD.ORGANIZATION_ID = B.ORGANIZATION_ID(+) AND 
         IP_PRODUCT_RUN_CARD.RUN_NO = :arg_run_no AND  
         IP_PRODUCT_RUN_CARD.ORGANIZATION_ID = :arg_organization_id
" arguments=(("arg_run_no", string),("arg_organization_id", number)) )
