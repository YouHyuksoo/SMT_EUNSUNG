table(column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_run_card.run_no" dbalias=".run_no" )
 column=(type=char(32) updatewhereclause=yes name=run_no_label dbname="run_no_label" )
 column=(type=datetime updatewhereclause=yes name=run_date dbname="run_date" )
 column=(type=char(100) updatewhereclause=yes name=model_name dbname="ip_product_run_card.model_name" dbalias=".model_name" )
 column=(type=char(2000) updatewhereclause=yes name=model_name_label dbname="model_name_label" )
 column=(type=char(100) updatewhereclause=yes name=b_model_name dbname="ip_product_model_master.b_model_name" dbalias="B.b_model_name" )
