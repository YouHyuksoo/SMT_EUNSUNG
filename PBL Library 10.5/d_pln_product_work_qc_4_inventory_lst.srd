 retrieve="  SELECT          ~"IP_PRODUCT_WORK_QC~".~"QC_SEQUENCE~" ,           ~"IP_PRODUCT_WORK_QC~".~"MODEL_NAME~" ,      
         ~"IP_PRODUCT_WORK_QC~".~"LINE_CODE~" ,           ~"IP_PRODUCT_WORK_QC~".~"WORKSTAGE_CODE~" ,    
       ~"IP_PRODUCT_WORK_QC~".~"SERIAL_NO~" ,           ~"IP_PRODUCT_WORK_QC~".~"QC_RESULT~" ,     
      ~"IP_PRODUCT_WORK_QC~".~"BAD_REASON_CODE~" ,           ~"IP_PRODUCT_WORK_QC~".~"BAD_QTY~" ,    
       ~"IP_PRODUCT_WORK_QC~".~"CHARGER~" ,           ~"IP_PRODUCT_WORK_QC~".~"REPAIR_BY~" ,           ~"IP_PRODUCT_WORK_QC~".~"QC_DATE~" ,      
     ~"IP_PRODUCT_WORK_QC~".~"REPAIR_DATE~" ,           ~"IP_PRODUCT_WORK_QC~".~"QC_INSPECT_HANDLING~" ,           ~"IP_PRODUCT_WORK_QC~".~"COMMENTS~" ,      
     ~"IP_PRODUCT_WORK_QC~".~"ORGANIZATION_ID~" ,           ~"IP_PRODUCT_WORK_QC~".~"ENTER_DATE~" ,           ~"IP_PRODUCT_WORK_QC~".~"ENTER_BY~" ,      
     ~"IP_PRODUCT_WORK_QC~".~"LAST_MODIFY_DATE~" ,           ~"IP_PRODUCT_WORK_QC~".~"LAST_MODIFY_BY~" ,           ~"IP_PRODUCT_WORK_QC~".~"SHIFT_CODE~" ,    
       ~"IP_PRODUCT_WORK_QC~".~"DEFECT_QTY~" ,           ~"IP_PRODUCT_WORK_QC~".~"RECEIPT_DEFICIT~" ,         
         ~"IP_PRODUCT_WORK_QC~".~"MACHINE_CODE~" ,           '' check_yn,      
       ~"IP_PRODUCT_WORK_QC~".~"REPAIR_RESULT_CODE~"     FROM ~"IP_PRODUCT_WORK_QC~"  
    WHERE     ( ~"IP_PRODUCT_WORK_QC~".~"MODEL_NAME~" like :ARG_MODEL_NAME ) and          ( ~"IP_PRODUCT_WORK_QC~".~"SERIAL_NO~" like :ARG_SERIAL_NO ) And 
         ( ~"IP_PRODUCT_WORK_QC~".~"RECEIPT_DEFICIT~" = '1' ) and          ( ~"IP_PRODUCT_WORK_QC~".~"QC_INSPECT_HANDLING~" like :ARG_INSPECT_HANDLING ) and       
   ( nvl(~"IP_PRODUCT_WORK_QC~".~"REPAIR_RESULT_CODE~",'*') like :ARG_REPAIR_RESULT_CODE ) and     
     ( ~"IP_PRODUCT_WORK_QC~".~"ORGANIZATION_ID~" = :ARG_ORG )   " update="IP_PRODUCT_WORK_QC" updatewhere=1 updatekeyinplace=no arguments=(("ARG_MODEL_NAME", string),("ARG_SERIAL_NO", string),("ARG_INSPECT_HANDLING", string),("ARG_REPAIR_RESULT_CODE", string),("ARG_ORG", number))  sort="model_name A receipt_deficit A repair_date A " )
