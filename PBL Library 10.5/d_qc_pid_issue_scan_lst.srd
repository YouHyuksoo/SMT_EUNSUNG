 retrieve="  SELECT ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"SERIAL_NO~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"SCAN_DATE~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"PID_ISSUE_TYPE~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"LOCATION~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"COMMENTS~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"ENTER_BY~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"LINE_CODE~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"CLEAN_CHARGER~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"INSPECT_CHARGER~",   
         ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~" 


    FROM ~"IP_PRODUCT_ISSUE_PID_SCAN~",   
         ~"ID_ITEM~"  
   WHERE ( ip_product_issue_pid_scan.item_code = id_item.item_code (+)) and  
         ( ip_product_issue_pid_scan.organization_id = id_item.organization_id (+)) and  
         ( ( ~"IP_PRODUCT_ISSUE_PID_SCAN~".~"SERIAL_NO~" = :arg_pid ) )    
" update="IP_PRODUCT_ISSUE_PID_SCAN" updatewhere=0 updatekeyinplace=no arguments=(("arg_pid", string))  sort="pid_issue_type A scan_date A " )
