 retrieve="  SELECT IMCN_MOLD_PURCHASE_ORDER.ORDER_NO,   
         IMCN_MOLD_PURCHASE_ORDER.ORGANIZATION_ID,   
         IMCN_MOLD_PURCHASE_ORDER.PURCHASE_ORDER_DATE,   
         IMCN_MOLD_PURCHASE_ORDER.DELIVERY_DATE,   
         IMCN_MOLD_PURCHASE_ORDER.ORDER_QTY,   
         IMCN_MOLD_PURCHASE_ORDER.ORDER_AMT,   
         IMCN_MOLD_PURCHASE_ORDER.RECEIPT_QTY,   
         IMCN_MOLD_PURCHASE_ORDER.UNIT_PRICE,   
         IMCN_MOLD_PURCHASE_ORDER.CURRENCY,   
         IMCN_MOLD_PURCHASE_ORDER.ENTER_DATE,   
         IMCN_MOLD_PURCHASE_ORDER.ENTER_BY,   
         IMCN_MOLD_PURCHASE_ORDER.MOLD_CODE,   
         IMCN_MOLD_PURCHASE_ORDER.LAST_MODIFY_DATE,   
         IMCN_MOLD_PURCHASE_ORDER.LAST_MODIFY_BY,   
         IMCN_MOLD.MOLD_NAME,   
         IMCN_MOLD.MOLD_SPEC,   
         IMCN_MOLD_PURCHASE_ORDER.SUPPLIER_CODE,   
         '' CHECK_YN,   
         IMCN_MOLD_PURCHASE_ORDER.ORDER_GROUP_NO,   
         IMCN_MOLD_PURCHASE_ORDER.INCIDENTAL_EXPENSE_CODE,   
         IMCN_MOLD_PURCHASE_ORDER.DELIVERY_METHOD,   
         ICOM_SUPPLIER.SUPPLIER_NAME, 
          IMCN_MOLD_PURCHASE_ORDER.ROWID
    FROM IMCN_MOLD_PURCHASE_ORDER,   
         IMCN_MOLD,   
         ICOM_SUPPLIER  
   WHERE ( IMCN_MOLD_PURCHASE_ORDER.MOLD_CODE = IMCN_MOLD.MOLD_CODE ) AND  
         ( IMCN_MOLD.ORGANIZATION_ID = IMCN_MOLD_PURCHASE_ORDER.ORGANIZATION_ID ) AND  
         ( IMCN_MOLD_PURCHASE_ORDER.SUPPLIER_CODE = ICOM_SUPPLIER.SUPPLIER_CODE ) AND  
         ( ICOM_SUPPLIER.ORGANIZATION_ID = IMCN_MOLD_PURCHASE_ORDER.ORGANIZATION_ID ) AND  
          IMCN_MOLD_PURCHASE_ORDER.SUPPLIER_CODE LIKE :ARG_SUPPLIER_CODE  AND  
          IMCN_MOLD_PURCHASE_ORDER.MOLD_CODE LIKE :ARG_MOLD_CODE  AND  
         IMCN_MOLD_PURCHASE_ORDER.DELIVERY_DATE >= :ARG_DATESET AND  
         IMCN_MOLD_PURCHASE_ORDER.DELIVERY_DATE <= :ARG_DATEEND AND  
         IMCN_MOLD_PURCHASE_ORDER.ORGANIZATION_ID = :ARG_ORG_ID 

" arguments=(("arg_supplier_code", string),("arg_mold_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org_id", number))  sort="order_group_no A supplier_code A mold_code A delivery_date A " )
