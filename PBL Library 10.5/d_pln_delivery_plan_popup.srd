table(column=(type=char(30) update=yes updatewhereclause=yes name=mfs dbname="ip_product_delivery_plan.mfs" dbalias=".mfs" )
 column=(type=datetime update=yes updatewhereclause=yes name=plan_date dbname="ip_product_delivery_plan.plan_date" dbalias=".plan_date" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="ip_product_delivery_plan.organization_id" dbalias=".organization_id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=line_code dbname="ip_product_delivery_plan.line_code" dbalias=".line_code" )
 column=(type=number update=yes updatewhereclause=yes name=plan_priority dbname="ip_product_delivery_plan.plan_priority" dbalias=".plan_priority" )
