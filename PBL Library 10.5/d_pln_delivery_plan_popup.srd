 column=(type=char(30) update=yes updatewhereclause=yes name=work_order_no dbname="ip_product_delivery_plan.work_order_no" dbalias=".work_order_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=item_code dbname="ip_product_delivery_plan.item_code" dbalias=".item_code" )
 column=(type=char(1) update=yes updatewhereclause=yes name=plan_transfer_yn dbname="ip_product_delivery_plan.plan_transfer_yn" dbalias=".plan_transfer_yn" )
 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=number updatewhereclause=yes name=actual_qty dbname="ip_product_delivery_plan.actual_qty" dbalias=".actual_qty" )
 column=(type=char(1) updatewhereclause=yes name=plan_status dbname="plan_status" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" dbalias=".item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias=".item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" dbalias=".item_uom" )
 column=(type=number updatewhereclause=yes name=plan_sequence dbname="ip_product_delivery_plan.plan_sequence" dbalias=".plan_sequence" )
 column=(type=char(50) updatewhereclause=yes name=model_name dbname="ip_product_delivery_plan.model_name" dbalias=".model_name" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="ip_product_delivery_plan.parent_item_code" dbalias=".parent_item_code" )
 column=(type=number updatewhereclause=yes name=lot_qty dbname="ip_product_delivery_plan.lot_qty" dbalias=".lot_qty" )
 retrieve="  SELECT IP_PRODUCT_DELIVERY_PLAN.MFS,   
			IP_PRODUCT_DELIVERY_PLAN.PLAN_DATE,   
			IP_PRODUCT_DELIVERY_PLAN.ORGANIZATION_ID,   
			IP_PRODUCT_DELIVERY_PLAN.LINE_CODE,   
			IP_PRODUCT_DELIVERY_PLAN.PLAN_PRIORITY,   
			IP_PRODUCT_DELIVERY_PLAN.PLAN_QTY,   
			IP_PRODUCT_DELIVERY_PLAN.CUSTOMER_CODE,   
			IP_PRODUCT_DELIVERY_PLAN.WORK_ORDER_NO,   
			IP_PRODUCT_DELIVERY_PLAN.ITEM_CODE,   
			IP_PRODUCT_DELIVERY_PLAN.PLAN_TRANSFER_YN,   
			'N' CHECK_YN,   
			IP_PRODUCT_DELIVERY_PLAN.ACTUAL_QTY,   
			NVL( IP_PRODUCT_DELIVERY_PLAN.PLAN_STATUS,   'W') PLAN_STATUS ,
			ID_ITEM.ITEM_NAME,   
			ID_ITEM.ITEM_SPEC,   
			ID_ITEM.ITEM_UOM,   
			IP_PRODUCT_DELIVERY_PLAN.PLAN_SEQUENCE,   
			IP_PRODUCT_DELIVERY_PLAN.MODEL_NAME AS MODEL_NAME ,   
			IP_PRODUCT_DELIVERY_PLAN.PARENT_ITEM_CODE ,
			IP_PRODUCT_DELIVERY_PLAN.PLAN_QTY  LOT_QTY
    FROM IP_PRODUCT_DELIVERY_PLAN,   
             ID_ITEM  
   WHERE  IP_PRODUCT_DELIVERY_PLAN.ITEM_CODE = ID_ITEM.ITEM_CODE(+)  and  
				IP_PRODUCT_DELIVERY_PLAN.ORGANIZATION_ID = ID_ITEM.ORGANIZATION_ID(+)  and  
				IP_PRODUCT_DELIVERY_PLAN.PLAN_DATE >= :ARG_DATESET  AND  
				IP_PRODUCT_DELIVERY_PLAN.PLAN_DATE <= :ARG_DATEEND  AND  
				IP_PRODUCT_DELIVERY_PLAN.LINE_CODE like :ARG_LINE_CODE AND  
				IP_PRODUCT_DELIVERY_PLAN.ORGANIZATION_ID = :ARG_ORG AND
				IP_PRODUCT_DELIVERY_PLAN.MODEL_NAME LIKE :ARG_MODEL_NAME
				" arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_ORG", number))  sort="organization_id A plan_transfer_yn A plan_date A plan_priority A " )
