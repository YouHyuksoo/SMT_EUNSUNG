 retrieve="  SELECT ~"IMCN_MACHINE~".~"MACHINE_CODE~",   
         ~"IMCN_MACHINE~".~"ORGANIZATION_ID~",   
         ~"IMCN_MACHINE~".~"MACHINE_NAME~",   
         ~"IMCN_MACHINE~".~"MACHINE_TYPE~",   
         ~"IMCN_MACHINE~".~"CAPACITY~",   
         ~"IMCN_MACHINE~".~"ACQUISITION_DATE~",   
         ~"IMCN_MACHINE~".~"ACQUISITION_TYPE~",   
         ~"IMCN_MACHINE~".~"MACHINE_MODEL_NAME~",   
         ~"IMCN_MACHINE~".~"LINE_CODE~",   
         ~"IMCN_MACHINE~".~"CUSTOMER_CODE~",   
         ~"IMCN_MACHINE~".~"USE_STATUS~",   
         ~"IMCN_MACHINE~".~"MANUAL_LOCATION_COMMENT~",   
         ~"IMCN_MACHINE~".~"NATION_CODE~",   
         ~"IMCN_MACHINE~".~"WORKSTAGE_CODE~",   
         ~"IMCN_MACHINE~".~"ENTER_BY~",   
         ~"IMCN_MACHINE~".~"ENTER_DATE~",   
         ~"IMCN_MACHINE~".~"LAST_MODIFY_BY~",   
         ~"IMCN_MACHINE~".~"LAST_MODIFY_DATE~",           
         ~"IMCN_MACHINE~".~"RESERVED_CAPACITY~"  
    FROM ~"IMCN_MACHINE~"  
   WHERE ( ~"IMCN_MACHINE~".~"MACHINE_CODE~" like :arg_machine_code ) AND  
( ~"IMCN_MACHINE~".~"MACHINE_TYPE~" like :arg_machine_type ) AND  
         ( ~"IMCN_MACHINE~".~"ORGANIZATION_ID~" = :arg_org )    
" update="IMCN_MACHINE" updatewhere=1 updatekeyinplace=no arguments=(("arg_machine_code", string),("arg_machine_type", string),("arg_org", number)) )
