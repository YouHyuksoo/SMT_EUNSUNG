export.xml(headgroups="1" includewhitespace="0" metadatatype=0 savemetadata=0  template=(comment="" encoding="UTF-16LE" name="s" xml="<?xml version=~"1.0~" encoding=~"UTF-16LE~" standalone=~"no~"?><d_mcn_machine_lst><d_mcn_machine_lst_row __pbband=~"detail~"><machine_code>machine_code</machine_code><organization_id>organization_id</organization_id><machine_name>machine_name</machine_name><machine_type>machine_type</machine_type><capacity>capacity</capacity><acquisition_date>acquisition_date</acquisition_date><acquisition_type>acquisition_type</acquisition_type><machine_model_name>machine_model_name</machine_model_name><line_code>line_code</line_code><customer_code>customer_code</customer_code><use_status>use_status</use_status><manual_location_comment>manual_location_comment</manual_location_comment><nation_code>nation_code</nation_code><workstage_code>workstage_code</workstage_code><enter_by/><enter_date/><last_modify_by/><last_modify_date/><rowid>rowid</rowid><reserved_capacity>reserved_capacity</reserved_capacity></d_mcn_machine_lst_row></d_mcn_machine_lst>"))
