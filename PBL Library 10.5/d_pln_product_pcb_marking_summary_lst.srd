table(column=(type=char(100) update=yes updatewhereclause=yes name=lotid dbname="iq_machine_inspect_data_mk.lotid" dbalias=".lotid" )
 column=(type=number updatewhereclause=yes name=pid_qty dbname="pid_qty" )
 column=(type=char(4000) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(100) updatewhereclause=yes name=min_pid dbname="min_pid" )
 column=(type=char(100) updatewhereclause=yes name=max_pid dbname="max_pid" )
 column=(type=char(20) update=yes updatewhereclause=yes name=equipmentid dbname="iq_machine_inspect_data_mk.equipmentid" dbalias=".equipmentid" )
 column=(type=char(20) update=yes updatewhereclause=yes name=dateset dbname="dateset" )
 column=(type=char(20) update=yes updatewhereclause=yes name=result_code dbname="iq_machine_inspect_data_mk.result_code" dbalias=".result_code" )
 column=(type=char(100) update=yes updatewhereclause=yes name=run_no dbname="iq_machine_inspect_data_mk.run_no" dbalias=".run_no" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="iq_machine_inspect_data_mk.line_code" dbalias=".line_code" )
 column=(type=char(30) updatewhereclause=yes name=machine_code dbname="iq_machine_inspect_data_mk.machine_code" dbalias=".machine_code" )
 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="enter_date" )
 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LOTID~",   
		COUNT(*) PID_QTY , 
		F_GET_MODEL_NAME_BY_RUN_NO( RUN_NO) MODEL_NAME ,
         MAX(~"IQ_MACHINE_INSPECT_DATA_MK~".~"SEQ~") SEQ,   
         MIN(~"IQ_MACHINE_INSPECT_DATA_MK~".~"PID~") MIN_PID,   
         MAX(~"IQ_MACHINE_INSPECT_DATA_MK~".~"PID~") MAX_PID,   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"EQUIPMENTID~",   
         MIN(~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~") DATESET,   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RESULT_CODE~",   
         
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RUN_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"MACHINE_CODE~",   
         MIN(~"IQ_MACHINE_INSPECT_DATA_MK~".~"ENTER_DATE~")   ENTER_DATE
    FROM ~"IQ_MACHINE_INSPECT_DATA_MK~"  
   WHERE ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RUN_NO~" like :ARG_RUN_NO ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"PID~" like :ARG_SERIAL_NO ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~" >= TO_CHAR(:ARG_DATESET , 'YYYY/MM/DD HH24:MI:SS') ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"DATESET~" < TO_CHAR(:ARG_DATEEND +1  , 'YYYY/MM/DD HH24:MI:SS') ) AND  
         ( ~"IQ_MACHINE_INSPECT_DATA_MK~".~"ORGANIZATION_ID~" = :ARG_ORG )    
GROUP BY ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LOTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"EQUIPMENTID~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RESULT_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"RUN_NO~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"LINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_MK~".~"MACHINE_CODE~"" arguments=(("ARG_RUN_NO", string),("ARG_SERIAL_NO", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_ORG", number))  sort="lotid A " )
