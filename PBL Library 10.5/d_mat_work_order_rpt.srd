 retrieve="  SELECT B.MFS , B.ORDER_QTY , B.CUSTOMER_CODE , B.CUSTOMER_ORDER_NO ,
         ~"IM_ITEM_WORK_ORDER~".~"WORK_ORDER_NO~",   
         ~"IM_ITEM_WORK_ORDER~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_WORK_ORDER~".~"PLAN_YYYYMM~",   
         ~"IM_ITEM_WORK_ORDER~".~"SHIFT_CODE~",   
         ~"IM_ITEM_WORK_ORDER~".~"LINE_CODE~",   
         ~"IM_ITEM_WORK_ORDER~".~"WORKSTAGE_CODE~",   
         ~"IM_ITEM_WORK_ORDER~".~"ISSUE_DATE~",   
         ~"IM_ITEM_WORK_ORDER~".~"ISSUE_PLAN_QTY~",   
         ~"IM_ITEM_WORK_ORDER~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"IM_ITEM_WORK_ORDER~".~"MFS~",   
         ~"IM_ITEM_WORK_ORDER~".~"PARENT_ITEM_CODE~",   
		C.ITEM_NAME SET_ITEM_NAME ,
		C.ITEM_SPEC SET_ITEM_SPEC ,
         ~"IM_ITEM_WORK_ORDER~".~"ISSUE_ACCOUNT~",   
         ~"IM_ITEM_WORK_ORDER~".~"PLAN_DATE~",   
         ~"IM_ITEM_WORK_ORDER~".~"LINE_TYPE~",   
         ~"IM_ITEM_WORK_ORDER~".~"ISSUE_QTY~"  
    FROM ~"IM_ITEM_WORK_ORDER~",   
         (
		SELECT  MFS ,ITEM_CODE ,  SUM(ORDER_QTY) ORDER_QTY , CUSTOMER_ORDER_NO ,CUSTOMER_CODE ,ORGANIZATION_ID
             FROM  ~"IP_PRODUCT_MASTER_PLAN~" 
          WHERE ~"IP_PRODUCT_MASTER_PLAN~".~"PLAN_DATE~" >= :arg_dateset  AND  
                       ~"IP_PRODUCT_MASTER_PLAN~".~"PLAN_DATE~" <= :arg_dateend AND
                       ~"IP_PRODUCT_MASTER_PLAN~".~"MFS~" like :arg_mfs AND
				   ~"IP_PRODUCT_MASTER_PLAN~".~"ORGANIZATION_ID~" = :arg_org_id
        GROUP BY  MFS , ITEM_CODE , CUSTOMER_CODE , CUSTOMER_ORDER_NO , ORGANIZATION_ID
         ) B ,
         ~"ID_ITEM~"  , ~"ID_ITEM~" C
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_WORK_ORDER~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_WORK_ORDER~".~"ORGANIZATION_ID~" ) and  
         ( B.ITEM_CODE = C.ITEM_CODE ) AND
         ( B.ORGANIZATION_ID = C.ORGANIZATION_ID ) AND
         ( ~"IM_ITEM_WORK_ORDER~".MFS = B.MFS ) AND
         ( ~"IM_ITEM_WORK_ORDER~".PARENT_ITEM_CODE = B.ITEM_CODE ) AND
         ( ~"IM_ITEM_WORK_ORDER~".~"PLAN_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_WORK_ORDER~".~"PLAN_DATE~" <= :arg_dateend ) AND  
         ( ~"IM_ITEM_WORK_ORDER~".~"MFS~" like :arg_mfs ) AND  
         ( ~"IM_ITEM_WORK_ORDER~".~"PARENT_ITEM_CODE~" like :arg_set_item_code ) AND  
         ( ~"IM_ITEM_WORK_ORDER~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IM_ITEM_WORK_ORDER~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IM_ITEM_WORK_ORDER~".~"ORGANIZATION_ID~" = :arg_org_id ) 
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_mfs", string),("arg_set_item_code", string),("arg_line_code", string),("arg_workstage_code", string),("arg_org_id", number))  sort="organization_id A mfs A line_code A workstage_code A item_code A " )
