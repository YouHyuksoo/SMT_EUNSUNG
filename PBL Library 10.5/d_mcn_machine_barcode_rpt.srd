table(column=(type=char(32) updatewhereclause=yes name=machine_code dbname="machine_code" )
 column=(type=char(100) updatewhereclause=yes name=machine_name dbname="imcn_machine.machine_name" )
 retrieve="  SELECT '*'||~"IMCN_MACHINE~".~"MACHINE_CODE~"||'*'  MACHINE_CODE ,   
         ~"IMCN_MACHINE~".~"MACHINE_NAME~"  
    FROM ~"IMCN_MACHINE~"   
WHERE MACHINE_TYPE LIKE :ARG_MACHINE_TYPE 
    AND ORGANIZATION_ID = :ARG_ORG
" arguments=(("arg_machine_type", string),("arg_org", number))  sort="machine_code A " )
