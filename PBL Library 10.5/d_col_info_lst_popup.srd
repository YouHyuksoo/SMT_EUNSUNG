 retrieve="  SELECT ~"ISYS_WINDOW_PROPERTY~".~"WINDOW_NAME~",   
         ~"ISYS_WINDOW_PROPERTY~".~"DATAWINDOW_NAME~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_FORMAT~",   
         ~"ISYS_WINDOW_PROPERTY~".~"EDITMASK~",   
         ~"ISYS_WINDOW_PROPERTY~".~"VISIBLE_YN~",   
         ~"ISYS_WINDOW_PROPERTY~".~"UPDATE_YN~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_TEXT_COLOR~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_BACK_COLOR~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_WIDTH~",   
         ~"ISYS_WINDOW_PROPERTY~".~"ENTER_BY~",   
         ~"ISYS_WINDOW_PROPERTY~".~"ENTER_DATE~",   
         ~"ISYS_WINDOW_PROPERTY~".~"LAST_MODIFY_BY~",   
         ~"ISYS_WINDOW_PROPERTY~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_WINDOW_PROPERTY~".~"ORGANIZATION_ID~",   
         ~"ISYS_WINDOW_PROPERTY~".~"SPARSE~",   
         ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_TYPE~",   
         ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_X1~",   
         ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_X2~",   
         ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_Y1~",   
         ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_Y2~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_ORDER~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_MEAN~",   
         ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_ALIGN~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_HEIGHT~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_EXPRESSION~",   
         ~"ISYS_WINDOW_PROPERTY~".~"BAND~",   
         ~"ISYS_WINDOW_PROPERTY~".~"COLUMN_NAME~"  ,
         'N' CHECK_YN
    FROM ~"ISYS_WINDOW_PROPERTY~"  
   WHERE ( ~"ISYS_WINDOW_PROPERTY~".~"WINDOW_NAME~" = UPPER(:ARG_WINDOW_NAME) ) AND  
                ( ~"ISYS_WINDOW_PROPERTY~".~"DATAWINDOW_NAME~" = UPPER(:ARG_DATAWINDOW_NAME) ) AND  
               NVL(~"ISYS_WINDOW_PROPERTY~".~"OBJECT_TYPE~" , '*') like :ARG_OBJECT_TYPE AND  
                ( ~"ISYS_WINDOW_PROPERTY~".~"ORGANIZATION_ID~" = :ARG_ORG )   
ORDER BY ~"ISYS_WINDOW_PROPERTY~".~"WINDOW_NAME~" , 
                 ~"ISYS_WINDOW_PROPERTY~".~"DATAWINDOW_NAME~",   
                 ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_TYPE~",  
                 TO_NUMBER( DECODE( ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_X1~" , '?' , -1 , ~"ISYS_WINDOW_PROPERTY~".~"OBJECT_X1~"  ) )  ASC 
" update="ISYS_WINDOW_PROPERTY" updatewhere=0 updatekeyinplace=no arguments=(("ARG_WINDOW_NAME", string),("ARG_DATAWINDOW_NAME", string),("ARG_OBJECT_TYPE", string),("ARG_ORG", number))  sort="organization_id A window_name A object_type A " )
