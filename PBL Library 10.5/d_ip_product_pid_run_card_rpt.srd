footer(height=52 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(30) update=yes updatewhereclause=yes key=yes name=run_no dbname="ip_product_run_card.run_no" dbalias=".run_no" )
 column=(type=number update=yes updatewhereclause=yes name=lot_size dbname="ip_product_run_card.lot_size" dbalias=".lot_size" )
 column=(type=char(1) update=yes updatewhereclause=yes name=run_status dbname="ip_product_run_card.run_status" dbalias=".run_status" )
 column=(type=char(1) updatewhereclause=yes name=product_run_type dbname="ip_product_run_card.product_run_type" dbalias=".product_run_type" )
 column=(type=datetime update=yes updatewhereclause=yes name=run_date dbname="ip_product_run_card.run_date" dbalias=".run_date" )
 column=(type=char(4000) update=yes updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(100) update=yes updatewhereclause=yes name=model_name dbname="ip_product_run_card.model_name" dbalias=".model_name" )
 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="ip_product_run_card.pcb_item" dbalias=".pcb_item" )
 column=(type=number updatewhereclause=yes name=carrier_size dbname="ip_product_run_card.carrier_size" dbalias=".carrier_size" )
 column=(type=number updatewhereclause=yes name=label_qty dbname="label_qty" )
 column=(type=number updatewhereclause=yes name=input_qty dbname="input_qty" )
 column=(type=number updatewhereclause=yes name=output_qty dbname="output_qty" )
 column=(type=number updatewhereclause=yes name=bad_qty dbname="bad_qty" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="ip_product_run_card.enter_date" dbalias=".enter_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_run_card.enter_by" dbalias=".enter_by" )
 column=(type=number update=yes updatewhereclause=yes key=yes name=organization_id dbname="ip_product_run_card.organization_id" dbalias=".organization_id" )
 retrieve="select run_no,
         lot_size, 
         run_status,
         product_run_type, 
         run_date, 
         f_get_line_name( line_code, organization_id) line_code, 
         model_name, 
         pcb_item, 
         carrier_size, 
         F_GET_PCB_LABEL_QTY_BY_RUN_NO( RUN_NO , ORGANIZATION_ID )  AS LABEL_QTY ,
         F_GET_PCB_INPUT_QTY_BY_RUN_NO( RUN_NO , ORGANIZATION_ID )  AS INPUT_QTY ,
         F_GET_PCB_OUTPUT_QTY_BY_RUN_NO( RUN_NO , ORGANIZATION_ID ) AS OUTPUT_QTY ,
         F_GET_PCB_BAD_QTY_BY_RUN_NO( RUN_NO , ORGANIZATION_ID )    AS BAD_QTY,
         enter_date, 
         enter_by, 
         organization_id
  from ip_product_run_card
 where run_no = (
                            select run_no   
                             from ip_product_2d_barcode  
                           where SERIAL_NO like :ARG_SERIAL_NO 
                              AND ORGANIZATION_ID = :ARG_ORG 
                              AND ROWNUM = 1
                         )
" update="ip_product_run_card" updatewhere=1 updatekeyinplace=no arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number)) )
