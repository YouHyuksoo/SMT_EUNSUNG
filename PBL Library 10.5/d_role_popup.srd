 retrieve="  SELECT ~"ISYS_ROLE~".~"ROLE_CODE~",   
         ~"ISYS_ROLE~".~"WINDOW_NAME~",   
         ~"ISYS_ROLE~".~"WINDOW_NAME~"  WINDOW_DESCRIPTION,   
         ~"ISYS_ROLE~".~"ORGANIZATION_ID~",   
         ~"ISYS_ROLE~".~"ROLE_NAME~",   
         ~"ISYS_ROLE~".~"DATESET~",   
         ~"ISYS_ROLE~".~"DATEEND~",   
         ~"ISYS_ROLE~".~"ENTER_DATE~",   
         ~"ISYS_ROLE~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_ROLE~".~"ENTER_BY~",   
         ~"ISYS_ROLE~".~"LAST_MODIFY_BY~",   
         ~"ISYS_ROLE~".~"ROLE_TYPE~"  
    FROM ~"ISYS_ROLE~"  
   WHERE    ( ~"ISYS_ROLE~".~"ROLE_NAME~" LIKE :ARG_ROLE_NAME )    
    AND   ( ~"ISYS_ROLE~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" update="ISYS_ROLE" updatewhere=1 updatekeyinplace=no arguments=(("ARG_ROLE_NAME", string),("ARG_ORG", number))  sort="organization_id A role_code A window_name A " )
