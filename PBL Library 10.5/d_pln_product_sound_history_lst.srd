table(column=(type=char(20) update=yes updatewhereclause=yes key=yes name=sound_id dbname="isys_sound_ment.sound_id" dbalias=".sound_id" )
 column=(type=char(30) update=yes updatewhereclause=yes name=line_code dbname="isys_sound_ment.line_code" dbalias=".line_code" )
