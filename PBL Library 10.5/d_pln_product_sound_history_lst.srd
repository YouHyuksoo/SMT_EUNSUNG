 column=(type=char(1) update=yes updatewhereclause=yes name=sound_status dbname="isys_sound_ment.sound_status" dbalias=".sound_status" values="Close	C/Open	O/" )
 column=(type=char(1000) update=yes updatewhereclause=yes name=action_history dbname="isys_sound_ment.action_history" dbalias=".action_history" )
 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="isys_sound_ment.enter_date" dbalias=".enter_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=warning_date dbname="isys_sound_ment.warning_date" dbalias=".warning_date" )
 column=(type=number update=yes updatewhereclause=yes name=time_term dbname="isys_sound_ment.time_term" dbalias=".time_term" )
 column=(type=number update=yes updatewhereclause=yes name=sound_level dbname="isys_sound_ment.sound_level" dbalias=".sound_level" )
 column=(type=char(30) update=yes updatewhereclause=yes name=enter_by dbname="isys_sound_ment.enter_by" dbalias=".enter_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="isys_sound_ment.last_modify_date" dbalias=".last_modify_date" )
 column=(type=char(30) update=yes updatewhereclause=yes name=last_modify_by dbname="isys_sound_ment.last_modify_by" dbalias=".last_modify_by" )
 column=(type=number update=yes updatewhereclause=yes key=yes name=organization_id dbname="isys_sound_ment.organization_id" dbalias=".organization_id" )
 column=(type=char(37) updatewhereclause=yes name=rowid dbname="isys_sound_ment.rowid" dbalias=".rowid" )
 retrieve="select sound_id, 
       line_code, 
       machine_code, 
       sound_group, 
       sound_text, 
       sound_status, 
       action_history, 
       enter_date, 
       warning_date,       
       time_term, 
       sound_level, 
       enter_by, 
       last_modify_date, 
       last_modify_by,
       organization_id,
       rowid
  from isys_sound_ment
where enter_date >=TO_DATE(:ARG_S_DATE ,'YYYY-MM-DD HH24:MI:SS')
   and  enter_date < TO_DATE(:ARG_E_DATE ,'YYYY-MM-DD HH24:MI:SS')  + (1/(24*60*60))
   and line_code like :ARG_LINE_CODE
   and machine_code like :ARG_MACHINE_CODE
   and sound_group like :ARG_SOUND_GROUP
   and sound_status like :ARG_SOUND_STATUS
   and organization_id like :ARG_ORG_ID
order by sound_id" update="isys_sound_ment" updatewhere=1 updatekeyinplace=no arguments=(("ARG_S_DATE", string),("ARG_E_DATE", string),("ARG_LINE_CODE", string),("ARG_MACHINE_CODE", string),("ARG_SOUND_GROUP", string),("ARG_SOUND_STATUS", string),("ARG_ORG_ID", number)) )
