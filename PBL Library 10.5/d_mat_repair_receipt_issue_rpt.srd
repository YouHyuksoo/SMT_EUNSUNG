footer(height=108 color="536870912" )
detail(height=80 color="16777215" )
table(column=(type=char(15) updatewhereclause=yes name=div dbname="id_item.div" )
 column=(type=number updatewhereclause=yes name=receipt_issue_sequence dbname="id_item.receipt_issue_sequence" )
 column=(type=datetime updatewhereclause=yes name=receipt_issue_date dbname="id_item.receipt_issue_date" )
 column=(type=number update=yes updatewhereclause=yes key=yes name=organization_id dbname="id_item.organization_id" )
 column=(type=char(1) updatewhereclause=yes name=receipt_issue_deficit dbname="id_item.receipt_issue_deficit" )
 column=(type=char(10) update=yes updatewhereclause=yes name=line_type dbname="id_item.line_type" values="" )
 column=(type=number updatewhereclause=yes name=qty dbname="id_item.qty" )
 column=(type=number update=yes updatewhereclause=yes name=material_cost dbname="id_item.material_cost" )
 column=(type=number updatewhereclause=yes name=price dbname="id_item.price" )
 column=(type=number update=yes updatewhereclause=yes name=material_cost_amt dbname="id_item.material_cost_amt" )
 column=(type=char(30) update=yes updatewhereclause=yes name=invoice_no dbname="id_item.invoice_no" )
 column=(type=number updatewhereclause=yes name=amt dbname="id_item.amt" )
 column=(type=number update=yes updatewhereclause=yes name=exchange_rate dbname="id_item.exchange_rate" )
 column=(type=number update=yes updatewhereclause=yes name=foreign_receipt_amt dbname="id_item.foreign_receipt_amt" )
 column=(type=char(20) update=yes updatewhereclause=yes name=supplier_code dbname="id_item.supplier_code" )
 column=(type=char(1) updatewhereclause=yes name=receipt_issue_type dbname="id_item.receipt_issue_type" )
 column=(type=char(3) update=yes updatewhereclause=yes name=currency dbname="id_item.currency" values="" )
 column=(type=char(1) updatewhereclause=yes name=receipt_issue_status dbname="id_item.receipt_issue_status" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=item_code dbname="id_item.item_code" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 retrieve="SELECT A.DIV ,
         A.RECEIPT_ISSUE_SEQUENCE,   
         A.RECEIPT_ISSUE_DATE,   
         A.ORGANIZATION_ID,   
         A.RECEIPT_ISSUE_DEFICIT,   
         A.LINE_TYPE,   
         A.QTY,   
         A.MATERIAL_COST,   
         A.PRICE,   
         A.MATERIAL_COST_AMT,   
         A.INVOICE_NO,   
         A.AMT,   
         A.EXCHANGE_RATE,   
         A.FOREIGN_RECEIPT_AMT,   
         A.SUPPLIER_CODE,   
         A.RECEIPT_ISSUE_TYPE ,   
         A.CURRENCY,   
         A.RECEIPT_ISSUE_STATUS,   
         A.ITEM_CODE  ,
	    B.ITEM_NAME,
	    B.ITEM_SPEC,
	    B.ITEM_UOM   
 FROM 
(

  SELECT 
         '(1) LAST INV' DIV ,
         0  RECEIPT_ISSUE_SEQUENCE,   
         LAST_DAY(ADD_MONTHS( TO_DATE( :ARG_YYYYMM||'01' , 'YYYYMMDD') ,-1))          RECEIPT_ISSUE_DATE,   
         ORGANIZATION_ID,   
         '' RECEIPT_ISSUE_DEFICIT      ,   
         LINE_TYPE,   
         LAST_INVENTORY_QTY  QTY,   
         0 MATERIAL_COST,   
         LAST_AVG_PRICE  PRICE            ,   
         0 MATERIAL_COST_AMT,   
         '' INVOICE_NO,   
         LAST_INVENTORY_AMT  AMT,
         0 EXCHANGE_RATE,   
         0 FOREIGN_RECEIPT_AMT,   
         '' SUPPLIER_CODE ,   
         ''  RECEIPT_ISSUE_TYPE              ,   
         ''  CURRENCY,   
         'N'   RECEIPT_ISSUE_STATUS      ,   
         ITEM_CODE  
    FROM IM_ITEM_REPAIR_INVENTORY_CLOSE
WHERE CLOSE_YYYYMM = :ARG_YYYYMM
      AND ITEM_CODE LIKE :ARG_ITEM
      AND ORGANIZATION_ID = :ARG_ORG

UNION ALL

  SELECT '(2) RECEIPT' DIV ,
         RECEIPT_SEQUENCE RECEIPT_ISSUE_SEQUENCE,   
         RECEIPT_DATE           RECEIPT_ISSUE_DATE,   
         ORGANIZATION_ID,   
         RECEIPT_DEFICIT        RECEIPT_ISSUE_DEFICIT,   
         LINE_TYPE,   
         RECEIPT_QTY               QTY,   
         MATERIAL_COST,   
         UNIT_PRICE                  PRICE,   
         MATERIAL_COST_AMT,   
         INVOICE_NO,   
         RECEIPT_AMT               AMT,   
         EXCHANGE_RATE,   
         FOREIGN_RECEIPT_AMT,   
         SUPPLIER_CODE,   
         RECEIPT_TYPE              RECEIPT_ISSUE_TYPE,   
         CURRENCY,   
         RECEIPT_STATUS         RECEIPT_ISSUE_STATUS,   
         ITEM_CODE  
    FROM IM_ITEM_REPAIR_RECEIPT   
WHERE RECEIPT_DATE >= TO_DATE(:ARG_YYYYMM||'01' , 'YYYYMMDD')
      AND RECEIPT_DATE < ADD_MONTHS( TO_DATE(:ARG_YYYYMM||'01' , 'YYYYMMDD') , 1 )
      AND ITEM_CODE LIKE :ARG_ITEM
      AND ORGANIZATION_ID = :ARG_ORG

UNION  ALL

  SELECT  '(3) ISSUE' DIV ,
         ISSUE_SEQUENCE  RECEIPT_ISSUE_SEQUENCE,   
         ISSUE_DATE                 RECEIPT_ISSUE_DATE,   
         ORGANIZATION_ID,   
         ISSUE_DEFICIT            RECEIPT_ISSUE_DEFICIT,   
         LINE_TYPE,   
         ISSUE_QTY                   QTY,   
         0 MATERIAL_COST,   
         ISSUE_PRICE               PRICE ,   
         0 MATERIAL_COST_AMT,   
         '' INVOICE_NO,   
         ISSUE_AMT                  AMT,   
         0 EXCHANGE_RATE,   
         0  FOREIGN_RECEIPT_AMT,
         SUPPLIER_CODE,   
         ISSUE_TYPE                 RECEIPT_ISSUE_TYPE,   
         '' CURRENCY,   
         ISSUE_STATUS            RECEIPT_ISSUE_STATUS,   
         ITEM_CODE  
    FROM IM_ITEM_REPAIR_ISSUE  
WHERE ISSUE_DATE >= TO_DATE(:ARG_YYYYMM||'01' , 'YYYYMMDD')
      AND ISSUE_DATE < ADD_MONTHS( TO_DATE(:ARG_YYYYMM||'01' , 'YYYYMMDD') , 1 )
      AND ITEM_CODE LIKE :ARG_ITEM
      AND ORGANIZATION_ID = :ARG_ORG

UNION ALL

  SELECT 
         '(4) CURRENT INV' DIV ,
         0  RECEIPT_ISSUE_SEQUENCE,   
         LAST_DAY(TO_DATE( :ARG_YYYYMM||'01' , 'YYYYMMDD') )           RECEIPT_ISSUE_DATE,   
         ORGANIZATION_ID,   
         '' RECEIPT_ISSUE_DEFICIT      ,   
         LINE_TYPE,   
         MM_INVENTORY_QTY  QTY,   
         0 MATERIAL_COST,   
         MM_AVG_PRICE  PRICE            ,   
         0 MATERIAL_COST_AMT,   
         '' INVOICE_NO,   
         MM_INVENTORY_AMT  AMT,
         0 EXCHANGE_RATE,   
         0 FOREIGN_RECEIPT_AMT,   
         '' SUPPLIER_CODE ,   
         ''  RECEIPT_ISSUE_TYPE              ,   
         ''  CURRENCY,   
         'N'   RECEIPT_ISSUE_STATUS      ,   
         ITEM_CODE  
    FROM IM_ITEM_REPAIR_INVENTORY_CLOSE
WHERE CLOSE_YYYYMM = :ARG_YYYYMM
      AND ITEM_CODE LIKE :ARG_ITEM
      AND ORGANIZATION_ID = :ARG_ORG

 ) A , ID_ITEM B

WHERE A.ITEM_CODE = B.ITEM_CODE
     AND A.ORGANIZATION_ID = B.ORGANIZATION_ID" update="ID_ITEM" updatewhere=0 updatekeyinplace=no arguments=(("arg_yyyymm", string),("arg_item", string),("arg_org", number))  sort="organization_id A item_code A receipt_issue_date A receipt_issue_sequence A " )
