 retrieve="  SELECT ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LABEL_TEXT~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ENTER_BY~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"WORKSTAGE_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ARRAY_TYPE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LINE_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MACHINE_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BCR_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BOX_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"PALLETE_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"CARRIER_BARCODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_YN~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_DATE~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"CUSTOMER_CODE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"LOT_QTY~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"BARCODE_STATUS~",   
         'N' CHECK_YN,   
         ~"IP_PRODUCT_2D_BARCODE~".~"MAPPING_LABEL~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"WORK_ORDER_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"CARRIER_SIZE~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"CUSTOMER_MODEL_NAME~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"EC_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"PART_NO~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"COMMENTS~",   
         ~"IP_PRODUCT_2D_BARCODE~".~"MAPPING_MODEL_NAME~"  ,
		~"IP_PRODUCT_2D_BARCODE~".~"ACTUAL_DATE~" ,
		~"IP_PRODUCT_2D_BARCODE~".~"RECEIPT_DATE~" ,
		~"IP_PRODUCT_2D_BARCODE~".~"SHIPPING_DATE~" ,
		~"IP_PRODUCT_2D_BARCODE~".~"LONGTERM_YN~" 
    FROM ~"IP_PRODUCT_2D_BARCODE~",   
         ~"ID_ITEM~"  
   WHERE ( ip_product_2d_barcode.item_code = id_item.item_code (+)) and  
         ( ip_product_2d_barcode.organization_id = id_item.organization_id (+)) and  
         ( ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~" like :ag_run_no ) AND  
         ( ~"IP_PRODUCT_2D_BARCODE~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" like :arg_serial_no ) AND  
         nvl(~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~" , '*') like :arg_magazine AND  
         nvl(~"IP_PRODUCT_2D_BARCODE~".~"BARCODE_STATUS~" , '*') like :arg_barcode_status AND  
         ( ~"IP_PRODUCT_2D_BARCODE~".~"ORGANIZATION_ID~" = :arg_org ) AND  
         ( ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~"   like :arg_model_name ) " update="IP_PRODUCT_2D_BARCODE" updatewhere=0 updatekeyinplace=yes arguments=(("arg_model_name", string),("ag_run_no", string),("arg_line_code", string),("arg_serial_no", string),("arg_magazine", string),("arg_barcode_status", string),("arg_org", number))  sort="barcode_status A run_no A enter_date A " )
