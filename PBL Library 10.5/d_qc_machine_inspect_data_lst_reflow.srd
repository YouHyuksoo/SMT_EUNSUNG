 retrieve="SELECT MEASURE_DATE, 
       LINE_CODE, 
       MACHINE_CODE,
       BELT_SPEED, 
       OXYGEN_CONCENTRATION, 
       TOP1, 
       BOTTOM1, 
       TOP2, 
       BOTTOM2, 
       TOP3, 
       BOTTOM3, 
       TOP4, 
       BOTTOM4, 
       TOP5, 
       BOTTOM5, 
       TOP6, 
       BOTTOM6, 
       TOP7, 
       BOTTOM7, 
       TOP8, 
       BOTTOM8, 
       TOP9, 
       BOTTOM9, 
       TOP10, 
       BOTTOM10, 
       TOP11, 
       BOTTOM11, 
       TOP12, 
       BOTTOM12, 
       TOP13, 
       BOTTOM13, 
       FILE_NAME, 
       ENTER_DATE, 
       ENTER_BY, 
       LAST_MODIFY_DATE, 
       LAST_MODIFY_BY, 
       ORGANIZATION_ID,
       JOB_FILE
  FROM IQ_MACHINE_INSPECT_DATA_REFLOW
 WHERE  MEASURE_DATE  >= TO_CHAR(TRUNC(:ARG_DATESET),'YYYY/MM/DD HH24:MI:SS' ) 
      AND  MEASURE_DATE  <   TO_CHAR(TRUNC(:ARG_DATEEND)+1 ,'YYYY/MM/DD HH24:MI:SS' )
      AND   LINE_CODE LIKE :ARG_LINE_CODE 
      AND   JOB_FILE   LIKE :ARG_JOB_FILE" arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_JOB_FILE", string))  sort="measure_date A line_code A " )
