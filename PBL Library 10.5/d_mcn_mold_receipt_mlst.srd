ring)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IMCN_MOLD_RECEIPT" updatewhere=1 updatekeyinplace=no arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_mold_code", string),("arg_supplier_code", string),("arg_org", number)) )
