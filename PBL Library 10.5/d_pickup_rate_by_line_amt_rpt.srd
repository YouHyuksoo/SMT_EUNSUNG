compute(band=summary alignment="1" expression="sum(machine_code for all )"border="0" color="33554432" x="398" y="8" height="88" width="539" format="###,###,###,##0.00" html.valueishtml="0"  name=compute_2 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression="crosstabsum(1)"border="0" color="255" x="946" y="4" height="88" width="590" format="###,###,###,##0.00" html.valueishtml="0"  name=grand_sum_miss_amount visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=summary alignment="1" expression="sum(grand_sum_miss_amount for all )"border="0" color="255" x="946" y="8" height="88" width="590" format="###,###,###,##0.00" html.valueishtml="0"  name=compute_3 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
 crosstab(band = foreground  crosstabonly = yes 
 columns = "actual_date" rows = "line_code" values = "sum(miss_amount for crosstab)" sourcenames = "line_code, actual_date, miss_amount")htmltable(border="0" cellpadding="1" cellspacing="1" )
