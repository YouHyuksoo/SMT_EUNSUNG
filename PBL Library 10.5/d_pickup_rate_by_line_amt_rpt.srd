text(band=header[2] alignment="2" text="Grand Total " border="0" color="33554432" x="946" y="4" height="120" width="590" html.valueishtml="0"  name=grand_sum_miss_amount_t visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="134217732" )
