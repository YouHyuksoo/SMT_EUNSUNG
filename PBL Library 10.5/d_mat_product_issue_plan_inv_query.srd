table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=number updatewhereclause=yes name=apply_qty dbname="apply_qty" )
 column=(type=number updatewhereclause=yes name=result_qty dbname="result_qty" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 retrieve="SELECT 
              A.DIV , 
			A.LOCATION_CODE,
              A.APPLY_FLAG, 
			A.ITEM_CODE,
			B.ITEM_NAME,
             C.PLAN_QTY, 
			A.INVENTORY_QTY, 
              SUM(DECODE(APPLY_FLAG,'Y',INVENTORY_QTY,0)) OVER ( PARTITION BY 
                                                                              A.ITEM_CODE,
                                                                              B.ITEM_NAME
              
              ) as APPLY_QTY, 
              SUM(DECODE(APPLY_FLAG,'Y',INVENTORY_QTY,0)) OVER ( PARTITION BY 
                                                                              A.ITEM_CODE,
                                                                              B.ITEM_NAME
              
              ) - c.plan_qty AS RESULT_QTY   
  FROM (

			 SELECT  'WAREHOUSE' DIV ,	
						f_get_basecode ('MATERIAL LOCATION CODE',location_code,'K',1) LOCATION_CODE,
            DECODE(LOCATION_CODE,'M01','Y','N') AS APPLY_FLAG, 
						ITEM_CODE,
						f_get_invenotry_time_qty( ORGANIZATION_ID,ITEM_CODE, LINE_TYPE, TO_DATE(:arg_date,'YYYYMMDDhh24miss')) AS INVENTORY_QTY
				FROM IM_ITEM_INVENTORY
	
		    UNION ALL
	
			SELECT  'WORKSTAGE' DIV ,
						A.LINE_CODE || '-' || 'LINE' LOCATION_CODE,
            'Y' AS APPLY_FLAG ,
						A.ITEM_CODE,
						f_get_mat_ws_inv_time_qty( A.ITEM_CODE, A.ORGANIZATION_ID,TO_DATE(:arg_date,'YYYYMMDDhh24miss')) AS INVENTORY_QTY
			    FROM IM_ITEM_WORKSTAGE_INVENTORY A,
               IP_PRODUCT_LINE             B  
         WHERE B.LINE_DIVISION IN  ( 'L', 'D' ) 
           AND A.LINE_CODE = B.LINE_CODE     
                  
         ) A,
		
		ID_ITEM B, 
    (
    
    SELECT child_item_code as iTEM_CODE, sum(issue_plan_qty) as PLAN_QTY 
        FROM (   
        select 
               x.MODEL_NAME, 
               x.ITEM_CODE, 
               x.ITEM_TYPE, 
               x.order_qty, 
               x.mfs      , 
               y.parent_item_code, 
               y.child_item_code,

               y.model_unit_qty, 
               
               order_qty * y.model_unit_qty as issue_plan_qty 
          from IP_PRODUCT_ISSUE_PLAN x, 
               id_mfs_bom            y
         where x.plan_date = TO_DATE(substr(:arg_date,1,8),'YYYYMMDD')
           and x.organization_id = :arg_org
           
           and x.item_code = y.item_code 
           and x.mfs       = y.mfs  
           and x.item_type = y.pcb_item
       ) 
        group by child_item_code    
    ) C 
    WHERE A.ITEM_CODE = B.ITEM_CODE
    AND A.iTEM_CODE = C.ITEM_CODE (+)
     
	 " arguments=(("arg_item", string),("arg_date", string),("arg_org", number),("arg_flag", string))  sort="item_code A item_name A plan_qty A apply_qty A result_qty A " )
group(level=1 header.height=0 trailer.height=0 by=("item_code" ) header.color="536870912" trailer.color="536870912" )
