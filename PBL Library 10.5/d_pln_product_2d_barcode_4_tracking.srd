 retrieve="  SELECT  ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"ORGANIZATION_ID~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"ENTER_DATE~" ,      
     ~"IP_PRODUCT_2D_BARCODE~".~"ENTER_BY~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"LAST_MODIFY_DATE~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"LAST_MODIFY_BY~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~" ,      
     ~"IP_PRODUCT_2D_BARCODE~".~"ITEM_CODE~" ,                ~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"BOX_NO~" ,      
     ~"IP_PRODUCT_2D_BARCODE~".~"PALLETE_NO~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"CARRIER_BARCODE~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_YN~" ,   
        ~"IP_PRODUCT_2D_BARCODE~".~"LOT_NO~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"QC_SCAN_DATE~" ,           ~"ID_ITEM~".~"ITEM_NAME~" ,           ~"ID_ITEM~".~"ITEM_SPEC~" ,           ~"ID_ITEM~".~"ITEM_CLASS~" ,     
      ~"ID_ITEM~".~"CUSTOMER_CODE~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"MODEL_NAME~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"LOT_QTY~" ,           ~"IP_PRODUCT_2D_BARCODE~".~"BARCODE_STATUS~" ,       
    ~"IQ_INTERLOCK_CHECK_RESULT~".~"LINE_CODE~" ,           ~"IQ_INTERLOCK_CHECK_RESULT~".~"WORKSTAGE_CODE~" ,           ~"IQ_INTERLOCK_CHECK_RESULT~".~"MACHINE_CODE~" ,           ~"IQ_INTERLOCK_CHECK_RESULT~".~"MAGAZINE_NO~" ,    
       ~"IQ_INTERLOCK_CHECK_RESULT~".~"PCB_ITEM~"     FROM ~"IP_PRODUCT_2D_BARCODE~" ,           ~"ID_ITEM~" ,           ~"IQ_INTERLOCK_CHECK_RESULT~"    
 WHERE ( ~"IP_PRODUCT_2D_BARCODE~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" (+)) and          ( ~"IP_PRODUCT_2D_BARCODE~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" (+)) and          ( ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" = ~"IQ_INTERLOCK_CHECK_RESULT~".~"SERIAL_NO~" (+)) and          ( ~"IP_PRODUCT_2D_BARCODE~".~"RUN_NO~" like :ag_run_no ) and          ( ~"IP_PRODUCT_2D_BARCODE~".~"SERIAL_NO~" like :arg_serial_no ) and          ( ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~" >= :arg_dateset ) and          ( ~"IP_PRODUCT_2D_BARCODE~".~"RUN_DATE~" < :arg_dateend+1 ) and          ( nvl(~"IP_PRODUCT_2D_BARCODE~".~"MAGAZINE_NO~" , '*') like :arg_magazine ) and          ( ~"IP_PRODUCT_2D_BARCODE~".~"ORGANIZATION_ID~" = :arg_org ) and          ( ~"ID_ITEM~".~"MODEL_NAME~" like :arg_model_name ) and          ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"WORKSTAGE_CODE~" = 'W050' )   " arguments=(("arg_model_name", string),("ag_run_no", string),("arg_serial_no", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_magazine", string),("arg_org", number))  sort="model_name A magazine_no A serial_no A " )
