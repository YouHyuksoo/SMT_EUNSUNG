table(column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="im_item_purchase_order.organization_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=supplier_code dbname="im_item_purchase_order.supplier_code" )
 column=(type=char(20) updatewhereclause=yes name=order_group_no dbname="im_item_purchase_order.order_group_no" )
 column=(type=char(100) updatewhereclause=yes name=supplier_name dbname="icom_supplier.supplier_name" )
 column=(type=char(20) updatewhereclause=yes name=fax_no dbname="icom_supplier.fax_no" )
 column=(type=char(50) updatewhereclause=yes name=email_address dbname="icom_supplier.email_address" )
 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 retrieve="  SELECT 
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_GROUP_NO~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"ICOM_SUPPLIER~".~"FAX_NO~",   
         ~"ICOM_SUPPLIER~".~"EMAIL_ADDRESS~",   
         'N' CHECK_YN  
    FROM ~"IM_ITEM_PURCHASE_ORDER~",   
         ~"ID_ITEM~",   
         ~"ICOM_SUPPLIER~"  
   WHERE ( ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~" = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" ) and  
         ( ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" = ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~" >= :arg_dateset AND  
         ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~" <= :arg_dateend AND  
         (~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
GROUP BY   ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_GROUP_NO~",~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",
 ~"ICOM_SUPPLIER~".~"FAX_NO~",    ~"ICOM_SUPPLIER~".~"EMAIL_ADDRESS~",          ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~",    ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~"" arguments=(("arg_supplier_code", string),("arg_item_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org_id", number))  sort="organization_id A supplier_code A order_group_no A " )
group(level=1 header.height=0 trailer.height=44 by=("organization_id" , "supplier_code" ) header.color="536870912" trailer.color="65535" )
