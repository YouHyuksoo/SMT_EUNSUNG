			0 MM_WORKSTAGE_INVENTORY_CHECK,
			0 MM_PRODUCT_RESULT,
			1 MODEL_UNIT_QTY
    FROM IM_ITEM_TOTAL_INVENTORY A   
  WHERE A.CLOSE_YYYYMM = :ARG_YYYYMM
       AND A.ITEM_CODE LIKE :ARG_ITEM_CODE
       AND A.ORGANIZATION_ID = :ARG_ORG
       AND A.TOTAL_INVENTORY_DIVISION = 'EXCEL MATERIAL RECEIPT'


UNION ALL

  SELECT A.CLOSE_YYYYMM,   
