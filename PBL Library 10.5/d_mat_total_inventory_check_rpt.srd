			0 MM_WORKSTAGE_INVENTORY_CHECK,
			0 MM_PRODUCT_RESULT,
			1 MODEL_UNIT_QTY
    FROM IM_ITEM_TOTAL_INVENTORY A   
  WHERE A.CLOSE_YYYYMM = :ARG_YYYYMM
       AND A.ITEM_CODE LIKE :ARG_ITEM_CODE
       AND A.ORGANIZATION_ID = :ARG_ORG
       AND A.TOTAL_INVENTORY_DIVISION = 'MM MATERIAL BAD ISSUE'

UNION ALL

  SELECT A.CLOSE_YYYYMM,   
			A.ITEM_CODE,   
			A.LINE_TYPE,   
			A.ORGANIZATION_ID,   
			0 LAST_MATERIAL_INVENTORY_QTY,   
			0 MM_MATERIAL_INVENTORY_QTY ,
			0 MM_MATERIAL_RECEIPT ,
			0 EXCEL_MATERIAL_RECEIPT ,
			0 MM_MATERIAL_BAD_ISSUE ,
			A.INVENTORY_QTY MM_MATERIAL_EXTRA_ISSUE ,
			0 MM_MATERIAL_INVENTORY_CHECK ,
			0 LAST_WORKSTAGE_INVENTORY,
