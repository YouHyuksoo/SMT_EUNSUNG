 column=(type=number updatewhereclause=yes name=mm_workstage_inventory dbname="mm_workstage_inventory" )
 column=(type=number updatewhereclause=yes name=mm_workstage_issue dbname="mm_workstage_issue" )
 column=(type=number updatewhereclause=yes name=mm_workstage_inventory_check dbname="mm_workstage_inventory_check" )
 column=(type=number updatewhereclause=yes name=mm_product_result dbname="mm_product_result" )
