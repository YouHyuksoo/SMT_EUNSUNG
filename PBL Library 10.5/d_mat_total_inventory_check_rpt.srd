table(column=(type=char(6) update=yes updatewhereclause=yes name=close_yyyymm dbname="id_item.close_yyyymm" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=item_code dbname="id_item.item_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=line_type dbname="id_item.line_type" )
 column=(type=number update=yes updatewhereclause=yes key=yes name=organization_id dbname="id_item.organization_id" )
 column=(type=number updatewhereclause=yes name=last_material_inventory_qty dbname="last_material_inventory_qty" )
 column=(type=number updatewhereclause=yes name=mm_material_inventory_qty dbname="mm_material_inventory_qty" )
 column=(type=number updatewhereclause=yes name=mm_material_receipt dbname="mm_material_receipt" )
