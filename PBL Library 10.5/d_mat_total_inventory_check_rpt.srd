 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 column=(type=char(1) updatewhereclause=yes name=item_division dbname="id_item.item_division" )
 retrieve="SELECT  A.CLOSE_YYYYMM,   
			A.ITEM_CODE,   
			A.LINE_TYPE,   
			A.ORGANIZATION_ID,   
			SUM(A.LAST_MATERIAL_INVENTORY_QTY) LAST_MATERIAL_INVENTORY_QTY,   
			SUM(A.MM_MATERIAL_INVENTORY_QTY) MM_MATERIAL_INVENTORY_QTY ,
			SUM(A.MM_MATERIAL_RECEIPT) MM_MATERIAL_RECEIPT ,
			SUM(A.EXCEL_MATERIAL_RECEIPT) EXCEL_MATERIAL_RECEIPT ,
			SUM(A.MM_MATERIAL_BAD_ISSUE) MM_MATERIAL_BAD_ISSUE ,
			SUM(A.MM_MATERIAL_EXTRA_ISSUE) MM_MATERIAL_EXTRA_ISSUE ,
			SUM(A.MM_MATERIAL_INVENTORY_CHECK) MM_MATERIAL_INVENTORY_CHECK ,
			SUM(A.LAST_WORKSTAGE_INVENTORY) LAST_WORKSTAGE_INVENTORY,
			SUM(A.MM_WORKSTAGE_INVENTORY) MM_WORKSTAGE_INVENTORY,
			SUM(A.MM_WORKSTAGE_ISSUE) MM_WORKSTAGE_ISSUE,
			SUM(A.MM_WORKSTAGE_INVENTORY_CHECK) MM_WORKSTAGE_INVENTORY_CHECK,
			SUM(A.MM_PRODUCT_RESULT) MM_PRODUCT_RESULT ,
			MAX(A.MODEL_UNIT_QTY) 	MODEL_UNIT_QTY,
			B.ITEM_NAME , B.ITEM_SPEC , B.ITEM_UOM , B.ITEM_DIVISION
FROM 
(
  SELECT A.CLOSE_YYYYMM,   
			A.ITEM_CODE,   
			A.LINE_TYPE,   
			A.ORGANIZATION_ID,   
			A.INVENTORY_QTY LAST_MATERIAL_INVENTORY_QTY,   
			0 MM_MATERIAL_INVENTORY_QTY ,
			0 MM_MATERIAL_RECEIPT ,
			0 EXCEL_MATERIAL_RECEIPT ,
			0 MM_MATERIAL_BAD_ISSUE ,
			0 MM_MATERIAL_EXTRA_ISSUE ,
			0 MM_MATERIAL_INVENTORY_CHECK ,
			0 LAST_WORKSTAGE_INVENTORY,
			0 MM_WORKSTAGE_INVENTORY,
			0 MM_WORKSTAGE_ISSUE,
			0 MM_WORKSTAGE_INVENTORY_CHECK,
			0 MM_PRODUCT_RESULT,
			1 MODEL_UNIT_QTY
    FROM IM_ITEM_TOTAL_INVENTORY A   
  WHERE A.CLOSE_YYYYMM = :ARG_YYYYMM
       AND A.ITEM_CODE LIKE :ARG_ITEM_CODE
       AND A.ORGANIZATION_ID = :ARG_ORG
       AND A.TOTAL_INVENTORY_DIVISION = 'LAST MATERIAL INVENTORY'

UNION ALL

  SELECT A.CLOSE_YYYYMM,   
			A.ITEM_CODE,   
			A.LINE_TYPE,   
			A.ORGANIZATION_ID,   
			0 LAST_MATERIAL_INVENTORY_QTY,   
			A.INVENTORY_QTY MM_MATERIAL_INVENTORY_QTY ,
			0 MM_MATERIAL_RECEIPT ,
			0 EXCEL_MATERIAL_RECEIPT ,
			0 MM_MATERIAL_BAD_ISSUE ,
			0 MM_MATERIAL_EXTRA_ISSUE ,
			0 MM_MATERIAL_INVENTORY_CHECK ,
			0 LAST_WORKSTAGE_INVENTORY,
			0 MM_WORKSTAGE_INVENTORY,
			0 MM_WORKSTAGE_ISSUE,
			0 MM_WORKSTAGE_INVENTORY_CHECK,
			0 MM_PRODUCT_RESULT,
			1 MODEL_UNIT_QTY
    FROM IM_ITEM_TOTAL_INVENTORY A   
  WHERE A.CLOSE_YYYYMM = :ARG_YYYYMM
       AND A.ITEM_CODE LIKE :ARG_ITEM_CODE
       AND A.ORGANIZATION_ID = :ARG_ORG
       AND A.TOTAL_INVENTORY_DIVISION = 'MM MATERIAL INVENTORY'

UNION ALL

  SELECT A.CLOSE_YYYYMM,   
			A.ITEM_CODE,   
			A.LINE_TYPE,   
			A.ORGANIZATION_ID,   
			0 LAST_MATERIAL_INVENTORY_QTY,   
			0 MM_MATERIAL_INVENTORY_QTY ,
			A.INVENTORY_QTY MM_MATERIAL_RECEIPT ,
			0 EXCEL_MATERIAL_RECEIPT ,
			0 MM_MATERIAL_BAD_ISSUE ,
			0 MM_MATERIAL_EXTRA_ISSUE ,
			0 MM_MATERIAL_INVENTORY_CHECK ,
			0 LAST_WORKSTAGE_INVENTORY,
			0 MM_WORKSTAGE_INVENTORY,
			0 MM_WORKSTAGE_ISSUE,
			0 MM_WORKSTAGE_INVENTORY_CHECK,
			0 MM_PRODUCT_RESULT,
			1 MODEL_UNIT_QTY
    FROM IM_ITEM_TOTAL_INVENTORY A   
  WHERE A.CLOSE_YYYYMM = :ARG_YYYYMM
       AND A.ITEM_CODE LIKE :ARG_ITEM_CODE
       AND A.ORGANIZATION_ID = :ARG_ORG
       AND A.TOTAL_INVENTORY_DIVISION = 'MM MATERIAL RECEIPT'

