       AND A.ITEM_CODE LIKE :ARG_ITEM_CODE
       AND A.ORGANIZATION_ID = :ARG_ORG
       AND A.TOTAL_INVENTORY_DIVISION = 'MM PRODUCT RESULT'  
)  A , ID_ITEM B

WHERE A.ITEM_CODE = B.ITEM_CODE(+)
AND A.ORGANIZATION_ID = B.ORGANIZATION_ID(+)
GROUP BY A.CLOSE_YYYYMM , A.ITEM_CODE , A.LINE_TYPE , A.ORGANIZATION_ID  , B.ITEM_NAME , B.ITEM_SPEC , B.ITEM_UOM , B.ITEM_DIVISION , B.ORGANIZATION_ID" update="ID_ITEM" updatewhere=0 updatekeyinplace=no arguments=(("ARG_YYYYMM", string),("ARG_ITEM_CODE", string),("ARG_ORG", number))  sort="close_yyyymm A item_division A item_code A item_code A " )
