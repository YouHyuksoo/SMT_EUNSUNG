table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="ip_product_workstage_io.line_code" )
 column=(type=char(20) updatewhereclause=yes name=workstage_code dbname="ip_product_workstage_io.workstage_code" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="ip_product_workstage_io.model_name" )
 column=(type=char(10) updatewhereclause=yes name=model_suffix dbname="ip_product_workstage_io.model_suffix" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_workstage_io.item_code" )
 column=(type=number updatewhereclause=yes name=scan_actual dbname="scan_actual" )
 column=(type=char(1) updatewhereclause=yes name=shift_code dbname="ip_product_workstage_io.shift_code" )
 column=(type=datetime updatewhereclause=yes name=actual_date dbname="ip_product_workstage_io.actual_date" )
 retrieve="select line_code, workstage_code, model_name, model_suffix, item_code, sum(io_Qty) as scan_actual, 
        shift_code , 

       actual_date
  from ip_product_workstage_io x 
 where x.organization_id = :arg_org
   and x.line_code           like :arg_line_code
   and x.workstage_code  like :arg_workstage_code
   and x.actual_date          =:arg_date 
  group by actual_date, shift_code, line_code, workstage_code, item_code, model_name, model_suffix" arguments=(("arg_line_code", string),("arg_workstage_code", string),("arg_date", datetime),("arg_org", number))  sort="actual_date D shift_code A model_name A model_suffix A item_code A " )
group(level=1 header.height=0 trailer.height=92 by=("actual_date" ) header.color="536870912" trailer.color="536870912" )
