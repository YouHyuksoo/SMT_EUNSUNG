// $$HEX6$$e0c2dcad2000200085c725b8$$ENDHEX$$
//==============================
lvl_issue_seq = f_get_sequence('seq_mat_issue')

INSERT INTO im_item_issue
            ( issue_date,
		issue_sequence,
		organization_id,
		material_mfs,				  
		mfs,
		item_code,		  
		location_code,
		supplier_code,		  
		item_type,
		line_code,
		workstage_code,machine_code,
		issue_deficit,
		issue_qty,
		issue_status,
		issue_amt,
		issue_account,
		line_type,
		issue_price,
		issue_type,	  
		virtual_receipt_yn ,
		work_order_no ,	 
		sale_price , sale_amt ,
		comments,
		enter_date,
		enter_by,
		last_modify_date,
		last_modify_by,
		invoice_no,parent_item_code , interface_yn , interface_date , arrival_date , arrival_seq_no , dest_organization_id ,
		barcode
            )
   SELECT 
	     issue_date, 
		:lvl_issue_seq,
		:gvi_organization_id,
		material_mfs,	 
		mfs,
		item_code,
		:as_change_location,
		supplier_code ,
		item_type,
		line_code,
		workstage_code,machine_code,
		ISSUE_DEFICIT ,
		issue_qty,
		'N',
		abs(issue_amt) ,
		issue_account,
		line_type,
		issue_price,
		issue_type,	 
		virtual_receipt_yn ,		
		work_order_no ,	
		sale_price, sale_amt,		  
		comments,
		SYSDATE,
		:gvs_user_id,
		SYSDATE,
		:gvs_user_id,
		invoice_no ,parent_item_code ,interface_yn , interface_date , arrival_date , arrival_seq_no , dest_organization_id ,
		barcode
      FROM im_item_issue
    WHERE issue_date       = :adt_issue_date
        AND issue_sequence = :al_seq
        AND organization_id = :gvi_organization_id;
		
	if f_sql_check() < 0 then 
		return -2
	end if 

return sqlca.sqlnrows
end function

