w_progress_popup.f_stepit()
w_progress_popup.f_set_message('Step 6 : Inventory Amount Set')


//=====================================================
// $$HEX21$$acc7e0ac2000c8b910ac15c8f4bcd0c52000c9d3e0ad2000e8b200ac00ac2000c6c544c7bdacb0c62000$$ENDHEX$$
// $$HEX25$$f5ac15c8200018c288bdd0c51cc12000c9d3e0ad2000e8b200ac7cb92000b0c09ccd58d5ecc5200000ac38c828c6e4b22000$$ENDHEX$$
// $$HEX23$$f9b2d4c674c72000c6c53cc774ba200004c8d4c62000c9d3e0ad2000e8b200ac7cb9200000ac38c828c6e4b22000$$ENDHEX$$
//=====================================================
update im_item_workstage_inv_close a
      set a.mm_avg_price = abs(decode( decode( last_inventory_qty + mm_receipt_qty , 0 , 0 , ( last_inventory_amt + mm_receipt_amt ) / ( last_inventory_qty + mm_receipt_qty) ) , 0 , last_avg_price , decode( last_inventory_qty + mm_receipt_qty , 0 , 0 , ( last_inventory_amt + mm_receipt_amt ) / ( last_inventory_qty + mm_receipt_qty) )  ))
where a.close_yyyymm = :as_yyyymm
    and a.organization_id = :gvi_organization_id 
    and nvl(mm_avg_price,0) = 0  ;

if f_sql_check_with_msg(string(phase)) < 0 then 
	return -25
end if

w_progress_popup.f_stepit()
w_progress_popup.f_set_message('Step 6-1 : Inventory Amount Set')

//=============================================================
// $$HEX10$$f9b2d4c6f5ac15c8200008ae61c5200024c115c8$$ENDHEX$$
//=============================================================
phase = 50
update im_item_workstage_inv_close 
	 set mm_issue_amt              = mm_issue_qty * mm_avg_price , 
		  mm_mass_issue_amt    = mm_mass_issue_qty * mm_avg_price, 
		  mm_bad_issue_amt      = mm_bad_issue_qty * mm_avg_price, 		  
		  mm_extra_issue_amt   = mm_extra_issue_qty * mm_avg_price,
		  mm_receipt_amt           = mm_receipt_qty * mm_avg_price,
		  mm_inventory_amt       = mm_inventory_qty * mm_avg_price 
where close_yyyymm = :as_yyyymm
    and organization_id = :gvi_organization_id ; 
	 
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -50
end if 

//===============================================================
//
//===============================================================

if Gvs_workstage_inventory_regenerate = 'Y' then
w_progress_popup.f_stepit()
w_progress_popup.f_set_message('Step 7 : Current Inventory Delete')

		//==============================================================
		// $$HEX14$$acc7e0ac7cb92000deb99ccd4cb5200084c7dcc25cb82000acc0a9c6$$ENDHEX$$
		//==============================================================
		DELETE FROM im_item_workstage_inventory WHERE ORGANIZATION_ID = :GVI_ORGANIZATION_ID ;
		if f_sql_check() < 0 then 
			return -55
		end if
				
		INSERT INTO im_item_workstage_inventory
					(line_code,
					 workstage_code,
					 material_mfs,
					 mfs,
					 item_code,
					 organization_id,
					 machine_code,
					 inventory_hold,
					 inventory_status,
					 line_type,
					 inventory_price,
					 inventory_qty,
					 inventory_amt,
					 enter_date,
					 enter_by,
					 last_modify_date,
					 last_modify_by
					)
  	       SELECT 
				      line_code,
					 workstage_code,
					'*'  material_mfs,
					'*'  mfs,
					item_code,
					organization_id,
					'*', //MACHINE_CODE,
					'W', //INVENTORY_HOLD,
					'G', //INVENTORY_STATUS,
					line_type,
				    max(mm_avg_price),
					SUM(mm_inventory_qty),
					max(mm_avg_price) * SUM(mm_inventory_qty),
					SYSDATE,
					:gvs_user_id,
					SYSDATE,
					:gvs_user_id
		     FROM im_item_workstage_inv_close
		   WHERE close_yyyymm = :as_yyyymm              AND
				      organization_id = :gvi_organization_id
	   GROUP BY
		               line_code,
					 workstage_code,
					 item_code,
					 line_type ,
//					 mfs,
//					 material_mfs,
					 organization_id;
				
				if f_sql_check() < 0 then 
					return -56
				end if
else
				
			//============================================
			// $$HEX21$$f5ac15c8acc7e0ac200018c2c9b7200008ae61c52000e8b200ac7cb92000acc724c115c820005cd5e4b2$$ENDHEX$$.
			//============================================
			
			update im_item_workstage_inventory a
				 set 
				     //a.inventory_qty    = f_get_mm_workstage_inv_qty (a.line_code,a.workstage_code, a.mfs , a.material_mfs , a.item_code, a.line_type , :as_yyyymm, :gvi_organization_id) , 
					  a.inventory_price = f_get_mm_ws_avg_price( :as_yyyymm , a.item_code , a.line_type , a.organization_id ) 
			 where a.organization_id = :gvi_organization_id ;
			  
			if f_sql_check_with_msg(string(phase)) < 0 then 
				return -90
			end if 				
			
			update im_item_workstage_inventory a
				 set  a.inventory_amt  = a.inventory_qty * a.inventory_price
			 where a.organization_id = :gvi_organization_id ;

			  
			if f_sql_check_with_msg(string(phase)) < 0 then 
				return -90
			end if 							
end if 
//============================================
// $$HEX21$$f5ac15c89ccde0ac200018c2c9b7200008ae61c52000e8b200ac7cb92000acc724c115c820005cd5e4b2$$ENDHEX$$.
//============================================
phase = 60
update im_item_workstage_issue a
      set a.issue_price  = f_get_mm_ws_avg_price( :as_yyyymm , a.item_code , a.line_type , a.organization_id ) 
 where a.issue_date  >= :LVDT_START_date 
     and a.issue_date <= :LVDT_end_date
   and a.organization_id = :gvi_organization_id ;


if f_sql_check_with_msg(string(phase)) < 0 then 
	return -60
end if 

update im_item_workstage_issue a
      set  a.issue_amt   = a.issue_qty * a.issue_price
 where  a.issue_date  >= :LVDT_START_date 
     and a.issue_date <= :LVDT_end_date											  
   and a.organization_id = :gvi_organization_id ;


if f_sql_check_with_msg(string(phase)) < 0 then 
	return -60
end if 

