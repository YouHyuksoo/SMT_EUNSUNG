HA$PBExportHeader$f_mat_workstage_inventory_close_new.srf
global type f_mat_workstage_inventory_close_new from function_object
end type

forward prototypes
global function integer f_mat_workstage_inventory_close_new (string as_yyyymm)
end prototypes

global function integer f_mat_workstage_inventory_close_new (string as_yyyymm);string as_last_yyyymm
long phase , lvl_count
datetime lvdt_start_date , lvdt_end_date
//======================================================
//
//======================================================
SELECT F_GET_INVENTORY_CLOSE_DATE( :as_yyyymm , 'START' , :gvi_organization_id ) ,
		   F_GET_INVENTORY_CLOSE_DATE( :as_yyyymm , 'END' , :gvi_organization_id  )
    INTO :LVDT_START_date , :Lvdt_end_date
   FROM DUAL  ;
  
 if f_sql_check_with_msg(string(phase)) < 0 then 
	return -10
 end if  

msg = f_msgbox1(1161 , string(LVDT_START_date)+'  '+string(Lvdt_end_date)+' Inventory Close ')
if msg = 1 then 
else
	return  0
end if
phase = 1 

open(w_progress_popup)
w_progress_popup.f_set_range( 1, 11)
w_progress_popup.f_setstep(1)

//=========================================
// $$HEX18$$f9b2d4c620003dcce0ac2000acc7e0ac2000c8b910ac2000ecc580bd2000b4cc6cd02000$$ENDHEX$$
//=========================================
 select count(*) into :lvl_count 
   from im_item_inventory_close  b
where b.close_yyyymm = :as_yyyymm
    and b.organization_id = :gvi_organization_id ;

 if f_sql_check_with_msg(string(phase)) < 0 then 
	close(w_progress_popup)
	return -1
  end if

IF LVL_COUNT < 1 THEN 
	msg = MESSAGEBoX("Notify" , "Material Inventory Not Closed Please Close Material Inventory First"  , question! , yesno!)
	if msg = 1 then 
	else
		close(w_progress_popup)
		return -1
	end if
END IF

//=========================================
// $$HEX21$$f9b2d4c6200018bc1cc888d43dcce0ac2000acc7e0ac2000c8b910ac2000ecc580bd2000b4cc6cd02000$$ENDHEX$$
//=========================================
 select count(*) into :lvl_count 
  from is_assembly_inventory_close  b
where b.close_yyyymm = :as_yyyymm
    and b.organization_id = :gvi_organization_id ;

 if f_sql_check_with_msg(string(phase)) < 0 then 
	close(w_progress_popup)
	return -1
  end if

IF LVL_COUNT < 1 THEN 
	msg = MESSAGEBoX("Notify" , "Assembly Inventory Not Closed. Please Close Assembly Inventory First"  , question! , yesno!)
	if msg = 1 then 
	else
		close(w_progress_popup)
		return -1
	end if	
END IF

//=========================================
// $$HEX20$$f9b2d4c620001cc888d43dcce0ac2000acc7e0ac2000c8b910ac2000ecc580bd2000b4cc6cd02000$$ENDHEX$$
//=========================================
 select count(*) into :lvl_count 
  from is_product_inventory_close  b
where b.close_yyyymm = :as_yyyymm
    and b.organization_id = :gvi_organization_id ;

 if f_sql_check_with_msg(string(phase)) < 0 then 
	close(w_progress_popup)
	return -1
  end if

IF LVL_COUNT < 1 THEN 
	msg = MESSAGEBoX("Notify" , "Product Inventory Not Closed Please Close Product Inventory First" , question! , yesno!)
	if msg = 1 then 
	else
		close(w_progress_popup)		
		return -1
	end if	
END IF
//=============================================================
//
//=============================================================
w_progress_popup.f_stepit()
w_progress_popup.f_set_message('Step 1 : Inventory Count')

select to_char(add_months(to_date(:as_yyyymm || '01', 'yyyymmdd') , -1) ,'yyyymm')
   into :as_last_yyyymm
  from dual  ; 
 if f_sql_check_with_msg(string(phase)) < 0 then 
	return -1
  end if
phase = 2 

w_progress_popup.f_stepit()
w_progress_popup.f_set_message('Step 2 : Inventory Delete')

delete from im_item_workstage_inv_close 
where close_yyyymm = :as_yyyymm
    and organization_id = :gvi_organization_id ; 
 if f_sql_check_with_msg(string(phase)) < 0 then 
	return -2
  end if
//=============================================================
// $$HEX16$$04c8d4c6d0b92000f5ac15c82000c8b910ac200090c7ccb8200085c725b82000$$ENDHEX$$
//=============================================================

w_progress_popup.f_stepit()
w_progress_popup.f_set_message('Step 3 : Inventory Create')
phase = 20

w_progress_popup.f_stepit()
w_progress_popup.f_set_message('Step 2 : Inventory Create Others')

insert into  im_item_workstage_inv_close
            ( close_yyyymm,                          mfs , material_mfs , 
			item_code,                                     line_code, workstage_code ,
			line_type,                                       organization_id,
			last_avg_price,                              last_inventory_qty,                          last_inventory_amt,
			mm_receipt_qty,                            mm_receipt_amt,            
			mm_issue_qty,                               mm_issue_amt,
			
			mm_mass_issue_qty,                     mm_mass_issue_amt,
			mm_bad_issue_qty,                       mm_bad_issue_amt,
			mm_extra_issue_qty,                    mm_extra_issue_amt,             
			
			mm_avg_price,                              mm_inventory_qty,                        
			mm_inventory_amt,
			enter_date,                                   enter_by,     
			last_modify_date,                          last_modify_by
            )
		     select  :as_yyyymm,   
					'*' , '*' , //a.mfs , a.material_mfs ,
					a.item_code,
					a.line_code, a.workstage_code ,
					a.line_type,                                    
					:gvi_organization_id,  

					max(last_avg_price) ,                                                 
					sum(last_inventory_qty),   					
					sum(last_inventory_amt),

					nvl(sum(receipt_qty),0) ,                                                nvl(sum(receipt_amt),0),
					sum(issue_qty)   ,                                                 0,
					
					sum(mm_mass_issue_qty),                                                 0,
					0,                                                 0,
					sum(mm_extra_issue_qty),                                                 0,           
					
					0,                                                 (sum(last_inventory_qty) + sum(receipt_qty) - sum(issue_qty) )mm_inventory_qty ,                                                 
					0,         
					SYSDATE,                                     :gvs_user_id,
					SYSDATE,                                     :gvs_user_id
					from (      
					
			          select '*' mfs , 
						     '*' material_mfs ,
							item_code,
							line_code , 
							workstage_code,
							line_type, 
							max(mm_avg_price) last_avg_price ,
							sum(mm_inventory_qty) last_inventory_qty, 
							sum(mm_inventory_amt) last_inventory_amt,
							0  receipt_qty , 0  receipt_amt ,
							0 issue_qty ,
							0 mm_mass_issue_qty,
							0 mm_extra_issue_qty,
							organization_id
					from im_item_workstage_inv_close
					where close_yyyymm = :as_last_yyyymm
						and organization_id = :gvi_organization_id
						group by //mfs , material_mfs, 
						item_code, line_type,
						line_code ,workstage_code ,
						organization_id					
					
					union all
					
					select	'*'  mfs , 
					         '*' material_mfs ,
							item_code,
							 line_code , 
							 workstage_code,
							line_type, 
							0 last_avg_price ,
							0 last_inventory_qty ,
							0 last_inventory_amt,
							sum(receipt_qty) receipt_qty ,sum(receipt_amt) receipt_amt ,
							0 issue_qty ,
							0 mm_mass_issue_qty,
							0 mm_extra_issue_qty,
							organization_id
					from im_item_workstage_receipt
					where receipt_date >= :LVDT_START_date 
					  AND receipt_date <= :LVDT_end_date 
						and organization_id = :gvi_organization_id
						group by //mfs , material_mfs, 
						             item_code, line_type,
									line_code ,workstage_code ,
									organization_id
					union all
					select 
							'*'  mfs , 
							'*' material_mfs ,
							item_code,
							 line_code ,
							workstage_code,
							line_type,
							0 last_avg_price ,
							0 last_inventory_qty , 
							0 last_inventory_amt,
							0 receipt_qty , 0 receipt_amt , 
							sum(issue_qty) issue_qty ,
							sum(decode( issue_account , 'M001' , issue_qty, 0 )) mm_mass_issue_qty,
							sum(decode(issue_account , 'M001' , 0 , issue_qty )) mm_extra_issue_qty,
							organization_id
					from im_item_workstage_issue
					where issue_date  >= :LVDT_START_date 
					    and issue_date <= :LVDT_end_date
						and organization_id = :gvi_organization_id 
						group by //mfs , material_mfs, 
						             item_code, line_type,
									line_code ,workstage_code ,
									organization_id)     a 

					group by //mfs , material_mfs,
								item_code, line_type,
								line_code ,workstage_code ,
								organization_id ;
					
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -20
end if
phase = 25

//w_progress_popup.f_stepit()
//w_progress_popup.f_set_message('Step 3 : Item Average Price Set')
