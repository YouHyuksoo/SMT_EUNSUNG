 column=(type=char(37) updatewhereclause=yes name=rowid dbname="im_item_inventory.rowid" )
 retrieve="  SELECT ~"A~".~"MATERIAL_MFS~",   
         ~"A~".~"ORGANIZATION_ID~",   
         ~"A~".~"ITEM_CODE~",   
         ~"A~".~"LINE_TYPE~",   
         ~"A~".~"INVENTORY_QTY~",   
         ~"A~".~"INVENTORY_STATUS~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         0 REQUEST_QTY,   
         'N' CHECK_YN,   
         ~"A~".~"INVENTORY_HOLD~",   
         ~"A~".~"INVENTORY_PRICE~",   
         ~"A~".~"INVENTORY_AMT~",   
         ~"A~".~"LOCATION_CODE~",   
         ~"A~".~"LAST_MODIFY_DATE~",   
         ~"A~".~"LAST_MODIFY_BY~",   
         ~"A~".~"ENTER_DATE~",   
         ~"A~".~"ENTER_BY~"  ,
	  ~"A~".ROWID
    FROM ~"IM_ITEM_INVENTORY~" ~"A~",   
         ~"ID_ITEM~"  
   WHERE ( ~"A~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"A~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( A.MATERIAL_MFS like :arg_mfs ) AND  
         ( A.ITEM_CODE like :arg_item_code ) AND  
         (  SIGN(A.INVENTORY_QTY) >= :arg_sign )     AND
         ( A.ORGANIZATION_ID = :arg_org_id )    
" arguments=(("arg_mfs", string),("arg_item_code", string),("arg_sign", number),("arg_org_id", number))  sort="organization_id A item_division A item_code A material_mfs A " )
group(level=1 header.height=64 trailer.height=0 by=("organization_id" , "item_division" ) header.color="65535" trailer.color="536870912" )
