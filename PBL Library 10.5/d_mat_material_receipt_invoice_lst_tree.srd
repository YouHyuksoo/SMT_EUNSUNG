 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_receipt_invoice_master~" )  TABLE(NAME=~"icom_supplier~" ) COLUMN(NAME=~"im_item_receipt_invoice_master.supplier_code~") COLUMN(NAME=~"im_item_receipt_invoice_master.invoice_no~") COLUMN(NAME=~"im_item_receipt_invoice_master.organization_id~") COLUMN(NAME=~"im_item_receipt_invoice_master.receipt_amt~") COLUMN(NAME=~"im_item_receipt_invoice_master.tax_rate~") COLUMN(NAME=~"im_item_receipt_invoice_master.tax_amt~") COLUMN(NAME=~"im_item_receipt_invoice_master.payment_type~") COLUMN(NAME=~"im_item_receipt_invoice_master.bill_disburse_date~") COLUMN(NAME=~"im_item_receipt_invoice_master.bill_disburse_type~") COLUMN(NAME=~"im_item_receipt_invoice_master.invoice_status~") COLUMN(NAME=~"im_item_receipt_invoice_master.last_modify_date~") COLUMN(NAME=~"im_item_receipt_invoice_master.last_modify_by~") COLUMN(NAME=~"im_item_receipt_invoice_master.enter_date~") COLUMN(NAME=~"im_item_receipt_invoice_master.enter_by~") COLUMN(NAME=~"icom_supplier.supplier_name~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"im_item_receipt_invoice_master.invoice_deficit~") COLUMN(NAME=~"im_item_receipt_invoice_master.invoice_open_yn~") COLUMN(NAME=~"im_item_receipt_invoice_master.invoice_date~") COLUMN(NAME=~"im_item_receipt_invoice_master.invoice_open_sequence~") COLUMN(NAME=~"im_item_receipt_invoice_master.invoice_account~") COLUMN(NAME=~"im_item_receipt_invoice_master.bill_disburse_amt~")    JOIN (LEFT=~"im_item_receipt_invoice_master.supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier.supplier_code~" )    JOIN (LEFT=~"im_item_receipt_invoice_master.organization_id~"    OP =~"=~"RIGHT=~"icom_supplier.organization_id~" )WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_INVOICE_MASTER~~~".~~~"INVOICE_NO~~~"~"   OP =~"=~"    EXP2 =~":ARG_INVOICE_NO~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_RECEIPT_INVOICE_MASTER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG~" ) ) ARG(NAME = ~"ARG_INVOICE_NO~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " update="IM_ITEM_RECEIPT_INVOICE_MASTER" updatewhere=0 updatekeyinplace=no arguments=(("ARG_INVOICE_NO", string),("ARG_ORG", number))  sort="organization_id A invoice_open_yn A supplier_code A invoice_date A " )
