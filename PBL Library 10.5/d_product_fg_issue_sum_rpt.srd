release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=140 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=96 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=model_name dbname="ip_product_fg_issue.model_name" )
 column=(type=char(10) updatewhereclause=yes name=model_suffix dbname="ip_product_fg_issue.model_suffix" )
 column=(type=char(20) updatewhereclause=yes name=customer_code dbname="ip_product_fg_issue.customer_code" )
 column=(type=char(10) updatewhereclause=yes name=product_location_code dbname="ip_product_fg_issue.location_code" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 column=(type=number updatewhereclause=yes name=issue_price dbname="issue_price" )
 retrieve="select  model_name, 
          model_suffix, 
          customer_code,
          location_code,
         sum(decode(txn_deficit,3,1,-1)*qty)  qty,
          max(f_get_sal_last_price_cfm(customer_code,item_code, 'T',issue_date,organization_id)) issue_price
  from ip_product_fg_issue 
where issue_date >= :arg_sDate
   and issue_date < :arg_eDate + 1 
   and model_name like :arg_model 
   and barcode like :arg_barcode 
 group by model_name, 
              model_suffix, 
              customer_code,
              location_code" arguments=(("arg_sDate", datetime),("arg_eDate", datetime),("arg_Model", string),("arg_barcode", string))  sort="model_name A " )
group(level=1 header.height=0 trailer.height=88 by=("model_name" ) header.color="536870912" trailer.color="536870912" )
