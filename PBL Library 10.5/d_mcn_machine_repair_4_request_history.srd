 column=(type=char(10) updatewhereclause=yes name=machine_type dbname="imcn_machine.machine_type" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="imcn_machine.line_code" )
 column=(type=char(10) updatewhereclause=yes name=imcn_machine_workstage_code dbname="imcn_machine.workstage_code" )
 column=(type=char(100) updatewhereclause=yes name=imcn_machine_machine_name dbname="imcn_machine.machine_name" )
 column=(type=char(100) updatewhereclause=yes name=machine_model_name dbname="imcn_machine.machine_model_name" )
 column=(type=char(0) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 retrieve="  SELECT ~"IMCN_MACHINE_REPAIR~".~"MACHINE_CODE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_SEQUENCE~",   
         ~"IMCN_MACHINE_REPAIR~".~"ORGANIZATION_ID~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_REQUEST_DATE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_REASON_CODE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_VENDOR_CODE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_STATUS~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_BY~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_DATE~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_TIME~",   
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_AMT~",   
         ~"IMCN_MACHINE_REPAIR~".~"CURRENCY~",   
         ~"IMCN_MACHINE_REPAIR~".~"COMMENTS~",   
         ~"IMCN_MACHINE_REPAIR~".~"ENTER_BY~",   
         ~"IMCN_MACHINE_REPAIR~".~"ENTER_DATE~",   
         ~"IMCN_MACHINE_REPAIR~".~"LAST_MODIFY_BY~",   
         ~"IMCN_MACHINE_REPAIR~".~"LAST_MODIFY_DATE~",   
         ~"IMCN_MACHINE_REPAIR~".~"ATTRIBUTE01~",   
         ~"IMCN_MACHINE_REPAIR~".~"ATTRIBUTE02~",   

         ~"IMCN_MACHINE~".~"MACHINE_TYPE~",   
         ~"IMCN_MACHINE~".~"LINE_CODE~",   
         ~"IMCN_MACHINE~".~"WORKSTAGE_CODE~",   
         ~"IMCN_MACHINE~".~"MACHINE_NAME~",   
         ~"IMCN_MACHINE~".~"MACHINE_MODEL_NAME~",   
         '' CHECK_YN  
    FROM ~"IMCN_MACHINE_REPAIR~",   
         ~"IMCN_MACHINE~"  
   WHERE ( imcn_machine_repair.machine_code = imcn_machine.machine_code (+)) and  
         ( imcn_machine_repair.organization_id = imcn_machine.organization_id (+)) and  
         ( ~"IMCN_MACHINE_REPAIR~".~"MACHINE_CODE~" LIKE :arg_machine_code ) AND  
         ~"IMCN_MACHINE~".~"MACHINE_TYPE~" like :arg_machine_type AND  
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_REQUEST_DATE~" >= :arg_dateset AND  
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_REQUEST_DATE~" <= :arg_dateend AND  
         NVL(~"IMCN_MACHINE~".~"LINE_CODE~" , '*') like :arg_line_code AND  
         ~"IMCN_MACHINE_REPAIR~".~"REPAIR_STATUS~" like :arg_repair_status AND  
         ( ~"IMCN_MACHINE_REPAIR~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_machine_code", string),("arg_machine_type", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_repair_status", string),("arg_org", number))  sort="organization_id A line_code A machine_code A repair_sequence A " )
