 column=(type=number updatewhereclause=yes name=mold_version dbname="imcn_mold_inventory.mold_version" dbalias=".mold_version" )
 column=(type=number updatewhereclause=yes name=mold_set_serial dbname="imcn_mold_inventory.mold_set_serial" dbalias=".mold_set_serial" )
 column=(type=char(42) updatewhereclause=yes name=barcode dbname="barcode" )
 column=(type=char(100) updatewhereclause=yes name=mold_name dbname="imcn_mold.mold_name" dbalias=".mold_name" )
 column=(type=char(100) updatewhereclause=yes name=mold_spec dbname="imcn_mold.mold_spec" dbalias=".mold_spec" )
 retrieve="  SELECT ~"IMCN_MOLD_INVENTORY~".~"MOLD_CODE~",   
			~"IMCN_MOLD_INVENTORY~".~"MOLD_VERSION~",   
			~"IMCN_MOLD_INVENTORY~".~"MOLD_SET_SERIAL~",   
			'*'||~"IMCN_MOLD_INVENTORY~".~"MOLD_CODE~"||'*' BARCODE,   
			~"IMCN_MOLD~".~"MOLD_NAME~",   
			~"IMCN_MOLD~".~"MOLD_SPEC~"  
    FROM ~"IMCN_MOLD_INVENTORY~",   
         ~"IMCN_MOLD~"  
   WHERE ( ~"IMCN_MOLD_INVENTORY~".~"MOLD_CODE~" = ~"IMCN_MOLD~".~"MOLD_CODE~" ) and  
			( ~"IMCN_MOLD_INVENTORY~".~"ORGANIZATION_ID~" = ~"IMCN_MOLD~".~"ORGANIZATION_ID~" ) and  
			( ~"IMCN_MOLD_INVENTORY~".~"MOLD_CODE~" like :arg_mold_code ) AND
			( ~"IMCN_MOLD_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org )     
" arguments=(("arg_mold_code", string),("arg_org", number))  sort="mold_code A " )
