HA$PBExportHeader$d_mat_purchase_order_analysis_rpt.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=124 color="536870912" )
header[3](height=112 color="536870912" )
summary(height=68 color="65535" )
footer(height=0 color="536870912" )
detail(height=64 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=number updatewhereclause=yes name=arrival_qty dbname="arrival_qty" )
 retrieve="  SELECT ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~"||' '||f_get_supplier_name( supplier_code , organization_id) supplier_code,   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ARRIVAL_QTY~",   
         f_get_item_name( item_code , trunc(delivery_date) , organization_id ) item_name  
    FROM ~"IM_ITEM_PURCHASE_ORDER~"  
   WHERE ( ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~" <= :arg_dateend ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( TO_CHAR(~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~") LIKE :arg_org )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_org", string))  sort="item_code A item_name A " )
text(band=header[2] alignment="2" text="@supplier_code" border="2" color="33554432" x="1234" y="4" height="116" width="315" html.valueishtml="0"  name=t_2 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="15780518" )
