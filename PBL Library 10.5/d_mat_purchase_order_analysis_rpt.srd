compute(band=summary alignment="1" expression="~"Grand Total~""border="2" color="33554432" x="224" y="4" height="64" width="480" format="[general]" html.valueishtml="0"  name=compute_6 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=summary alignment="1" expression="sum(order_qty for all )"border="2" color="33554432" x="1234" y="4" height="64" width="315" format="###,##0.00" html.valueishtml="0"  name=compute_7 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=summary alignment="1" expression="sum(grand_sum_order_qty for all )"border="2" color="33554432" x="2121" y="4" height="64" width="375" format="###,##0.00" html.valueishtml="0"  name=compute_9 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65280" )
compute(band=summary alignment="1" expression="sum(arrival_qty for all )"border="2" color="33554432" x="1559" y="4" height="64" width="320" format="###,##0.00" html.valueishtml="0"  name=compute_8 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65535" )
compute(band=summary alignment="1" expression="avg( arrival_qty / order_qty  for all)"border="2" color="33554432" x="1888" y="4" height="64" width="229" format="##0.00%" html.valueishtml="0"  name=compute_3 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65280" )
compute(band=summary alignment="1" expression="sum(grand_sum_arrival_qty for all )"border="2" color="33554432" x="2505" y="4" height="64" width="379" format="###,##0.00" html.valueishtml="0"  name=compute_10 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65280" )
 crosstab(band = foreground  crosstabonly = yes 
 columns = "supplier_code" rows = "item_code, item_name" values = "sum(order_qty for crosstab), sum(arrival_qty for crosstab)" sourcenames = "delivery_date, supplier_code, item_code, order_qty, arrival_qty, item_name")
