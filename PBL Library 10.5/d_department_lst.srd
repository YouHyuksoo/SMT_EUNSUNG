 retrieve="  SELECT ~"ISYS_DEPARTMENT~".~"ORGANIZATION_ID~",   
         ~"ISYS_DEPARTMENT~".~"PRE_DEPARTMENT_CODE~",   
         ~"ISYS_DEPARTMENT~".~"PRE_DEPARTMENT_NAME_LOCAL~",   
         ~"ISYS_DEPARTMENT~".~"DEPARTMENT_CODE~",   
         ~"ISYS_DEPARTMENT~".~"DEPARTMENT_NAME_LOCAL~",   
         ~"ISYS_DEPARTMENT~".~"COMMENTS~",   
         ~"ISYS_DEPARTMENT~".~"ENTER_DATE~",   
         ROWID,   
         ~"ISYS_DEPARTMENT~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_DEPARTMENT~".~"ENTER_BY~",   
         ~"ISYS_DEPARTMENT~".~"LAST_MODIFY_BY~"  
    FROM ~"ISYS_DEPARTMENT~"  
   WHERE ( nvl( ~"ISYS_DEPARTMENT~".~"PRE_DEPARTMENT_CODE~", '%') like :ARG_PRE_DEPARTMENT_CODE ) AND  
         ( ~"ISYS_DEPARTMENT~".~"ORGANIZATION_ID~" like :ARG_ORG ) AND  
         ( ~"ISYS_DEPARTMENT~".~"DEPARTMENT_NAME_LOCAL~" like :ARG_DEPARTMENT_NAME_LOCAL )    
" update="ISYS_DEPARTMENT" updatewhere=0 updatekeyinplace=no arguments=(("ARG_PRE_DEPARTMENT_CODE", string),("ARG_ORG", string),("ARG_DEPARTMENT_NAME_LOCAL", string))  sort="organization_id A pre_department_code A department_code A " )
