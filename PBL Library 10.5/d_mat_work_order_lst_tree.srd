 retrieve="  SELECT A.ORGANIZATION_ID,   
         A.PLAN_DATE,   
         A.ITEM_CODE,   
         A.ISSUE_DATE,   
         A.ISSUE_TYPE,   
         A.ISSUE_DIVISION,   
         A.ISSUE_ACCOUNT,   
         A.ISSUE_STATUS,   
         A.WORK_ORDER_TYPE,   
         A.ITEM_TYPE,   
         A.LINE_TYPE,   
         B.ITEM_SPEC,   
         B.ITEM_UOM,   
         B.ITEM_NAME,   
         A.LAST_MODIFY_DATE,   
         A.LAST_MODIFY_BY,   
         A.ENTER_DATE,   
         A.ENTER_BY,   
         decode( A.LINE_TYPE , 'T' ,  f_get_sal_assy_inventory_qty(a.item_code, a.line_type, a.organization_id) , f_get_mat_inventory_qty(a.item_code, a.line_type, a.organization_id)  ) inventory_qty,   
         'N' check_yn,   
         A.PLAN_YYYYMM,   
         A.LINE_CODE,   
         A.WORKSTAGE_CODE,   
         A.ISSUE_QTY,   
         A.ISSUE_PLAN_QTY,   
         A.ISSUE_PLAN_QTY - A.ISSUE_QTY REMAIN_QTY,   
         A.PLAN_DATE_SEQUENCE,   
         A.WORK_ORDER_NO,   
         ID_ITEM_B.ITEM_DIVISION,   
         A.ROUTE_NO,   
         A.ORIGIN_MFS,   
         A.PARENT_ITEM_CODE,   
         A.MFS,   
         A.PLAN_PRIORITY,   
         A.SHIFT_CODE,   
         A.MODEL_UNIT_QTY ,
		A.SORT_SEQUENCE,
         F_GET_PRODUCT_PLAN_STATUS( A.PLAN_DATE , A.PLAN_DATE_SEQUENCE , A.ORGANIZATION_ID ) PLAN_STATUS
    FROM IM_ITEM_WORK_ORDER A, 
         ID_ITEM B,   
         ID_ITEM ID_ITEM_B  
   WHERE ( A.ITEM_CODE = B.ITEM_CODE ) and  
         ( A.ORGANIZATION_ID = B.ORGANIZATION_ID ) and  
         ( A.PARENT_ITEM_CODE = ID_ITEM_B.ITEM_CODE ) and  
         ( A.ORGANIZATION_ID = ID_ITEM_B.ORGANIZATION_ID ) and  
         ( ( A.ISSUE_DATE >= :arg_dateset ) AND  
         ( A.ISSUE_DATE <= :art_dateend ) AND  
         ( a.mfs LIKE :arg_mfs ) AND  
         ( a.item_code LIKE :arg_item_code ) AND  
         ( a.parent_item_code LIKE :arg_parent_item_code ) AND  
         ( a.line_code LIKE :arg_line_code ) AND  
         ( a.line_type LIKE :arg_line_type ) AND  
         ( a.organization_id = :arg_org_id ) )    

" arguments=(("arg_dateset", datetime),("art_dateend", datetime),("arg_mfs", string),("arg_item_code", string),("arg_line_code", string),("arg_parent_item_code", string),("arg_line_type", string),("arg_org_id", number))  sort="organization_id A line_code A plan_yyyymm A mfs A parent_item_code A item_code A plan_date A " )
