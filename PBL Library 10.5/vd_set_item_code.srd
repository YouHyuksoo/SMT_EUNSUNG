 retrieve="  SELECT ~"ID_ITEM~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"SET_ITEM_YN~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"MODEL_NAME~",   
         ~"ID_ITEM~".~"ORGANIZATION_ID~"  
    FROM ~"ID_ITEM~"  
   WHERE ~"ID_ITEM~".~"SET_ITEM_YN~" = 'Y'   
     AND ORGANIZATION_ID = TO_NUMBER(:ARG_ORG)
" arguments=(("ARG_ORG", string))  sort="set_item_yn D item_code A " )
