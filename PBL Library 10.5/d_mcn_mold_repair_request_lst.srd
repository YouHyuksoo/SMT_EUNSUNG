 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_mold_repair~" ) COLUMN(NAME=~"imcn_mold_repair.mold_code~") COLUMN(NAME=~"imcn_mold_repair.repair_sequence~") COLUMN(NAME=~"imcn_mold_repair.organization_id~") COLUMN(NAME=~"imcn_mold_repair.repair_request_date~") COLUMN(NAME=~"imcn_mold_repair.repair_reason_code~") COLUMN(NAME=~"imcn_mold_repair.repair_vendor_code~") COLUMN(NAME=~"imcn_mold_repair.repair_status~") COLUMN(NAME=~"imcn_mold_repair.repair_by~") COLUMN(NAME=~"imcn_mold_repair.repair_date~") COLUMN(NAME=~"imcn_mold_repair.repair_qty~") COLUMN(NAME=~"imcn_mold_repair.repair_amt~") COLUMN(NAME=~"imcn_mold_repair.currency~") COLUMN(NAME=~"imcn_mold_repair.comments~") COLUMN(NAME=~"imcn_mold_repair.enter_by~") COLUMN(NAME=~"imcn_mold_repair.enter_date~") COLUMN(NAME=~"imcn_mold_repair.last_modify_by~") COLUMN(NAME=~"imcn_mold_repair.last_modify_date~") COLUMN(NAME=~"imcn_mold_repair.mold_version~") COLUMN(NAME=~"imcn_mold_repair.mold_set_serial~") COLUMN(NAME=~"imcn_mold_repair.repair_time~") COLUMN(NAME=~"imcn_mold_repair.apply_machine_code~") COLUMN(NAME=~"imcn_mold_repair.repair_type~") COLUMN(NAME=~"imcn_mold_repair.line_code~")WHERE(    EXP1 =~"( ~~~"IMCN_MOLD_REPAIR~~~".~~~"MOLD_CODE~~~"~"   OP =~"=~"    EXP2 =~":arg_mold_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_REPAIR~~~".~~~"REPAIR_REQUEST_DATE~~~"~"   OP =~"=~"    EXP2 =~":arg_reapair_request_date~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_REPAIR~~~".~~~"REPAIR_SEQUENCE~~~"~"   OP =~"=~"    EXP2 =~":arg_repair_sequence~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD_REPAIR~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org )~" ) ) ARG(NAME = ~"arg_mold_code~" TYPE = string)  ARG(NAME = ~"arg_reapair_request_date~" TYPE = datetime)  ARG(NAME = ~"arg_repair_sequence~" TYPE = number)  ARG(NAME = ~"arg_org~" TYPE = number) " update="IMCN_MOLD_REPAIR" updatewhere=1 updatekeyinplace=no arguments=(("arg_mold_code", string),("arg_reapair_request_date", datetime),("arg_repair_sequence", number),("arg_org", number)) )
