 retrieve="  SELECT ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MASTER_GB~" ,
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MACHINE_CODE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"LINE_CODE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"APPLY_LOCATION~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"PARTNAME~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"PART_TYPE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"SIZE_L~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"SIZE_W~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"SIZE_T~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"VISION_CODE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"NOZZLE_A~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"NOZZLE_B~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"SPEED_DETACT~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"SPEED_MOUNT~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"SPEED_PICKUP~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"GAP_PICKUP~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"GAP_MOUNT~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"DETACT_ANGLE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"STYLE_VALUE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"RECOVERY_COUNT~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"FIX_PICKUP_OFFSET_X~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"FIX_PICKUP_OFFSET_Y~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"FIX_PICKUP_OFFSET_Z~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"LAST_UPDATE_DATE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MATERIAL_FEEDER_PITCH~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MATERIAL_REEL_SIZE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MATERIAL_PART_PER_REEL~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"ENTER_DATE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"ENTER_BY~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"LAST_MODIFY_DATE~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"LAST_MODIFY_BY~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"ORGANIZATION_ID~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MASTER_YN~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"NOZZLE_C~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"NOZZLE_D~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"WORK_NO~",   
         ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"COMMENTS~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"MSL_LEVEL~",   
         ~"ID_ITEM~".~"ECO_CHECK_YN~",   
         ~"ID_ITEM~".~"ECO_CHECK_COMMENTS~"  ,
		  ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"IS_NEW_YN~",
           ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"COMPARE_DATE~"
          
    FROM ~"IB_MNT_PARTLIB_COMPARE_MASTER~",   
         ~"ID_ITEM~"  
   WHERE ( IB_MNT_PARTLIB_COMPARE_MASTER.partname = id_item.item_code (+)) and  
         ( IB_MNT_PARTLIB_COMPARE_MASTER.organization_id = id_item.organization_id (+)) and  
         (DECODE(~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MASTER_YN~" , 'Y', :arg_line_code,  ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"LINE_CODE~") like :arg_line_code  )  AND  
         ( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"PARTNAME~" like :arg_item_code ) AND  
         ( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"PART_TYPE~" like :arg_part_type ) AND  
		( NVL( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"IS_NEW_YN~",'Y') like :arg_is_new_yn ) and 
		 ( DECODE(~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MASTER_YN~" , 'Y', :arg_mounter_model_type, ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MACHINE_CODE~") like :arg_mounter_model_type ) and 
         ( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"COMPARE_DATE~" >= :arg_dateset ) AND  
         ( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"COMPARE_DATE~" <=   :arg_dateend) AND  
         ( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"ORGANIZATION_ID~" = :arg_org )   and
        ( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"QUERY~" = :arg_yn )   and
        ( ~"IB_MNT_PARTLIB_COMPARE_MASTER~".~"MASTER_CHK~" like :arg_masterchk )   " arguments=(("arg_line_code", string),("arg_item_code", string),("arg_part_type", string),("arg_IS_NEW_YN", string),("arg_mounter_model_type", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number),("arg_yn", string),("arg_masterchk", string))  sort="work_no A master_gb D " )
