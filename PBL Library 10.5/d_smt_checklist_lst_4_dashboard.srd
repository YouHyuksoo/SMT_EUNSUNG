 retrieve="  SELECT f_get_ccs_ok_count( IB_SMT_CHECKHIST.LINE_CODE ) CCS_COUNT,
		IB_SMT_CHECKHIST.FEEDER_SHAFT,
         IB_SMT_CHECKHIST.CHECK_DATE,   
         IB_SMT_CHECKHIST.CHECK_SEQUENCE,   
         IB_SMT_CHECKHIST.PLAN_DATE,   
         IB_SMT_CHECKHIST.LOT_NAME,   
         IB_SMT_CHECKHIST.PARTNAME,   
         IB_SMT_CHECKHIST.CHIPNAME,   
         IB_SMT_CHECKHIST.CHECK_STATUS,   
         IB_SMT_CHECKHIST.CHECK_MSG,   
         IB_SMT_CHECKHIST.CHECK_BY,   
         IB_SMT_CHECKHIST.LINE_CODE,   
         IB_SMT_CHECKHIST.MACHINE,   
         IB_SMT_CHECKHIST.PLAN_DATE_SEQUENCE,   
         IB_SMT_CHECKHIST.SCAN_PARTNAME,   
         ID_ITEM_A.ITEM_NAME,   
         ID_ITEM_A.ITEM_SPEC,   
         IM_ITEM_RECEIPT_BARCODE.SCAN_QTY,   
         IM_ITEM_RECEIPT_BARCODE.SUPPLIER_CODE,   
         IM_ITEM_RECEIPT_BARCODE.BARCODE_STATUS,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_COMPARE_DATE,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_DATE,   
         NVL(IM_ITEM_RECEIPT_BARCODE.LOT_DIVIDE_YN,'N') LOT_DIVIDE_YN,   
         IM_ITEM_RECEIPT_BARCODE.LOT_DIVIDE_DATE,   
         IB_SMT_CHECKHIST.LOCATION_CODE,   
         IB_SMT_CHECKHIST.TABLE_ID,   
         IB_SMT_CHECKHIST.CHECK_TYPE,   
         IB_SMT_CHECKHIST.NG_REASON,   
         IB_SMT_CHECKHIST.SCAN_SUPPLIER_PARTNAME,   
         IB_SMT_CHECKHIST.FULL_CHECK_SEQUENCE,   
         IB_SMT_CHECKHIST.PCB_ITEM,   
         IB_SMT_CHECKHIST.UNLOCK_BY,   
         IB_SMT_CHECKHIST.UNLOCK_DATE,   
         ID_ITEM_A.MSL_LEVEL,   
         ID_ITEM_A.MSL_MAX_TIME,   
         IB_SMT_CHECKHIST.CCS_END_DATE,   
         IB_SMT_CHECKHIST.LOT_NO,   
         IB_SMT_CHECKHIST.SUPPLIER_BARCODE_ORIGIN,   
         IB_SMT_CHECKHIST.OUR_BARCODE_ORIGIN,   
         IB_SMT_CHECKHIST.VALID_DATE,   
         IB_SMT_CHECKHIST.LOT_SERIAL,
		IB_SMT_CHECKHIST.OLD_BARCODE ,
		IB_SMT_CHECKHIST.ITEM_CODE  ,
		IB_SMT_CHECKHIST.COMMENTS  ,
		IB_SMT_CHECKHIST.NG_TYPE  ,
		IB_SMT_CHECKHIST.SMT_MODEL_NAME
    FROM IB_SMT_CHECKHIST,   
         ID_ITEM ID_ITEM_A,   
         IM_ITEM_RECEIPT_BARCODE  
   WHERE ( ib_smt_checkhist.partname = ID_ITEM_A.item_code (+)) and  
         ( ib_smt_checkhist.lot_no = im_item_receipt_barcode.lot_no (+)) and  
            IB_SMT_CHECKHIST.run_no = :arg_run_no
" arguments=(("arg_run_no", string))  sort="check_type A line_code A machine A lot_name A table_id A location_code A check_date A check_sequence A " )
