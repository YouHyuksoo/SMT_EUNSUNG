global function string f_get_line_code_by_run_no (string arg_run_no);string lvs_line_code
select line_code into :lvs_line_code
 from ip_product_run_card
 where run_no = :arg_run_no ;
 
 if f_sql_check() < 0 then 
	return ''
end if 

return lvs_line_code
end function

