 retrieve="SELECT   ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~" ,           
			~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" , 		          
			~"IM_ITEM_ISSUE~".~"ITEM_CODE~" ,           
			SUM(~"IM_ITEM_ISSUE~".~"ISSUE_QTY~") ISSUE_QTY,           
			AVG(~"IM_ITEM_ISSUE~".~"ISSUE_PRICE~") ISSUE_PRICE,   
			SUM(~"IM_ITEM_ISSUE~".~"ISSUE_AMT~") ISSUE_AMT,    	           
			MAX(~"ID_ITEM~".~"ITEM_NAME~") ITEM_NAME,           
			MAX(~"ID_ITEM~".~"ITEM_SPEC~") ITEM_SPEC,    
			MAX(~"ID_ITEM~".~"ITEM_DIVISION~") ITEM_DIVISION,           
			MAX(~"ID_ITEM~".~"ITEM_UOM~" ) ITEM_UOM
    FROM ~"IM_ITEM_ISSUE~" ,      
               ~"ID_ITEM~"    
WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_ISSUE~".~"ITEM_CODE~" ) and
			( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" ) and
		     ( ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~" = :arg_date)   and
			( ~"IM_ITEM_ISSUE~".~"ITEM_CODE~" like :arg_item_code ) and
			( ~"IM_ITEM_ISSUE~".~"ISSUE_STATUS~"<> 'C' ) and
			( ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" = :arg_org_id ) 
GROUP BY ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~" ,           
			   ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" ,       
			   ~"IM_ITEM_ISSUE~".~"ITEM_CODE~",
                  ~"ID_ITEM~".~"ITEM_CODE~",
                  ~"ID_ITEM~".~"ORGANIZATION_ID~" 
" arguments=(("arg_date", datetime),("arg_item_code", string),("arg_org_id", number)) )
