HA$PBExportHeader$d_qc_visual_inspect_period_query.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=140 color="536870912" )
summary(height=0 color="16777215" )
footer(height=80 color="16777215" )
detail(height=84 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=inspect_date dbname="inspect_date" )
 column=(type=char(100) updatewhereclause=yes name=customer_name dbname="customer_name" )
 column=(type=char(4000) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(30) updatewhereclause=yes name=run_no dbname="run_no" )
 column=(type=char(30) updatewhereclause=yes name=lot_wo dbname="lot_wo" )
 column=(type=number updatewhereclause=yes name=lot_size dbname="lot_size" )
 column=(type=number updatewhereclause=yes name=in_qty dbname="in_qty" )
 column=(type=number updatewhereclause=yes name=ok_qty dbname="ok_qty" )
 column=(type=number updatewhereclause=yes name=ng_qty dbname="ng_qty" )
 retrieve="  select INSPECT_DATE,
         CUSTOMER_NAME,
         f_get_line_name(LINE_CODE,1) LINE_CODE,
         MODEL_NAME,
         ITEM_CODE,
         RUN_NO,
         LOT_WO,
         LOT_SIZE,
         sum(1)                           in_qty,
         sum(DECODE(REPAIR_RESULT,'G',1)) ok_qty,
         sum(DECODE(REPAIR_RESULT,'N',1)) ng_qty
   from (     
          SELECT TRUNC(~"IQ_PRODUCT_WQC~".~"INSPECT_DATE~")  INSPECT_DATE,   
                 ~"IQ_PRODUCT_WQC~".~"LINE_CODE~",   
                 ~"IQ_PRODUCT_WQC~".~"MODEL_NAME~",   
                 ~"IQ_PRODUCT_WQC~".~"ITEM_CODE~",   
                 (select customer_name
                    from ip_product_model_master
                   where model_name = ~"IQ_PRODUCT_WQC~".~"MODEL_NAME~"
                     and organization_id = ~"IQ_PRODUCT_WQC~".~"ORGANIZATION_ID~"
                     and rownum = 1
                 )  CUSTOMER_NAME,
                 (
                  select r.run_no
                    from ip_product_run_card r,
                           ip_product_2d_barcode b
                  where b.run_no = r.run_no
                      and b.serial_no = ~"IQ_PRODUCT_WQC~".~"SERIAL_NO~"
                      and b.organization_id =  ~"IQ_PRODUCT_WQC~".~"ORGANIZATION_ID~"
                      and rownum = 1
                 ) RUN_NO,
                (
                  select r.marking_no
                    from ip_product_run_card r,
                           ip_product_2d_barcode b
                  where b.run_no = r.run_no
                      and b.serial_no = ~"IQ_PRODUCT_WQC~".~"SERIAL_NO~"
                      and b.organization_id =  ~"IQ_PRODUCT_WQC~".~"ORGANIZATION_ID~"
                      and rownum = 1
                 ) LOT_WO,
                (
                  select r.lot_size
                    from ip_product_run_card r,
                           ip_product_2d_barcode b
                  where b.run_no = r.run_no
                      and b.serial_no = ~"IQ_PRODUCT_WQC~".~"SERIAL_NO~"
                      and b.organization_id =  ~"IQ_PRODUCT_WQC~".~"ORGANIZATION_ID~"
                      and rownum = 1
                 ) LOT_SIZE,
                 ~"IQ_PRODUCT_WQC~".~"REPAIR_RESULT~" 
            FROM ~"IQ_PRODUCT_WQC~"  
           WHERE ( ~"IQ_PRODUCT_WQC~".~"INSPECT_DATE~" >= trunc(:arg_dateset) ) AND  
                 ( ~"IQ_PRODUCT_WQC~".~"INSPECT_DATE~" <  trunc(:arg_dateend +1) ) AND  
                 ( ~"IQ_PRODUCT_WQC~".~"LINE_CODE~" like :arg_line_code ) AND  
                 ( ~"IQ_PRODUCT_WQC~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
                 ( ~"IQ_PRODUCT_WQC~".~"MODEL_NAME~" like :arg_model_name ) AND  
                 ( ~"IQ_PRODUCT_WQC~".~"ORGANIZATION_ID~" = :arg_org )
        )
 group by INSPECT_DATE,
          f_get_line_name(LINE_CODE,1),
          CUSTOMER_NAME,
          MODEL_NAME,
          ITEM_CODE,
          RUN_NO,
          LOT_WO,
         LOT_SIZE
 order by INSPECT_DATE,
          f_get_line_name(LINE_CODE,1),
          CUSTOMER_NAME,
          MODEL_NAME,
          ITEM_CODE,
          RUN_NO,
          LOT_WO  ,
          LOT_SIZE" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_workstage_code", string),("arg_model_name", string),("arg_lang", string),("arg_org", number)) )
