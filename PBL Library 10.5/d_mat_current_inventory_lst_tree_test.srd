table(column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="supplier_code" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(20) updatewhereclause=yes name=msl_level dbname="msl_level" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="location_address" )
 column=(type=number updatewhereclause=yes name=last_inventory_qty dbname="last_inventory_qty" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number updatewhereclause=yes name=reel_qty dbname="reel_qty" )
 retrieve="SELECT * FROM 
(
  SELECT
         IM_ITEM_INVENTORY.ITEM_CODE,   
          IM_ITEM_INVENTORY.LINE_TYPE,   
         SUM(IM_ITEM_INVENTORY.INVENTORY_QTY) INVENTORY_QTY,   
         f_get_reel_qty( IM_ITEM_INVENTORY.ITEM_CODE, 1,  SUM(IM_ITEM_INVENTORY.INVENTORY_QTY) , IM_ITEM_INVENTORY.ORGANIZATION_ID ) REEL_QTY , 
		NVL(f_get_mm_last_mon_loc_inv_qty( TO_CHAR(SYSDATE,'YYYYMM') , IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.LINE_TYPE , IM_ITEM_INVENTORY.LOCATION_CODE , IM_ITEM_INVENTORY.ORGANIZATION_ID ) ,0 ) LAST_INVENTORY_QTY ,

         F_GET_BASECODE( 'MATERIAL LOCATION CODE' , IM_ITEM_INVENTORY.LOCATION_CODE,   :ARG_LANG , :arg_org_id )  LOCATION_CODE ,
         MAX(ID_ITEM.LOCATION_ADDRESS) LOCATION_ADDRESS,   
         MAX(ID_ITEM.ITEM_SPEC) ITEM_SPEC,   
         MAX(ID_ITEM.ITEM_NAME) ITEM_NAME,
         MAX(ID_ITEM.ITEM_DIVISION) ITEM_DIVISION ,
         MAX(ID_ITEM.MSL_LEVEL) MSL_LEVEL ,
		IM_ITEM_INVENTORY.SUPPLIER_CODE  SUPPLIER_CODE,
         F_GET_MAT_MAX_UNIT_PRICE_CFM( IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.LINE_TYPE , SYSDATE , IM_ITEM_INVENTORY.ORGANIZATION_ID ) UNIT_PRICE 
    FROM IM_ITEM_INVENTORY,   ID_ITEM  
   WHERE ( ID_ITEM.ITEM_CODE = IM_ITEM_INVENTORY.ITEM_CODE ) and  
         ( ID_ITEM.ORGANIZATION_ID = IM_ITEM_INVENTORY.ORGANIZATION_ID ) and  
         ( ( IM_ITEM_INVENTORY.ITEM_CODE like :arg_item_code ) AND  
		( IM_ITEM_INVENTORY.MATERIAL_MFS like :arg_material_mfs ) AND  
         ( IM_ITEM_INVENTORY.LOCATION_CODE like :arg_location_code )     AND
         ( IM_ITEM_INVENTORY.INVENTORY_TYPE like :arg_inventory_type )     AND
         ( nvl(IM_ITEM_INVENTORY.SUPPLIER_CODE,'*') like :arg_supplier_code )     AND

         ( IM_ITEM_INVENTORY.ORGANIZATION_ID = :arg_org_id ) )    
GROUP BY
         IM_ITEM_INVENTORY.ITEM_CODE,   
         IM_ITEM_INVENTORY.LINE_TYPE,   
         IM_ITEM_INVENTORY.LOCATION_CODE ,
         IM_ITEM_INVENTORY.SUPPLIER_CODE ,
         IM_ITEM_INVENTORY.ORGANIZATION_ID,  
         IM_ITEM_INVENTORY.INVENTORY_HOLD 
) 
WHERE          (  SIGN(INVENTORY_QTY) >= :arg_sign )  
" arguments=(("arg_item_code", string),("arg_material_mfs", string),("arg_sign", number),("arg_supplier_code", string),("arg_location_code", string),("arg_lang", string),("arg_inventory_type", string),("arg_org_id", number))  sort="supplier_code A item_code A item_name A item_spec A msl_level A location_address A last_inventory_qty A " )
