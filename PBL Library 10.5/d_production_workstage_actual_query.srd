footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) updatewhereclause=yes name=model_suffix dbname="model_suffix" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=number updatewhereclause=yes name=actual_qty dbname="actual_qty" )
 retrieve="SELECT 
              MODEL_NAME, MODEL_SUFFIX, item_code,workstage_code, workstage_name, actual_qty, seq
  FROM ( 

SELECT  
            MODEL_NAME, MODEL_SUFFIX, item_code, workstage_code,f_get_workstage_name(workstage_code) workstage_name,  SUM(IO_QTY) as actual_qty, 
            decode(workstage_code,'W80',3,'W30',5,'W50',9,'W60',10,'W70',11,'W53',12 ,'W55',14) as seq  
  FROM IP_PRODUCT_WORKSTAGE_IO 
 WHERE ORGANIZATION_ID = 1 
   AND ACTUAL_DATE = :arg_date 
   AND model_name like :arg_model||'%'
   
 GROUP BY  workstage_code, MODEL_NAME, MODEL_SUFFIX, item_code 
 
 
 union
 
 select /*+INDEX( IP_PRODUCT_RUN_CARD_IO XPKIP_PRODUCT_RUN_CARD_IO)*/
         model_name, model_suffix, item_code, workstage_code, f_get_workstage_name(workstage_code) workstage_name, 
        decode( workstage_code,'W10',sum(decode(  receipt_deficit, 1, lot_qty ,0 )),
       --sum(decode(  receipt_deficit, 2, lot_qty ,0 )) as out_qty, 
       --sum(decode(receipt_confirm_yn, 'N', lot_qty)) as wait_qty, 
        sum(decode(receipt_confirm_yn, 'Y', lot_qty)) )  as Actual_qty, 
        decode(workstage_code,'W10',1,'W20',2) as seq  
  from IP_PRODUCT_RUN_CARD_IO 
 where organization_id =1 
   and receipt_date >= F_GET_WORK_ACTUAL_DATE(:arg_date+1,'S') 
   and receipt_date  < F_GET_WORK_ACTUAL_DATE(:arg_date+1,'E')
   and pcb_item = 'B' 
   and model_name like :arg_model||'%'
 group by model_name, model_suffix,item_code, workstage_code
  
 union
 
   
  select
                model, 
                buyer, 
                item_code, 
                operationname, 
                f_get_basecode('OPERATIONNAME',operationname,'C',1) as operation_desc,
                count(distinct x.PRODUCT_ID ) as actual, 
                decode(operationname, 'SMT3500',4,
                              'PCB2300',6,
                              'PCB2100',7,
                              'FLD4500',8
               ) as seq 
          from tb_vis_tstrslt x
        where x.CREATED_DATE >= to_char(F_GET_WORK_ACTUAL_DATE(:arg_date+1 ,'S'),'yyyymmddhh24mi') 
            and x.CREATED_DATE  < to_char(F_GET_WORK_ACTUAL_DATE(:arg_date+1 ,'E'),'yyyymmddhh24mi') 
            and model like :arg_model||'%'
         group by model, buyer, item_code, operationname
  
  union
 
 
 select 
        /*+INDEX(x XPKTB_VIS_TXNHISTORY_2)*/  
        model, buyer, item_code,operationname,  f_get_basecode('OPERATIONNAME',operationname,'C',1) as operation_desc,sum(1) as actual , 
        decode(operationname, 'PCB8100',13,
                                           'FNL1000',15)  as seq 
   from tb_vis_txnhistory x 
  where x.CREATED_DATE >= to_char(F_GET_WORK_ACTUAL_DATE(:arg_date+1,'S'),'yyyymmddhh24mi') 
    and x.CREATED_DATE < to_char(F_GET_WORK_ACTUAL_DATE(:arg_date+1,'E'),'yyyymmddhh24mi') 
  and model like :arg_model||'%'
   group by model, buyer, item_code,operationname    
) " arguments=(("arg_date", datetime),("arg_model", string))  sort="model_name A model_suffix A item_code A " )
