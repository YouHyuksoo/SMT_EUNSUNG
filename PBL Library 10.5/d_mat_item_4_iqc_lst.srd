 retrieve="  SELECT ~"IM_ITEM_MASTER~".~"ITEM_CODE~",   
         ~"IM_ITEM_MASTER~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_MASTER~".~"DATESET~",   
         ~"IM_ITEM_MASTER~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_MASTER~".~"ORDER_TYPE~",   
         ~"IM_ITEM_MASTER~".~"ORDER_RATE~",   
         ~"IM_ITEM_MASTER~".~"ORDER_LEADTIME~",   
         ~"IM_ITEM_MASTER~".~"ORDER_BAD_RATE~",   
         ~"IM_ITEM_MASTER~".~"MIM_ORDER_QTY~",   
         ~"IM_ITEM_MASTER~".~"PACKING_QTY~",   
         ~"IM_ITEM_MASTER~".~"LONGTERM_DELIVERY_YN~",   
         ~"IM_ITEM_MASTER~".~"WAREHOUSE_CHARGE~",   
         ~"IM_ITEM_MASTER~".~"ORDER_CHARGE~",   
         ~"IM_ITEM_MASTER~".~"DATEEND~",   
         ~"IM_ITEM_MASTER~".~"MAIN_VENDOR_YN~",   
         ~"IM_ITEM_MASTER~".~"PAYMENT_TYPE~",   
         ~"IM_ITEM_MASTER~".~"ENTER_BY~",   
         ~"IM_ITEM_MASTER~".~"ENTER_DATE~",   
         ~"IM_ITEM_MASTER~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_MASTER~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_MASTER~".~"INSPECT_RULE~",   
         ~"IM_ITEM_MASTER~".~"INSPECT_METHOD~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"LINE_TYPE~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"IM_ITEM_MASTER~".~"VIRTUAL_RECEIPT_YN~", 
         im_item_master.rowid,
         'N' CHECK_YN
    FROM ~"IM_ITEM_MASTER~",   
         ~"ID_ITEM~",   
         ~"ICOM_SUPPLIER~"  
   WHERE ( ~"IM_ITEM_MASTER~".~"ITEM_CODE~"      = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_MASTER~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_MASTER~".~"SUPPLIER_CODE~"      = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~"(+) ) and  
         ( ~"IM_ITEM_MASTER~".~"ORGANIZATION_ID~" = ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~"(+) ) and  
         ( ( ~"IM_ITEM_MASTER~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_MASTER~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_MASTER~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" update="IM_ITEM_MASTER" updatewhere=0 updatekeyinplace=yes arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_org_id", number))  sort="supplier_code A item_code A " )
