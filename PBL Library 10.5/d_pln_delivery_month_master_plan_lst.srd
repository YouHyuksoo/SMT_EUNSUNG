 retrieve="  SELECT ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_YM~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_1~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_2~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_3~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_4~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_5~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_6~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_7~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_8~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_9~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_10~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_11~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_12~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"COMMENTS~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"ENTER_BY~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"LAST_MODIFY_BY~"  ,

		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M1_ACTUAL ,0) M1_ACTUAL ,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M2_ACTUAL ,0)   M2_ACTUAL,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M3_ACTUAL  ,0) M3_ACTUAL,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M4_ACTUAL  ,0) M4_ACTUAL ,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M5_ACTUAL  ,0) M5_ACTUAL,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M6_ACTUAL  ,0) M6_ACTUAL ,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M7_ACTUAL  ,0) M7_ACTUAL ,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M8_ACTUAL  ,0) M8_ACTUAL,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M9_ACTUAL  ,0) M9_ACTUAL,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M10_ACTUAL  ,0) M10_ACTUAL ,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M11_ACTUAL  ,0) M11_ACTUAL,
		NVL( IP_PRODUCT_DELIVERY_MONTH_V.M12_ACTUAL ,0)  M12_ACTUAL 

    FROM ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~"   ,
			IP_PRODUCT_DELIVERY_MONTH_V 
   WHERE IP_PRODUCT_DELIVERY_MONTH_PLAN.PLAN_YM = IP_PRODUCT_DELIVERY_MONTH_V.PLAN_YM(+) AND 
              IP_PRODUCT_DELIVERY_MONTH_PLAN.MODEL_NAME = IP_PRODUCT_DELIVERY_MONTH_V.MODEL_NAME(+) AND 
         ( ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"PLAN_YM~" = :ARG_YYYYMM ) AND  
         ( ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"MODEL_NAME~" like :ARG_MODEL_NAME ) AND  
         ( ~"IP_PRODUCT_DELIVERY_MONTH_PLAN~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" update="IP_PRODUCT_DELIVERY_MONTH_PLAN" updatewhere=0 updatekeyinplace=no arguments=(("ARG_YYYYMM", string),("ARG_MODEL_NAME", string),("ARG_ORG", number))  sort="plan_ym A model_name A model_suffix A " )
