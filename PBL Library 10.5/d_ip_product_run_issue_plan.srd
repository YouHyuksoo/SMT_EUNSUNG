 retrieve="  SELECT ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"RUN_NO~",   
               F_BACODE_CODE128( 'B' , ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"RUN_NO~") RUN_NO_LABEL,   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ENTER_BY~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"LOT_SIZE~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ITEM_PACKING_QTY~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"LOCATION_QTY~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ITEM_UNIT_QTY~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"GROUP_ID~",   
         ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_SIZE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",   
         ~"ID_ITEM~".~"MATERIAL_QTY~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_NO~",   
         ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"LOCATION_CODE~"  
    FROM ~"IP_PRODUCT_RUN_CARD_DETAIL~",   
         ~"ID_ITEM~",   
         ~"IP_PRODUCT_RUN_CARD~"  
   WHERE ( ip_product_run_card_detail.item_code = id_item.item_code (+)) and  
         ( ip_product_run_card_detail.organization_id = id_item.organization_id (+)) and  
         ( ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"RUN_NO~" = ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~" ) and  
         ( ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ORGANIZATION_ID~" = ~"IP_PRODUCT_RUN_CARD~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"RUN_NO~" = :RUN_NO ) AND  
         ( ~"IP_PRODUCT_RUN_CARD_DETAIL~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID ) )    
" arguments=(("RUN_NO", string),("ARG_ORGANIZATION_ID", number))  sort="run_no A location_code A item_code A location_address A " )
