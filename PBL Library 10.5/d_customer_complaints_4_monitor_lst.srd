 retrieve="  SELECT ~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLAINTS_NO~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"ITEM_CODE~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"ORGANIZATION_ID~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLAINTS_COMMENT~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"ENTER_BY~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"ENTER_DATE~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"SET_ITEM_YN~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"WEIGHT~",   
         ~"ID_ITEM~".~"HEIGHT~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"IMAGE_FORMAT~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"FILE_NAME~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"LAST_MODIFY_DATE~",   
         ~"ID_ITEM~".~"PART_NO~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"KEY_WORD~",   
         ~"ID_ITEM~".~"RAW_MATERIAL~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"VERSION~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"CUSTOMER_CODE~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"USER_ID~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"DEPARTMENT_CODE~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"MODEL_NAME~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"MODEL_SUFFIX~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"PART_NO~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLAINTS_DATE~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLETE_YN~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"STATUS~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"CHECK_IN_OUT~",   
         ICOM_CUSTOMER_COMPLAINTS.ROWID,   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"CHECK_IN_OUT_DATE~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"CHECK_IN_OUT_BY~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLAINTS_GRADE~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLAINTS_DIVISION~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"SERIAL_NO~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"CUSTOMER_CLOSE_YN~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"RUN_NO~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"REASON_COMMENT~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"IMPROVEMENT_COMMENT~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLAINTS_QTY~",   
         ~"ICOM_CUSTOMER_COMPLAINTS~".~"ISSUE_IMPROVMENT_YN~"  
    FROM ~"ICOM_CUSTOMER_COMPLAINTS~",   
         ~"ID_ITEM~"  
   WHERE ( icom_customer_complaints.item_code = id_item.item_code (+)) and  
         ( icom_customer_complaints.organization_id = id_item.organization_id (+)) and  
		~"ICOM_CUSTOMER_COMPLAINTS~".~"COMPLETE_YN~" <>  'Y' and
         ( ~"ICOM_CUSTOMER_COMPLAINTS~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID ) 
" arguments=(("ARG_ORGANIZATION_ID", number))  sort="organization_id A customer_code A complaints_division A item_division A item_code A version A complaints_no A " )
