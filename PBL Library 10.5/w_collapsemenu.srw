on tab_1.create
this.start=create start
this.basis=create basis
this.design=create design
this.planning=create planning
this.material=create material
this.sale=create sale
this.qc=create qc
this.spare=create spare
this.Control[]={this.start,&
this.basis,&
this.design,&
this.planning,&
this.material,&
this.sale,&
this.qc,&
this.spare}
end on

on tab_1.destroy
destroy(this.start)
destroy(this.basis)
destroy(this.design)
destroy(this.planning)
destroy(this.material)
destroy(this.sale)
destroy(this.qc)
destroy(this.spare)
end on

