pb_close pb_close
pb_2 pb_2
tab_1 tab_1
end type
global w_collapsemenu w_collapsemenu

type prototypes
Function ulong SetCapture(ulong hWnd) Library "USER32.DLL"
Function BOOLEAN ReleaseCapture() Library "USER32.DLL"
end prototypes

type variables
Boolean ib_mousecaptured
Boolean ib_locked = false
end variables

forward prototypes
public function boolean of_ismousecaptured ()
public function integer of_releasemouse ()
public function integer of_capturemouse ()
end prototypes

public function boolean of_ismousecaptured ();
return ib_mousecaptured
end function

public function integer of_releasemouse ();
if NOT of_ismousecaptured() then return -1

ReleaseCapture()

ib_mousecaptured = FALSE

Return 1
end function

public function integer of_capturemouse ();
if of_ismousecaptured() then Return -1

SetCapture(handle(this))

ib_mousecaptured = TRUE

return 1
end function

event open;call super::open;this.x = w_main_frame.workspacex( ) + 240
this.y = w_main_frame.workspacey( )+ 165
this.height = w_main_frame.height - 460
this.width = w_main_frame.width - 280

//slide left to right
AnimateWindow ( Handle( this ),200,AW_HOR_POSITIVE)
this.setredraw( true)
end event

on w_collapsemenu.create
int iCurrent
call super::create
this.pb_close=create pb_close
this.pb_2=create pb_2
this.tab_1=create tab_1
iCurrent=UpperBound(this.Control)
this.Control[iCurrent+1]=this.pb_close
this.Control[iCurrent+2]=this.pb_2
this.Control[iCurrent+3]=this.tab_1
end on

on w_collapsemenu.destroy
call super::destroy
destroy(this.pb_close)
destroy(this.pb_2)
destroy(this.tab_1)
end on

event mousemove;call super::mousemove;//if NOT of_ismousecaptured() then 
//	
//	of_capturemouse()
//	SetRedraw(true)
////	this.event mouseenter()
//		
//else
//	
//	if xpos < 0 or ypos < 0 or xpos > width or ypos > height then
//	
//		of_releasemouse()
//		pb_close.event post clicked()
////		this.event post mouseleave()
//		
//	end if
//
//end if
//
////IF ib_mousecaptured  THEN
////	SetRedraw(TRUE)
////END IF
end event

event ue_post_open;call super::ue_post_open;tab_1.width = w_collapsemenu.width - ( tab_1.x+ 34)
tab_1.height = w_collapsemenu.height - ( tab_1.y)

end event

event resize;call super::resize;tab_1.width = w_collapsemenu.width - ( tab_1.x + 34)
tab_1.height = w_collapsemenu.height - ( tab_1.y)


end event

event deactivate;call super::deactivate;this.bringtotop = false
end event

