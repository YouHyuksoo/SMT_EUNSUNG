integer height = 88
integer taborder = 20
boolean bringtotop = true
integer textsize = -8
integer weight = 700
fontcharset fontcharset = ansi!
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Tahoma"
boolean originalsize = true
string picturename = "Exit!"
alignment htextalign = left!
end type

event clicked;int i

parent.of_releasemouse( )

w_collapsemenu.tab_1.visible = false

do
	i = i + 100
	parent.width = parent.width - i 

loop until  parent.width <= 0 

close(parent)

end event

