 retrieve="SELECT  ~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~" ,      
			~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ,     
			~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ,   
			~"IM_ITEM_INVENTORY~".~"LINE_TYPE~" ,  
			~"IM_ITEM_INVENTORY~".~"INVENTORY_PRICE~" ,  
			~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~" ,   
			~"IM_ITEM_INVENTORY~".~"INVENTORY_AMT~" ,    
			~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~" ,  
			~"IM_ITEM_INVENTORY~".~"COMMENTS~" ,  
			~"IM_ITEM_INVENTORY~".~"ENTER_DATE~" ,    
			~"IM_ITEM_INVENTORY~".~"ENTER_BY~" ,      
			~"ID_ITEM~".~"ITEM_SPEC~" ,           ~"ID_ITEM~".~"ITEM_NAME~" , 
			~"ID_ITEM~".~"ITEM_UOM~" ,           ~"ID_ITEM~".~"ITEM_DIVISION~" ,  
			~"ID_ITEM~".~"MSL_LEVEL~" ,
			F_GET_MAT_FREE_QTY_MFS ( IM_ITEM_INVENTORY.MATERIAL_MFS , IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.LINE_TYPE , IM_ITEM_INVENTORY.ORGANIZATION_ID ) FREE_INVENTORY_QTY,           ~"ID_ITEM~".~"LOCATION_ADDRESS~" ,           0 MOVE_QTY,        
			F_GET_REEL_QTY( IM_ITEM_INVENTORY.ITEM_CODE , 1 , IM_ITEM_INVENTORY.INVENTORY_QTY , IM_ITEM_INVENTORY.ORGANIZATION_ID ) REEL_QTY1,      
			F_GET_REEL_QTY( IM_ITEM_INVENTORY.ITEM_CODE , 2 , IM_ITEM_INVENTORY.INVENTORY_QTY , IM_ITEM_INVENTORY.ORGANIZATION_ID ) REEL_QTY2,    
			f_get_mat_receipt_by_loc_mfs(IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.MATERIAL_MFS, IM_ITEM_INVENTORY.LOCATION_CODE  , 
			IM_ITEM_INVENTORY.ORGANIZATION_ID ) RECEIPT_QTY,      
			f_get_mat_issue_by_loc_mfs(IM_ITEM_INVENTORY.ITEM_CODE , IM_ITEM_INVENTORY.MATERIAL_MFS, IM_ITEM_INVENTORY.LOCATION_CODE ,IM_ITEM_INVENTORY.ORGANIZATION_ID ) ISSUE_QTY,    
			~"IM_ITEM_INVENTORY~".~"MANUFACTURE_WEEK~" ,       
			~"IM_ITEM_INVENTORY~".~"LAST_RECEIPT_DATE~" ,        
			~"ID_ITEM~".~"LIFE_CYCLE~" ,           
			~"IM_ITEM_INVENTORY~".~"BAKING_DATE~"  ,
			IM_ITEM_INVENTORY.LOCATION_ADDRESS_RACK LOCATION_ADDRESS_RACK ,
			IM_ITEM_INVENTORY.SUPPLIER_CODE SUPPLIER_CODE
FROM ~"IM_ITEM_INVENTORY~" ,           ~"ID_ITEM~"   
WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and      
( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) and   
( ~"IM_ITEM_INVENTORY~".~"SUPPLIER_CODE~" like :arg_supplier_code ) and 
( NVL(~"IM_ITEM_INVENTORY~".~"LOCATION_ADDRESS_RACK~" , '*') = :arg_location_code ) and    
( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id )  " arguments=(("arg_item_code", string),("arg_location_code", string),("arg_supplier_code", string),("arg_org_id", number))  sort="last_receipt_date A organization_id A location_code A item_code A material_mfs A " )
group(level=1 header.height=0 trailer.height=0 by=("organization_id" , "location_code" ) header.color="65535" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=0 by=("organization_id" , "location_code" , "item_code" ) header.color="65280" trailer.color="536870912" )
