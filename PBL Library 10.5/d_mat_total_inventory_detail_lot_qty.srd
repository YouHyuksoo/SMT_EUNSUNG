HA$PBExportHeader$d_mat_total_inventory_detail_lot_qty.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=136 color="536870912" )
summary(height=80 color="65535" )
footer(height=0 color="65535" )
detail(height=64 color="536870912" )
table(column=(type=char(9) updatewhereclause=yes name=window_group dbname="window_group" )
 column=(type=char(4000) updatewhereclause=yes name=location_code dbname="location_code" )
 column=(type=char(30) updatewhereclause=yes name=material_mfs dbname="im_item_inventory.material_mfs" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="im_item_inventory.inventory_qty" )
 retrieve="select 'WAREHOUSE' WINDOW_GROUP,
		f_get_basecode('LOCATION CODE', location_code, :arg_lang, 1) location_code,
       material_mfs,
       inventory_qty
from IM_ITEM_INVENTORY
where item_code = :arg_item and
		inventory_qty <> 0 and
		organization_id = :arg_org

union all

select 'WORKSTAGE' WINDOW_GROUP,
		f_get_line_name( a.line_code  , a.organization_id)  location_code, 
		a.material_mfs,
		f_get_mat_ws_inv_qty_by_line( a.item_code ,  a.line_code , a.material_mfs ,  a.organization_id ) inventory_qty 
  from im_item_workstage_inventory a
where a.item_code = :arg_item 
    and a.organization_id = :arg_org 
    and f_get_mat_ws_inv_qty_by_line( a.item_code ,  a.line_code , a.material_mfs ,  a.organization_id ) <> 0 
group by a.line_code , a.item_code , a.material_mfs  , a.organization_id" arguments=(("arg_item", string),("arg_lang", string),("arg_org", number)) )
