 retrieve="  SELECT ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_NO~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"PURCHASE_ORDER_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"LINE_TYPE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_TYPE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"UNIT_PRICE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"CURRENCY~",   
         nvl(arrival_qty, 0) arrival_qty,   
         nvl(order_qty, 0) - nvl(arrival_qty , 0) order_remain_qty,   
         nvl(order_qty, 0) - nvl(arrival_qty , 0) order_remain_qty_org,   
         ~"IM_ITEM_PURCHASE_ORDER~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"MFS~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ENTER_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ENTER_BY~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         '' check_yn,   
         ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_GROUP_NO~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"INCIDENTAL_EXPENSE_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORIGIN_NATION_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_METHOD~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"DELIVERY_PLACE~",   
         ~"ID_ITEM~".~"ITEM_DIVISION~",   
         trunc(sysdate) DEPARTURE_DATE,   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORIGIN_MFS~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"SUBCONTRACT_INVOICE_NO~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_AMT~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"SHIPMENT_COMMENT~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"ATTN_NAME~",   
         ~"IM_ITEM_PURCHASE_ORDER~".~"CC_NAME~"  
    FROM ~"IM_ITEM_PURCHASE_ORDER~",   
         ~"ID_ITEM~",   
         ~"ICOM_SUPPLIER~"  
   WHERE ( ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" = ~"ICOM_SUPPLIER~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~" = ~"ICOM_SUPPLIER~".~"SUPPLIER_CODE~" ) and  
         ( ( ~"IM_ITEM_PURCHASE_ORDER~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ~"IM_ITEM_PURCHASE_ORDER~".~"SUPPLIER_CODE~" like :arg_supplier_code AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"PURCHASE_ORDER_DATE~" between :arg_dateset and :arg_dateend ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER~".~"ORGANIZATION_ID~" = :arg_org_id ) ) AND  
         ID_ITEM.ITEM_DIVISION  NOT IN  ('G','C') AND  
         nvl(~"IM_ITEM_PURCHASE_ORDER~".~"ORDER_QTY~",0) > nvl(arrival_qty,0)    
" update="IM_ITEM_PURCHASE_ORDER" updatewhere=0 updatekeyinplace=no arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org_id", number))  sort="order_group_no A supplier_code A item_code A delivery_date A " )
