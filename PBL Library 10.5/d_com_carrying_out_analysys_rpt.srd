table(column=(type=char(20) updatewhereclause=yes name=carrying_out_receiptor dbname="carrying_out_receiptor" )
 column=(type=char(20) updatewhereclause=yes name=carrying_out_item dbname="carrying_out_item" )
 column=(type=char(20) updatewhereclause=yes name=carrying_out_item_spec dbname="carrying_out_item_spec" )
 column=(type=number updatewhereclause=yes name=carrying_out_qty dbname="carrying_out_qty" )
 retrieve="  SELECT ~"IMAN_CARRYING_OUT~".~"ORGANIZATION_ID~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_RECEIPTOR~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM_SPEC~",   
         f_get_basecode( 'CARRYING OUT TYPE' , ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_TYPE~",  :ARG_LANG , ORGANIZATION_ID )  CARRYING_OUT_TYPE ,
         f_get_basecode( 'CARRYING OUT DIVISION' , ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DIVISION~",  :ARG_LANG , ORGANIZATION_ID )  CARRYING_OUT_DIVISION ,
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_QTY~"  
    FROM ~"IMAN_CARRYING_OUT~"   
WHERE CARRYING_OUT_DATE >= :ARG_DATESET
AND CARRYING_OUT_DATE <= :ARG_DATEEND
AND CARRYING_OUT_RECEIPTOR LIKE :ARG_SUPPLIER_CODE
AND CARRYING_OUT_ITEM LIKE :ARG_ITEM_CODE
AND ORGANIZATION_ID = :ARG_ORG" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_lang", string),("arg_org", number))  sort="carrying_out_receiptor A carrying_out_item A carrying_out_item_spec A " )
