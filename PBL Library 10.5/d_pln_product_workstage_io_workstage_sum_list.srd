release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=148 color="536870912" )
summary(height=76 color="134217728" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=run_no dbname="run_no" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=number updatewhereclause=yes name=io_qty dbname="io_qty" )
 retrieve="  SELECT ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~",   
         WORKSTAGE_CODE||'('||f_get_workstage_name ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_CODE~" )||')'  as WORKSTAGE_CODE ,
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"RUN_NO~"  ,
		SUM(IO_QTY) AS IO_QTY
    FROM ~"IP_PRODUCT_WORKSTAGE_IO~"  
   WHERE ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ACTUAL_DATE~" >= :arg_dateset ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ACTUAL_DATE~" <= :arg_dateend ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"ORGANIZATION_ID~" = :arg_org )    
GROUP BY  ~"IP_PRODUCT_WORKSTAGE_IO~".~"LINE_CODE~",   
        WORKSTAGE_CODE||'('||f_get_workstage_name ( ~"IP_PRODUCT_WORKSTAGE_IO~".~"WORKSTAGE_CODE~" )||')'  ,
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_WORKSTAGE_IO~".~"RUN_NO~"  " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_workstage_code", string),("arg_model_name", string),("arg_org", number))  sort="run_no A line_code A " )
group(level=1 header.height=0 trailer.height=104 by=("run_no" ) header.color="536870912" trailer.color="67108864" )
