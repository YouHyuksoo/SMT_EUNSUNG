 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number updatewhereclause=yes name=unit_price dbname="unit_price" )
 retrieve="  SELECT ID_ENG_BOM_TEMP.SESSION_ID,   
		ID_ENG_BOM_TEMP.PARENT_ITEM_CODE,   
		ID_ENG_BOM_TEMP.CHILD_ITEM_CODE,   
	
		ID_ENG_BOM_TEMP.SORT_SEQUENCE,   
		ID_ENG_BOM_TEMP.SORT_ORDER,   
		ID_ENG_BOM_TEMP.ITEM_UNIT_QTY,   
	
		ID_ENG_BOM_TEMP.WORKSTAGE_CODE,   
		A.ITEM_NAME PARENT_ITEM_NAME,   
		A.ITEM_SPEC PARENT_ITEM_SPEC,   
		B.ITEM_NAME  CHILD_ITEM_NAME,   
		B.ITEM_SPEC  CHILD_ITEM_SPEC,   

		B.ITEM_CLASS   ITEM_CLASS ,   
		B.ITEM_DIVISION   ITEM_DIVISION ,   
		'' STATUS ,
		'' CHECK_YN ,
		f_get_mat_inventory_qty( ID_ENG_BOM_TEMP.child_item_code , ID_ENG_BOM_TEMP.line_type , ID_ENG_BOM_TEMP.organization_id ) INVENTORY_QTY  ,
	    f_get_mat_max_unit_price_cfm( ID_ENG_BOM_TEMP.CHILD_ITEM_CODE , 'F' , SYSDATE , ID_ENG_BOM_TEMP.ORGANIZATION_ID ) UNIT_PRICE
    FROM ID_ENG_BOM_TEMP,   ID_ITEM A , ID_ITEM B  
   WHERE ( ID_ENG_BOM_TEMP.parent_item_code = a.item_code (+)) and  
         ( ID_ENG_BOM_TEMP.organization_id  = a.organization_id (+)) and
         (ID_ENG_BOM_TEMP.child_item_code = b.item_code (+)) and  
         ( ID_ENG_BOM_TEMP.organization_id  = b.organization_id (+)) and
         ( ID_ENG_BOM_TEMP.session_id  = :arg_session_id ) and
         ( ID_ENG_BOM_TEMP.organization_id  = :arg_org_id ) and
            ID_ENG_BOM_TEMP.BOM_LEVEL <> 1 AND
            ID_ENG_BOM_TEMP.LINE_TYPE NOT IN ( 'M' , 'S' ) AND 
            ID_ENG_BOM_TEMP.BOM_LEVEL <= :ARG_LIMIT_LEVEL AND 
           A.ITEM_CLASS LIKE :ARG_TOP_BOT " arguments=(("arg_session_id", number),("arg_plan_qty", number),("arg_actual_qty", number),("arg_limit_level", number),("arg_line_code", string),("arg_workstage_code", string),("arg_top_bot", string),("arg_org_id", number))  sort="item_division A " )
group(level=1 header.height=0 trailer.height=40 by=("item_division" ) header.color="536870912" trailer.color="536870912" )
