table(column=(type=number updatewhereclause=yes name=session_id dbname="id_eng_bom_temp.session_id" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="id_eng_bom_temp.parent_item_code" )
 column=(type=char(30) updatewhereclause=yes name=child_item_code dbname="id_eng_bom_temp.child_item_code" )
 column=(type=number updatewhereclause=yes name=sort_sequence dbname="id_eng_bom_temp.sort_sequence" )
