 column=(type=char(10) updatewhereclause=yes name=workstage_code dbname="id_eng_bom_temp.workstage_code" )
 column=(type=char(300) updatewhereclause=yes name=parent_item_name dbname="id_item.parent_item_name" )
 column=(type=char(300) updatewhereclause=yes name=parent_item_spec dbname="id_item.parent_item_spec" )
