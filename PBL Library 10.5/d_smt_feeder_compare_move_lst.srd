table(column=(type=char(30) updatewhereclause=yes name=line_code dbname="im_item_receipt_barcode.line_code" dbalias=".line_code" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="im_item_receipt_barcode.model_name" dbalias=".model_name" )
 column=(type=char(1) updatewhereclause=yes name=pcb_item dbname="im_item_receipt_barcode.pcb_item" dbalias=".pcb_item" )
 column=(type=char(1) updatewhereclause=yes name=shaft dbname="im_item_receipt_barcode.shaft" dbalias=".shaft" )
 column=(type=char(10) updatewhereclause=yes name=location_code dbname="im_item_receipt_barcode.location_code" dbalias=".location_code" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="im_item_receipt_barcode.item_code" dbalias=".item_code" )
 column=(type=char(20) updatewhereclause=yes name=lot_no dbname="im_item_receipt_barcode.lot_no" dbalias=".lot_no" )
 column=(type=char(50) updatewhereclause=yes name=item_barcode dbname="im_item_receipt_barcode.item_barcode" dbalias=".item_barcode" )
 column=(type=char(30) updatewhereclause=yes name=dest_line_code dbname="im_item_receipt_barcode.dest_line_code" dbalias=".dest_line_code" )
 retrieve="		SELECT :arg_line_code as line_code,
					 :arg_model_name as model_name ,
					 :arg_pcb_item as pcb_item ,
					 :arg_shaft as shaft ,
					 LOCATION_CODE,
					 ITEM_CODE,
					 LOT_NO,
					 ITEM_BARCODE,
					 :ARG_LINE_CODE_NEW as dest_line_code
			  FROM IM_ITEM_RECEIPT_BARCODE 
			 WHERE LINE_CODE         = :ARG_LINE_CODE
				AND FEEDING_MODEL  = :ARG_MODEL_NAME
				AND NVL(FEEDER_SHAFT ,'*') = NVL( :arg_shaft	  , '*')  
				AND ISSUE_COMPARE_YN = 'Y'
				AND FEEDING_YN = 'N'
				AND (ITEM_CODE , LOCATION_CODE ) IN					 

							( SELECT NVL(ITEM_CODE , '*')  , NVL(LOCATION_CODE , '*') 
							     FROM 

								(   SELECT A.ITEM_CODE ITEM_CODE , A.LOCATION_CODE LOCATION_CODE
									  FROM IB_PRODUCT_PLANDATA A
									 WHERE  A.LINE_CODE = :ARG_LINE_CODE
											 AND A.MODEL_NAME = :ARG_MODEL_NAME
											 AND A.PCB_ITEM = :ARG_PCB_ITEM
											 AND NVL (A.FEEDER_SHAFT, '*') = NVL (:ARG_SHAFT, '*')
											 AND A.REVISION = :ARG_REVISION
											 AND A.ORGANIZATION_ID = :ARG_ORG
											 
									UNION 
									
									SELECT B.ITEM_CODE ITEM_CODE , DECODE( SUBSTR(B.ITEM_CODE,1,3)   , 'EAX' , B.LOCATION_CODE , DECODE( 'Y' , 'Y' , F_SET_FEEDER_SHAFT_CHANGE( :ARG_LINE_CODE , :ARG_SHAFT_NEW , :ARG_SHAFT  ,  B.LOCATION_CODE ) , B.LOCATION_CODE ) ) LOCATION_CODE 
									  FROM IB_PRODUCT_PLANDATA B
									 WHERE  B.LINE_CODE = :ARG_LINE_CODE_NEW
											 AND B.MODEL_NAME = :ARG_MODEL_NAME_NEW
											 AND B.PCB_ITEM = :ARG_PCB_ITEM_NEW
											 AND NVL (B.FEEDER_SHAFT, '*') =  NVL (:ARG_SHAFT_NEW, '*')
											  AND B.REVISION = :ARG_REVISION_NEW 
											 AND B.ORGANIZATION_ID = :ARG_ORG
									) 
							)" arguments=(("arg_line_code", string),("arg_line_code_new", string),("arg_model_name", string),("arg_model_name_new", string),("arg_pcb_item", string),("arg_pcb_item_new", string),("arg_shaft", string),("ARG_SHAFT_NEW", string),("arg_revision", string),("arg_revision_new", string),("arg_org", number)) )
