 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_workstage_inventory~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"im_item_workstage_inventory.material_mfs~") COLUMN(NAME=~"im_item_workstage_inventory.item_code~") COLUMN(NAME=~"im_item_workstage_inventory.inventory_status~") COLUMN(NAME=~"im_item_workstage_inventory.organization_id~") COLUMN(NAME=~"im_item_workstage_inventory.line_type~") COLUMN(NAME=~"im_item_workstage_inventory.inventory_hold~") COLUMN(NAME=~"im_item_workstage_inventory.inventory_price~") COLUMN(NAME=~"im_item_workstage_inventory.inventory_qty~") COLUMN(NAME=~"im_item_workstage_inventory.inventory_amt~") COLUMN(NAME=~"im_item_workstage_inventory.enter_date~") COLUMN(NAME=~"im_item_workstage_inventory.enter_by~") COLUMN(NAME=~"im_item_workstage_inventory.last_modify_date~") COLUMN(NAME=~"im_item_workstage_inventory.last_modify_by~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_division~") COLUMN(NAME=~"im_item_workstage_inventory.line_code~") COLUMN(NAME=~"im_item_workstage_inventory.workstage_code~") COLUMN(NAME=~"im_item_workstage_inventory.mfs~") COLUMN(NAME=~"id_item.item_uom~")    JOIN (LEFT=~"id_item.item_code~"    OP =~"=~"RIGHT=~"im_item_workstage_inventory.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_workstage_inventory.organization_id~" )WHERE(    EXP1 =~"( ~~~"IM_ITEM_WORKSTAGE_INVENTORY~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_WORKSTAGE_INVENTORY~~~".~~~"INVENTORY_QTY~~~"~"   OP =~">~"    EXP2 =~"0 )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_WORKSTAGE_INVENTORY~~~".~~~"WORKSTAGE_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_workstage_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_WORKSTAGE_INVENTORY~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_workstage_code~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_item_code", string),("arg_workstage_code", string),("arg_org_id", number))  sort="organization_id A line_code A workstage_code A item_division A " )
