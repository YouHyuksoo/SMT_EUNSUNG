table(column=(type=char(10) updatewhereclause=yes name=issue_account dbname="im_item_issue.issue_account" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="im_item_issue.item_code" )
 column=(type=char(10) updatewhereclause=yes name=line_type dbname="im_item_issue.line_type" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 column=(type=number updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=number updatewhereclause=yes name=issue_amt dbname="issue_amt" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="im_item_issue.organization_id" )
 retrieve=" select  a.issue_account , a.item_code,   a.line_type , b.item_name,  b.item_spec, b.item_uom, 
       
            sum(a.issue_qty)  issue_qty, 
            sum(nvl(a.issue_amt,0)) issue_amt,
           
            a.organization_id           
 from    im_item_issue  a, 
            id_item    b
 where   a.item_code = b.item_code(+) 
 and      a.organization_id = b.organization_id(+)  
 and      a.issue_date between :arg_dateset   and  :arg_dateend
 and      a.item_code like :arg_item_code
and  a.issue_account like :arg_issue_account
 and      a.organization_id = :arg_org_id 
 and      a.issue_status <> 'C'
group by a.issue_account , a.item_code, a.line_type , b.item_name, b.item_spec, b.item_uom, a.organization_id
 
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_issue_account", string),("arg_org_id", number))  sort="organization_id A issue_account A item_code A " )
