footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=check_date dbname="check_date" )
 column=(type=number updatewhereclause=yes name=check_sequence dbname="check_sequence" )
 column=(type=char(30) updatewhereclause=yes name=lot_name dbname="lot_name" )
 column=(type=char(200) updatewhereclause=yes name=partname dbname="partname" )
 column=(type=char(1) updatewhereclause=yes name=check_status dbname="check_status" )
 column=(type=char(200) updatewhereclause=yes name=chipname dbname="chipname" )
 column=(type=char(200) updatewhereclause=yes name=check_msg dbname="check_msg" )
 column=(type=char(30) updatewhereclause=yes name=check_by dbname="check_by" )
 column=(type=char(30) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(30) updatewhereclause=yes name=machine dbname="machine" )
 column=(type=char(200) updatewhereclause=yes name=scan_partname dbname="scan_partname" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="location_code" )
 column=(type=char(10) updatewhereclause=yes name=table_id dbname="table_id" )
 column=(type=char(10) updatewhereclause=yes name=check_type dbname="check_type" )
 column=(type=char(100) updatewhereclause=yes name=ng_reason dbname="ng_reason" )
 column=(type=char(100) updatewhereclause=yes name=scan_supplier_partname dbname="scan_supplier_partname" )
 column=(type=char(50) updatewhereclause=yes name=unlock_by dbname="unlock_by" )
 column=(type=datetime updatewhereclause=yes name=unlock_date dbname="unlock_date" )
 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="pcb_item" )
 column=(type=number updatewhereclause=yes name=full_check_sequence dbname="full_check_sequence" )
 column=(type=datetime updatewhereclause=yes name=full_check_start_time dbname="full_check_start_time" )
 column=(type=datetime updatewhereclause=yes name=full_check_end_time dbname="full_check_end_time" )
 retrieve="SELECT  A.CHECK_DATE,   
         A.CHECK_SEQUENCE,   
         A.LOT_NAME,   
         A.PARTNAME,   
         A.CHECK_STATUS,   
         A.CHIPNAME,   
         A.CHECK_MSG,   
         A.CHECK_BY,   
         A.LINE_CODE,   
         A.MACHINE,   
         A.SCAN_PARTNAME,   
         A.LOCATION_CODE,   
         A.TABLE_ID,   
         A.CHECK_TYPE,   
         A.NG_REASON,   
         A.SCAN_SUPPLIER_PARTNAME,   
         A.UNLOCK_BY,   
         A.UNLOCK_DATE,   
         A.PCB_ITEM,   
         A.FULL_CHECK_SEQUENCE ,
		DECODE( A.CHECK_TYPE , '1' , CCS_CHECK_START_TIME , FULL_CHECK_START_TIME ) FULL_CHECK_START_TIME ,
		DECODE( A.CHECK_TYPE , '1' , CCS_CHECK_END_TIME , FULL_CHECK_END_TIME ) FULL_CHECK_END_TIME 

FROM
(
  SELECT A.CHECK_DATE,   
         A.CHECK_SEQUENCE,   
         A.LOT_NAME,   
         A.PARTNAME,   
         A.CHECK_STATUS,   
         A.CHIPNAME,   
         A.CHECK_MSG,   
         A.CHECK_BY,   
         A.LINE_CODE,   
         A.MACHINE,   
         A.SCAN_PARTNAME,   
         A.LOCATION_CODE,   
         A.TABLE_ID,   
         A.CHECK_TYPE,   
         A.NG_REASON,   
         A.SCAN_SUPPLIER_PARTNAME,   
         A.UNLOCK_BY,   
         A.UNLOCK_DATE,   
         A.PCB_ITEM,   
         A.FULL_CHECK_SEQUENCE ,

         A.CCS_END_DATE  CCS_CHECK_START_TIME,
		A.CCS_END_DATE  CCS_CHECK_END_TIME,

		( SELECT MIN(B.CHECK_DATE) 
             FROM IB_SMT_CHECKHIST B 
		  WHERE B.LINE_CODE = A.LINE_CODE 
               AND B.LOT_NAME = A.LOT_NAME 
               AND B.FULL_CHECK_SEQUENCE = A.FULL_CHECK_SEQUENCE  
               AND B.CHECK_TYPE = A.CHECK_TYPE
          ) FULL_CHECK_START_TIME,

		( SELECT MAX(B.CHECK_DATE) FROM IB_SMT_CHECKHIST B 
		  WHERE B.LINE_CODE = A.LINE_CODE 
               AND B.LOT_NAME = A.LOT_NAME 
               AND B.FULL_CHECK_SEQUENCE = A.FULL_CHECK_SEQUENCE  
               AND B.CHECK_TYPE = A.CHECK_TYPE 
           ) FULL_CHECK_END_TIME

    FROM IB_SMT_CHECKHIST   A 
WHERE          ( A.CHECK_DATE >= to_date(:arg_dateset,'yyyy-mm-dd hh24:mi:ss' )) AND  
         (A.CHECK_DATE <= to_date(:arg_dateend,'yyyy-mm-dd hh24:mi:ss' )) AND  
         ( A.LINE_CODE like :arg_line_code ) AND  
         (A.PARTNAME like :arg_item_code ) AND  
         ( NVL(A.CHECK_STATUS , '*') like :arg_check_status ) AND  
         ( A.CHECK_TYPE like :arg_check_type ) AND  
         ( A.LOT_NAME like :arg_model_name ) AND  
         A.SCAN_PARTNAME like :arg_lot_no    
) A" arguments=(("arg_dateset", string),("arg_dateend", string),("arg_line_code", string),("arg_model_name", string),("arg_item_code", string),("arg_lot_no", string),("arg_check_type", string),("arg_check_status", string),("arg_org", number))  sort="check_type A line_code A lot_name A full_check_start_time A full_check_sequence A check_date A machine A table_id A location_code A " )
