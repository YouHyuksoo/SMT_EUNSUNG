table(column=(type=datetime updatewhereclause=yes name=imcn_sample_input_hist_input_date dbname="imcn_sample_input_hist.input_date" )
 column=(type=char(20) updatewhereclause=yes name=imcn_sample_input_hist_line_code dbname="imcn_sample_input_hist.line_code" )
