 column=(type=datetime updatewhereclause=yes name=imcn_sample_input_hist_current_apply_date dbname="imcn_sample_input_hist.current_apply_date" )
 column=(type=char(30) updatewhereclause=yes name=ip_product_run_card_run_no dbname="ip_product_run_card.run_no" )
 column=(type=char(30) updatewhereclause=yes name=ip_product_run_card_item_code dbname="ip_product_run_card.item_code" )
 column=(type=char(100) updatewhereclause=yes name=ip_product_run_card_model_name dbname="ip_product_run_card.model_name" )
 column=(type=char(20) updatewhereclause=yes name=imcn_sample_input_hist_enter_by dbname="imcn_sample_input_hist.enter_by" )
 column=(type=datetime updatewhereclause=yes name=imcn_sample_input_hist_enter_date dbname="imcn_sample_input_hist.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=imcn_sample_input_hist_last_modify_by dbname="imcn_sample_input_hist.last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=imcn_sample_input_hist_last_modify_date dbname="imcn_sample_input_hist.last_modify_date" )
 column=(type=datetime updatewhereclause=yes name=imcn_sample_sample_apply_date dbname="imcn_sample.sample_apply_date" )
 column=(type=char(30) updatewhereclause=yes name=imcn_sample_input_hist_model_name dbname="imcn_sample_input_hist.model_name" )
 retrieve="  select h.input_date, 
           h.line_code, 
           h.sample_type, 
           h.sample_code, 
           h.sample_lot_no,  
           j.sample_spec, 
           h.current_apply_date, 
           r.run_no, 
           r.item_code, 
           r.model_name,  
           h.enter_by, 
           h.enter_date, 
           h.last_modify_by, 
           h.last_modify_date,
            j.sample_apply_date,
           h.model_name
    from IMCN_sample_input_hist h,
           ip_product_run_card r,
           imcn_sample            j
   where h.run_no               = r.run_no
     and h.organization_id     = r.organization_id
     and h.sample_code        = j.sample_code
     and h.sample_lot_no      = j.sample_lot_no
     and h.organization_id     = j.organization_id
     and h.input_date            >= trunc(:arg_input_sdate)
     and h.input_date            <  trunc(:arg_input_edate) + 1
     and h.line_code              like  :arg_line_code
     and h.sample_type          like  :arg_sample_type
     and h.sample_lot_no       like :arg_sample_lot_no
     and h.organization_id      like :arg_org_id
     and r.item_code             like :arg_model_item
    " arguments=(("arg_input_sdate", datetime),("arg_input_edate", datetime),("arg_line_code", string),("arg_sample_type", string),("arg_sample_lot_no", string),("arg_model_item", string),("arg_org_id", number))  sort="imcn_sample_input_hist_input_date A imcn_sample_input_hist_line_code A sample_type A imcn_sample_input_hist_sample_lot_no A " )
