summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" height.autosize=yes )
table(column=(type=char(7) updatewhereclause=yes name=div dbname="div" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="id_eng_bom_smt.parent_item_code" )
 column=(type=char(30) updatewhereclause=yes name=child_item_code dbname="id_eng_bom_smt.child_item_code" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(20) updatewhereclause=yes name=line_code dbname="id_eng_bom_smt.line_code" )
 column=(type=char(10) updatewhereclause=yes name=table_id dbname="id_eng_bom_smt.table_id" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="id_eng_bom_smt.location_code" )
 column=(type=char(30) updatewhereclause=yes name=pcb_item dbname="id_eng_bom_smt.pcb_item" )
 column=(type=char(0) updatewhereclause=yes name=our_barcode dbname="our_barcode" )
 column=(type=number updatewhereclause=yes name=item_unit_qty dbname="item_unit_qty" )
 column=(type=number updatewhereclause=yes name=feeding_qty dbname="feeding_qty" )
 column=(type=number updatewhereclause=yes name=actual_qty dbname="actual_qty" )
 column=(type=number updatewhereclause=yes name=unfeeding_qty dbname="unfeeding_qty" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" )
 column=(type=number updatewhereclause=yes name=plan_qty dbname="id_eng_bom_smt.plan_qty" )
 column=(type=number updatewhereclause=yes name=st_value dbname="st_value" )
 column=(type=char(50) updatewhereclause=yes name=smt_model_name dbname="id_eng_bom_smt.smt_model_name" )
 retrieve="  SELECT 'BOM'  DIV ,
         A.PARENT_ITEM_CODE,   
         A.CHILD_ITEM_CODE,   
         B.ITEM_NAME,   
         B.ITEM_SPEC,   
         A.LINE_CODE , 
         A.TABLE_ID,
         A.LOCATION_CODE ,
		A.PCB_ITEM,
		'' OUR_BARCODE ,
		SUM(A.ITEM_UNIT_QTY)  ITEM_UNIT_QTY ,
		SUM(F_GET_SHAFT_FEEDING_QTY(A.LINE_CODE , A.PARENT_ITEM_CODE , A.LOCATION_CODE , A.PCB_ITEM  , A.FEEDER_SHAFT ))  FEEDING_QTY,
         SUM(F_GET_FEEDER_ACTUAL_QTY( A.LINE_CODE , A.PARENT_ITEM_CODE , A.LOCATION_CODE , A.PCB_ITEM ))  ACTUAL_QTY ,
		SUM(F_GET_UNFEEDING_QTY(  A.LINE_CODE , A.PARENT_ITEM_CODE , A.CHILD_ITEM_CODE , A.LOCATION_CODE,A.FEEDER_SHAFT )) UNFEEDING_QTY ,
		DECODE( :ARG_INVENTORY_YN , 'Y' , f_get_mat_inventory_qty_all( A.CHILD_ITEM_CODE , A.organization_id) , 0 )  INVENTORY_QTY ,
		B.LOCATION_ADDRESS LOCATION_ADDRESS  ,
		:ARG_PLAN_QTY AS PLAN_QTY ,

         F_GET_MODEL_ST(A.PARENT_ITEM_CODE , A.LINE_CODE , 'A' , A.ORGANIZATION_ID ) ST_VALUE ,
		A.SMT_MODEL_NAME

		
    FROM ID_ENG_BOM_SMT A  ,   
         ID_ITEM B
   WHERE ( A.child_item_code = B.item_code (+)) and  
         ( A.organization_id = B.organization_id (+)) and  
 
         ( A.SMT_MODEL_NAME = :ARG_PARENT_ITEM ) and
         ( A.LINE_CODE = :ARG_LINE_CODE ) and
         ( A.DATESET <= :ARG_DATESET ) and
         ( NVL(A.DATEEND,  TO_DATE('99991231','YYYYMMDD')) >= :ARG_DATESET ) and
         ( A.PCB_ITEM LIKE :ARG_TOPBOT ) and
         ( NVL(A.FEEDER_SHAFT ,'A') LIKE :ARG_FEEDER_SHAFT ) and
         ( A.ORGANIZATION_ID = :ARG_ORG ) 
 
   GROUP BY 
			A.SMT_MODEL_NAME,
			A.PARENT_ITEM_CODE,   
			A.CHILD_ITEM_CODE,   
			B.ITEM_NAME,   
			B.ITEM_SPEC,   
			A.LINE_CODE , 
			A.TABLE_ID,
			A.LOCATION_CODE ,
			A.PCB_ITEM,
			A.FEEDER_SHAFT  ,
			A.ORGANIZATION_ID ,
			B.LOCATION_ADDRESS


UNION ALL 
  SELECT 'REPLACE' DIV ,
		A.PARENT_ITEM_CODE,   
         A.REPLACE_ITEM_CODE,   

         B.ITEM_NAME,   
         B.ITEM_SPEC,   
         A.LINE_CODE , 

         A.TABLE_ID,
         '' LOCATION_CODE ,
		A.PCB_ITEM,
		'' OUR_BARCODE ,
		SUM(A.ITEM_UNIT_QTY)  ITEM_UNIT_QTY ,
		0  FEEDING_QTY,
		0 ACTUAL_QTY ,
		0 UNFEEDING_QTY ,
		DECODE( :ARG_INVENTORY_YN , 'Y' , f_get_mat_inventory_qty_all( A.REPLACE_ITEM_CODE , A.organization_id) ,0)  INVENTORY_QTY ,
	     B.LOCATION_ADDRESS LOCATION_ADDRESS ,
		:ARG_PLAN_QTY AS PLAN_QTY ,
		0 ST_VALUE ,
		A.SMT_MODEL_NAME


    FROM ID_ENG_BOM_SMT_REPLACE A,   
              ID_ITEM B
   WHERE ( A.child_item_code = B.item_code (+)) and  
         ( A.organization_id = B.organization_id (+)) and  

         ( A.PARENT_ITEM_CODE = :ARG_PARENT_ITEM ) and
         ( A.LINE_CODE = :ARG_LINE_CODE ) and
         ( A.DATESET <= :ARG_DATESET ) and
         ( NVL(A.DATEEND,  TO_DATE('99991231','YYYYMMDD')) >= :ARG_DATESET ) and
         ( A.PCB_ITEM LIKE :ARG_TOPBOT ) and
         ( A.ORGANIZATION_ID = :ARG_ORG ) 
   GROUP BY 
			A.SMT_MODEL_NAME,
			A.PARENT_ITEM_CODE,   
			A.REPLACE_ITEM_CODE,   

			B.ITEM_NAME,   
			B.ITEM_SPEC,   
			
			A.LINE_CODE , 
			A.TABLE_ID,
			A.LOCATION_CODE, 
			A.PCB_ITEM,
			A.ORGANIZATION_ID ,
			B.LOCATION_ADDRESS" arguments=(("ARG_PARENT_ITEM", string),("ARG_DATESET", datetime),("ARG_LINE_CODE", string),("ARG_TOPBOT", string),("ARG_FEEDER_SHAFT", string),("arg_plan_qty", number),("ARG_INVENTORY_YN", string),("arg_org", number))  sort="line_code A production_quantity A " )
