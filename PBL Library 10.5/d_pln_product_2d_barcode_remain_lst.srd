table(column=(type=char(20) updatewhereclause=yes name=customer_code dbname="customer_code" )
 column=(type=char(50) updatewhereclause=yes name=model_name dbname="ip_product_run_card.model_name" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_run_card.item_code" )
 column=(type=datetime updatewhereclause=yes name=run_date dbname="ip_product_run_card.run_date" )
 column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_run_card.run_no" )
 column=(type=char(30) updatewhereclause=yes name=lot_no dbname="ip_product_run_card.lot_no" )
 column=(type=char(10) updatewhereclause=yes name=line_code dbname="ip_product_run_card.line_code" )
 column=(type=char(1) updatewhereclause=yes name=run_type dbname="ip_product_run_card.product_run_type" )
 column=(type=number updatewhereclause=yes name=lot_size dbname="ip_product_run_card.lot_size" )
 column=(type=number updatewhereclause=yes name=bcr_count dbname="bcr_count" )
 column=(type=number updatewhereclause=yes name=input_count dbname="input_count" )
 retrieve="  SELECT  /*+ orderd */  M.Customer_Code ,
         ~"P~".~"MODEL_NAME~",   
         ~"P~".~"ITEM_CODE~",   
         ~"P~".~"RUN_DATE~",   
         ~"P~".~"RUN_NO~",   
         ~"P~".~"LOT_NO~",   
         ~"P~".~"LINE_CODE~",   
         ~"P~".~"PRODUCT_RUN_TYPE~",   
         ~"P~".~"LOT_SIZE~",   
         COUNT(DISTINCT B.SERIAL_NO) AS BCR_COUNT,   
         COUNT(DISTINCT C.SERIAL_NO) AS INPUT_COUNT  
    FROM ~"IP_PRODUCT_RUN_CARD~" ~"P~",   
         ~"IP_PRODUCT_2D_BARCODE~" ~"B~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~" ~"C~",   
         ~"IP_PRODUCT_MODEL_MASTER~" ~"M~"  
   WHERE ( P.RUN_NO = B.RUN_NO(+) ) AND  
         ( B.SERIAL_NO = C.SERIAL_NO(+) ) AND  
         ( P.MODEL_NAME = M.MODEL_NAME(+) ) AND  
         ( P.ORGANIZATION_ID = :ARG_ORGANIZATION_ID ) AND  
         ( NVL( M.CUSTOMER_CODE,'*')  LIKE :ARG_CUSTOMER_CODE ) AND  
         ( P.RUN_NO LIKE :ARG_RUN_NO ) AND  
         ( P.MODEL_NAME LIKE :ARG_MODEL_NAME )   AND
         ( P.RUN_DATE >=  to_date(:ARG_S_RUNDATE,'yyyy-mm-dd') ) AND   
         ( P.RUN_DATE <  to_date(:ARG_E_RUNDATE,'yyyy-mm-dd') +1 )
GROUP BY M.Customer_Code ,
         ~"P~".~"MODEL_NAME~",   
         ~"P~".~"ITEM_CODE~",   
         ~"P~".~"RUN_DATE~",   
         ~"P~".~"RUN_NO~",   
         ~"P~".~"LOT_NO~",   
         ~"P~".~"LINE_CODE~",   
         ~"P~".~"PRODUCT_RUN_TYPE~",   
         ~"P~".~"LOT_SIZE~"  
ORDER BY (COUNT(DISTINCT B.SERIAL_NO)  - COUNT(DISTINCT C.SERIAL_NO)) DESC,
             M.Customer_Code ,
             ~"P~".~"MODEL_NAME~" ASC,   
              ~"P~".~"RUN_DATE~" DESC

//ORDER BY M.Customer_Code ,
//         ~"P~".~"MODEL_NAME~" ASC,   
//         ~"P~".~"RUN_DATE~" DESC
" arguments=(("ARG_MODEL_NAME", string),("ARG_RUN_NO", string),("ARG_CUSTOMER_CODE", string),("ARG_ORGANIZATION_ID", number),("ARG_S_RUNDATE", string),("ARG_E_RUNDATE", string)) )
