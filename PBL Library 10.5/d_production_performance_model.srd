       sum(case when substr(create_date,9,2) = '12' and operationname = 'SMT3500' then cnt else 0 end) as G_SMT3500,
       sum(case when substr(create_date,9,2) = '12' and operationname = 'PCB2300' then cnt else 0 end) as G_PCB2300,
