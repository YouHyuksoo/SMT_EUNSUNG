 retrieve="select model, item_code, buyer as Suffix,
       --$$HEX5$$74d5f9b27cc790c72000$$ENDHEX$$TOTAL
       0 as T_TOP,
       0 as T_BOT,
       sum(decode(operationname, 'SMT3500', cnt , 0)) as T_SMT3500,
       sum(decode(operationname, 'PCB2300', cnt , 0)) as T_PCB2300,
       sum(decode(operationname, 'PCB2100', cnt , 0)) as T_PCB2100,
       sum(decode(operationname, 'PCB8100', cnt , 0)) as T_PCB8100,
       --6~~7 = A_TIME
       0 as A_TOP,
       0 as A_BOT,
       sum(case when substr(create_date,9,2) = '06' and operationname = 'SMT3500' then cnt else 0 end) as A_SMT3500,
       sum(case when substr(create_date,9,2) = '06' and operationname = 'PCB2300' then cnt else 0 end) as A_PCB2300,
       sum(case when substr(create_date,9,2) = '06' and operationname = 'PCB2100' then cnt else 0 end) as A_PCB2100,
       sum(case when substr(create_date,9,2) = '06' and operationname = 'PCB8100' then cnt else 0 end) as A_PCB8100,
       --7~~8 = B_TIME
       0 as B_TOP,
       0 as B_BOT,
       sum(case when substr(create_date,9,2) = '07' and operationname = 'SMT3500' then cnt else 0 end) as B_SMT3500,
       sum(case when substr(create_date,9,2) = '07' and operationname = 'PCB2300' then cnt else 0 end) as B_PCB2300,
       sum(case when substr(create_date,9,2) = '07' and operationname = 'PCB2100' then cnt else 0 end) as B_PCB2100,
       sum(case when substr(create_date,9,2) = '07' and operationname = 'PCB8100' then cnt else 0 end) as B_PCB8100,
       --8~~9 = C_TIME
       0 as C_TOP,
       0 as C_BOT,
       sum(case when substr(create_date,9,2) = '08' and operationname = 'SMT3500' then cnt else 0 end) as C_SMT3500,
       sum(case when substr(create_date,9,2) = '08' and operationname = 'PCB2300' then cnt else 0 end) as C_PCB2300,
       sum(case when substr(create_date,9,2) = '08' and operationname = 'PCB2100' then cnt else 0 end) as C_PCB2100,
       sum(case when substr(create_date,9,2) = '08' and operationname = 'PCB8100' then cnt else 0 end) as C_PCB8100,
       --9~~10 = D_TIME
       0 as D_TOP,
       0 as D_BOT,
       sum(case when substr(create_date,9,2) = '09' and operationname = 'SMT3500' then cnt else 0 end) as D_SMT3500,
       sum(case when substr(create_date,9,2) = '09' and operationname = 'PCB2300' then cnt else 0 end) as D_PCB2300,
       sum(case when substr(create_date,9,2) = '09' and operationname = 'PCB2100' then cnt else 0 end) as D_PCB2100,
       sum(case when substr(create_date,9,2) = '09' and operationname = 'PCB8100' then cnt else 0 end) as D_PCB8100,
       --10~~11 = E_TIME
       0 as E_TOP,
       0 as E_BOT,
       sum(case when substr(create_date,9,2) = '10' and operationname = 'SMT3500' then cnt else 0 end) as E_SMT3500,
       sum(case when substr(create_date,9,2) = '10' and operationname = 'PCB2300' then cnt else 0 end) as E_PCB2300,
       sum(case when substr(create_date,9,2) = '10' and operationname = 'PCB2100' then cnt else 0 end) as E_PCB2100,
       sum(case when substr(create_date,9,2) = '10' and operationname = 'PCB8100' then cnt else 0 end) as E_PCB8100,
       --11~~12 = F_TIME
