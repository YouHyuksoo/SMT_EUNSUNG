       sum(case when substr(create_date,9,2) = '20' and operationname = 'PCB8100' then cnt else 0 end) as O_PCB8100,
         --21~~22 = P_TIME
       0 as p_TOP,
       0 as p_BOT,
       sum(case when substr(create_date,9,2) = '21' and operationname = 'SMT3500' then cnt else 0 end) as P_SMT3500,
       sum(case when substr(create_date,9,2) = '21' and operationname = 'PCB2300' then cnt else 0 end) as P_PCB2300,
       sum(case when substr(create_date,9,2) = '21' and operationname = 'PCB2100' then cnt else 0 end) as P_PCB2100,
       sum(case when substr(create_date,9,2) = '21' and operationname = 'PCB8100' then cnt else 0 end) as P_PCB8100,
       --22~~23 = Q_TIME
       0 as Q_TOP,
       0 as Q_BOT,
       sum(case when substr(create_date,9,2) = '22' and operationname = 'SMT3500' then cnt else 0 end) as Q_SMT3500,
       sum(case when substr(create_date,9,2) = '22' and operationname = 'PCB2300' then cnt else 0 end) as Q_PCB2300,
       sum(case when substr(create_date,9,2) = '22' and operationname = 'PCB2100' then cnt else 0 end) as Q_PCB2100,
       sum(case when substr(create_date,9,2) = '22' and operationname = 'PCB8100' then cnt else 0 end) as Q_PCB8100,
       --23~~00 = R_TIME
       0 as R_TOP,
       0 as R_BOT,
       sum(case when substr(create_date,9,2) = '23' and operationname = 'SMT3500' then cnt else 0 end) as R_SMT3500,
       sum(case when substr(create_date,9,2) = '23' and operationname = 'PCB2300' then cnt else 0 end) as R_PCB2300,
       sum(case when substr(create_date,9,2) = '23' and operationname = 'PCB2100' then cnt else 0 end) as R_PCB2100,
       sum(case when substr(create_date,9,2) = '23' and operationname = 'PCB8100' then cnt else 0 end) as R_PCB8100,
       --00~~01 = S_TIME
       0 as S_TOP,
       0 as S_BOT,
       sum(case when substr(create_date,9,2) = '00' and operationname = 'SMT3500' then cnt else 0 end) as S_SMT3500,
       sum(case when substr(create_date,9,2) = '00' and operationname = 'PCB2300' then cnt else 0 end) as S_PCB2300,
       sum(case when substr(create_date,9,2) = '00' and operationname = 'PCB2100' then cnt else 0 end) as S_PCB2100,
       sum(case when substr(create_date,9,2) = '00' and operationname = 'PCB8100' then cnt else 0 end) as S_PCB8100,
       --01~~02 = T_TIME
       0 as T_TOP,
       0 as T_BOT,
       sum(case when substr(create_date,9,2) = '01' and operationname = 'SMT3500' then cnt else 0 end) as T_SMT3500,
       sum(case when substr(create_date,9,2) = '01' and operationname = 'PCB2300' then cnt else 0 end) as T_PCB2300,
       sum(case when substr(create_date,9,2) = '01' and operationname = 'PCB2100' then cnt else 0 end) as T_PCB2100,
       sum(case when substr(create_date,9,2) = '01' and operationname = 'PCB8100' then cnt else 0 end) as T_PCB8100,
       --02~~03 = U_TIME
       0 as U_TOP,
       0 as U_BOT,
       sum(case when substr(create_date,9,2) = '02' and operationname = 'SMT3500' then cnt else 0 end) as U_SMT3500,
       sum(case when substr(create_date,9,2) = '02' and operationname = 'PCB2300' then cnt else 0 end) as U_PCB2300,
       sum(case when substr(create_date,9,2) = '02' and operationname = 'PCB2100' then cnt else 0 end) as U_PCB2100,
       sum(case when substr(create_date,9,2) = '02' and operationname = 'PCB8100' then cnt else 0 end) as U_PCB8100,
       --03~~04 = V_TIME
       0 as V_TOP,
       0 as V_BOT,
       sum(case when substr(create_date,9,2) = '03' and operationname = 'SMT3500' then cnt else 0 end) as V_SMT3500,
       sum(case when substr(create_date,9,2) = '03' and operationname = 'PCB2300' then cnt else 0 end) as V_PCB2300,
       sum(case when substr(create_date,9,2) = '03' and operationname = 'PCB2100' then cnt else 0 end) as V_PCB2100,
       sum(case when substr(create_date,9,2) = '03' and operationname = 'PCB8100' then cnt else 0 end) as V_PCB8100,
       --04~~05 = W_TIME
       0 as W_TOP,
       0 as W_BOT,
       sum(case when substr(create_date,9,2) = '04' and operationname = 'SMT3500' then cnt else 0 end) as W_SMT3500,
       sum(case when substr(create_date,9,2) = '04' and operationname = 'PCB2300' then cnt else 0 end) as W_PCB2300,
       sum(case when substr(create_date,9,2) = '04' and operationname = 'PCB2100' then cnt else 0 end) as W_PCB2100,
       sum(case when substr(create_date,9,2) = '04' and operationname = 'PCB8100' then cnt else 0 end) as W_PCB8100,
       --05~~06 = X_TIME
       0 as X_TOP,
       0 as X_BOT,
       sum(case when substr(create_date,9,2) = '05' and operationname = 'SMT3500' then cnt else 0 end) as X_SMT3500,
       sum(case when substr(create_date,9,2) = '05' and operationname = 'PCB2300' then cnt else 0 end) as X_PCB2300,
       sum(case when substr(create_date,9,2) = '05' and operationname = 'PCB2100' then cnt else 0 end) as X_PCB2100,
       sum(case when substr(create_date,9,2) = '05' and operationname = 'PCB8100' then cnt else 0 end) as X_PCB8100
from (
        select model, item_code, operationname, nvl(sum(actual),0) cnt, create_date, buyer
                  
         from ( 
             select model, item_code, operationname, product_id, 1 as actual , max(created_date) create_date, buyer
               from tb_vis_tstrslt x   
              where x.created_date >= :arg_sdate
                and x.created_date < :arg_edate
                --and x.test_count > 1
                and x.result = 'P' 
				  and x.model like :arg_model
               group by model, item_code, operationname, product_id, buyer
             
             union 
             
             select model, item_code, operationname, product_id, 1 , (created_date) , buyer
               from tb_vis_txnhistory x 
              where x.created_date >= :arg_sdate
                and x.created_date < :arg_edate
                and x.operationname = 'PCB8100'
        )
       group by model, item_code, operationname, create_date, buyer
       )
group by model, item_code, buyer" arguments=(("arg_sdate", string),("arg_edate", string),("arg_model", string))  sort="t_smt3500 D " )
