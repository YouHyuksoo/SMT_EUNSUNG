t_div_yn~") COLUMN(NAME=~"im_item_arrival.arrival_seq_no_origin~") COMPUTE(NAME=~"F_GET_MAT_UNIT_PRICE_CONFIRM( IM_ITEM_ARRIVAL.SUPPLIER_CODE,IM_ITEM_ARRIVAL.ITEM_CODE,IM_ITEM_ARRIVAL.LINE_TYPE ,TRUNC(SYSDATE) , IM_ITEM_ARRIVAL.ORGANIZATION_ID ) UNIT_PRICE_CFM~") COLUMN(NAME=~"id_item.auto_issue_yn~") COLUMN(NAME=~"im_item_arrival.arrival_location_code~") COLUMN(NAME=~"im_item_arrival.origin_supplier_code~") COLUMN(NAME=~"im_item_arrival.origin_mfs~") COLUMN(NAME=~"icom_supplier_b.supplier_name~") COLUMN(NAME=~"im_item_arrival.order_type~")    JOIN (LEFT=~"im_item_arrival.origin_supplier_code~"    OP =~"=~"RIGHT=~"icom_supplier_b.supplier_code~"    OUTER1 =~"im_item_arrival.origin_supplier_code~" )    JOIN (LEFT=~"im_item_arrival.organization_id~"    OP =~"=~"RIGHT=~"icom_supplier_b.organization_id~"    OUTER1 =~"im_item_arrival.organization_id~" )    JOIN (LEFT=~"im_item_arrival.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"im_item_arrival.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~" )    JOIN (LEFT=~"icom_supplier_a.supplier_code~"    OP =~"=~"RIGHT=~"im_item_arrival.supplier_code~" )    JOIN (LEFT=~"icom_supplier_a.organization_id~"    OP =~"=~"RIGHT=~"im_item_arrival.organization_id~" )WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ARRIVAL~~~".~~~"MATERIAL_MFS~~~"~"   OP =~"like~"    EXP2 =~":arg_material_mfs~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ARRIVAL_DATE~~~"~"   OP =~"between~"    EXP2 =~":arg_dateset and :arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ARRIVAL_TYPE~~~"~"   OP =~"=~"    EXP2 =~"'A' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ARRIVAL_STATUS~~~"~"   OP =~"=~"    EXP2 =~"'N' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"NVL(~~~"IM_ITEM_ARRIVAL~~~".~~~"ORDER_TYPE~~~" , '*')~"   OP =~"<>~"    EXP2 =~"'R'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"LINE_TYPE~~~"~"   OP =~"IN~"    EXP2 =~"( 'G' , 'D' , 'F' , 'L' , 'P' , 'Y' ,'N'))~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"ID_ITEM~~~".~~~"ITEM_DIVISION~~~"~"   OP =~"NOT IN~"    EXP2 =~"( 'G' , 'F','C' ) )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ARRIVAL~~~".~~~"INVOICE_NO~~~"~"   OP =~"like~"    EXP2 =~":arg_invoice_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ARRIVAL~~~".~~~"INSPECT_RESULT~~~"~"   OP =~"in~"    EXP2 =~"('P' ,'U')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"NVL(~~~"IM_ITEM_ARRIVAL~~~".~~~"INSPECT_RESULT~~~" , '*')~"   OP =~"like~"    EXP2 =~":arg_inspect_result~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ARRIVAL~~~".~~~"ARRIVAL_QTY~~~"~"   OP =~"<>~"    EXP2 =~"0~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_material_mfs~" TYPE = string)  ARG(NAME = ~"arg_invoice_no~" TYPE = string)  ARG(NAME = ~"arg_inspect_result~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " update="IM_ITEM_ARRIVAL" updatewhere=0 updatekeyinplace=no arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_material_mfs", string),("arg_invoice_no", string),("arg_inspect_result", string),("arg_org_id", number))  sort="inspect_result A supplier_code A item_code A order_group_no A invoice_no A material_mfs A " )
