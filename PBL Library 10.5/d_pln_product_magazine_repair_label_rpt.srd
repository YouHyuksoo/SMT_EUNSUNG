table(column=(type=char(50) updatewhereclause=yes name=model_name dbname="ip_product_run_card_io.model_name" dbalias="A.model_name" )
 column=(type=char(10) updatewhereclause=yes name=model_suffix dbname="ip_product_run_card_io.model_suffix" dbalias="A.model_suffix" )
 column=(type=datetime updatewhereclause=yes name=receipt_date dbname="ip_product_run_card_io.receipt_date" dbalias="A.receipt_date" )
 column=(type=char(4000) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(4000) updatewhereclause=yes name=workstage_code dbname="workstage_code" )
 column=(type=number updatewhereclause=yes name=lot_qty dbname="ip_product_run_card_io.lot_qty" dbalias="A.lot_qty" )
 column=(type=char(30) updatewhereclause=yes name=magazine_label_no dbname="ip_product_run_card_io.magazine_label_no" dbalias="A.magazine_label_no" )
 column=(type=char(4000) updatewhereclause=yes name=pcb_item dbname="pcb_item" )
 column=(type=char(32) updatewhereclause=yes name=magazine_label_barcode dbname="magazine_label_barcode" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_run_card_io.enter_by" dbalias="A.enter_by" )
 column=(type=char(20) updatewhereclause=yes name=last_line_code dbname="ip_product_run_card_io.last_line_code" dbalias="A.last_line_code" )
 column=(type=char(20) updatewhereclause=yes name=last_workstage_code dbname="ip_product_run_card_io.last_workstage_code" dbalias="A.last_workstage_code" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_run_card_io.organization_id" dbalias="A.organization_id" )
 column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_run_card_io.run_no" dbalias="A.run_no" )
 column=(type=char(32) updatewhereclause=yes name=run_no_barcode dbname="run_no_barcode" )
 column=(type=char(4000) updatewhereclause=yes name=magazine_label_type dbname="magazine_label_type" )
 column=(type=char(1) updatewhereclause=yes name=label_title dbname="ip_product_run_card_io.label_title" dbalias=".label_title" )
 column=(type=datetime updatewhereclause=yes name=run_date dbname="ip_product_run_card.run_date" dbalias="B.run_date" )
 column=(type=number updatewhereclause=yes name=lot_size dbname="ip_product_run_card.lot_size" dbalias="B.lot_size" )
 column=(type=number updatewhereclause=yes name=destroy_qty dbname="ip_product_run_card_io.destroy_qty" dbalias="A.destroy_qty" )
 column=(type=number updatewhereclause=yes name=repair_qty dbname="ip_product_run_card_io.repair_qty" dbalias="A.repair_qty" )
 column=(type=char(30) updatewhereclause=yes name=origin_magazine_label_no dbname="ip_product_run_card_io.origin_magazine_label_no" dbalias="A.origin_magazine_label_no" )
 retrieve="  SELECT A.MODEL_NAME,   
         A.MODEL_SUFFIX,   
         A.RECEIPT_DATE,   
         f_get_line_name(a.line_code, a.organization_id) as line_code, 
         f_get_workstage_name(a.workstage_code) as WORKSTAGE_CODE, 
         A.LOT_QTY,   
         A.MAGAZINE_LABEL_NO,   
          f_get_basecode('PCB ITEM',a.pcb_item, :arg_lang,a.organization_id) as PCB_ITEM, 
    
         '*'||A.MAGAZINE_LABEL_NO||'*' MAGAZINE_LABEL_BARCODE,   
         A.ENTER_BY,   
         A.LAST_LINE_CODE,   
         A.LAST_WORKSTAGE_CODE  ,
         A.ORGANIZATION_ID  AS ORGANIZATION_ID ,
         A.RUN_NO ,
	     '*'||A.RUN_NO||'*' RUN_NO_BARCODE ,
		f_get_basecode('MAGAZINE LABEL TYPE',a.magazine_label_type, :arg_lang, a.organization_id ) as MAGAZINE_LABEL_TYPE  , 
         :ARG_LABEL_TITLE   LABEL_TITLE ,
		B.RUN_DATE , B.LOT_SIZE  ,
		A.DESTROY_QTY ,
		A.REPAIR_QTY, 
         A.ORIGIN_MAGAZINE_LABEL_NO
    FROM IP_PRODUCT_RUN_CARD_IO A  , IP_PRODUCT_RUN_CARD B 
   WHERE ( A.MAGAZINE_LABEL_NO = :ARG_MAGAZINE_LABEL_NO )
       AND  ( A.ORGANIZATION_ID = :ARG_ORG )    
       AND  A.RUN_NO = B.RUN_NO(+) 
" arguments=(("ARG_MAGAZINE_LABEL_NO", string),("ARG_LABEL_TITLE", string),("ARG_ORG", number),("ARG_LANG", string)) )
