 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(1) updatewhereclause=yes name=inventory_status dbname="im_item_inventory.inventory_status" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 column=(type=char(20) updatewhereclause=yes name=item_class dbname="id_item.item_class" )
 retrieve="  SELECT ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",   
          DECODE(SUM(~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~") , 0 , 0 ,  SUM(~"IM_ITEM_INVENTORY~".~"INVENTORY_AMT~") / SUM(~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~")) INVENTORY_PRICE,   
         SUM(~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~") INVENTORY_QTY,   
         SUM(~"IM_ITEM_INVENTORY~".~"INVENTORY_AMT~") INVENTORY_AMT,   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"ID_ITEM~".~"ITEM_UOM~" ,
         ~"ID_ITEM~".~"ITEM_CLASS~" 

    FROM ~"IM_ITEM_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and  
          ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
          ( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
          ( 
	     ( NVL(~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~",'*')  like :arg_location_code ) AND  
          ( SIGN(~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~") >= :arg_sign ) AND
		( NVL(~"ID_ITEM~".~"ITEM_CLASS~",'*' )  LIKE :ARG_ITEM_CLASS ) AND
          ( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )
GROUP BY   ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_UOM~" ,
	    ~"ID_ITEM~".~"ITEM_CLASS~" 
" arguments=(("arg_item_code", string),("arg_location_code", string),("arg_sign", number),("arg_item_class", string),("arg_org_id", number))  sort="organization_id A item_class A item_code A " )
