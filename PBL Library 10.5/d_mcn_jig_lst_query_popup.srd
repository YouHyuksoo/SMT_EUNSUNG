 column=(type=number updatewhereclause=yes name=imcn_jig_hit_value dbname="imcn_jig.hit_value" )
 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="imcn_jig.pcb_item" )
 column=(type=char(10) updatewhereclause=yes name=solder_type dbname="imcn_jig.solder_type" )
 column=(type=number updatewhereclause=yes name=imcn_jig_apply_model_organization_id dbname="imcn_jig_apply_model.organization_id" )
 retrieve="
select m.item_code, j.jig_type, m.jig_lot_no, j.jig_name, j.jig_spec, j.jig_status, j.use_status, j.break_value, j.hit_value, j.pcb_item, j.solder_type, m.organization_id
  from imcn_jig_apply_model M,
       imcn_jig             J
 where M.item_code like '%'
   and M.jig_lot_no = J.jig_lot_no
   and m.item_code        = :ARG_ITEM_CODE
   and m.organization_id = :ARG_ORG_ID" arguments=(("ARG_ITEM_CODE", string),("ARG_ORG_ID", number))  sort="jig_type A imcn_jig_apply_model_jig_lot_no A " )
