 column=(type=number updatewhereclause=yes name=issue_packing_qty dbname="id_item.issue_packing_qty" )
 column=(type=number updatewhereclause=yes name=unit_price dbname="unit_price" )
 column=(type=char(30) updatewhereclause=yes name=location_address_rack dbname="im_item_inventory.location_address_rack" )
 column=(type=char(1) updatewhereclause=yes name=inventory_type dbname="im_item_inventory.inventory_type" )
 retrieve="  SELECT 'N' check_yn,   
         'INTERNAL' WAREHOUSE_TYPE,   
         ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_HOLD~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_AMT~",   
         ~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"COMMENTS~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_BY~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~",   
         INVENTORY_QTY ISSUE_QTY,   
         ~"ID_ITEM~".~"ISSUE_PACKING_QTY~"  ,

		 f_get_mat_max_unit_price_cfm( IM_ITEM_INVENTORY.item_code , IM_ITEM_INVENTORY.line_type , sysdate , IM_ITEM_INVENTORY.organization_id ) UNIT_PRICE ,
          location_address_rack ,
          IM_ITEM_INVENTORY.inventory_type
    FROM ~"IM_ITEM_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~" like :arg_material_mfs AND  
         sign(~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~") >= :arg_sign AND  
         NVL(~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~",'*') like :arg_location_code AND  
         ( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    

UNION  ALL

  SELECT 'N' check_yn,   
         'RECYCLE' WAREHOUSE_TYPE,   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_HOLD~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_AMT~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LOCATION_CODE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"COMMENTS~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ENTER_DATE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"ENTER_BY~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"MATERIAL_MFS~",   
         INVENTORY_QTY ISSUE_QTY,   
         ~"ID_ITEM~".~"ISSUE_PACKING_QTY~"  ,
		0,
         '' location_address_rack ,
         '' inventory_type
    FROM ~"IM_ITEM_RECYCLE_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ~"IM_ITEM_RECYCLE_INVENTORY~".~"MATERIAL_MFS~" like :arg_material_mfs AND  
         sign(~"IM_ITEM_RECYCLE_INVENTORY~".~"INVENTORY_QTY~") >= :arg_sign AND  
         NVL(~"IM_ITEM_RECYCLE_INVENTORY~".~"LOCATION_CODE~",'*') like :arg_location_code AND  
         ( ~"IM_ITEM_RECYCLE_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    


" arguments=(("arg_item_code", string),("arg_material_mfs", string),("arg_sign", number),("arg_location_code", string),("arg_org_id", number))  sort="organization_id A warehouse_type A location_code A item_code A " )
