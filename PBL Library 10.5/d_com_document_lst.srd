 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"icom_document~" )  TABLE(NAME=~"ip_product_model_master~" ) COLUMN(NAME=~"icom_document.model_name~") COLUMN(NAME=~"ip_product_model_master.model_desc~") COLUMN(NAME=~"ip_product_model_master.model_spec~") COLUMN(NAME=~"icom_document.doc_id~") COLUMN(NAME=~"icom_document.doc_name~") COLUMN(NAME=~"icom_document.doc_keyword~") COLUMN(NAME=~"icom_document.doc_comment~") COLUMN(NAME=~"icom_document.enter_date~") COLUMN(NAME=~"icom_document.enter_by~") COLUMN(NAME=~"icom_document.last_modify_date~") COLUMN(NAME=~"icom_document.last_modify_by~") COLUMN(NAME=~"icom_document.organization_id~") COLUMN(NAME=~"icom_document.doc_group~") COLUMN(NAME=~"icom_document.doc_file_name~") COLUMN(NAME=~"icom_document.doc_code~") COLUMN(NAME=~"icom_document.line_code~") COLUMN(NAME=~"icom_document.workstage_code~") COLUMN(NAME=~"icom_document.machine_code~") COLUMN(NAME=~"icom_document.dateset~") COLUMN(NAME=~"icom_document.dateend~") COMPUTE(NAME=~"ICOM_DOCUMENT.ROWID~")    JOIN (LEFT=~"icom_document.model_name~"    OP =~"=~"RIGHT=~"ip_product_model_master.item_code~"    OUTER1 =~"icom_document.model_name~" )    JOIN (LEFT=~"icom_document.organization_id~"    OP =~"=~"RIGHT=~"ip_product_model_master.organization_id~"    OUTER1 =~"icom_document.organization_id~" )WHERE(    EXP1 =~"~~~"ICOM_DOCUMENT~~~".~~~"MODEL_NAME~~~"~"   OP =~"like~"    EXP2 =~":ARG_ITEM_CODE~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(~~~"ICOM_DOCUMENT~~~".~~~"DOC_GROUP~~~",'*')~"   OP =~"like~"    EXP2 =~":ARG_DOC_GROUP )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(~~~"ICOM_DOCUMENT~~~".~~~"DOC_KEYWORD~~~" , '*')~"   OP =~"like~"    EXP2 =~":ARG_DOC_KEYWORD )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"ICOM_DOCUMENT~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG )~" ) ) ARG(NAME = ~"ARG_ITEM_CODE~" TYPE = string)  ARG(NAME = ~"ARG_DOC_GROUP~" TYPE = string)  ARG(NAME = ~"ARG_DOC_KEYWORD~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " update="ICOM_DOCUMENT" updatewhere=0 updatekeyinplace=no arguments=(("ARG_ITEM_CODE", string),("ARG_DOC_GROUP", string),("ARG_DOC_KEYWORD", string),("ARG_ORG", number))  sort="model_name A workstage_code A " )
