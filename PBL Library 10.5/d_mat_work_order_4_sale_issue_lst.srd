 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_work_order~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"im_item_work_order.work_order_no~") COLUMN(NAME=~"im_item_work_order.organization_id~") COLUMN(NAME=~"im_item_work_order.plan_yyyymm~") COLUMN(NAME=~"im_item_work_order.plan_priority~") COLUMN(NAME=~"im_item_work_order.plan_date~") COLUMN(NAME=~"im_item_work_order.shift_code~") COLUMN(NAME=~"im_item_work_order.item_type~") COLUMN(NAME=~"im_item_work_order.item_code~") COLUMN(NAME=~"im_item_work_order.line_type~") COLUMN(NAME=~"im_item_work_order.issue_date~") COLUMN(NAME=~"im_item_work_order.line_code~") COLUMN(NAME=~"im_item_work_order.workstage_code~") COLUMN(NAME=~"im_item_work_order.issue_type~") COLUMN(NAME=~"im_item_work_order.mfs~") COLUMN(NAME=~"im_item_work_order.issue_division~") COLUMN(NAME=~"im_item_work_order.model_unit_qty~") COLUMN(NAME=~"im_item_work_order.issue_plan_qty~") COLUMN(NAME=~"im_item_work_order.issue_qty~") COLUMN(NAME=~"im_item_work_order.issue_account~") COLUMN(NAME=~"im_item_work_order.issue_status~") COLUMN(NAME=~"im_item_work_order.work_order_type~") COLUMN(NAME=~"im_item_work_order.enter_by~") COLUMN(NAME=~"im_item_work_order.enter_date~") COLUMN(NAME=~"im_item_work_order.last_modify_by~") COLUMN(NAME=~"im_item_work_order.last_modify_date~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COMPUTE(NAME=~"'N' CHECK_YN~") COMPUTE(NAME=~"NVL(ISSUE_PLAN_QTY,0) - NVL(ISSUE_QTY,0) REQUEST_REMAIN~") COMPUTE(NAME=~"NVL(ISSUE_PLAN_QTY,0) - NVL(ISSUE_QTY,0) REQUEST_REMAIN_ORG~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"im_item_work_order.parent_item_code~") COLUMN(NAME=~"im_item_work_order.plan_date_sequence~") COMPUTE(NAME=~"F_GET_MAT_INVENTORY_QTY(IM_ITEM_WORK_ORDER.ITEM_CODE , IM_ITEM_WORK_ORDER.LINE_TYPE , IM_ITEM_WORK_ORDER.ORGANIZATION_ID ) INVENTORY_QTY~")    JOIN (LEFT=~"im_item_work_order.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_work_order.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_WORK_ORDER~~~".~~~"PLAN_DATE~~~"~"   OP =~"BETWEEN~"    EXP2 =~":ARG_DATESET AND :ARG_DATEEND )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_WORK_ORDER~~~".~~~"ITEM_CODE~~~"~"   OP =~"LIKE~"    EXP2 =~":ARG_ITEM_CODE )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_WORK_ORDER~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG_ID ) )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_WORK_ORDER~~~".~~~"ISSUE_ACCOUNT~~~"~"   OP =~"=~"    EXP2 =~"'M004'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(ISSUE_PLAN_QTY,0)~"   OP =~">~"    EXP2 =~"NVL(ISSUE_QTY,0) )~" ) ) ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_org_id", number))  sort="organization_id A item_code A plan_date A " )
