 retrieve="  SELECT ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"RECEIPT_DATE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"LINE_CODE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"PRODUCT_ACTUAL_QTY~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"ORIGIN_COUNT~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"LAST_RECEIPT_DATE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"ADJUST_QTY~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"RECEIPT_SEQUENCE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"WORKSTAGE_CODE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"ENTER_BY~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"LAST_MODIFY_BY~",   
         ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"PRODUCT_ACTUAL_SUM~",   
         ~"IP_PRODUCT_LINE~".~"LAST_ACTUAL_DATE~",   
         ~"IP_PRODUCT_LINE~".~"NSNP_REASON~",   
         ~"IP_PRODUCT_LINE~".~"REAL_ST~",   
         ~"IP_PRODUCT_LINE~".~"NSNP_STATUS~",   
         ~"IP_PRODUCT_LINE~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_LINE~".~"MODEL_SUFFIX~",   
         ( SYSDATE - ~"IP_PRODUCT_LINE~".~"LAST_ACTUAL_DATE~" ) * 24 * 60 * 60   ,
f_get_carrier_size( ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"MODEL_NAME~",    ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"ORGANIZATION_ID~" ) carrier_size
    FROM ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~",   
         ~"IP_PRODUCT_LINE~"  
   WHERE ( ip_product_line.line_code = ip_product_sensor_actual_back.line_code (+)) and  
         ( ( ~"IP_PRODUCT_SENSOR_ACTUAL_BACK~".~"LINE_CODE~" like :ARG_LINE_CODE ) )    
" arguments=(("ARG_LINE_CODE", string))  sort="line_code A last_receipt_date A " )
