 retrieve="  SELECT ~"IQ_DAILY_NOTIFY~".~"ACTION_DATE~",   
         ~"IQ_DAILY_NOTIFY~".~"LINE_CODE~",   
         ~"IQ_DAILY_NOTIFY~".~"LINE_STATUS_NOTIFY~",   
         ~"IQ_DAILY_NOTIFY~".~"ENTER_DATE~",   
         ~"IQ_DAILY_NOTIFY~".~"ENTER_BY~",   
         ~"IQ_DAILY_NOTIFY~".~"LAST_MODIFY_DATE~",   
         ~"IQ_DAILY_NOTIFY~".~"LAST_MODIFY_BY~",   
         ~"IQ_DAILY_NOTIFY~".~"ORGANIZATION_ID~",   
         ~"IQ_DAILY_NOTIFY~".~"NOTIFY_SEQUENCE~",   
         ~"IQ_DAILY_NOTIFY~".~"START_TIME~",   
         ~"IQ_DAILY_NOTIFY~".~"END_TIME~",   
         ~"IQ_DAILY_NOTIFY~".~"ITEM_CODE~",   
         ~"IQ_DAILY_NOTIFY~".~"INSPECT_BAD_QTY~",   
         ~"IQ_DAILY_NOTIFY~".~"GRADE~",   
         ~"IQ_DAILY_NOTIFY~".~"INSPECT_QTY~",   
         ~"IQ_DAILY_NOTIFY~".~"BAD_REASON_CODE~",   
         ~"IQ_DAILY_NOTIFY~".~"WORKSTAGE_CODE~",   
         ~"IQ_DAILY_NOTIFY~".~"RUN_NO~",   
         ~"IQ_DAILY_NOTIFY~".~"COMPLETE_YN~",   
         ~"IQ_DAILY_NOTIFY~".~"COMPLETE_DATE~",   
         ~"IQ_DAILY_NOTIFY~".~"NOTIFY_STATUS~",   
         ~"IQ_DAILY_NOTIFY~".~"COMMENTS~",   
         ~"IQ_DAILY_NOTIFY~".~"MODEL_NAME~",   
         ~"IQ_DAILY_NOTIFY~".~"DETECT_LOCATION~",   
         ~"IQ_DAILY_NOTIFY~".~"MATERIAL_MAKER~",   
         ~"IQ_DAILY_NOTIFY~".~"MACHINE_CODE~",   
         ~"IQ_DAILY_NOTIFY~".~"LOCATION_INFO~",   
         ~"IQ_DAILY_NOTIFY~".~"BAD_DESCRIPTION~",   
         ~"IQ_DAILY_NOTIFY~".~"INSPECT_CHARGER~",   
         ~"IQ_DAILY_NOTIFY~".~"INSPECT_MANAGER~",   
		LENGTH( NG_IMAGE) FILE1 ,
		LENGTH( INSPECT_IMAGE) FILE2 ,
		LENGTH( DOCUMENT_IMAGE) FILE3,
         ROWID  
    FROM ~"IQ_DAILY_NOTIFY~"  
   WHERE ( TRUNC(~"IQ_DAILY_NOTIFY~".~"ACTION_DATE~") >= :arg_dateset ) AND  
         ( TRUNC(~"IQ_DAILY_NOTIFY~".~"ACTION_DATE~") <= :arg_dateend ) AND  
         ~"IQ_DAILY_NOTIFY~".~"MODEL_NAME~" like :arg_mdel_name AND  
         ( NVL(~"IQ_DAILY_NOTIFY~".~"LINE_CODE~",'*') like :arg_line_code ) AND  
         ( ~"IQ_DAILY_NOTIFY~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( NVL(~"IQ_DAILY_NOTIFY~".~"ITEM_CODE~",'*') like :arg_item_code ) AND  
         ( NVL(~"IQ_DAILY_NOTIFY~".~"MATERIAL_MAKER~" ,'*') like :arg_material_maker ) AND  
         ( ~"IQ_DAILY_NOTIFY~".~"ORGANIZATION_ID~" = :arg_org ) AND  
         ( NVL(~"IQ_DAILY_NOTIFY~".~"MACHINE_CODE~" , '*') like :arg_machine_code )    AND 

		( UPPER(NVL(LINE_STATUS_NOTIFY,'*') ) LIKE :ARG_KEY_WORD OR UPPER(NVL(COMMENTS,'*') ) LIKE :ARG_KEY_WORD OR UPPER(NVL(BAD_DESCRIPTION,'*') ) LIKE  :ARG_KEY_WORD )
" update="IQ_DAILY_NOTIFY" updatewhere=0 updatekeyinplace=no arguments=(("arg_mdel_name", string),("arg_line_code", string),("arg_workstage_code", string),("arg_item_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_material_maker", string),("arg_machine_code", string),("arg_key_word", string),("arg_org", number))  sort="action_date A notify_sequence A line_code A " )
