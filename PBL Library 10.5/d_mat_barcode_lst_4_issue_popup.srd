 column=(type=char(1000) updatewhereclause=yes name=feeding_model dbname="im_item_receipt_barcode.feeding_model" )
 column=(type=char(0) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(30) updatewhereclause=yes name=origin_lot_no dbname="im_item_receipt_barcode.origin_lot_no" )
 column=(type=datetime updatewhereclause=yes name=lot_divide_date dbname="im_item_receipt_barcode.lot_divide_date" )
 column=(type=char(20) updatewhereclause=yes name=location_address dbname="id_item.location_address" )
 column=(type=char(1) updatewhereclause=yes name=feeder_shaft dbname="im_item_receipt_barcode.feeder_shaft" )
 column=(type=char(10) updatewhereclause=yes name=location_code dbname="im_item_receipt_barcode.location_code" )
 column=(type=number updatewhereclause=yes name=new_scan_qty dbname="im_item_receipt_barcode.new_scan_qty" )
 column=(type=char(30) updatewhereclause=yes name=line_code dbname="im_item_receipt_barcode.line_code" )
 column=(type=datetime updatewhereclause=yes name=feeding_date dbname="im_item_receipt_barcode.feeding_date" )
