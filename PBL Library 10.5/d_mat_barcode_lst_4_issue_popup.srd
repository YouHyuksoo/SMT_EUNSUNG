 column=(type=char(1) updatewhereclause=yes name=receipt_type dbname="im_item_receipt_barcode.receipt_type" )
 column=(type=char(1) updatewhereclause=yes name=return_yn dbname="im_item_receipt_barcode.return_yn" )
 column=(type=char(10) updatewhereclause=yes name=im_item_receipt_barcode_revision dbname="im_item_receipt_barcode.revision" )
 column=(type=char(1) updatewhereclause=yes name=im_item_receipt_barcode_issue_division dbname="im_item_receipt_barcode.issue_division" )
 retrieve="  SELECT IM_ITEM_RECEIPT_BARCODE.ITEM_BARCODE,   
         IM_ITEM_RECEIPT_BARCODE.SUPPLIER_CODE,   
         IM_ITEM_RECEIPT_BARCODE.ITEM_CODE,   
         IM_ITEM_RECEIPT_BARCODE.SCAN_DATE,   
         IM_ITEM_RECEIPT_BARCODE.LOT_NO,   
         IM_ITEM_RECEIPT_BARCODE.SCAN_QTY,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_COMPARE_YN,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_COMPARE_DATE,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_COMPARE_BY,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_YN,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_DATE,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_BY,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_TYPE,   
         IM_ITEM_RECEIPT_BARCODE.LOT_DIVIDE_YN,   
         IM_ITEM_RECEIPT_BARCODE.LABEL_TYPE,   
         IM_ITEM_RECEIPT_BARCODE.FEEDING_YN,   
         IM_ITEM_RECEIPT_BARCODE.FEEDING_MODEL,   
         '' check_yn,   
         IM_ITEM_RECEIPT_BARCODE.ORIGIN_LOT_NO,   
         IM_ITEM_RECEIPT_BARCODE.LOT_DIVIDE_DATE,   
         ID_ITEM.LOCATION_ADDRESS,   
         IM_ITEM_RECEIPT_BARCODE.FEEDER_SHAFT,   
         IM_ITEM_RECEIPT_BARCODE.LOCATION_CODE,   
         IM_ITEM_RECEIPT_BARCODE.NEW_SCAN_QTY,   
         IM_ITEM_RECEIPT_BARCODE.LINE_CODE,   
         IM_ITEM_RECEIPT_BARCODE.FEEDING_DATE,   
         IM_ITEM_RECEIPT_BARCODE.REAL_DIVIDE_REASON,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_TYPE,   
         IM_ITEM_RECEIPT_BARCODE.RETURN_YN,   
         IM_ITEM_RECEIPT_BARCODE.REVISION,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_DIVISION  
    FROM IM_ITEM_RECEIPT_BARCODE,   
         ID_ITEM  
   WHERE ( im_item_receipt_barcode.item_code = id_item.item_code (+)) and  
         ( IM_ITEM_RECEIPT_BARCODE.LINE_CODE = :arg_line_code ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.FEEDING_MODEL = :arg_model_name ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.FEEDER_SHAFT = :arg_feeder_shaft ) AND  
         ( NVL(IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_YN , 'N') = 'Y' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.FEEDING_YN = 'N' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.BARCODE_STATUS <> 'C' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.RETURN_YN <> 'Y' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.ORGANIZATION_ID = :arg_org )   

UNION ALL

  SELECT IM_ITEM_RECEIPT_BARCODE.ITEM_BARCODE,   
         IM_ITEM_RECEIPT_BARCODE.SUPPLIER_CODE,   
         IM_ITEM_RECEIPT_BARCODE.ITEM_CODE,   
         IM_ITEM_RECEIPT_BARCODE.SCAN_DATE,   
         IM_ITEM_RECEIPT_BARCODE.LOT_NO,   
         IM_ITEM_RECEIPT_BARCODE.SCAN_QTY,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_COMPARE_YN,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_COMPARE_DATE,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_COMPARE_BY,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_YN,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_DATE,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_BY,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_TYPE,   
         IM_ITEM_RECEIPT_BARCODE.LOT_DIVIDE_YN,   
         IM_ITEM_RECEIPT_BARCODE.LABEL_TYPE,   
         IM_ITEM_RECEIPT_BARCODE.FEEDING_YN,   
         IM_ITEM_RECEIPT_BARCODE.FEEDING_MODEL,   
         '' check_yn,   
         IM_ITEM_RECEIPT_BARCODE.ORIGIN_LOT_NO,   
         IM_ITEM_RECEIPT_BARCODE.LOT_DIVIDE_DATE,   
         ID_ITEM.LOCATION_ADDRESS,   
         IM_ITEM_RECEIPT_BARCODE.FEEDER_SHAFT,   
         IM_ITEM_RECEIPT_BARCODE.LOCATION_CODE,   
         IM_ITEM_RECEIPT_BARCODE.NEW_SCAN_QTY,   
         IM_ITEM_RECEIPT_BARCODE.LINE_CODE,   
         IM_ITEM_RECEIPT_BARCODE.FEEDING_DATE,   
         IM_ITEM_RECEIPT_BARCODE.REAL_DIVIDE_REASON,   
         IM_ITEM_RECEIPT_BARCODE.RECEIPT_TYPE,   
         IM_ITEM_RECEIPT_BARCODE.RETURN_YN,   
         IM_ITEM_RECEIPT_BARCODE.REVISION,   
         IM_ITEM_RECEIPT_BARCODE.ISSUE_DIVISION  
    FROM IM_ITEM_RECEIPT_BARCODE,   
         ID_ITEM  
   WHERE ( im_item_receipt_barcode.item_code = id_item.item_code (+)) and  
         ( IM_ITEM_RECEIPT_BARCODE.LINE_CODE = :arg_line_code ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.FEEDING_MODEL = :arg_model_name ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.FEEDER_SHAFT = :arg_feeder_shaft ) AND  
         ( NVL(IM_ITEM_RECEIPT_BARCODE.ISSUE_COMPARE_YN , 'N') = 'Y' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.FEEDING_YN = 'Y' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.BARCODE_STATUS <> 'C' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.RETURN_YN <> 'Y' ) AND  
         ( IM_ITEM_RECEIPT_BARCODE.ORGANIZATION_ID = :arg_org )    AND 
		  IM_ITEM_RECEIPT_BARCODE.LOT_NO IN ( SELECT NVL(A.LOT_NO,'*') 
																   FROM IB_PRODUCT_PLANDATA A 
																 WHERE   A.LINE_CODE = :arg_line_code AND  
																			 A.MODEL_NAME = :arg_model_name  AND  
																			 A.FEEDER_SHAFT = :arg_feeder_shaft AND  
																			 A.PCB_ITEM = :arg_pcb_item AND 
																			 A.ACTIVE_YN = 'Y'
                                                                           ) 

        


