footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=loc dbname="id_item.loc" )
 column=(type=char(100) updatewhereclause=yes name=a_item dbname="id_item.a_item" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(100) updatewhereclause=yes name=b_item dbname="id_item.b_item" )
 column=(type=char(300) updatewhereclause=yes name=id_item_item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=id_item_item_spec dbname="id_item.item_spec" )
 column=(type=char(1) updatewhereclause=yes name=model_name dbname="id_item.model_name" )
 column=(type=char(1) updatewhereclause=yes name=comp_model_name dbname="id_item.comp_model_name" )
 retrieve="SELECT   loc ,
              a_item , a.item_name , a.item_spec ,
              b_item , b.item_name , b.item_spec ,
              :arg_model_name  model_name ,
              :arg_comp_model_name comp_model_name

  FROM   (  SELECT   loc, MAX (nvl(a_item,'*')) a_item, MAX (nvl(b_item,'*')) b_item
              FROM   (SELECT   a.location_code loc, a.item_code a_item, '' b_item
                        FROM   ib_product_plandata a
                       WHERE   a.line_code = :arg_line_code
                           AND a.model_name = :arg_model_name
                           AND a.pcb_item = :arg_topbot
                           AND a.organization_id = :arg_org
                      UNION ALL
                      SELECT   b.location_code loc, '' a_item, b.item_code b_item
                        FROM   ib_product_plandata b
                       WHERE   b.line_code = :arg_comp_line_code
                           AND b.model_name = :arg_comp_model_name
                           AND b.pcb_item = :arg_topbot
                           AND b.organization_id = :arg_org)
          GROUP BY   loc)  C , ID_ITEM  A ,  ID_ITEM  B
 WHERE  C.a_item =  A.ITEM_CODE(+) 
     AND  C.b_item =  B.ITEM_CODE(+) 
     AND   C.a_item <> C.b_item" arguments=(("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_COMP_LINE_CODE", string),("ARG_COMP_MODEL_NAME", string),("ARG_TOPBOT", string),("ARG_ORG", number))  sort="loc A " )
