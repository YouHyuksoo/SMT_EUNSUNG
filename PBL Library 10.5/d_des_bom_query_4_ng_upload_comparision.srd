table(column=(type=number updatewhereclause=yes name=session_id dbname="id_eng_bom_temp.session_id" dbalias=".session_id" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="id_eng_bom_temp.parent_item_code" dbalias=".parent_item_code" )
