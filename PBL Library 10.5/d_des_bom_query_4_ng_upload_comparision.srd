 column=(type=char(300) updatewhereclause=yes name=child_item_name dbname="id_item.child_item_name" dbalias="B.child_item_name" )
 column=(type=char(300) updatewhereclause=yes name=child_item_spec dbname="id_item.child_item_spec" dbalias="B.child_item_spec" )
 column=(type=char(3) updatewhereclause=yes name=child_item_uom dbname="id_item.child_item_uom" dbalias="B.child_item_uom" )
 column=(type=char(10) update=yes updatewhereclause=yes name=line_type dbname="id_eng_bom_temp.line_type" dbalias=".line_type" )
 column=(type=char(20) updatewhereclause=yes name=item_class dbname="id_item.item_class" dbalias="A.item_class" )
 retrieve="  SELECT ~"ID_ENG_BOM_TEMP~".~"SESSION_ID~",   
         ~"ID_ENG_BOM_TEMP~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_TEMP~".~"CHILD_ITEM_CODE~",   

         LPAD(BOM_LEVEL ,BOM_LEVEL , '.' ) BOM_LEVEL,   
         ~"ID_ENG_BOM_TEMP~".~"SORT_SEQUENCE~",   
         ~"ID_ENG_BOM_TEMP~".~"SORT_ORDER~",   
         ~"ID_ENG_BOM_TEMP~".~"ITEM_UNIT_QTY~",   
         ~"ID_ENG_BOM_TEMP~".~"MODEL_UNIT_QTY~",   
         ~"ID_ENG_BOM_TEMP~".~"LOCATION_INFO~",  
         ~"B~".~"ITEM_CODE~" ITEM_CODE ,   
         ~"A~".~"ORGANIZATION_ID~" ,   

         ~"A~".~"ITEM_NAME~" PARENT_ITEM_NAME ,   
         ~"A~".~"ITEM_SPEC~" PARENT_ITEM_SPEC,   

         ~"B~".~"ITEM_NAME~" CHILD_ITEM_NAME,   
         ~"B~".~"ITEM_SPEC~" CHILD_ITEM_SPEC,   
         ~"B~".~"ITEM_UOM~" CHILD_ITEM_UOM,   
         ~"ID_ENG_BOM_TEMP~".~"LINE_TYPE~" ,
		A.ITEM_CLASS ITEM_CLASS
    FROM ~"ID_ENG_BOM_TEMP~",   
         ~"ID_ITEM~" ~"A~",   
         ~"ID_ITEM~" ~"B~" 
   WHERE ( ~"ID_ENG_BOM_TEMP~".~"PARENT_ITEM_CODE~" = ~"A~".~"ITEM_CODE~"(+) ) and  
         ( ~"ID_ENG_BOM_TEMP~".~"ORGANIZATION_ID~" = ~"A~".~"ORGANIZATION_ID~"(+) ) and  
         ( ~"ID_ENG_BOM_TEMP~".~"CHILD_ITEM_CODE~" = ~"B~".~"ITEM_CODE~"(+) ) and  
         ( ~"ID_ENG_BOM_TEMP~".~"ORGANIZATION_ID~" = ~"B~".~"ORGANIZATION_ID~"(+) ) and  

         ( ID_eng_bom_temp.session_id = :arg_session_id ) AND  
         ( ID_eng_bom_temp.organization_id = :arg_organization_id )   AND 
		A.ITEM_CLASS LIKE :ARG_TOPBOT
			
" arguments=(("ARG_SESSION_ID", number),("ARG_TOPBOT", string),("ARG_ORGANIZATION_ID", number))  sort="sort_order A sort_sequence A child_item_code A " )
