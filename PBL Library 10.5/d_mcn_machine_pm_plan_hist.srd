 retrieve="  SELECT  ~"IMCN_MACHINE_PM_MASTER_HIST~".~"ORGANIZATION_ID~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"LINE_CODE~" 
,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"MACHINE_CODE~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"PM_TYPE~" ,     
      ~"IMCN_MACHINE_PM_MASTER_HIST~".~"PLAN_DATE~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"BREAK_VALUE~" ,       
    ~"IMCN_MACHINE_PM_MASTER_HIST~".~"HIT_VALUE~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"PM_DATE~" ,         
  ~"IMCN_MACHINE_PM_MASTER_HIST~".~"COMMENTS~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"CONFIRM_YN~" ,       
    ~"IMCN_MACHINE_PM_MASTER_HIST~".~"CONFIRM_BY~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"CHARGER~" ,      
    ~"IMCN_MACHINE_PM_MASTER_HIST~".~"ENTER_DATE~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"ENTER_BY~" ,    
       ~"IMCN_MACHINE_PM_MASTER_HIST~".~"LAST_MODIFY_DATE~" ,           ~"IMCN_MACHINE_PM_MASTER_HIST~".~"LAST_MODIFY_BY~" ,    
       ~"IMCN_MACHINE_PM_MASTER_HIST~".~"PM_DIVISION~"    
  FROM ~"IMCN_MACHINE_PM_MASTER_HIST~"      WHERE ( ~"IMCN_MACHINE_PM_MASTER_HIST~".~"LINE_CODE~" = :arg_line_code ) And     
     ( ~"IMCN_MACHINE_PM_MASTER_HIST~".~"MACHINE_CODE~" = :arg_machine_code ) And         
   ( ~"IMCN_MACHINE_PM_MASTER_HIST~".~"PM_TYPE~" = :arg_pm_type ) And          ( ~"IMCN_MACHINE_PM_MASTER_HIST~".~"ORGANIZATION_ID~" = :arg_org )   " update="IMCN_MACHINE_PM_MASTER_HIST" updatewhere=0 updatekeyinplace=no arguments=(("arg_line_code", string),("arg_machine_code", string),("arg_pm_type", string),("arg_org", number))  sort="organization_id A pm_date A " )
