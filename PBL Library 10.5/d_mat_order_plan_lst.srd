 column=(type=datetime update=yes updatewhereclause=yes name=purchase_order_date dbname="im_item_purchase_order_plan.purchase_order_date" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="im_item_purchase_order_plan.organization_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=supplier_code dbname="im_item_purchase_order_plan.supplier_code" )
