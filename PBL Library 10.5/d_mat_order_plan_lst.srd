 column=(type=char(30) update=yes updatewhereclause=yes name=mfs dbname="im_item_purchase_order_plan.mfs" )
 column=(type=char(20) update=yes updatewhereclause=yes name=enter_by dbname="im_item_purchase_order_plan.enter_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="im_item_purchase_order_plan.enter_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="im_item_purchase_order_plan.last_modify_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="im_item_purchase_order_plan.last_modify_date" )
 column=(type=char(100) updatewhereclause=yes name=supplier_name dbname="icom_supplier.supplier_name" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 column=(type=char(10) updatewhereclause=yes name=item_type dbname="id_item.item_type" )
 column=(type=number updatewhereclause=yes name=total_inventory_qty dbname="im_item_purchase_order_plan.total_inventory_qty" )
 column=(type=number update=yes updatewhereclause=yes name=purchase_order_qty dbname="im_item_purchase_order_plan.purchase_order_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=purchase_order_status dbname="im_item_purchase_order_plan.purchase_order_status" )
 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 retrieve="  SELECT ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORDER_NO~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"PURCHASE_ORDER_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ITEM_CODE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"DELIVERY_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"DELIVERY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"LINE_TYPE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORDER_TYPE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORDER_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"UNIT_PRICE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"CURRENCY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ARRIVAL_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"PRE_ORDER_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"MFS~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ENTER_BY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ENTER_DATE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"LAST_MODIFY_DATE~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_TYPE~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"TOTAL_INVENTORY_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"PURCHASE_ORDER_QTY~",   
         ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"PURCHASE_ORDER_STATUS~"  ,
         'N' CHECK_YN
    FROM ~"IM_ITEM_PURCHASE_ORDER_PLAN~",   
         ~"ICOM_SUPPLIER~",   
         ~"ID_ITEM~"  
   WHERE ( im_item_purchase_order_plan.supplier_code = icom_supplier.supplier_code (+)) and  
         ( im_item_purchase_order_plan.organization_id = icom_supplier.organization_id (+)) and  
         ( im_item_purchase_order_plan.item_code = id_item.item_code (+)) and  
         ( im_item_purchase_order_plan.organization_id = id_item.organization_id (+)) and  
         ( ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"SUPPLIER_CODE~" like :ARG_SUPPLIER_CODE ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ITEM_CODE~" like :ARG_ITEM_CODE ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"PURCHASE_ORDER_DATE~" >= :ARG_DATESET ) AND  
         ( ~"IM_ITEM_PURCHASE_ORDER_PLAN~".~"ORGANIZATION_ID~" = :ARG_ORG ) )    
" arguments=(("ARG_SUPPLIER_CODE", string),("ARG_ITEM_CODE", string),("ARG_DATESET", datetime),("ARG_ORG", number))  sort="organization_id A item_code A delivery_date A " )
group(level=1 header.height=0 trailer.height=64 by=("organization_id" , "item_code" ) header.color="536870912" trailer.color="65535" )
