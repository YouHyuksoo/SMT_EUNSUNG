 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="iq_interlock_check_result.pcb_item" )
 column=(type=char(30) updatewhereclause=yes name=run_no dbname="iq_interlock_check_result.run_no" )
 column=(type=char(30) updatewhereclause=yes name=magazine_no dbname="iq_interlock_check_result.magazine_no" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(30) updatewhereclause=yes name=child_item_code dbname="iq_interlock_check_result.child_item_code" )
 column=(type=char(30) updatewhereclause=yes name=customer_model_name dbname="iq_interlock_check_result.customer_model_name" )
 column=(type=char(30) updatewhereclause=yes name=part_no dbname="iq_interlock_check_result.part_no" )
 column=(type=char(30) updatewhereclause=yes name=ec_no dbname="iq_interlock_check_result.ec_no" )
 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(1000) updatewhereclause=yes name=force_pass_message dbname="iq_interlock_check_result.force_pass_message" )
 column=(type=datetime updatewhereclause=yes name=force_pass_date dbname="iq_interlock_check_result.force_pass_date" )
 column=(type=char(30) updatewhereclause=yes name=force_pass_by dbname="iq_interlock_check_result.force_pass_by" )
 column=(type=char(1000) updatewhereclause=yes name=bad_reason_comments dbname="iq_interlock_check_result.bad_reason_comments" )
 column=(type=char(100) updatewhereclause=yes name=customer_name dbname="ip_product_model_master.customer_name" )
 column=(type=char(100) updatewhereclause=yes name=mapping_label dbname="iq_interlock_check_result.mapping_label" )
 column=(type=char(10) updatewhereclause=yes name=aoi_review_result dbname="iq_interlock_check_result.aoi_review_result" )
 column=(type=char(1) updatewhereclause=yes name=solder_type dbname="ip_product_model_master.solder_type" )
 column=(type=char(30) updatewhereclause=yes name=mapping_model_name dbname="iq_interlock_check_result.mapping_model_name" )
 retrieve="  SELECT

		/*+ index ( IQ_INTERLOCK_CHECK_RESULT XPKIQ_INTERLOCK_CHECK_RESULT ) */

         ~"IQ_INTERLOCK_CHECK_RESULT~".~"RECEIPT_DATE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"ITEM_CODE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"SERIAL_NO~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"LINE_CODE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"WORKSTAGE_CODE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"MACHINE_CODE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"CHECK_RESULT~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"ENTER_DATE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"ENTER_BY~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"LAST_MODIFY_DATE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"LAST_MODIFY_BY~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"ORGANIZATION_ID~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"IS_LAST_YN~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"MODEL_NAME~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"PCB_ITEM~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"RUN_NO~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"MAGAZINE_NO~", 
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
  
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"CHILD_ITEM_CODE~",   
         
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"CUSTOMER_MODEL_NAME~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"PART_NO~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"EC_NO~",   
         'N' CHECK_YN,   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"FORCE_PASS_MESSAGE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"FORCE_PASS_DATE~",   
         ~"IQ_INTERLOCK_CHECK_RESULT~".~"FORCE_PASS_BY~"  ,
	     ~"IQ_INTERLOCK_CHECK_RESULT~".~"BAD_REASON_COMMENTS~"  ,
		M.CUSTOMER_NAME  CUSTOMER_NAME,
          ~"IQ_INTERLOCK_CHECK_RESULT~".~"MAPPING_LABEL~" ,
	     IQ_INTERLOCK_CHECK_RESULT.AOI_REVIEW_RESULT,
          M.SOLDER_TYPE ,
		 ~"IQ_INTERLOCK_CHECK_RESULT~".~"MAPPING_MODEL_NAME~"

    FROM ~"IQ_INTERLOCK_CHECK_RESULT~",   
         ~"ID_ITEM~",   
         IP_PRODUCT_MODEL_MASTER M
   WHERE           ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"RECEIPT_DATE~" >= :arg_dateset ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"RECEIPT_DATE~" < :arg_dateend+1 ) AND  
		 ( iq_interlock_check_result.item_code = id_item.item_code (+)) and  
         ( iq_interlock_check_result.organization_id = id_item.organization_id (+)) and  
 
         ( iq_interlock_check_result.item_code = m.item_code (+)) and  
         ( iq_interlock_check_result.organization_id = m.organization_id (+)) and 

         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"MODEL_NAME~"  like :arg_model_name ) AND  
  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"RUN_NO~" like :arg_run_no ) AND  

         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"SERIAL_NO~" like :arg_serial_no ) AND  

         ( NVL(~"IQ_INTERLOCK_CHECK_RESULT~".~"IS_LAST_YN~" , 'N') like :arg_is_last_yn ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"CHECK_RESULT~" like :arg_result ) AND  
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"ORGANIZATION_ID~" = :arg_org )  AND 
         ( ~"IQ_INTERLOCK_CHECK_RESULT~".~"MODEL_NAME~"  IN ( SELECT MODEL_NAME FROM IP_PRODUCT_MODEL_MASTER WHERE CUSTOMER_CODE LIKE :ARG_CUSTOMER_CODE ) )
" arguments=(("arg_line_code", string),("arg_workstage_code", string),("arg_run_no", string),("arg_model_name", string),("arg_serial_no", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_is_last_yn", string),("arg_result", string),("arg_customer_code", string),("arg_org", number))  sort="serial_no A receipt_date A line_code A workstage_code A " )
