table(column=(type=datetime updatewhereclause=yes name=receipt_date dbname="receipt_date" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="iq_interlock_check_result.item_code" )
 column=(type=char(30) updatewhereclause=yes name=serial_no dbname="iq_interlock_check_result.serial_no" )
