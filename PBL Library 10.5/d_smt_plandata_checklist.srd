table(column=(type=char(30) updatewhereclause=yes name=line_code_1 dbname="ib_product_plandata.line_code" )
 column=(type=char(30) updatewhereclause=yes name=ib_product_plandata_model_name dbname="ib_product_plandata.model_name" )
 column=(type=char(10) updatewhereclause=yes name=ib_product_plandata_table_id dbname="ib_product_plandata.table_id" )
 column=(type=char(30) updatewhereclause=yes name=ib_product_plandata_pcb_item dbname="ib_product_plandata.pcb_item" )
