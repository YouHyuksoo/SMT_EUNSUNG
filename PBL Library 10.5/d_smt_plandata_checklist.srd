 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=number updatewhereclause=yes name=im_item_receipt_barcode_scan_qty dbname="im_item_receipt_barcode.scan_qty" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="im_item_receipt_barcode.supplier_code" )
 column=(type=char(1) updatewhereclause=yes name=barcode_status dbname="im_item_receipt_barcode.barcode_status" )
 column=(type=datetime updatewhereclause=yes name=receipt_compare_date dbname="im_item_receipt_barcode.receipt_compare_date" )
 column=(type=datetime updatewhereclause=yes name=issue_compare_date dbname="im_item_receipt_barcode.issue_compare_date" )
 column=(type=char(1) updatewhereclause=yes name=lot_divide_yn dbname="lot_divide_yn" )
 column=(type=datetime updatewhereclause=yes name=lot_divide_date dbname="im_item_receipt_barcode.lot_divide_date" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="ib_smt_checkhist.location_code" )
 column=(type=char(10) updatewhereclause=yes name=table_id dbname="ib_smt_checkhist.table_id" )
 column=(type=char(10) updatewhereclause=yes name=check_type dbname="ib_smt_checkhist.check_type" )
 column=(type=char(100) update=yes updatewhereclause=yes name=ib_smt_checkhist_ng_reason dbname="ib_smt_checkhist.ng_reason" )
 column=(type=char(500) updatewhereclause=yes name=ib_smt_checkhist_scan_supplier_partname dbname="ib_smt_checkhist.scan_supplier_partname" )
 column=(type=number updatewhereclause=yes name=ib_smt_checkhist_full_check_sequence dbname="ib_smt_checkhist.full_check_sequence" )
 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="ib_smt_checkhist.pcb_item" )
 column=(type=char(50) updatewhereclause=yes name=unlock_by dbname="ib_smt_checkhist.unlock_by" )
 column=(type=datetime updatewhereclause=yes name=unlock_date dbname="ib_smt_checkhist.unlock_date" )
 column=(type=char(10) updatewhereclause=yes name=msl_level dbname="id_item.msl_level" )
 column=(type=number updatewhereclause=yes name=msl_max_time dbname="id_item.msl_max_time" )
 column=(type=datetime updatewhereclause=yes name=ccs_end_date dbname="ib_smt_checkhist.ccs_end_date" )
 column=(type=char(1) updatewhereclause=yes name=ccs_yn dbname="ib_product_plandata.ccs_yn" )
 retrieve="  SELECT IB_PRODUCT_PLANDATA.LINE_CODE , 
			IB_PRODUCT_PLANDATA.MODEL_NAME,
			IB_PRODUCT_PLANDATA.TABLE_ID,
			IB_PRODUCT_PLANDATA.PCB_ITEM,
			IB_PRODUCT_PLANDATA.LOCATION_CODE ,

			f_get_ccs_ok_count( IB_PRODUCT_PLANDATA.LINE_CODE ) CCS_COUNT ,
			
			~"IB_SMT_CHECKHIST~".~"CHECK_DATE~",   
			~"IB_SMT_CHECKHIST~".~"CHECK_SEQUENCE~",   
			~"IB_SMT_CHECKHIST~".~"PLAN_DATE~",   
			~"IB_SMT_CHECKHIST~".~"LOT_NAME~",   
			~"IB_SMT_CHECKHIST~".~"PARTNAME~",   
			~"IB_SMT_CHECKHIST~".~"CHIPNAME~",   
			~"IB_SMT_CHECKHIST~".~"CHECK_STATUS~",   
			~"IB_SMT_CHECKHIST~".~"CHECK_MSG~",   
			~"IB_SMT_CHECKHIST~".~"CHECK_BY~",   
			~"IB_SMT_CHECKHIST~".~"LINE_CODE~",   
			~"IB_SMT_CHECKHIST~".~"MACHINE~",   
			~"IB_SMT_CHECKHIST~".~"PLAN_DATE_SEQUENCE~",   
			~"IB_SMT_CHECKHIST~".~"SCAN_PARTNAME~",   

			f_get_lot_no_from_barcode( ~"IB_SMT_CHECKHIST~".~"SCAN_PARTNAME~" ) LOT_NO,

			~"ID_ITEM_A~".~"ITEM_NAME~",   
			~"ID_ITEM_A~".~"ITEM_SPEC~",   
	
			~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_QTY~",   
			~"IM_ITEM_RECEIPT_BARCODE~".~"SUPPLIER_CODE~",   
			~"IM_ITEM_RECEIPT_BARCODE~".~"BARCODE_STATUS~",   
			~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_DATE~",   
			~"IM_ITEM_RECEIPT_BARCODE~".~"ISSUE_COMPARE_DATE~",   
			NVL(~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_DIVIDE_YN~",'N') LOT_DIVIDE_YN , 
			~"IM_ITEM_RECEIPT_BARCODE~".~"LOT_DIVIDE_DATE~",

			~"IB_SMT_CHECKHIST~".~"LOCATION_CODE~",   
			~"IB_SMT_CHECKHIST~".~"TABLE_ID~",   
			~"IB_SMT_CHECKHIST~".~"CHECK_TYPE~",   
			~"IB_SMT_CHECKHIST~".~"NG_REASON~",   
			~"IB_SMT_CHECKHIST~".~"SCAN_SUPPLIER_PARTNAME~",   
			~"IB_SMT_CHECKHIST~".~"FULL_CHECK_SEQUENCE~",   
			~"IB_SMT_CHECKHIST~".~"PCB_ITEM~",   
			~"IB_SMT_CHECKHIST~".~"UNLOCK_BY~",   
			~"IB_SMT_CHECKHIST~".~"UNLOCK_DATE~",   
			~"ID_ITEM_A~".~"MSL_LEVEL~",   
			~"ID_ITEM_A~".~"MSL_MAX_TIME~",
			~"IB_SMT_CHECKHIST~".~"CCS_END_DATE~" ,
			~"IB_PRODUCT_PLANDATA~".~"CCS_YN~"  	 	  
    FROM 
			 IB_PRODUCT_PLANDATA ,
			 ~"IB_SMT_CHECKHIST~",   
			~"ID_ITEM~" ~"ID_ITEM_A~", 
			~"IM_ITEM_RECEIPT_BARCODE~"  
   WHERE IB_PRODUCT_PLANDATA.LINE_CODE = IB_SMT_CHECKHIST.LINE_CODE(+) AND 
     IB_PRODUCT_PLANDATA.MODEL_NAME = IB_SMT_CHECKHIST.LOT_NAME(+) AND

     IB_PRODUCT_PLANDATA.PCB_ITEM = IB_SMT_CHECKHIST.PCB_ITEM(+) AND 
     IB_PRODUCT_PLANDATA.LOCATION_CODE = IB_SMT_CHECKHIST.LOCATION_CODE(+) AND


         ( ib_smt_checkhist.partname = ID_ITEM_A.item_code (+)) and  
         ( ib_smt_checkhist.lot_no = im_item_receipt_barcode.lot_no (+)) and  

         ( ~"IB_PRODUCT_PLANDATA~".~"LINE_CODE~" like :arg_line_code ) AND  
         (~"IB_PRODUCT_PLANDATA~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IB_PRODUCT_PLANDATA~".~"MODEL_NAME~" like :arg_feeder_layout_name ) AND  

         ( ~"IB_SMT_CHECKHIST~".~"CHECK_DATE~" >= to_date(:arg_dateset,'yyyy-mm-dd hh24:mi:ss' )) AND  
         ( ~"IB_SMT_CHECKHIST~".~"CHECK_DATE~" <= to_date(:arg_dateend,'yyyy-mm-dd hh24:mi:ss' )) AND  
         ( ~"IB_SMT_CHECKHIST~".~"LINE_CODE~" like :arg_line_code ) AND  
         (~"IB_SMT_CHECKHIST~".~"PARTNAME~" like :arg_item_code ) AND  
         ( NVL(~"IB_SMT_CHECKHIST~".~"CHECK_STATUS~" , '*') like :arg_check_status ) AND  
         ( NVL(~"IB_SMT_CHECKHIST~".~"CHECK_TYPE~" , '*') like :arg_check_type ) AND  
         ( ~"IB_SMT_CHECKHIST~".~"LOT_NAME~" like :arg_feeder_layout_name ) AND  
         ( NVL(~"IB_SMT_CHECKHIST~".~"SMT_MODEL_NAME~",'*') like :arg_smt_model_name ) AND  
	     ( ~"IB_SMT_CHECKHIST~".~"LOCATION_CODE~" like :arg_location_code) AND  
         NVL(~"IB_SMT_CHECKHIST~".~"SCAN_PARTNAME~",'*') like :arg_lot_no AND  
         NVL(~"IB_SMT_CHECKHIST~".~"SCAN_SUPPLIER_PARTNAME~" , '*') like :arg_scan_supplier_partname    
" update="IB_SMT_CHECKHIST" updatewhere=0 updatekeyinplace=yes arguments=(("arg_dateset", string),("arg_dateend", string),("arg_line_code", string),("arg_feeder_layout_name", string),("arg_smt_model_name", string),("arg_location_code", string),("arg_item_code", string),("arg_check_status", string),("arg_check_type", string),("arg_lot_no", string),("arg_scan_supplier_partname", string))  sort="check_type A line_code A machine A lot_name A table_id A location_code A check_date A check_sequence A " )
group(level=1 header.height=0 trailer.height=36 by=("check_type" ) newpage=yes resetpagecount=yes header.color="536870912" trailer.color="134217730" )
group(level=2 header.height=0 trailer.height=56 by=("line_code" ) header.color="536870912" trailer.color="536870912" )
