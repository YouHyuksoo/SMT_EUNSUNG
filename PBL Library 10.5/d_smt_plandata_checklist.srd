 column=(type=number updatewhereclause=yes name=plan_date_sequence dbname="ib_smt_checkhist.plan_date_sequence" )
 column=(type=char(500) updatewhereclause=yes name=scan_partname dbname="ib_smt_checkhist.scan_partname" )
