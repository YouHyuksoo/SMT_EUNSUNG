 retrieve="  SELECT ~"ID_ITEM_REPLACE~".~"PARENT_ITEM_CODE~",   
         ~"ID_ITEM_REPLACE~".~"CHILD_ITEM_CODE~",   
         ~"ID_ITEM_REPLACE~".~"REPLACE_ITEM_CODE~",   
         ~"ID_ITEM_REPLACE~".~"ORGANIZATION_ID~",   
         ~"ID_ITEM_REPLACE~".~"DATESET~",   
         ~"ID_ITEM_REPLACE~".~"DATEEND~",   
         ~"ID_ITEM_REPLACE~".~"ITEM_UNIT_QTY~",   
         ~"ID_ITEM_REPLACE~".~"WORKSTAGE_CODE~",   
         ~"ID_ITEM_REPLACE~".~"ENTER_BY~",   
         ~"ID_ITEM_REPLACE~".~"ENTER_DATE~",   
         ~"ID_ITEM_REPLACE~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM_REPLACE~".~"LAST_MODIFY_DATE~",   
         ~"ID_ITEM_REPLACE~".~"REPLACE_SEQUENCE~",   
         ~"ID_ITEM_REPLACE~".~"ITEM_UNIT_QTY_EXT~",   
         ~"ID_ITEM_REPLACE~".~"BOM_LOCATION_CODE~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SMT_MODEL_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MASTER_MODEL_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_NAME~"  
    FROM ~"ID_ITEM_REPLACE~",   
         ~"ID_ITEM~",   
         ~"IP_PRODUCT_MODEL_MASTER~"  
   WHERE ( ~"ID_ITEM_REPLACE~".~"REPLACE_ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM_REPLACE~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( id_item_replace.parent_item_code = ip_product_model_master.item_code (+)) and  
         ( ~"ID_ITEM_REPLACE~".~"PARENT_ITEM_CODE~" ) IN ( SELECT NVL(ITEM_CODE,'*')FROM IP_PRODUCT_MODEL_MASTER WHERE SMT_MODEL_NAME LIKE :arg_smt_model_name )  AND
           ( ~"ID_ITEM_REPLACE~".~"ORGANIZATION_ID~" = :arg_org )   
" arguments=(("arg_smt_model_name", string),("arg_org", number))  sort="organization_id A parent_item_code A child_item_code A replace_sequence A " )
