 column=(type=char(30) updatewhereclause=yes name=code_group_third dbname="isys_code_master.code_group_third" )
 retrieve="SELECT CODE_NAME ,
		   DECODE(:ARG_LANG, 'K', CODE_MEAN_KOR, 'E', CODE_MEAN_ENG ,CODE_MEAN_LOCAL ) AS CODE_MEAN  ,
             CODE_GROUP , CODE_GROUP_SECOND  , CODE_GROUP_THIRD
  FROM ISYS_CODE_MASTER
WHERE CODE_TYPE        = 'WQC BAD REASON CODE'
    AND ORGANIZATION_ID = :ARG_ORG " arguments=(("ARG_LANG", string),("ARG_ORG", string))  sort="code_group A code_group_second A code_group_third A code_mean A " )
