 retrieve="  SELECT
         ~"IMCN_JIG~".~"JIG_CODE~",   
         ~"IMCN_JIG~".~"ORGANIZATION_ID~",   
         ~"IMCN_JIG~".~"JIG_NAME~",   
         ~"IMCN_JIG~".~"JIG_TYPE~",   
         ~"IMCN_JIG~".~"CAPACITY~",   
         ~"IMCN_JIG~".~"RESERVED_CAPACITY~",   
         ~"IMCN_JIG~".~"ACQUISITION_DATE~",   
         ~"IMCN_JIG~".~"ACQUISITION_TYPE~",   
         ~"IMCN_JIG~".~"JIG_MODEL_NAME~",   
         ~"IMCN_JIG~".~"LINE_CODE~",   
         ~"IMCN_JIG~".~"CUSTOMER_CODE~",   
         ~"IMCN_JIG~".~"USE_STATUS~",   
         ~"IMCN_JIG~".~"MANUAL_LOCATION_COMMENT~",   
         ~"IMCN_JIG~".~"NATION_CODE~",   
         ~"IMCN_JIG~".~"WORKSTAGE_CODE~",   
         ~"IMCN_JIG~".~"ENTER_BY~",   
         ~"IMCN_JIG~".~"ENTER_DATE~",   
         ~"IMCN_JIG~".~"LAST_MODIFY_BY~",   
         ~"IMCN_JIG~".~"LAST_MODIFY_DATE~",   
         ~"IMCN_JIG~".~"USE_RATE~",   
         ~"IMCN_JIG~".~"UPH_VALUE~",   
         ~"IMCN_JIG~".~"CAPACITY_UOM~",   
         ~"IMCN_JIG~".~"SUPPLIER_CODE~",   
         ~"IMCN_JIG~".~"JIG_STATUS~",   
         ~"IMCN_JIG~".~"JIG_IMAGE_FILE_NAME~",   
         ~"IMCN_JIG~".~"USE_TPM_YN~",   
         ~"IMCN_JIG~".~"JIG_LOT_NO~",   
         ~"IMCN_JIG~".~"MACHINE_CODE~",   
         ~"IMCN_JIG~".~"BREAK_VALUE~",   
         ~"IMCN_JIG~".~"HIT_VALUE~",   
         ~"IMCN_JIG~".~"JIG_SPEC~",   
         ~"IMCN_JIG~".~"ITEM_CODE~",   
         ~"IMCN_JIG~".~"LOCATION_ADDRESS~",   
         ~"IMCN_JIG~".~"USE_NSNP_YN~",   
         ~"IMCN_JIG~".~"SOLDER_TYPE~",   
         ~"IMCN_JIG~".~"MANAGEMENT_COMMNETS~",
		 'N' CHECK_YN,   
         DECODE( NVL( LENGTH(IMCN_JIG.JIG_IMAGE) ,0 ) ,0 , 'N' , 'Y' ) JIG_IMAGE_EXISTS_YN,   
		TENSION_CHECK_YN ,
         ROWID
    FROM ~"IMCN_JIG~"  
   WHERE  ( ~"IMCN_JIG~".~"JIG_LOT_NO~" like :arg_jig_lot_no ) AND  
		( ~"IMCN_JIG~".~"JIG_CODE~" like :arg_jig_code ) AND  
         ( NVL(~"IMCN_JIG~".~"JIG_MODEL_NAME~",'*') like :arg_model_name ) AND  
         ( ~"IMCN_JIG~".~"JIG_TYPE~" like :arg_jig_type ) AND  
         ( ~"IMCN_JIG~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IMCN_JIG~".~"JIG_STATUS~" like :arg_jig_status ) AND  
         ( ~"IMCN_JIG~".~"ORGANIZATION_ID~" = :arg_org )    
" update="IMCN_JIG" updatewhere=0 updatekeyinplace=yes arguments=(("arg_jig_code", string),("arg_jig_lot_no", string),("arg_model_name", string),("arg_jig_type", string),("arg_line_code", string),("arg_jig_status", string),("arg_org", number))  sort="jig_type A jig_status A jig_code A jig_lot_no A " )
group(level=1 header.height=0 trailer.height=64 by=("organization_id" , "jig_type" ) header.color="536870912" trailer.color="65280" )
