 column=(type=number updatewhereclause=yes name=amt6 dbname="amt6" )
 column=(type=number updatewhereclause=yes name=amt7 dbname="amt7" )
 column=(type=number updatewhereclause=yes name=amt8 dbname="amt8" )
 column=(type=number updatewhereclause=yes name=amt9 dbname="amt9" )
 column=(type=number updatewhereclause=yes name=amt10 dbname="amt10" )
 column=(type=number updatewhereclause=yes name=amt11 dbname="amt11" )
 column=(type=number updatewhereclause=yes name=amt12 dbname="amt12" )
 retrieve=" select  a.supplier_code ,  b.supplier_name, 
          max(a.delivery) delivery, max(a.currency) currency,a.organization_id,
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'01', a.order_qty, 0 ))  qty1, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'02', a.order_qty, 0 ))   qty2, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'03', a.order_qty, 0 ))   qty3, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'04', a.order_qty, 0 ))   qty4, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'05', a.order_qty, 0 ))    qty5, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'06', a.order_qty, 0 ))    qty6, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'07', a.order_qty, 0 ))    qty7, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'08', a.order_qty, 0 ))    qty8, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'09', a.order_qty, 0 ))    qty9, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'10', a.order_qty, 0 ))  qty10, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'11', a.order_qty, 0 ))  qty11, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'12', a.order_qty, 0 ))  qty12, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'01', a.order_amt, 0 ))    amt1, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'02', a.order_amt, 0 ))    amt2, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'03', a.order_amt, 0 ))    amt3, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'04', a.order_amt, 0 ))    amt4, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'05', a.order_amt, 0 ))    amt5, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'06', a.order_amt, 0 ))    amt6, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'07', a.order_amt, 0 ))    amt7, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'08', a.order_amt, 0 ))    amt8, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'09', a.order_amt, 0 ))    amt9, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'10', a.order_amt, 0 ))    amt10, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'11', a.order_amt, 0 ))    amt11, 
          sum(decode(to_char(a.delivery_date,'yyyymm'), :arg_yyyy||'12', a.order_amt, 0 ))    amt12
 from   im_item_purchase_order a ,       
          icom_supplier     b
 where a.supplier_code = b.supplier_code 
 and    a.organization_id = b.organization_id 
 and    a.delivery_date between to_date(:arg_yyyy||'0101', 'yyyymmdd')  and  to_date(:arg_yyyy||'1231', 'yyyymmdd')
 and    a.supplier_code like :arg_supplier_code
 and    a.item_code like :arg_item_code
 and    to_char(a.organization_id) like :arg_org_id 
group by a.supplier_code ,  b.supplier_name,  a.organization_id 
" arguments=(("arg_yyyy", string),("arg_supplier_code", string),("arg_item_code", string),("arg_org_id", string))  sort="organization_id A supplier_code A " )
