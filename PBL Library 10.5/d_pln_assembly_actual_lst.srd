datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=140 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=receipt_date dbname="receipt_date" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="iq_interlock_check_result.item_code" dbalias=".item_code" )
 column=(type=char(100) updatewhereclause=yes name=line_code dbname="iq_interlock_check_result.line_code" dbalias=".line_code" )
 column=(type=char(30) updatewhereclause=yes name=run_no dbname="iq_interlock_check_result.run_no" dbalias=".run_no" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="iq_interlock_check_result.model_name" dbalias=".model_name" )
 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="iq_interlock_check_result.pcb_item" dbalias=".pcb_item" )
 column=(type=number updatewhereclause=yes name=actual_qty dbname="actual_qty" )
 column=(type=number updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=datetime updatewhereclause=yes name=min_date dbname="min_date" )
 column=(type=datetime updatewhereclause=yes name=max_date dbname="max_date" )
 column=(type=number updatewhereclause=yes name=actual_time dbname="actual_time" )
 retrieve="  SELECT TRUNC( IQ_INTERLOCK_CHECK_RESULT.RECEIPT_DATE) RECEIPT_DATE ,   
         IQ_INTERLOCK_CHECK_RESULT.ITEM_CODE,   
         IQ_INTERLOCK_CHECK_RESULT.LINE_CODE,   
         IQ_INTERLOCK_CHECK_RESULT.RUN_NO,   
         IQ_INTERLOCK_CHECK_RESULT.MODEL_NAME,   
         IQ_INTERLOCK_CHECK_RESULT.PCB_ITEM ,
		COUNT(DISTINCT SERIAL_NO) ACTUAL_QTY  ,
         ( SELECT SUM(LOT_SIZE) FROM IP_PRODUCT_RUN_CARD WHERE RUN_NO = IQ_INTERLOCK_CHECK_RESULT.RUN_NO ) PLAN_QTY ,

		MIN(RECEIPT_DATE) MIN_DATE ,
		MAX(RECEIPT_DATE) MAX_DATE ,
		( MAX(RECEIPT_DATE)  - MIN(RECEIPT_DATE)  ) * 24  * 60 * 60  ACTUAL_TIME 
	

		
    FROM IQ_INTERLOCK_CHECK_RESULT   
  WHERE  RECEIPT_DATE >= :ARG_DATESET
      AND RECEIPT_DATE <= :ARG_DATEEND
      AND LINE_CODE  LIKE :ARG_LINE_CODE 
	 AND MODEL_NAME LIKE :ARG_MODEL_NAME 
      AND IS_LAST_YN = 'Y' 
      AND WORKSTAGE_CODE = 'W030' 
      AND ORGANIZATION_ID = :ARG_ORG
   
GROUP BY TRUNC( IQ_INTERLOCK_CHECK_RESULT.RECEIPT_DATE) ,   
         IQ_INTERLOCK_CHECK_RESULT.ITEM_CODE,   
         IQ_INTERLOCK_CHECK_RESULT.LINE_CODE,   
         IQ_INTERLOCK_CHECK_RESULT.RUN_NO,   
         IQ_INTERLOCK_CHECK_RESULT.MODEL_NAME,   
         IQ_INTERLOCK_CHECK_RESULT.PCB_ITEM  " arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_ORG", number))  sort="receipt_date A line_code A model_name A pcb_item A " )
group(level=1 header.height=0 trailer.height=60 by=("receipt_date" ) header.color="536870912" trailer.color="30474192" )
