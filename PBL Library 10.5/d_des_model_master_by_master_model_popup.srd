 column=(type=char(30) update=yes updatewhereclause=yes name=customer_model_name dbname="ip_product_model_master.customer_model_name" )
 retrieve="  SELECT ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_SPEC~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_TYPE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"PART_NO~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CUSTOMER_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CUSTOMER_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"EC_NO~",   
         F_CHECK_BOM_EXISTS( ITEM_CODE , ORGANIZATION_ID ) BOM_EXISTS,   
         F_CHECK_SMT_BOM_EXISTS( MODEL_NAME, ORGANIZATION_ID ) SMT_BOM_EXISTS,   
         F_CHECK_JIG_EXISTS( MODEL_NAME, ORGANIZATION_ID ) JIG_EXISTS,   
         F_CHECK_CALENDER_EXISTS( MODEL_NAME, ORGANIZATION_ID ) CALENDER_EXISTS,   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"SMT_MODEL_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"MASTER_MODEL_NAME~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_MODEL_MASTER~".~"CUSTOMER_MODEL_NAME~"  
    FROM ~"IP_PRODUCT_MODEL_MASTER~"  
   WHERE ( ~"IP_PRODUCT_MODEL_MASTER~".~"MASTER_MODEL_NAME~" like :ARG_MASTER_MODEL_NAME ) AND  
         ~"IP_PRODUCT_MODEL_MASTER~".~"ORGANIZATION_ID~" = :ARG_ORG  " arguments=(("ARG_MASTER_MODEL_NAME", string),("ARG_ORG", number))  sort="customer_code A model_name A " )
