table(column=(type=char(30) update=yes updatewhereclause=yes name=jig_code dbname="imcn_jig.jig_code" )
 column=(type=char(20) updatewhereclause=yes name=imcn_jig_jig_lot_no dbname="imcn_jig.jig_lot_no" )
