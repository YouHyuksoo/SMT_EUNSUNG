 column=(type=number updatewhereclause=yes name=imcn_jig_mask_check_tension_check5 dbname="imcn_jig_mask_check.tension_check5" )
 column=(type=number updatewhereclause=yes name=break_value dbname="break_value" )
 column=(type=number updatewhereclause=yes name=hit_value dbname="hit_value" )
 column=(type=number updatewhereclause=yes name=remain_value dbname="remain_value" )
 column=(type=char(2000) updatewhereclause=yes name=imcn_jig_management_commnets dbname="imcn_jig.management_commnets" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="imcn_jig.organization_id" )
 retrieve="SELECT 
      IMCN_JIG.JIG_CODE,
      IMCN_JIG.JIG_LOT_NO,
      IMCN_JIG.JIG_NAME,
      IMCN_JIG.JIG_MODEL_NAME,
      IMCN_JIG.ENTER_DATE,
      IMCN_JIG_MASK_CHECK.TENSION_CHECK1,
      IMCN_JIG_MASK_CHECK.TENSION_CHECK2,
      IMCN_JIG_MASK_CHECK.TENSION_CHECK3,
      IMCN_JIG_MASK_CHECK.TENSION_CHECK4,
      IMCN_JIG_MASK_CHECK.TENSION_CHECK5,
      NVL(IMCN_JIG.BREAK_VALUE,0) BREAK_VALUE,
      NVL(IMCN_JIG.HIT_VALUE,0) HIT_VALUE,
      NVL(IMCN_JIG.BREAK_VALUE,0) - NVL(IMCN_JIG.HIT_VALUE,0) REMAIN_VALUE,
      IMCN_JIG.MANAGEMENT_COMMNETS,
      IMCN_JIG.ORGANIZATION_ID
FROM IMCN_JIG LEFT OUTER JOIN (SELECT JIG_LOT_NO, TENSION_CHECK1, TENSION_CHECK2, TENSION_CHECK3, TENSION_CHECK4, TENSION_CHECK5, ORGANIZATION_ID
                                FROM (SELECT RANK() OVER(ORDER BY ENTER_DATE DESC) RNK, JIG_LOT_NO, TENSION_CHECK1, TENSION_CHECK2, TENSION_CHECK3, TENSION_CHECK4, TENSION_CHECK5, ORGANIZATION_ID
                                      FROM IMCN_JIG_MASK_CHECK
                                      )TBL
                                WHERE RNK = 1) IMCN_JIG_MASK_CHECK ON IMCN_JIG.JIG_LOT_NO = IMCN_JIG_MASK_CHECK.JIG_LOT_NO AND IMCN_JIG.ORGANIZATION_ID = IMCN_JIG_MASK_CHECK.ORGANIZATION_ID
WHERE IMCN_JIG.JIG_TYPE = 'M' AND
      IMCN_JIG.ENTER_DATE >= :arg_dateset AND
      IMCN_JIG.ENTER_DATE <= :arg_dateend AND
      IMCN_JIG.JIG_CODE LIKE :arg_jig_code AND
	  IMCN_JIG.LINE_CODE LIKE :arg_line_code AND
	  IMCN_JIG.ORGANIZATION_ID = :arg_org" arguments=(("arg_jig_code", string),("arg_line_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number))  sort="jig_code A " )
