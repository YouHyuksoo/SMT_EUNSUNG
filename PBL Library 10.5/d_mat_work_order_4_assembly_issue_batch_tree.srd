 column=(type=char(4000) updatewhereclause=yes name=inventory_mfs dbname="inventory_mfs" )
 column=(type=char(100) updatewhereclause=yes key=yes name=sort_sequence dbname="im_item_work_order.sort_sequence" dbalias="A.sort_sequence" )
 retrieve="  SELECT A.ORGANIZATION_ID,   
			A.PLAN_DATE,   
			A.ITEM_CODE,   
			A.ISSUE_DATE,   
			A.ISSUE_TYPE,   
			A.MFS,   
			A.ISSUE_DIVISION,   
			A.ISSUE_ACCOUNT,   
			A.ISSUE_STATUS,   
			A.WORK_ORDER_TYPE,   
			A.ITEM_TYPE,   
			A.LINE_TYPE,   
			B.ITEM_NAME,  
			B.ITEM_SPEC,    
			B.ITEM_UOM,   
			B.ITEM_DIVISION,   
			NVL(B.AUTO_ISSUE_YN,'N') AUTO_ISSUE_YN,   
			A.LAST_MODIFY_DATE,   
			A.LAST_MODIFY_BY,   
			A.ENTER_DATE,   
			A.ENTER_BY,   
			f_get_sal_assy_inventory_qty(a.item_code, a.line_type, a.organization_id) inventory_qty,   
			'N' check_yn,   
			A.PLAN_YYYYMM,   
			A.LINE_CODE,   
			A.WORKSTAGE_CODE,   
			A.ISSUE_QTY,   
			A.ISSUE_PLAN_QTY,   
			A.ISSUE_PLAN_QTY - A.ISSUE_QTY REMAIN_QTY,   
			A.PLAN_DATE_SEQUENCE,   
			A.WORK_ORDER_NO,   
			
			A.ROUTE_NO,   
			A.ORIGIN_MFS,   
			A.PARENT_ITEM_CODE  ,
			F_GET_PRODUCT_PLAN_STATUS( A.MFS , A.PLAN_DATE , A.PLAN_DATE_SEQUENCE , A.ORGANIZATION_ID ) PLAN_STATUS ,
			F_GET_SAL_ASSY_INV_MFS_BY_ITEM ( A.ITEM_CODE , A.LINE_TYPE , A.ORGANIZATION_ID ) INVENTORY_MFS ,
             A.SORT_SEQUENCE
    FROM IM_ITEM_WORK_ORDER A,   
         ID_ITEM B,   
         ID_ITEM ID_ITEM_B  
   WHERE ( A.ITEM_CODE = B.ITEM_CODE ) and  
         ( A.ORGANIZATION_ID = B.ORGANIZATION_ID ) and  
         ( A.PARENT_ITEM_CODE = ID_ITEM_B.ITEM_CODE ) and  
         ( A.ORGANIZATION_ID = ID_ITEM_B.ORGANIZATION_ID ) and  
         ( ( A.ISSUE_DATE >= :arg_dateset ) AND  
         ( A.ISSUE_DATE <= :art_dateend ) AND  
         ( a.mfs LIKE :arg_mfs ) AND  
         ( a.item_code LIKE :arg_item_code ) AND  
         ( a.item_type <> 'M' ) AND  
         ( a.line_type = 'T' ) AND  
         ( a.issue_account  in( 'M001' , 'M011') ) AND  
         ( a.organization_id = :arg_org_id ) )    
" update="IM_ITEM_WORK_ORDER" updatewhere=0 updatekeyinplace=yes arguments=(("arg_dateset", datetime),("art_dateend", datetime),("arg_item_code", string),("arg_mfs", string),("arg_org_id", number))  sort="organization_id A line_code A plan_yyyymm A mfs A item_code A plan_date A " )
