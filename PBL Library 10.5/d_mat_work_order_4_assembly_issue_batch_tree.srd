 column=(type=char(6) updatewhereclause=yes name=plan_yyyymm dbname="im_item_work_order.plan_yyyymm" dbalias="A.plan_yyyymm" )
 column=(type=char(20) update=yes updatewhereclause=yes name=line_code dbname="im_item_work_order.line_code" dbalias="A.line_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=workstage_code dbname="im_item_work_order.workstage_code" dbalias="A.workstage_code" )
 column=(type=number updatewhereclause=yes name=issue_qty dbname="im_item_work_order.issue_qty" dbalias="A.issue_qty" )
