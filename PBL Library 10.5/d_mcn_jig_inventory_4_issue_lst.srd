 retrieve="  SELECT ~"IMCN_JIG~".~"ORGANIZATION_ID~",   
         ~"IMCN_JIG~".~"JIG_NAME~",   
         ~"IMCN_JIG~".~"JIG_TYPE~",   
         ~"IMCN_JIG~".~"CAPACITY~",   
         ~"IMCN_JIG~".~"RESERVED_CAPACITY~",   
         ~"IMCN_JIG~".~"ACQUISITION_DATE~",   
         ~"IMCN_JIG~".~"ACQUISITION_TYPE~",   
         ~"IMCN_JIG~".~"JIG_MODEL_NAME~",   
         ~"IMCN_JIG~".~"LINE_CODE~",   
         ~"IMCN_JIG~".~"CUSTOMER_CODE~",   
         ~"IMCN_JIG~".~"USE_STATUS~",   
         ~"IMCN_JIG~".~"MANUAL_LOCATION_COMMENT~",   
         ~"IMCN_JIG~".~"NATION_CODE~",   
         ~"IMCN_JIG~".~"WORKSTAGE_CODE~",   
         ~"IMCN_JIG~".~"ENTER_BY~",   
         ~"IMCN_JIG~".~"ENTER_DATE~",   
         ~"IMCN_JIG~".~"LAST_MODIFY_BY~",   
         ~"IMCN_JIG~".~"LAST_MODIFY_DATE~",   
         ~"IMCN_JIG~".~"USE_RATE~",   
         ~"IMCN_JIG~".~"UPH_VALUE~",   
         ~"IMCN_JIG~".~"CAPACITY_UOM~",   
         ~"IMCN_JIG~".~"SUPPLIER_CODE~",   
         ~"IMCN_JIG~".~"JIG_STATUS~",   
         ~"IMCN_JIG~".~"JIG_IMAGE_FILE_NAME~",   
         ~"IMCN_JIG~".~"JIG_CODE~",   
         'N' CHECK_YN,   
         ~"IMCN_JIG~".~"USE_TPM_YN~",   
         ~"IMCN_JIG~".~"JIG_LOT_NO~",   
         ~"IMCN_JIG~".~"MACHINE_CODE~",   
         ~"IMCN_JIG~".~"BREAK_VALUE~",   
         ~"IMCN_JIG~".~"HIT_VALUE~",   
         ~"IMCN_JIG~".~"JIG_SPEC~",
         ~"IMCN_JIG~".~"RECEIPT_DATE~",   
         ~"IMCN_JIG~".~"ISSUE_DATE~",   
         ~"IMCN_JIG~".~"TENSION_CHECK_YN~"    
    FROM ~"IMCN_JIG~"  
   WHERE ( ~"IMCN_JIG~".~"JIG_CODE~" like :ARG_JIG_CODE ) AND  
         ( ~"IMCN_JIG~".~"JIG_TYPE~" like :ARG_JIG_TYPE ) AND  
         ( ~"IMCN_JIG~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" update="IMCN_JIG" updatewhere=0 updatekeyinplace=no arguments=(("ARG_JIG_CODE", string),("ARG_JIG_TYPE", string),("ARG_ORG", number))  sort="jig_status A jig_type A jig_code A " )
