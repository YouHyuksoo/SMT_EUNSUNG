 retrieve="  SELECT ~"ID_ENG_BOM_WORKSPACE~".~"BOM_WORK_NO~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"PARENT_ITEM_CODE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"CHILD_ITEM_CODE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"ORGANIZATION_ID~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"DATESET~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"NEW_BOM_YN~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"ITEM_CODE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"SORT_SEQUENCE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"ITEM_UNIT_QTY~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"WORKSTAGE_CODE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"DATEEND~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"ENTER_BY~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"ENTER_DATE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"LAST_MODIFY_BY~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"LAST_MODIFY_DATE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"ITEM_TYPE~",   
         ~"ID_ENG_BOM_WORKSPACE~".~"LINE_TYPE~"   , ROWID
    FROM ~"ID_ENG_BOM_WORKSPACE~"  
   WHERE ( ~"ID_ENG_BOM_WORKSPACE~".~"BOM_WORK_NO~" = :ARG_WORK_NO ) AND  
         ( ~"ID_ENG_BOM_WORKSPACE~".~"ITEM_CODE~" like :ARG_ITEM_CODE ) AND  
         ( ~"ID_ENG_BOM_WORKSPACE~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" update="ID_ENG_BOM_WORKSPACE" updatewhere=1 updatekeyinplace=no arguments=(("ARG_WORK_NO", number),("ARG_ITEM_CODE", string),("ARG_ORG", number)) )
