 column=(type=number updatewhereclause=yes name=ib_smt_checkhist_full_check_sequence dbname="ib_smt_checkhist.full_check_sequence" dbalias="A.full_check_sequence" )
 column=(type=char(10) updatewhereclause=yes name=ib_smt_checkhist_pcb_item dbname="ib_smt_checkhist.pcb_item" dbalias="A.pcb_item" )
 column=(type=char(200) updatewhereclause=yes name=ib_smt_checkhist_old_barcode dbname="ib_smt_checkhist.old_barcode" dbalias="A.old_barcode" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ib_smt_checkhist.item_code" dbalias="A.item_code" )
 column=(type=datetime updatewhereclause=yes name=ib_smt_checkhist_ccs_end_date dbname="ib_smt_checkhist.ccs_end_date" dbalias="A.ccs_end_date" )
 column=(type=char(30) updatewhereclause=yes name=ib_smt_checkhist_lot_no dbname="ib_smt_checkhist.lot_no" dbalias="A.lot_no" )
 column=(type=datetime updatewhereclause=yes name=valid_date dbname="ib_smt_checkhist.valid_date" dbalias="A.valid_date" )
 column=(type=char(10) updatewhereclause=yes name=lot_serial dbname="ib_smt_checkhist.lot_serial" dbalias="A.lot_serial" )
 column=(type=char(20) updatewhereclause=yes name=trace_code dbname="ib_smt_checkhist.trace_code" dbalias="A.trace_code" )
 column=(type=char(100) updatewhereclause=yes name=supplier_barcode_origin dbname="ib_smt_checkhist.supplier_barcode_origin" dbalias="A.supplier_barcode_origin" )
 retrieve="  SELECT 'MIN' div,   
         A.LOT_NAME,   
         A.LINE_CODE,   
         A.MACHINE,   
         A.PARTNAME,   
         A.SCAN_PARTNAME,   
         A.CHIPNAME,   
         B.ITEM_NAME,   
         B.ITEM_SPEC,   
         A.CHECK_DATE,   
         A.TABLE_ID,   
         A.LOCATION_CODE,   
         A.CHECK_SEQUENCE,   
         A.CHECK_STATUS,   
         A.CHECK_MSG,   
         A.CHECK_TYPE,   
         A.NG_REASON,   
         A.FULL_CHECK_SEQUENCE,   
         A.PCB_ITEM,   
         A.OLD_BARCODE,   
         A.ITEM_CODE,   
         A.CCS_END_DATE,   
         A.LOT_NO  ,
		A.VALID_DATE ,
		A.LOT_SERIAL ,
		A.TRACE_CODE ,
         A.SUPPLIER_BARCODE_ORIGIN
    FROM IB_SMT_CHECKHIST A,   
         ID_ITEM B  
   WHERE a.partname = b.item_code(+)    
     AND a.check_date <= (SELECT   MAX (receipt_date)
                            FROM   iq_interlock_check_result
                           WHERE serial_no = :arg_serial_no 
							AND line_code = :arg_line_code
							AND workstage_code = :arg_workstage_code)
     AND a.lot_name = :arg_model_name
     AND a.line_code = :arg_line_code
     AND (a.check_date, a.line_code, a.lot_name, a.pcb_item, a.location_code) IN
                 (  SELECT   MAX (check_date),
                             line_code,
                             lot_name,
                             pcb_item,
                             location_code
                      FROM   ib_smt_checkhist
                     WHERE   check_date <= (SELECT   MAX (receipt_date)
                                              FROM   iq_interlock_check_result
                                             WHERE   serial_no = :arg_serial_no 
											 AND line_code = :arg_line_code
										     AND workstage_code = :arg_workstage_code)
                         AND lot_name = :arg_model_name
					   AND line_code = :arg_line_code
                         AND check_type IN (1, 2)
					  AND CHECK_STATUS = 'P'
                    
                  GROUP BY   line_code,
                             lot_name,
                             pcb_item,
                             location_code)
     AND check_type IN (1, 2)
     AND  CHECK_STATUS = 'P'" arguments=(("arg_model_name", string),("arg_line_code", string),("arg_workstage_code", string),("arg_serial_no", string),("arg_org", number))  sort="line_code A machine A table_id A partname A " )
