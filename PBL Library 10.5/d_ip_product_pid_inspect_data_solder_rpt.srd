footer(height=56 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=im_item_solder_input_hist_run_no dbname="im_item_solder_input_hist.run_no" dbalias="h.run_no" )
 column=(type=char(4000) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(100) updatewhereclause=yes name=item_barcode dbname="im_item_solder_master.item_barcode" dbalias="m.item_barcode" )
 column=(type=char(10) updatewhereclause=yes name=solder_type dbname="im_item_solder_master.solder_type" dbalias="m.solder_type" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="im_item_solder_master.item_code" dbalias="m.item_code" )
 column=(type=datetime updatewhereclause=yes name=im_item_solder_input_hist_input_date dbname="im_item_solder_input_hist.input_date" dbalias="h.input_date" )
 column=(type=datetime updatewhereclause=yes name=destroy_date dbname="im_item_solder_master.destroy_date" dbalias="m.destroy_date" )
 column=(type=datetime updatewhereclause=yes name=valid_date dbname="im_item_solder_master.valid_date" dbalias="m.valid_date" )
 column=(type=number updatewhereclause=yes name=viscosity dbname="im_item_solder_master.viscosity" dbalias="m.viscosity" )
 retrieve="
   select h.run_no, 
            f_get_line_name( h.line_code, 1) line_code,
            m.item_barcode,
            m.solder_type,  
            m.item_code, 
            h.input_date, 
            m.destroy_date,  
            m.valid_date, 
            m.viscosity
     from im_item_solder_input_hist h,
             im_item_solder_master     m
    where h.solder_lot_no = m.item_barcode
      and h.run_no  = (                    
                                 select run_no
                                  from ip_product_2d_barcode
                                 where serial_no like  :ARG_SERIAL_NO 
                                     and rownum = 1
                                ) " arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="item_barcode A " )
