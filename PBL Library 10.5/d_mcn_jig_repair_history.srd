 column=(type=number update=yes updatewhereclause=yes name=repair_time dbname="imcn_jig_repair.repair_time" )
 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(20) updatewhereclause=yes name=jig_lot_no dbname="imcn_jig_repair.jig_lot_no" )
 column=(type=char(20) updatewhereclause=yes name=jig_type dbname="imcn_jig.jig_type" )
 column=(type=number updatewhereclause=yes name=repair_count dbname="repair_count" )
 retrieve="  SELECT ~"IMCN_JIG_REPAIR~".~"JIG_CODE~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_SEQUENCE~",   
         ~"IMCN_JIG_REPAIR~".~"ORGANIZATION_ID~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_REQUEST_DATE~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_REASON_CODE~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_VENDOR_CODE~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_STATUS~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_BY~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_DATE~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_AMT~",   
         ~"IMCN_JIG_REPAIR~".~"CURRENCY~",   
         ~"IMCN_JIG_REPAIR~".~"COMMENTS~",   
         ~"IMCN_JIG_REPAIR~".~"ENTER_BY~",   
         ~"IMCN_JIG_REPAIR~".~"ENTER_DATE~",   
         ~"IMCN_JIG_REPAIR~".~"LAST_MODIFY_BY~",   
         ~"IMCN_JIG_REPAIR~".~"LAST_MODIFY_DATE~",   
         ~"IMCN_JIG_REPAIR~".~"REPAIR_TIME~",   
         'N' CHECK_YN,   
         ~"IMCN_JIG_REPAIR~".~"JIG_LOT_NO~",   
         ~"IMCN_JIG~".~"JIG_TYPE~"  ,

		( SELECT COUNT(*)  FROM IMCN_JIG_REPAIR B WHERE B.JIG_LOT_NO = IMCN_JIG_REPAIR.JIG_LOT_NO AND    REPAIR_DATE >= SYSDATE - 100 ) REPAIR_COUNT

    FROM ~"IMCN_JIG_REPAIR~",   
         ~"IMCN_JIG~"  
   WHERE ( imcn_jig_repair.jig_lot_no = imcn_jig.jig_lot_no (+)) and  
         ( imcn_jig_repair.organization_id = imcn_jig.organization_id (+)) and  
         ( ~"IMCN_JIG_REPAIR~".~"JIG_LOT_NO~" in ( select jig_lot_no from imcn_jig where jig_type = :arg_jig_type ) ) AND  
         ( ~"IMCN_JIG_REPAIR~".~"JIG_CODE~" like :arg_jig_code ) AND  
         ( ~"IMCN_JIG_REPAIR~".~"REPAIR_REQUEST_DATE~" >= :arg_dateset ) AND  
         ( ~"IMCN_JIG_REPAIR~".~"REPAIR_REQUEST_DATE~" <= :arg_dateend ) AND  
         ( ~"IMCN_JIG_REPAIR~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_jig_type", string),("arg_jig_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number))  sort="organization_id A jig_code A repair_sequence A " )
