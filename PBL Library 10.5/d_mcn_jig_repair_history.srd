table(column=(type=char(30) update=yes updatewhereclause=yes name=jig_code dbname="imcn_jig_repair.jig_code" )
 column=(type=number update=yes updatewhereclause=yes name=repair_sequence dbname="imcn_jig_repair.repair_sequence" )
