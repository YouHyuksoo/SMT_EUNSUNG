 column=(type=char(20) update=yes updatewhereclause=yes name=repair_vendor_code dbname="imcn_jig_repair.repair_vendor_code" )
 column=(type=char(1) update=yes updatewhereclause=yes name=repair_status dbname="imcn_jig_repair.repair_status" )
 column=(type=char(20) update=yes updatewhereclause=yes name=repair_by dbname="imcn_jig_repair.repair_by" )
