HA$PBExportHeader$f_retrieve.srf
$PBExportComments$Re Retrieve
global type f_retrieve from function_object
end type

forward prototypes
global function integer f_retrieve ()
end prototypes

global function integer f_retrieve ();window activesheet
string mtext
activesheet = w_main_frame.GetActiveSheet( )
IF IsValid(activesheet) THEN
	Gvs_ue_data_control = 'RETRIEVE'
	activesheet.TRIGGEREVENT('UE_DATA_CONTROL')
ELSE 
   RETURN -1
   
END IF

RETURN 0 
end function

