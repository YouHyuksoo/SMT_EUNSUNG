 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(1) updatewhereclause=yes name=item_division dbname="id_item.item_division" )
 retrieve="  SELECT 'N' CHECK_YN ,
          ~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_HOLD~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_PRICE~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~",   
         ~"IM_ITEM_INVENTORY~".~"INVENTORY_AMT~",   
         F_GET_MAT_ORDER_QTY( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) ORDER_QTY , 
         F_GET_MAT_DEPARTURE_QTY( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) DEPARTURE_QTY , 
         F_GET_MAT_ARRIVAL_QTY( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~",  ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) ARRIVAL_QTY , 
         F_GET_MAT_WS_INV_QTY ( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~", ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) WORKSTAGE_QTY , 
         ~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~",   
         ~"IM_ITEM_INVENTORY~".~"COMMENTS~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"ENTER_BY~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_INVENTORY~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~" ,
         ~"ID_ITEM~".~"ITEM_DIVISION~"
    FROM ~"IM_ITEM_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and  
( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
( ( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
( ~"IM_ITEM_INVENTORY~".~"LINE_TYPE~" like :arg_line_type ) AND  
( ~"IM_ITEM_INVENTORY~".~"INVENTORY_QTY~" <> 0 ) AND
( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    


UNION ALL

  SELECT 'N' CHECK_YN ,
         ~"IS_ASSEMBLY_INVENTORY~".~"MFS~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"ITEM_CODE~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"INVENTORY_STATUS~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"ORGANIZATION_ID~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"PRODUCT_LINE_TYPE~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"INVENTORY_HOLD~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"INVENTORY_PRICE~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"INVENTORY_QTY~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"INVENTORY_AMT~",   
         0 ORDER_QTY , 
         0 DEPARTURE_QTY , 
         0 ARRIVAL_QTY , 
         F_GET_MAT_WS_INV_QTY ( ~"IS_ASSEMBLY_INVENTORY~".~"ITEM_CODE~", ~"IS_ASSEMBLY_INVENTORY~".~"ORGANIZATION_ID~" ) WORKSTAGE_QTY , 
         ~"IS_ASSEMBLY_INVENTORY~".~"LOCATION_CODE~",   
         '*' COMMENTS,   
         ~"IS_ASSEMBLY_INVENTORY~".~"ENTER_DATE~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"ENTER_BY~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"LAST_MODIFY_DATE~",   
         ~"IS_ASSEMBLY_INVENTORY~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~" ,
         ~"ID_ITEM~".~"ITEM_DIVISION~"
    FROM ~"IS_ASSEMBLY_INVENTORY~",   
         ~"ID_ITEM~"  
   WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IS_ASSEMBLY_INVENTORY~".~"ITEM_CODE~" ) and  
( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IS_ASSEMBLY_INVENTORY~".~"ORGANIZATION_ID~" ) and  
( ( ~"IS_ASSEMBLY_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) AND  
( ~"IS_ASSEMBLY_INVENTORY~".~"PRODUCT_LINE_TYPE~" like :arg_line_type ) AND  
( ~"IS_ASSEMBLY_INVENTORY~".~"INVENTORY_QTY~" <> 0 ) AND
( ~"IS_ASSEMBLY_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" arguments=(("arg_item_code", string),("arg_line_type", string),("arg_org_id", number))  sort="organization_id A item_code A material_mfs A " )
