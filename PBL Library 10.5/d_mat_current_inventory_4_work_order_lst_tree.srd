 column=(type=char(10) update=yes updatewhereclause=yes name=line_type dbname="im_item_inventory.line_type" )
 column=(type=char(1) update=yes updatewhereclause=yes name=inventory_hold dbname="im_item_inventory.inventory_hold" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_price dbname="im_item_inventory.inventory_price" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_qty dbname="im_item_inventory.inventory_qty" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_amt dbname="im_item_inventory.inventory_amt" )
 column=(type=number updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=number updatewhereclause=yes name=departure_qty dbname="departure_qty" )
