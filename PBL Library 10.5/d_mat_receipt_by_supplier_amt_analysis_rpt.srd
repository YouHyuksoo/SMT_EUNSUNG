HA$PBExportHeader$d_mat_receipt_by_supplier_amt_analysis_rpt.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=33554431 processing=0 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 0 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=yes )
header(height=568 color="536870912" )
summary(height=2316 color="16777215" )
footer(height=88 color="536870912" )
detail(height=88 color="536870912~tif(mod(getrow(),2)= 0 , rgb(255,255,255), rgb(219,219,219))" )
table(column=(type=char(8) updatewhereclause=yes name=div dbname="div" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="supplier_code" )
 column=(type=char(100) updatewhereclause=yes name=supplier_name dbname="supplier_name" )
 column=(type=char(10) updatewhereclause=yes name=line_type dbname="line_type" )
 column=(type=char(3) updatewhereclause=yes name=currency dbname="currency" )
 column=(type=number updatewhereclause=yes name=receipt_qty dbname="receipt_qty" )
 column=(type=number updatewhereclause=yes name=receipt_amt dbname="receipt_amt" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="organization_id" )
 retrieve="select    div ,
             supplier_code , supplier_name , line_type ,
            currency ,
		sum(receipt_qty) receipt_qty ,
		sum(receipt_amt)  receipt_amt,
		organization_id 

from (
select   'MATERIAL' DIV ,
            a.supplier_code,              
		max(b.supplier_name) supplier_name , 
		max(a.line_type) line_type,
		currency ,
		sum(decode( receipt_type , 'R' , 0 , a.receipt_qty)) receipt_qty ,  
		sum(decode( receipt_type , 'R' , 0 , a.receipt_amt)) receipt_amt, 
		a.organization_id
from   im_item_receipt   a, 
          icom_supplier b
where  a.supplier_code = b.supplier_code
and     a.organization_id = b.organization_id
and     a.receipt_date  >=  :arg_dateset
and     a.receipt_date  <=  :arg_dateend
and     a.supplier_code like :arg_supplier_code
and     a.item_code like :arg_item_code
and     a.organization_id = :arg_org_id 
and     a.receipt_status = 'N' 
group by a.supplier_code, a.line_type , a.currency , a.organization_id   

union all

select    'SUBMAT' DIV ,
            a.supplier_code,              
		max(b.supplier_name) supplier_name , 
		'' line_type,
		currency ,
		sum(a.receipt_qty) receipt_qty ,  
		sum(a.receipt_amt) receipt_amt, 
		a.organization_id
from   IMCN_MOLD_RECEIPT   a, 
          icom_supplier b
where  a.supplier_code = b.supplier_code
and     a.organization_id = b.organization_id
and     a.receipt_date  >=  :arg_dateset
and     a.receipt_date  <=  :arg_dateend
and     a.supplier_code like :arg_supplier_code
and     a.mold_code like :arg_item_code
and     a.organization_id = :arg_org_id 
and     a.receipt_status = 'N' 
group by a.supplier_code, a.line_type , a.currency , a.organization_id   







 )

group by div , supplier_code,supplier_name , line_type , currency , organization_id 


" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_org_id", number))  sort="organization_id A div A supplier_code A " )
