 retrieve="  SELECT ~"IM_ITEM_RECEIPT~".~"RECEIPT_SEQUENCE~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~",   
         ~"IM_ITEM_RECEIPT~".~"LOCATION_CODE~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_DEFICIT~",   
         ~"IM_ITEM_RECEIPT~".~"LINE_TYPE~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_QTY~",   
         ~"IM_ITEM_RECEIPT~".~"UNIT_PRICE~",   
         ~"IM_ITEM_RECEIPT~".~"MATERIAL_COST_AMT~",   
         ~"IM_ITEM_RECEIPT~".~"ENTER_DATE~",   
         ~"IM_ITEM_RECEIPT~".~"INVOICE_NO~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_AMT~",   
         ~"IM_ITEM_RECEIPT~".~"ENTER_BY~",   
         ~"IM_ITEM_RECEIPT~".~"EXCHANGE_RATE~",   
         ~"IM_ITEM_RECEIPT~".~"FOREIGN_RECEIPT_AMT~",   
         ~"IM_ITEM_RECEIPT~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_RECEIPT~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_RECEIPT~".~"CONFIRM_YN~",   
         ~"IM_ITEM_RECEIPT~".~"CONFIRM_DATE~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_TYPE~",   
         ~"IM_ITEM_RECEIPT~".~"MFS~",   
         ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT~".~"COMMENTS~",   
         ~"IM_ITEM_RECEIPT~".~"CURRENCY~",   
         ~"IM_ITEM_RECEIPT~".~"BARCODE~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_STATUS~",   
         ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ICOM_SUPPLIER~".~"SUPPLIER_NAME~",   
         ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_RECEIPT~".~"MATERIAL_MFS~",   
         F_GET_MAT_UNIT_PRICE_CONFIRM( IM_ITEM_RECEIPT.SUPPLIER_CODE , IM_ITEM_RECEIPT.ITEM_CODE , IM_ITEM_RECEIPT.LINE_TYPE , IM_ITEM_RECEIPT.RECEIPT_DATE , IM_ITEM_RECEIPT.ORGANIZATION_ID ) CHECK_UNIT_PRICE,   
         ~"IM_ITEM_RECEIPT~".~"ORDER_TYPE~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"IM_ITEM_RECEIPT~".~"RECEIPT_LOT_NO~",   
         ~"IM_ITEM_RECEIPT~".~"FROM_SUPPLIER_CODE~",   
         ~"IM_ITEM_RECEIPT~".~"SUBCONTRACT_INVOICE_NO~",   
         ~"IM_ITEM_RECEIPT~".~"ORIGIN_MFS~",  
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_COMPARE_YN~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"RECEIPT_SLIP_NO~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"ENTER_DATE~" ,
         IM_ITEM_RECEIPT_BARCODE.VENDOR_LOTNO ,
         IM_ITEM_RECEIPT_BARCODE.VENDOR_CODE 
    FROM ~"IM_ITEM_RECEIPT~",   
			~"ID_ITEM~",   
			~"ICOM_SUPPLIER~",   
			~"IM_ITEM_RECEIPT_BARCODE~"  
   WHERE ( im_item_receipt.item_code = id_item.item_code (+)) and  
         ( im_item_receipt.organization_id = id_item.organization_id (+)) and  
         ( im_item_receipt.supplier_code = icom_supplier.supplier_code (+)) and  
         ( im_item_receipt.organization_id = icom_supplier.organization_id (+)) and  
         ( im_item_receipt.item_code = im_item_receipt_barcode.item_code (+)) and  
         ( im_item_receipt.material_mfs = im_item_receipt_barcode.lot_no (+)) and  
         ( im_item_receipt.supplier_code = icom_supplier.supplier_code(+)) AND  
         ( im_item_receipt.organization_id = icom_supplier.organization_id(+)) AND  
         ( ( ~"IM_ITEM_RECEIPT~".~"RECEIPT_DATE~" between :arg_dateset and :arg_dateend ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"SUPPLIER_CODE~" like :arg_supplier_code ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"ORGANIZATION_ID~" = :arg_org_id ) AND  
         ( NVL(~"ID_ITEM~".~"ITEM_CLASS~",'*') like :arg_item_class ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"RECEIPT_TYPE~" like :arg_receipt_type ) AND  
         ( ~"IM_ITEM_RECEIPT~".~"LOCATION_CODE~" like :arg_location_code ) )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_item_class", string),("arg_location_code", string),("arg_receipt_type", string),("arg_org_id", number))  sort="organization_id A location_code A receipt_date A receipt_sequence A item_code A receipt_type A " )
