 column=(type=datetime updatewhereclause=yes name=kitting_date dbname="ip_product_run_card.kitting_date" dbalias=".kitting_date" )
 retrieve="  SELECT ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~",   
         ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_NO~",   
         ~"IP_PRODUCT_RUN_CARD~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~",   
 
         ~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"MARKING_NO~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_SIZE~",   
    
         ~"IP_PRODUCT_RUN_CARD~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_RUN_CARD~".~"RUN_STATUS~",   
         ~"IP_PRODUCT_RUN_CARD~".~"PRODUCT_RUN_TYPE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"KITTING_DATE~" 

    FROM ~"IP_PRODUCT_RUN_CARD~"  
   WHERE
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~" >= :ARG_DATESET ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~" <= :ARG_DATEEND ) AND 
         ( ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~" like :ARG_MODEL_NAME ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~" like :ARG_RUN_NO ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"MARKING_NO~" like :ARG_MARKING_NO ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"LOT_NO~" like :ARG_LOT_NO ) AND  
		( ~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~" like :ARG_LINE_CODE ) AND   
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_STATUS~" like :ARG_RUN_STATUS ) AND  
         ( ~"IP_PRODUCT_RUN_CARD~".~"ORGANIZATION_ID~" = :ARG_ORG )  " update="IP_PRODUCT_RUN_CARD" updatewhere=1 updatekeyinplace=no arguments=(("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_RUN_NO", string),("ARG_LOT_NO", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_RUN_STATUS", string),("ARG_MARKING_NO", string),("ARG_ORG", number))  sort="line_code A run_date A " )
