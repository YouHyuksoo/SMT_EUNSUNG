 column=(type=char(20) updatewhereclause=yes name=inventory_type dbname="im_item_receipt_barcode.inventory_type" )
 retrieve="  SELECT ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"CHECK_YYYYMM~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"ITEM_BARCODE~",   
         NVL(~"IM_ITEM_INVENTORY_CHECK_BCD~".~"BARCODE_QTY~",0) BARCODE_QTY,   
         NVL(~"IM_ITEM_INVENTORY_CHECK_BCD~".~"INVENTORY_QTY~",0)  INVENTORY_QTY,   
		~"IM_ITEM_INVENTORY_CHECK_BCD~".~"LOCATION_CODE~"   ,
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"ORGANIZATION_ID~",   

         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"ITEM_CODE~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"ENTER_BY~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"ENTER_DATE~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"LOT_NO~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"LINE_CODE~",   

         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"SCAN_QTY~",   
         ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"UNIT_PRICE~",   
         ~"IM_ITEM_RECEIPT_BARCODE~".~"LABEL_TYPE~" RECEIPT_LABEL_TYPE  ,

		~"IM_ITEM_INVENTORY_CHECK_BCD~".~"CHECK_TYPE~" ,
		~"IM_ITEM_INVENTORY_CHECK_BCD~".~"LABEL_TYPE~",
		~"IM_ITEM_RECEIPT_BARCODE~".~"INVENTORY_TYPE~"
    FROM ~"IM_ITEM_INVENTORY_CHECK_BCD~",   
         ~"ID_ITEM~",   
         ~"IM_ITEM_RECEIPT_BARCODE~"  
   WHERE ( im_item_inventory_check_bcd.item_code = id_item.item_code (+)) and  

         ( im_item_inventory_check_bcd.item_code = im_item_receipt_barcode.item_code (+)) and  
         ( im_item_inventory_check_bcd.lot_no = im_item_receipt_barcode.lot_no (+)) and  
         ( ( ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"CHECK_YYYYMM~" = :arg_yyyymm ) AND  
         ( ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"ITEM_BARCODE~" like :arg_item_barcode ) AND  
         ( NVL(~"IM_ITEM_INVENTORY_CHECK_BCD~".~"BARCODE_QTY~",0) = DECODE(:arg_check_qty , 0 , 0 , NVL(~"IM_ITEM_INVENTORY_CHECK_BCD~".~"BARCODE_QTY~",0) ) ) AND  
         ( ~"IM_ITEM_INVENTORY_CHECK_BCD~".~"ORGANIZATION_ID~" = :arg_org ) )    
" update="IM_ITEM_INVENTORY_CHECK_BCD" updatewhere=0 updatekeyinplace=yes arguments=(("arg_yyyymm", string),("arg_item_barcode", string),("arg_check_qty", number),("arg_org", number))  sort="item_code A lot_no A " )
