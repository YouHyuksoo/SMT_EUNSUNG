 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_receipt~" )  TABLE(NAME=~"icom_supplier~" )  TABLE(NAME=~"id_item~" )  TABLE(NAME=~"isys_organization~" ) COLUMN(NAME=~"im_item_receipt.receipt_date~") COLUMN(NAME=~"im_item_receipt.receipt_sequence~") COLUMN(NAME=~"im_item_receipt.organization_id~") COLUMN(NAME=~"im_item_receipt.supplier_code~") COLUMN(NAME=~"im_item_receipt.receipt_qty~") COLUMN(NAME=~"im_item_receipt.invoice_no~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"im_item_receipt.item_code~") COLUMN(NAME=~"im_item_receipt.mfs~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"im_item_receipt.material_mfs~") COLUMN(NAME=~"im_item_receipt.receipt_deficit~") COLUMN(NAME=~"im_item_receipt.receipt_lot_no~") COLUMN(NAME=~"icom_supplier.fax_no~") COLUMN(NAME=~"icom_supplier.tel_no~") COLUMN(NAME=~"icom_supplier.address~") COLUMN(NAME=~"icom_supplier.supplier_charge_name~") COLUMN(NAME=~"icom_supplier.business_no~") COLUMN(NAME=~"isys_organization.organization_name~") COLUMN(NAME=~"isys_organization.business_no~") COLUMN(NAME=~"isys_organization.tel_no~") COLUMN(NAME=~"isys_organization.address~") COLUMN(NAME=~"isys_organization.fax_no~") COLUMN(NAME=~"isys_organization.owner_name~") COLUMN(NAME=~"im_item_receipt.delivery~") COLUMN(NAME=~"im_item_receipt.line_type~") COLUMN(NAME=~"im_item_receipt.material_cost~") COLUMN(NAME=~"im_item_receipt.unit_price~") COLUMN(NAME=~"im_item_receipt.material_cost_amt~") COLUMN(NAME=~"im_item_receipt.receipt_amt~") COLUMN(NAME=~"im_item_receipt.foreign_receipt_amt~") COLUMN(NAME=~"im_item_receipt.exchange_rate~") COLUMN(NAME=~"im_item_receipt.currency~")    JOIN (LEFT=~"icom_supplier.supplier_code~"    OP =~"=~"RIGHT=~"im_item_receipt.supplier_code~" )    JOIN (LEFT=~"icom_supplier.organization_id~"    OP =~"=~"RIGHT=~"im_item_receipt.organization_id~" )    JOIN (LEFT=~"im_item_receipt.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"im_item_receipt.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~" )    JOIN (LEFT=~"im_item_receipt.organization_id~"    OP =~"=~"RIGHT=~"isys_organization.organization_id~" )WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"RECEIPT_LOT_NO~~~"~"   OP =~"=~"    EXP2 =~":arg_receipt_lot_no )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_RECEIPT~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id )~" ) ) ARG(NAME = ~"arg_receipt_lot_no~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_receipt_lot_no", string),("arg_org_id", number)) )
