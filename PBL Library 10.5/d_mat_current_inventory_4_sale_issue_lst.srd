 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_inventory~" )  TABLE(NAME=~"id_item~" ) COMPUTE(NAME=~"'N' check_yn~") COMPUTE(NAME=~"'INTERNAL' WAREHOSUE_TYPE~") COLUMN(NAME=~"im_item_inventory.item_code~") COLUMN(NAME=~"im_item_inventory.inventory_status~") COLUMN(NAME=~"im_item_inventory.organization_id~") COLUMN(NAME=~"im_item_inventory.line_type~") COLUMN(NAME=~"im_item_inventory.inventory_hold~") COLUMN(NAME=~"im_item_inventory.inventory_price~") COLUMN(NAME=~"im_item_inventory.inventory_qty~") COLUMN(NAME=~"im_item_inventory.inventory_amt~") COLUMN(NAME=~"im_item_inventory.location_code~") COLUMN(NAME=~"im_item_inventory.comments~") COLUMN(NAME=~"im_item_inventory.enter_date~") COLUMN(NAME=~"im_item_inventory.enter_by~") COLUMN(NAME=~"im_item_inventory.last_modify_date~") COLUMN(NAME=~"im_item_inventory.last_modify_by~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_type~") COLUMN(NAME=~"id_item.item_division~") COMPUTE(NAME=~"INVENTORY_QTY ISSUE_QTY~") COLUMN(NAME=~"id_item.item_uom~") COLUMN(NAME=~"im_item_inventory.material_mfs~")    JOIN (LEFT=~"id_item.item_code~"    OP =~"=~"RIGHT=~"im_item_inventory.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_inventory.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_INVENTORY~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"SIGN(~~~"IM_ITEM_INVENTORY~~~".~~~"INVENTORY_QTY~~~")~"   OP =~">=~"    EXP2 =~":arg_inventory_sign~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_INVENTORY~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_inventory_sign~" TYPE = number)  ARG(NAME = ~"arg_org_id~" TYPE = number) " arguments=(("arg_item_code", string),("arg_inventory_sign", number),("arg_org_id", number))  sort="organization_id A warehosue_type A item_code A " )
