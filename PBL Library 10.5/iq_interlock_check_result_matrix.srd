HA$PBExportHeader$iq_interlock_check_result_matrix.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes grid.lines=1 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=84 color="536870912" )
header[3](height=132 color="536870912" )
header[4](height=120 color="536870912" )
summary(height=72 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) updatewhereclause=yes name=run_no dbname="run_no" )
 column=(type=number updatewhereclause=yes name=check_result dbname="check_result" )
 retrieve="  SELECT /*+ index ( IQ_INTERLOCK_CHECK_RESULT XPKIQ_INTERLOCK_CHECK_RESULT ) */ IQ_INTERLOCK_CHECK_RESULT.LINE_CODE AS LINE_CODE,   
         IQ_INTERLOCK_CHECK_RESULT.WORKSTAGE_CODE||' '||F_GET_WORKSTAGE_NAME(IQ_INTERLOCK_CHECK_RESULT.WORKSTAGE_CODE) AS WORKSTAGE_NAME ,
		 IQ_INTERLOCK_CHECK_RESULT.WORKSTAGE_CODE AS WORKSTAGE_CODE,   
         IQ_INTERLOCK_CHECK_RESULT.CHECK_RESULT AS CHECK_RESULT ,   
         IQ_INTERLOCK_CHECK_RESULT.ITEM_CODE AS ITEM_CODE ,   
         IQ_INTERLOCK_CHECK_RESULT.RUN_NO AS RUN_NO,   
         IQ_INTERLOCK_CHECK_RESULT.MODEL_NAME AS MODEL_NAME ,   
         IQ_INTERLOCK_CHECK_RESULT.PCB_ITEM AS PCB_ITEM,   
         IQ_INTERLOCK_CHECK_RESULT.CHILD_ITEM_CODE AS CHILD_ITEM_CODE  
    FROM IQ_INTERLOCK_CHECK_RESULT   , ID_ITEM 
  WHERE          ( IQ_INTERLOCK_CHECK_RESULT.RECEIPT_DATE >= :arg_dateset ) AND  
         ( IQ_INTERLOCK_CHECK_RESULT.RECEIPT_DATE < :arg_dateend+1 ) AND  
			( iq_interlock_check_result.item_code = id_item.item_code (+)) and  
         ( iq_interlock_check_result.organization_id = id_item.organization_id (+)) and  
         ( ( IQ_INTERLOCK_CHECK_RESULT.LINE_CODE like :arg_line_code ) AND  
         ( IQ_INTERLOCK_CHECK_RESULT.WORKSTAGE_CODE like :arg_workstage_code ) AND  
         ( IQ_INTERLOCK_CHECK_RESULT.RUN_NO like :arg_run_no ) AND  
         ( NVL(IQ_INTERLOCK_CHECK_RESULT.MODEL_NAME , '*')  like :arg_model_name ) AND  
         ( IQ_INTERLOCK_CHECK_RESULT.SERIAL_NO like :arg_serial_no ) AND  
         ( NVL(IQ_INTERLOCK_CHECK_RESULT.IS_LAST_YN , 'N') like :arg_is_last_yn ) AND  
         ( IQ_INTERLOCK_CHECK_RESULT.ORGANIZATION_ID = :arg_org ) )    
	    ORDER BY WORKSTAGE_CODE
" arguments=(("ARG_LINE_CODE", string),("ARG_WORKSTAGE_CODE", string),("ARG_RUN_NO", string),("ARG_MODEL_NAME", string),("ARG_SERIAL_NO", string),("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_IS_LAST_YN", string),("ARG_ORG", number))  sort="model_name A run_no A " )
