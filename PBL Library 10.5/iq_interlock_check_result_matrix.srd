compute(band=detail alignment="2" expression="crosstabsum(1, 3, ~"@line_code~")"border="2" color="33554432" x="1207" y="4" height="68" width="261" format="[general]" html.valueishtml="0"  name=count_check_result_1 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65535" crosstab.repeat=yes )
compute(band=summary alignment="2" expression="~"Grand Total~""border="2" color="0" x="9" y="4" height="68" width="539" format="[general]" html.valueishtml="0"  name=compute_6 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=summary alignment="2" expression="sum(check_result for all )"border="2" color="33554432" x="919" y="4" height="68" width="274" format="[general]" html.valueishtml="0"  name=compute_7 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="536870912" )
compute(band=summary alignment="2" expression="sum(count_check_result_1 for all )"border="2" color="33554432" x="1207" y="4" height="68" width="261" format="[general]" html.valueishtml="0"  name=compute_9 visible="1"  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="65535" )
 crosstab(band = foreground  crosstabonly = yes 
 columns = "line_code, workstage_name, check_result" rows = "model_name, run_no" values = "count(check_result for crosstab)" sourcenames = "line_code, workstage_name, workstage_code, check_result, item_code, run_no, model_name, pcb_item, child_item_code")
sparse(names="model_name")htmltable(border="0" cellpadding="1" cellspacing="1" )
