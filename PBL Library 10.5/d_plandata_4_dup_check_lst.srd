 retrieve="  SELECT COUNT(*) DUP_COUNT ,
         ~"IB_MNT_PLANDATA~".~"LOT_NAME~",   
         ~"IB_MNT_PLANDATA~".~"TABLE_ID~",   
         ~"IB_MNT_PLANDATA~".~"ADDRESS~",   
         ~"IB_MNT_PLANDATA~".~"POSITION~",   
        MAX( ~"IB_MNT_PLANDATA~".~"PARTNAME~") PARTNAME,   
         ~"IB_MNT_PLANDATA~".~"MACHINE_CODE~",   
         ~"IB_MNT_PLANDATA~".~"LINE_CODE~",   
         MAX(~"IB_MNT_PLANDATA~".~"LOCATION_INFO~") LOCATION_INFO,   
         ~"IB_MNT_PLANDATA~".~"MODEL_NAME~",   
         ~"IB_MNT_PLANDATA~".~"PCB_ITEM~"
    FROM ~"IB_MNT_PLANDATA~"   
GROUP BY    
         ~"IB_MNT_PLANDATA~".~"MACHINE_CODE~",   
         ~"IB_MNT_PLANDATA~".~"LINE_CODE~",   
          ~"IB_MNT_PLANDATA~".~"LOT_NAME~",   
         ~"IB_MNT_PLANDATA~".~"TABLE_ID~",   
         ~"IB_MNT_PLANDATA~".~"ADDRESS~",   
         ~"IB_MNT_PLANDATA~".~"POSITION~",   
          ~"IB_MNT_PLANDATA~".~"MODEL_NAME~",   
         ~"IB_MNT_PLANDATA~".~"PCB_ITEM~"
HAVING COUNT(*) > 1 " )
