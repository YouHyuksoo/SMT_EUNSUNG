 column=(type=char(20) updatewhereclause=yes name=customer_code dbname="id_item.customer_code" )
 column=(type=char(2000) updatewhereclause=yes name=comments dbname="ip_product_run_card.comments" )
 column=(type=char(20) updatewhereclause=yes name=metalmask_code dbname="ip_product_run_card.metalmask_code" )
 column=(type=char(22) updatewhereclause=yes name=metalmask_code_label dbname="metalmask_code_label" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="ip_product_run_card.item_code" )
 column=(type=char(30) updatewhereclause=yes name=parent_item_code dbname="ip_product_run_card.parent_item_code" )
 column=(type=char(300) updatewhereclause=yes name=id_item_item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=id_item_item_spec dbname="id_item.item_spec" )
 column=(type=char(20) updatewhereclause=yes name=item_class dbname="id_item.item_class" )
 column=(type=char(54) updatewhereclause=yes name=model_part_image dbname="model_part_image" )
 column=(type=char(30) updatewhereclause=yes name=lot_no dbname="ip_product_run_card.lot_no" )
 column=(type=char(30) updatewhereclause=yes name=marking_no dbname="ip_product_run_card.marking_no" )
 retrieve="  SELECT ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~",   
         '*'||UPPER(~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~")||'*' RUN_NO_LABEL,   
         TRUNC(~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~") RUN_DATE,   


         ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~",   
         '*'||~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~"||'*' MODEL_NAME_LABEL,   

         ~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~",   
         '*'||~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~"||'*' LINE_CODE_LABEL ,   

         ~"IP_PRODUCT_RUN_CARD~".~"LOT_SIZE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"PRODUCT_RUN_TYPE~",   
         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   
         ~"ID_ITEM_A~".~"PART_NO~",   
         ~"ID_ITEM_A~".~"CUSTOMER_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"COMMENTS~",   

         ~"IP_PRODUCT_RUN_CARD~".~"METALMASK_CODE~",   
         '*'||~"IP_PRODUCT_RUN_CARD~".~"METALMASK_CODE~"||'*' METALMASK_CODE_LABEL,   

         ~"IP_PRODUCT_RUN_CARD~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"PARENT_ITEM_CODE~",   
         ~"ID_ITEM_B~".~"ITEM_NAME~",   
         ~"ID_ITEM_B~".~"ITEM_SPEC~",   
         ~"ID_ITEM_B~".~"ITEM_CLASS~",   
		IP_PRODUCT_RUN_CARD.MODEL_NAME||'.JPG' MODEL_PART_IMAGE ,
		~"IP_PRODUCT_RUN_CARD~".~"LOT_NO~" ,
		~"IP_PRODUCT_RUN_CARD~".~"MARKING_NO~" AS MARKING_NO

    FROM ~"IP_PRODUCT_RUN_CARD~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~",   
         ~"ID_ITEM~" ~"ID_ITEM_B~"  
   WHERE ( ip_product_run_card.parent_item_code = id_item_a.item_code (+)) and  
         ( ip_product_run_card.item_code = id_item_b.item_code (+)) and  
         ( ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~" = :arg_run_no) AND  
         (~"IP_PRODUCT_RUN_CARD~".~"ORGANIZATION_ID~" = :arg_organization_id)    
" arguments=(("arg_run_no", string),("arg_organization_id", number)) )
