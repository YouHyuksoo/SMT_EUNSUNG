table(column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_run_card.run_no" )
 column=(type=char(32) updatewhereclause=yes name=run_no_label dbname="run_no_label" )
 column=(type=datetime updatewhereclause=yes name=run_date dbname="run_date" )
 column=(type=char(50) updatewhereclause=yes name=model_name dbname="ip_product_run_card.model_name" )
 column=(type=char(52) updatewhereclause=yes name=model_name_label dbname="model_name_label" )
 column=(type=char(10) updatewhereclause=yes name=line_code dbname="ip_product_run_card.line_code" )
 column=(type=char(12) updatewhereclause=yes name=line_code_label dbname="line_code_label" )
 column=(type=number updatewhereclause=yes name=lot_size dbname="ip_product_run_card.lot_size" )
 column=(type=char(1) updatewhereclause=yes name=product_run_type dbname="ip_product_run_card.product_run_type" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
