 retrieve="  SELECT ~"ISYS_REPORT_SOURCE_WHERE~".~"DATAWINDOW_NAME~",   
         ~"ISYS_REPORT_SOURCE_WHERE~".~"ARGUMENT_NAME~",   
         ~"ISYS_REPORT_SOURCE_WHERE~".~"ARGUMENT_SORT_ORDER~",   
         ~"ISYS_REPORT_SOURCE_WHERE~".~"DATA_TYPE~",   
         F_GET_DUAL_LANG_TEXT( ~"ISYS_REPORT_SOURCE_WHERE~".~"COLUMN_NAME~",  :ARG_LANG , :ARG_ORG ) COLUMN_NAME , 
	  ~"ISYS_REPORT_SOURCE_WHERE~".~"COLUMN_NAME~" COLUMN_NAME_ORIGIN ,
         ~"ISYS_REPORT_SOURCE_WHERE~".~"DEFAULT_VALUE~",   
         ~"ISYS_REPORT_SOURCE_WHERE~".~"ORGANIZATION_ID~" ,
         NULL ARGUMENT_DATA
     
    FROM ~"ISYS_REPORT_SOURCE_WHERE~"  
   WHERE ( ~"ISYS_REPORT_SOURCE_WHERE~".~"DATAWINDOW_NAME~" = :ARG_DATAWINDOW_NAME ) AND  
         ( ~"ISYS_REPORT_SOURCE_WHERE~".~"ORGANIZATION_ID~" = :ARG_ORG )    
" update="ISYS_REPORT_SOURCE_WHERE" updatewhere=1 updatekeyinplace=no arguments=(("ARG_DATAWINDOW_NAME", string),("ARG_LANG", string),("ARG_ORG", number))  sort="organization_id A datawindow_name A argument_sort_order A " )
