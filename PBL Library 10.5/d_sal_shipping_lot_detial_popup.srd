~"ISAL_SHIPPING_LOT_DETAIL~".~"ORGANIZATION_ID~" ,      
~"ISAL_SHIPPING_LOT_DETAIL~".~"ENTER_BY~" ,        
~"ISAL_SHIPPING_LOT_DETAIL~".~"ENTER_DATE~" ,      
~"ISAL_SHIPPING_LOT_DETAIL~".~"LAST_MODIFY_BY~" ,    
~"ISAL_SHIPPING_LOT_DETAIL~".~"LAST_MODIFY_DATE~" ,    
~"ISAL_SHIPPING_LOT_DETAIL~".~"MARKING_NO~" ,   
~"ISAL_SHIPPING_LOT_DETAIL~".~"MODEL_NAME~" ,    
~"ISAL_SHIPPING_LOT_DETAIL~".~"LOT_COMPLETE_YN~" ,  
~"ISAL_SHIPPING_LOT_DETAIL~".~"OLD_LOT_NO~"     
FROM ~"ISAL_SHIPPING_LOT_DETAIL~"    
 WHERE ( ~"ISAL_SHIPPING_LOT_DETAIL~".~"LOT_NO~" = :arg_lot_no ) And    
( ~"ISAL_SHIPPING_LOT_DETAIL~".~"ORGANIZATION_ID~" = :arg_org )   " update="ISAL_SHIPPING_LOT_DETAIL" updatewhere=0 updatekeyinplace=no arguments=(("arg_lot_no", string),("arg_org", number)) )
