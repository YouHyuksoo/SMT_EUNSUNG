 retrieve="SELECT  ~"ISAL_SHIPPING_LOT_DETAIL~".~"LOT_NO~" ,      
~"ISAL_SHIPPING_LOT_DETAIL~".~"LOT_SEQUENCE~" ,        
~"ISAL_SHIPPING_LOT_DETAIL~".~"LOT_DATE~" ,    
