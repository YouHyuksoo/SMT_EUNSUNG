datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=136 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(30) updatewhereclause=yes name=pcb_item dbname="pcb_item" )
 column=(type=char(1) updatewhereclause=yes name=ccs_yn dbname="ccs_yn" )
 column=(type=char(100) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(30) updatewhereclause=yes name=location_code dbname="location_code" )
 column=(type=char(200) updatewhereclause=yes name=item_barcode dbname="item_barcode" )
 column=(type=datetime updatewhereclause=yes name=change_date dbname="change_date" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(1) updatewhereclause=yes name=issue_compare_yn dbname="issue_compare_yn" )
 column=(type=char(100) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(100) updatewhereclause=yes name=lot_no dbname="lot_no" )
 column=(type=number updatewhereclause=yes name=scan_qty dbname="scan_qty" )
 column=(type=number updatewhereclause=yes name=new_scan_qty dbname="new_scan_qty" )
 column=(type=datetime updatewhereclause=yes name=issue_compare_date dbname="issue_compare_date" )
 column=(type=char(10) updatewhereclause=yes name=msl_level dbname="msl_level" )
 column=(type=number updatewhereclause=yes name=msl_passed_hour dbname="msl_passed_hour" )
 column=(type=number updatewhereclause=yes name=msl_max_time dbname="msl_max_time" )
 column=(type=number updatewhereclause=yes name=msl_remain_hour dbname="msl_remain_hour" )
 column=(type=number updatewhereclause=yes name=msl_pre_passed_time dbname="msl_pre_passed_time" )
 column=(type=number updatewhereclause=yes name=check_count dbname="check_count" )
 column=(type=number updatewhereclause=yes name=baking_count dbname="baking_count" )
 column=(type=datetime updatewhereclause=yes name=check_min_time dbname="check_min_time" )
 column=(type=datetime updatewhereclause=yes name=check_max_time dbname="check_max_time" )
 column=(type=datetime updatewhereclause=yes name=baking_start_date dbname="baking_start_date" )
 column=(type=datetime updatewhereclause=yes name=baking_end_date dbname="baking_end_date" )
 column=(type=number updatewhereclause=yes name=passed_rate dbname="passed_rate" )
 column=(type=char(200) updatewhereclause=yes name=part_no dbname="part_no" )
 retrieve="
select LINE_CODE,   
       PCB_ITEM,   
       CCS_YN,   
       MODEL_NAME,   
       LOCATION_CODE,   
       ITEM_BARCODE,   
       CHANGE_DATE,   
       ITEM_NAME,   
       ITEM_SPEC,   
       ISSUE_COMPARE_YN,   
       ITEM_CODE,   
       LOT_NO,   
       SCAN_QTY,   
       NEW_SCAN_QTY,   
       ISSUE_COMPARE_DATE,   
     
       MSL_LEVEL,   
       trunc(passed_time , 2)                              msl_passed_hour,
       MSL_MAX_TIME,   
       trunc(msl_max_time - passed_time, 2)       msl_remain_hour,
       
       trunc(MSL_PRE_PASSED_TIME, 2)              MSL_PRE_PASSED_TIME ,   
       check_count,
       baking_count,
       check_min_time,
       check_max_time,
       BAKING_START_DATE,   
       BAKING_END_DATE ,
       PASSED_RATE                                          PASSED_RATE,
       part_no
  from (
          SELECT ~"IM_ITEM_MSL_CHECK_VIEW~".~"LINE_CODE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"PCB_ITEM~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"CCS_YN~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"MODEL_NAME~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"LOCATION_CODE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"ITEM_BARCODE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"CHANGE_DATE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"MSL_LEVEL~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"MSL_MAX_TIME~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"PASSED_TIME~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"PASSED_RATE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"MSL_PRE_PASSED_TIME~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"ITEM_NAME~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"ITEM_SPEC~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"ISSUE_COMPARE_YN~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"ITEM_CODE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"LOT_NO~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"SCAN_QTY~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"NEW_SCAN_QTY~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"ISSUE_COMPARE_DATE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"BAKING_START_DATE~",   
                 ~"IM_ITEM_MSL_CHECK_VIEW~".~"BAKING_END_DATE~",
                 (
                  select min(check_date)
                    from ib_smt_checkhist
                   where lot_no = ~"IM_ITEM_MSL_CHECK_VIEW~".~"LOT_NO~"
                  ) check_min_time,
                  (
                   select max(check_date)
                     from ib_smt_checkhist
                    where lot_no = ~"IM_ITEM_MSL_CHECK_VIEW~".~"LOT_NO~"
                  ) check_max_time,   
                 (
                    select (max(check_date) - min(check_date)) * 24
                      from ib_smt_checkhist
                     where lot_no = ~"IM_ITEM_MSL_CHECK_VIEW~".~"LOT_NO~"
                  ) check_pass_time, 
                  (
                   select sum(1) 
                     from ib_smt_checkhist
                    where lot_no = ~"IM_ITEM_MSL_CHECK_VIEW~".~"LOT_NO~"
                      and check_status = 'P'
                  )  check_count ,
                  (
                   select nvl(sum(1),0)
                     from IM_ITEM_BAKING_MASTER
                    where lot_no = ~"IM_ITEM_MSL_CHECK_VIEW~".~"LOT_NO~"
                      and rownum = 1
                  ) baking_count  ,
                  f_get_line_name(line_code,1) line_name ,
                  part_no               
            FROM ~"IM_ITEM_MSL_CHECK_VIEW~"  
            WHERE ( ~"IM_ITEM_MSL_CHECK_VIEW~".~"LINE_CODE~" like :arg_line_code )
             AND ( ~"IM_ITEM_MSL_CHECK_VIEW~".~"ITEM_CODE~"  like :arg_item_code )        
             AND ( ~"IM_ITEM_MSL_CHECK_VIEW~".~"MSL_LEVEL~"  >=   :arg_msl_level )      
             AND  ~"IM_ITEM_MSL_CHECK_VIEW~".~"MSL_MAX_TIME~" > 0
       )
    
   WHERE PASSED_RATE  >= :arg_rate   
   order by line_name, location_code
   
   " arguments=(("arg_line_code", string),("arg_item_code", string),("arg_rate", number),("arg_msl_level", string)) )
group(level=1 header.height=0 trailer.height=48 by=("line_code" ) header.color="536870912" trailer.color="65535" )
