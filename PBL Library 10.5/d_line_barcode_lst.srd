table(column=(type=char(20) update=yes updatewhereclause=yes name=line_code dbname="ib_line_master.line_code" )
 column=(type=char(30) updatewhereclause=yes name=machine dbname="ib_line_master.machine" )
 retrieve="SELECT  DISTINCT ~"IB_LINE_MASTER~".~"LINE_CODE~" ,   
             ~"IB_LINE_MASTER~".~"MACHINE~"   
  FROM ~"IB_LINE_MASTER~"  
    WHERE ( ~"IB_LINE_MASTER~".~"LINE_CODE~" like :ARG_LINE_CODE ) And          ( ~"IB_LINE_MASTER~".~"MACHINE~" like :ARG_MACHINE_CODE ) And          ( ~"IB_LINE_MASTER~".~"ORGANIZATION_ID~" = :ARG_ORG )   " arguments=(("ARG_LINE_CODE", string),("ARG_MACHINE_CODE", string),("ARG_ORG", number))  sort="line_code A machine A " )
group(level=1 header.height=0 trailer.height=44 by=("line_code" ) header.color="536870912" trailer.color="65535" )
