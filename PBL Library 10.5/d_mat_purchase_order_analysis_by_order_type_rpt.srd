 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_purchase_order~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"im_item_purchase_order.delivery_date~") COLUMN(NAME=~"im_item_purchase_order.item_code~") COLUMN(NAME=~"im_item_purchase_order.order_qty~") COLUMN(NAME=~"im_item_purchase_order.arrival_qty~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~")    JOIN (LEFT=~"im_item_purchase_order.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~"    OUTER1 =~"im_item_purchase_order.item_code~" )    JOIN (LEFT=~"im_item_purchase_order.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~"    OUTER1 =~"im_item_purchase_order.organization_id~" )WHERE(    EXP1 =~"( ~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"DELIVERY_DATE~~~"~"   OP =~">=~"    EXP2 =~":arg_dateset )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"DELIVERY_DATE~~~"~"   OP =~"<=~"    EXP2 =~":arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( TO_CHAR(~~~"IM_ITEM_PURCHASE_ORDER~~~".~~~"ORGANIZATION_ID~~~")~"   OP =~"LIKE~"    EXP2 =~":arg_org )~" ) ) ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = string) " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_org", string))  sort="item_name A " )
