 column=(type=number update=yes updatewhereclause=yes key=yes name=organization_id dbname="ip_product_work_qc.organization_id" )
 retrieve=" select  QC_SEQUENCE, 
           SERIAL_NO, 
           QC_DATE, 
           QC_RESULT,
           BAD_REASON_CODE, 
           RECEIPT_DEFICIT, 
           BAD_QTY, 
           DEFECT_QTY, 
           MODEL_NAME, 
           RUN_NO, 
           RUN_DATE, 
           f_get_line_name( line_code, organization_id) LINE_CODE, 
           WORKSTAGE_CODE,  
           CHARGER, 
           REPAIR_DATE, 
           REPAIR_BY,
           QC_INSPECT_HANDLING, 
           COMMENTS, 
           ENTER_DATE, 
           ENTER_BY, 
           LAST_MODIFY_DATE,
           LAST_MODIFY_BY, 
           ORGANIZATION_ID
  from  ip_product_work_qc
 where serial_no like :ARG_SERIAL_NO 
    and  ORGANIZATION_ID = :ARG_ORG " update="ip_product_work_qc" updatewhere=1 updatekeyinplace=no arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="serial_no A qc_date A " )
