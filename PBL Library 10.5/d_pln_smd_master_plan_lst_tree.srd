 column=(type=char(1) update=yes updatewhereclause=yes name=production_type dbname="ip_product_smd_plan.production_type" )
 retrieve="  SELECT ~"IP_PRODUCT_SMD_PLAN~".~"LINE_CODE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_DATE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_SEQUENCE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"WORK_ORDER_NO~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"MFS~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_PRIORITY~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"MASTER_MODEL_NAME~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"MODEL_SUFFIX~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PARENT_ITEM_CODE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"ITEM_CODE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PCB_ITEM~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_QTY~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"ACTUAL_QTY~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME1~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME2~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME3~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME4~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME5~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME6~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME7~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME8~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME9~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME10~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"COMMENTS~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"ORGANIZATION_ID~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"ENTER_DATE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"ENTER_BY~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"LAST_MODIFY_DATE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_CLASS~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_STATUS~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"CUSTOMER_CODE~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TRANSFER_YN~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"LOT_DIVIDE_YN~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"A_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"B_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"C_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"D_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"E_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"F_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"G_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"H_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"I_TIME_ACTUAL~",   
         ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"J_TIME_ACTUAL~",
		F_GET_MODEL_ST( IP_PRODUCT_SMD_PLAN.MODEL_NAME , IP_PRODUCT_SMD_PLAN.LINE_CODE , IP_PRODUCT_SMD_PLAN.PCB_ITEM , IP_PRODUCT_SMD_PLAN.ORGANIZATION_ID ) MODEL_ST ,
		F_GET_CARRIER_SIZE(  IP_PRODUCT_SMD_PLAN.MODEL_NAME , IP_PRODUCT_SMD_PLAN.ORGANIZATION_ID ) CARRIER_SIZE ,


         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME1~" +  
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME2~"+   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME3~"+  
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME4~"+   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME5~"+     
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME6~"+     
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME7~"+     
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME8~"+     
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME9~"+     
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_TIME10~" PLAN_QTY_CALC   ,
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_QTY_D1~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_QTY_D2~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_QTY_D3~" ,
         ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_CAPA_QTY~" ,

         ~"IP_PRODUCT_SMD_PLAN~".~"MC_TIME~" ,
		
         NVL( IP_PRODUCT_MODEL_MASTER.CUSTOMER_MODEL_NAME  , 'NOTFOUND' ) CUSTOMER_MODEL_NAME ,
		IP_PRODUCT_SMD_PLAN.CONFIRM_YN	CONFIRM_YN ,
		IP_PRODUCT_SMD_PLAN.CONFIRM_BY	CONFIRM_BY ,
		IP_PRODUCT_SMD_PLAN.CONFIRM_DATE	CONFIRM_DATE ,

         ~"IP_PRODUCT_SMD_PLAN~".~"TIME1_DESC~" ,
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME2_DESC~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME3_DESC~",  
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME4_DESC~",   
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME5_DESC~",     
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME6_DESC~",     
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME7_DESC~",     
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME8_DESC~",     
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME9_DESC~",     
         ~"IP_PRODUCT_SMD_PLAN~".~"TIME10_DESC~" ,
		IP_PRODUCT_SMD_PLAN.MFS_GROUP_NO MFS_GROUP_NO ,
		IP_PRODUCT_SMD_PLAN.SHIFT_CODE ,
		IP_PRODUCT_SMD_PLAN.PRODUCTION_TYPE 
	

    FROM ~"IP_PRODUCT_SMD_PLAN~",   
              ~"ID_ITEM~",   
              ~"IP_ASSEMBLY_ACTUAL_TIME_V~"  ,
			IP_PRODUCT_MODEL_MASTER 
   WHERE ( ip_product_smd_plan.item_code = id_item.item_code (+)) and  
         ( ip_product_smd_plan.organization_id = id_item.organization_id (+)) and  
         IP_PRODUCT_SMD_PLAN.MODEL_NAME = IP_PRODUCT_MODEL_MASTER.MODEL_NAME(+) and 
         IP_PRODUCT_SMD_PLAN.ORGANIZATION_ID = IP_PRODUCT_MODEL_MASTER.ORGANIZATION_ID(+) and 
         ( ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_DATE~" = ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"RECEIPT_DATE~"(+) ) and  
         ( ~"IP_PRODUCT_SMD_PLAN~".~"LINE_CODE~" = ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"LINE_CODE~"(+) ) and  
         ( ~"IP_PRODUCT_SMD_PLAN~".~"MODEL_NAME~" = ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"MODEL_NAME~"(+) ) and  
         ( ~"IP_PRODUCT_SMD_PLAN~".~"MODEL_SUFFIX~" = ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"MODEL_SUFFIX~"(+) ) and  
         ( ~"IP_PRODUCT_SMD_PLAN~".~"PCB_ITEM~" = ~"IP_ASSEMBLY_ACTUAL_TIME_V~".~"PCB_ITEM~"(+) ) and  
         ( ( ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_DATE~" >= :arg_dateset ) AND  
         ( ~"IP_PRODUCT_SMD_PLAN~".~"PLAN_DATE~" <= :arg_dateend ) AND  
         ( ~"IP_PRODUCT_SMD_PLAN~".~"MODEL_NAME~" like :arg_model_name) AND  
         ~"IP_PRODUCT_SMD_PLAN~".~"MFS~" like :arg_mfs AND  
         ~"IP_PRODUCT_SMD_PLAN~".~"LINE_CODE~" like :arg_line_code AND  
         NVL(~"IP_PRODUCT_SMD_PLAN~".~"PCB_ITEM~",'*')  like :arg_topbottom AND
         ( ~"IP_PRODUCT_SMD_PLAN~".~"ORGANIZATION_ID~" = :arg_org_id ) )    

UNION ALL


  SELECT

         A.LINE_CODE ,   
         A.RECEIPT_DATE PLAN_DATE,   
         0 PLAN_SEQUENCE,   
        NULL WORK_ORDER_NO,   
         '*' MFS,   
         NULL PLAN_PRIORITY,   
         IP_PRODUCT_MODEL_MASTER.MASTER_MODEL_NAME,   
         A.MODEL_NAME,   
         A.MODEL_SUFFIX,   
         '*' PARENT_ITEM_CODE,   
         '*' ITEM_CODE,   
         A.PCB_ITEM,   
         0 PLAN_QTY,   
         0 ACTUAL_QTY,   
         0 PLAN_TIME1,   
         0 PLAN_TIME2,   
         0 PLAN_TIME3,   
         0 PLAN_TIME4,   
         0 PLAN_TIME5,   
         0 PLAN_TIME6,   
         0 PLAN_TIME7,   
         0 PLAN_TIME8,   
         0 PLAN_TIME9,   
         0 PLAN_TIME10,   
         '*' COMMENTS,   
         :arg_org_id ORGANIZATION_ID,   
         ENTER_DATE,   
         ENTER_BY,   
         LAST_MODIFY_DATE,   
         LAST_MODIFY_BY,   

         '*' ITEM_CLASS,   
         '*' ITEM_NAME,   
         '*' ITEM_SPEC,   
         '*' ITEM_UOM,   

         '*' PLAN_STATUS,   
         '*' CUSTOMER_CODE,   
         'N' PLAN_TRANSFER_YN,   
         'N' LOT_DIVIDE_YN,   

         ~"A~".~"A_TIME_ACTUAL~",   
         ~"A~".~"B_TIME_ACTUAL~",   
         ~"A~".~"C_TIME_ACTUAL~",   
         ~"A~".~"D_TIME_ACTUAL~",   
         ~"A~".~"E_TIME_ACTUAL~",   
         ~"A~".~"F_TIME_ACTUAL~",   
         ~"A~".~"G_TIME_ACTUAL~",   
         ~"A~".~"H_TIME_ACTUAL~",   
         ~"A~".~"I_TIME_ACTUAL~",   
         ~"A~".~"J_TIME_ACTUAL~",
		0 MODEL_ST ,
		0 CARRIER_SIZE ,


        0 PLAN_QTY_CALC   ,
        0 PLAN_QTY_D1,   
        0 PLAN_QTY_D2,   
        0 PLAN_QTY_D3 ,
        0 PLAN_CAPA_QTY ,

        0 MC_TIME ,
		
         '*' CUSTOMER_MODEL_NAME ,
		'*'	CONFIRM_YN ,
		'*' CONFIRM_BY ,
		NULL	CONFIRM_DATE ,

         '*' TIME1_DESC ,
         '*' TIME2_DESC,   
         '*' TIME3_DESC,  
         '*' TIME4_DESC,   
         '*' TIME5_DESC,     
         '*' TIME6_DESC,     
         '*' TIME7_DESC,     
         '*' TIME8_DESC,     
         '*' TIME9_DESC,     
         '*' TIME10_DESC ,
		'*' MFS_GROUP_NO ,
		'*' SHIFT_CODE,
		'*' PRODUCTION_TYPE 

    FROM      
              IP_ASSEMBLY_ACTUAL_TIME_V A ,
			IP_PRODUCT_MODEL_MASTER 
   WHERE 
    
         A.MODEL_NAME = IP_PRODUCT_MODEL_MASTER.MODEL_NAME(+) and 

         A.RECEIPT_DATE >= :arg_dateset AND  
         A.RECEIPT_DATE <= :arg_dateend AND  
         A.MODEL_NAME like :arg_model_name AND  
         A.LINE_CODE like :arg_line_code AND  
         NVL(A.PCB_ITEM,'*')  like :arg_topbottom AND 
     
         ( A.LINE_CODE , A.MODEL_NAME , A.MODEL_SUFFIX ,  A.RECEIPT_DATE , A.PCB_ITEM )
         NOT IN ( SELECT B.LINE_CODE , B.MODEL_NAME , B.MODEL_SUFFIX ,  B.PLAN_DATE , B.PCB_ITEM 
                         FROM IP_PRODUCT_SMD_PLAN  B
                        WHERE 
							B.PLAN_DATE >= :arg_dateset AND  
							B.PLAN_DATE <= :arg_dateend AND  
							B.MODEL_NAME like :arg_model_name AND  
							B.MFS like :arg_mfs AND  
							B.LINE_CODE like :arg_line_code AND  
							NVL(B.PCB_ITEM,'*')  like :arg_topbottom AND
							B.ORGANIZATION_ID = :arg_org_id     
                      )

" update="IP_PRODUCT_SMD_PLAN" updatewhere=0 updatekeyinplace=no arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_model_name", string),("arg_mfs", string),("arg_topbottom", string),("arg_org_id", number))  sort="line_code A plan_date A plan_priority A master_model_name A model_name A " )
