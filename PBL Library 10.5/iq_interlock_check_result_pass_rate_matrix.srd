compute(band=trailer.1 alignment="2" expression="sum(ok_qty for group 1)"border="2" color="33554432" x="992" y="4" height="72" width="197" format="[general]" html.valueishtml="0"  name=compute_3 visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="553648127" )
compute(band=trailer.1 alignment="2" expression="avg(pass_rate for group 1)"border="2" color="33554432" x="1198" y="4" height="72" width="288" format="###,##0.0" html.valueishtml="0"  name=compute_4 visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="1" background.color="553648127" )
 crosstab(band = foreground  crosstabonly = yes 
 columns = "workstage_name" rows = "line_code, model_name" values = "sum(ng_qty for crosstab), sum(ok_qty for crosstab), AVG(pass_rate for crosstab)" sourcenames = "line_code, workstage_code, workstage_name, model_name, ng_qty, ok_qty, pass_rate")
