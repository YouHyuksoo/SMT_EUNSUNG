column(band=detail id=5 alignment="2" tabsequence=32766 border="2" color="33554432~tif (  pass_rate < 90 , 255 , 0 )" x="1198" y="4" height="88" width="288" format="[general]" html.valueishtml="0"  name=pass_rate visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.autohscroll=yes crosstab.repeat=yes  font.face="Tahoma" font.height="-8" font.weight="700"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="15780518" )
