HA$PBExportHeader$iq_interlock_check_result_pass_rate_matrix.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes grid.lines=1 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=88 color="536870912" )
header[3](height=140 color="536870912" )
summary(height=76 color="8421504" )
footer(height=0 color="536870912" )
detail(height=96 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=number updatewhereclause=yes name=ng_qty dbname="ng_qty" )
 column=(type=number updatewhereclause=yes name=ok_qty dbname="ok_qty" )
 column=(type=number updatewhereclause=yes name=pass_rate dbname="pass_rate" )
 retrieve="SELECT  /*+ index ( IQ_INTERLOCK_CHECK_RESULT XPKIQ_INTERLOCK_CHECK_RESULT ) */  line_code , workstage_code , workstage_code||' '||f_get_workstage_name( workstage_code) workstage_name  , model_name,
        SUM( DECODE( CHECK_RESULT , 'OK' , 0 , 1 ) ) NG_QTY, 
        SUM( DECODE( CHECK_RESULT , 'OK' , 1 , 0 ) ) OK_QTY ,
        
        round(SUM( DECODE( CHECK_RESULT , 'OK' , 1 , 0 ) ) / ( SUM( DECODE( CHECK_RESULT , 'OK' , 0 , 1 ) ) + SUM( DECODE( CHECK_RESULT , 'OK' , 1 , 0 ) ))  * 100 , 1) pass_rate
 FROM IQ_INTERLOCK_CHECK_RESULT 
 WHERE LINE_CODE LIKE :ARG_LINE_CODE
 AND MODEL_NAME LIKE  :ARG_MODEL_NAME
AND ORGANIZATION_ID =:ARG_ORG
AND RECEIPT_DATE >= :ARG_DATESET
AND RECEIPT_DATE <   :ARG_DATEEND +1
group by line_code , workstage_code  , model_name" arguments=(("arg_line_code", string),("arg_model_name", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number))  sort="line_code A model_name A " )
group(level=1 header.height=0 trailer.height=84 by=("line_code" ) header.color="536870912" trailer.color="12639424" )
text(band=header[2] alignment="2" text="@workstage_name" border="2" color="33554432" x="777" y="4" height="80" width="713" html.valueishtml="0"  name=t_2 visible="1"  font.face="Tahoma" font.height="-8" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="12632256" )
