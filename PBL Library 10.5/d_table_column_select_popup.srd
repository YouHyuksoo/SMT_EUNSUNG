 retrieve="  SELECT ~"USER_TAB_COLUMNS~".~"COLUMN_NAME~",   
         ~"USER_TAB_COLUMNS~".~"DATA_TYPE~",   
         '' SHOW_COLUMN,   
         '' CONDITION_COLUMN,   
         DECODE( '0' , 'K' , WORD_KOR , 'E' , WORD_ENG , WORD_LOCAL ) COLUMN_DESC  
    FROM ~"USER_TAB_COLUMNS~",   
         ~"ISYS_WORD_DICTIONARY~"  
   WHERE ( ~"USER_TAB_COLUMNS~".~"COLUMN_NAME~" = ~"ISYS_WORD_DICTIONARY~".~"COLUMN_NAME~" ) and  
         ( ~"USER_TAB_COLUMNS~".~"TABLE_NAME~" = :ARG_TABLE_NAME )    
" arguments=(("ARG_LANGUAGE", string),("ARG_TABLE_NAME", string)) )
