 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_arrival~" )  TABLE(NAME=~"icom_supplier~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"im_item_arrival.arrival_date~") COLUMN(NAME=~"im_item_arrival.arrival_seq_no~") COLUMN(NAME=~"im_item_arrival.organization_id~") COLUMN(NAME=~"im_item_arrival.arrival_qty~") COLUMN(NAME=~"im_item_arrival.arrival_status~") COLUMN(NAME=~"im_item_arrival.enter_date~") COLUMN(NAME=~"im_item_arrival.order_no~") COLUMN(NAME=~"im_item_arrival.enter_by~") COLUMN(NAME=~"im_item_arrival.last_modify_date~") COLUMN(NAME=~"im_item_arrival.line_type~") COLUMN(NAME=~"im_item_arrival.last_modify_by~") COLUMN(NAME=~"im_item_arrival.unit_price~") COLUMN(NAME=~"im_item_arrival.currency~") COLUMN(NAME=~"im_item_arrival.arrival_amt~") COLUMN(NAME=~"im_item_arrival.receipt_sequence~") COLUMN(NAME=~"im_item_arrival.invoice_no~") COLUMN(NAME=~"im_item_arrival.inspect_rule~") COLUMN(NAME=~"im_item_arrival.inspect_result~") COLUMN(NAME=~"im_item_arrival.supplier_code~") COLUMN(NAME=~"im_item_arrival.delivery~") COLUMN(NAME=~"im_item_arrival.receipt_date~") COLUMN(NAME=~"im_item_arrival.inspect_date~") COLUMN(NAME=~"im_item_arrival.mfs~") COLUMN(NAME=~"im_item_arrival.comments~") COLUMN(NAME=~"im_item_arrival.item_code~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COMPUTE(NAME=~"'' check_yn~") COLUMN(NAME=~"im_item_arrival.departure_date~") COLUMN(NAME=~"im_item_arrival.product_date~") COLUMN(NAME=~"im_item_arrival.iqc_inspect_no~") COLUMN(NAME=~"im_item_arrival.order_group_no~") COLUMN(NAME=~"im_item_arrival.virtual_receipt_yn~") COLUMN(NAME=~"im_item_arrival.arrival_type~") COLUMN(NAME=~"im_item_arrival.material_mfs~") COLUMN(NAME=~"icom_supplier.supplier_name~") COLUMN(NAME=~"im_item_arrival.arrival_location_code~") COLUMN(NAME=~"im_item_arrival.lot_div_yn~") COMPUTE(NAME=~"im_item_arrival.rowid~")    JOIN (LEFT=~"im_item_arrival.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"id_item.organization_id~"    OP =~"=~"RIGHT=~"im_item_arrival.organization_id~" )    JOIN (LEFT=~"icom_supplier.supplier_code~"    OP =~"=~"RIGHT=~"im_item_arrival.supplier_code~" )    JOIN (LEFT=~"icom_supplier.organization_id~"    OP =~"=~"RIGHT=~"im_item_arrival.organization_id~" )WHERE(    EXP1 =~"( ( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ITEM_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_item_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( NVL(~~~"IM_ITEM_ARRIVAL~~~".~~~"INVOICE_NO~~~",'*')~"   OP =~"like~"    EXP2 =~":arg_invoice_no)~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ARRIVAL_DATE~~~"~"   OP =~"between~"    EXP2 =~":arg_dateset and :arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"ID_ITEM.ITEM_DIVISION~"   OP =~"<>~"    EXP2 =~"'G'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ARRIVAL~~~".~~~"ARRIVAL_STATUS~~~"~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IM_ITEM_ARRIVAL~~~".~~~"INVOICE_NO~~~"~"   OP =~"like~"    EXP2 =~":arg_invoice_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_ARRIVAL~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org_id ) )~" ) ) ARG(NAME = ~"arg_item_code~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_invoice_no~" TYPE = string)  ARG(NAME = ~"arg_org_id~" TYPE = number) " update="IM_ITEM_ARRIVAL" updatewhere=0 updatekeyinplace=no arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_invoice_no", string),("arg_org_id", number))  sort="arrival_date A item_code A " )
