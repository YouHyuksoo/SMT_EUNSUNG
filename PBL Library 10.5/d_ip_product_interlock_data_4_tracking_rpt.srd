 column=(type=char(20) update=yes updatewhereclause=yes name=machine_code dbname="iq_interlock_check_result.machine_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=check_result dbname="iq_interlock_check_result.check_result" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="iq_interlock_check_result.organization_id" )
 column=(type=char(30) update=yes updatewhereclause=yes name=run_no dbname="iq_interlock_check_result.run_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=magazine_no dbname="iq_interlock_check_result.magazine_no" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="iq_interlock_check_result.model_name" )
 column=(type=char(1) updatewhereclause=yes name=is_last_yn dbname="iq_interlock_check_result.is_last_yn" )
 retrieve="SELECT   
         a.receipt_date,
         a.item_code,
         a.serial_no,
         a.line_code,
         a.workstage_code,
         a.machine_code,
         a.check_result,
         a.organization_id,
         a.run_no,
         a.magazine_no ,
		a.model_name ,
		a.is_last_yn
  FROM   iq_interlock_check_result a
WHERE a.receipt_date >=:arg_dateset
      and a.receipt_date < :arg_dateend 
	 and a.line_code like :arg_line_code
      and a.workstage_code like :arg_workstage_code
      and a.organization_id = :arg_org" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_workstage_code", string),("arg_org", number)) )
