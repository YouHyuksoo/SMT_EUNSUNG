table(column=(type=datetime update=yes updatewhereclause=yes name=receipt_date dbname="iq_interlock_check_result.receipt_date" )
 column=(type=char(30) update=yes updatewhereclause=yes name=item_code dbname="iq_interlock_check_result.item_code" )
 column=(type=char(30) update=yes updatewhereclause=yes name=serial_no dbname="iq_interlock_check_result.serial_no" )
 column=(type=char(100) update=yes updatewhereclause=yes name=line_code dbname="iq_interlock_check_result.line_code" )
