 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_jig_issue~" )  TABLE(NAME=~"imcn_jig~" ) COLUMN(NAME=~"imcn_jig_issue.issue_date~") COLUMN(NAME=~"imcn_jig_issue.issue_sequence~") COLUMN(NAME=~"imcn_jig_issue.organization_id~") COLUMN(NAME=~"imcn_jig_issue.jig_code~") COLUMN(NAME=~"imcn_jig_issue.issue_deficit~") COLUMN(NAME=~"imcn_jig_issue.issue_qty~") COLUMN(NAME=~"imcn_jig_issue.issue_status~") COLUMN(NAME=~"imcn_jig_issue.enter_by~") COLUMN(NAME=~"imcn_jig_issue.enter_date~") COLUMN(NAME=~"imcn_jig_issue.last_modify_by~") COLUMN(NAME=~"imcn_jig_issue.last_modify_date~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"imcn_jig_issue.workstage_code~") COLUMN(NAME=~"imcn_jig_issue.machine_code~") COLUMN(NAME=~"imcn_jig_issue.issue_account~") COLUMN(NAME=~"imcn_jig.jig_type~") COLUMN(NAME=~"imcn_jig.jig_status~")    JOIN (LEFT=~"imcn_jig_issue.jig_code~"    OP =~"=~"RIGHT=~"imcn_jig.jig_code~" )    JOIN (LEFT=~"imcn_jig_issue.organization_id~"    OP =~"=~"RIGHT=~"imcn_jig.organization_id~" )WHERE(    EXP1 =~"( ~~~"IMCN_JIG_ISSUE~~~".~~~"ISSUE_DATE~~~"~"   OP =~">=~"    EXP2 =~":arg_dateset )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG_ISSUE~~~".~~~"ISSUE_DATE~~~"~"   OP =~"<=~"    EXP2 =~":arg_dateend )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG_ISSUE~~~".~~~"JIG_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_jig_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_JIG~~~".~~~"JIG_TYPE~~~"~"   OP =~"like~"    EXP2 =~":arg_jig_type~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_JIG_ISSUE~~~".~~~"ISSUE_STATUS~~~"~"   OP =~"like~"    EXP2 =~":arg_issue_status~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_JIG_ISSUE~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":arg_org )~" ) ) ARG(NAME = ~"arg_dateset~" TYPE = datetime)  ARG(NAME = ~"arg_dateend~" TYPE = datetime)  ARG(NAME = ~"arg_jig_code~" TYPE = string)  ARG(NAME = ~"arg_jig_type~" TYPE = string)  ARG(NAME = ~"arg_issue_status~" TYPE = string)  ARG(NAME = ~"arg_org~" TYPE = number) " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_jig_code", string),("arg_jig_type", string),("arg_issue_status", string),("arg_org", number))  sort="workstage_code A machine_code A issue_date A issue_sequence D " )
