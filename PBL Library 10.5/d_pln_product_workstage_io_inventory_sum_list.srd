 column=(type=char(30) update=yes updatewhereclause=yes name=item_code dbname="ip_product_workstage_io.item_code" dbalias=".item_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=line_code dbname="ip_product_workstage_io.line_code" dbalias=".line_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=workstage_code dbname="ip_product_workstage_io.workstage_code" dbalias=".workstage_code" )
 column=(type=number update=yes updatewhereclause=yes name=io_qty dbname="io_qty" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="ip_product_workstage_io.organization_id" dbalias=".organization_id" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="ip_product_workstage_io.model_name" dbalias=".model_name" )
 column=(type=char(10) updatewhereclause=yes name=model_suffix dbname="ip_product_workstage_io.model_suffix" dbalias=".model_suffix" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="item_spec" )
 retrieve="  SELECT /*+INDEX(IP_PRODUCT_WORKSTAGE_IO INDXIP_PRODUCT_WORKSTAGE_IO3)*/         
         IP_PRODUCT_WORKSTAGE_IO.IO_DEFICIT,   
         IP_PRODUCT_WORKSTAGE_IO.ITEM_CODE,   
         IP_PRODUCT_WORKSTAGE_IO.LINE_CODE,   
         IP_PRODUCT_WORKSTAGE_IO.WORKSTAGE_CODE,   
         SUM( IP_PRODUCT_WORKSTAGE_IO.IO_QTY) IO_QTY ,   
         IP_PRODUCT_WORKSTAGE_IO.ORGANIZATION_ID,   
         IP_PRODUCT_WORKSTAGE_IO.MODEL_NAME,   
         IP_PRODUCT_WORKSTAGE_IO.MODEL_SUFFIX ,
		MAX(ID_ITEM.ITEM_NAME) as ITEM_NAME ,
        MAX( ID_ITEM.ITEM_SPEC) as  ITEM_SPEC
    FROM  IP_PRODUCT_WORKSTAGE_IO  ,  ID_ITEM 


   WHERE IP_PRODUCT_WORKSTAGE_IO.ITEM_CODE =  ID_ITEM.ITEM_CODE(+) AND 

		( IP_PRODUCT_WORKSTAGE_IO.LINE_CODE like :arg_line_code ) AND  
         ( IP_PRODUCT_WORKSTAGE_IO.WORKSTAGE_CODE like :arg_workstage_code ) AND  
         ( IP_PRODUCT_WORKSTAGE_IO.MODEL_NAME like :arg_model_name ) AND  
         ( IP_PRODUCT_WORKSTAGE_IO.MODEL_SUFFIX like :arg_model_suffix ) AND  
		(         IP_PRODUCT_WORKSTAGE_IO.IO_DEFICIT = 'I' ) AND
         ( IP_PRODUCT_WORKSTAGE_IO.ORGANIZATION_ID = :arg_org )    

GROUP BY 
         IP_PRODUCT_WORKSTAGE_IO.IO_DEFICIT,  
		IP_PRODUCT_WORKSTAGE_IO.ITEM_CODE,   
         IP_PRODUCT_WORKSTAGE_IO.LINE_CODE,   
         IP_PRODUCT_WORKSTAGE_IO.WORKSTAGE_CODE,   
         IP_PRODUCT_WORKSTAGE_IO.IO_DEFICIT,   
         IP_PRODUCT_WORKSTAGE_IO.ORGANIZATION_ID,  
         IP_PRODUCT_WORKSTAGE_IO.MODEL_NAME,   
         IP_PRODUCT_WORKSTAGE_IO.MODEL_SUFFIX" arguments=(("arg_line_code", string),("arg_workstage_code", string),("arg_model_name", string),("arg_model_suffix", string),("arg_org", number))  sort="io_deficit A line_code A workstage_code A item_code A " )
