table(column=(type=char(30) update=yes updatewhereclause=yes name=model_name dbname="ip_product_workstage_inv.model_name" dbalias=".model_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=model_suffix dbname="ip_product_workstage_inv.model_suffix" dbalias=".model_suffix" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=char(20) update=yes updatewhereclause=yes name=line_code dbname="ip_product_workstage_inv.line_code" dbalias=".line_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=workstage_code dbname="ip_product_workstage_inv.workstage_code" dbalias=".workstage_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=inventory_type dbname="ip_product_workstage_inv.inventory_type" dbalias=".inventory_type" )
 retrieve="  SELECT
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_SUFFIX~",   
         SUM(~"IP_PRODUCT_WORKSTAGE_INV~".~"INVENTORY_QTY~") AS INVENTORY_QTY,   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"LINE_CODE~",   
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"WORKSTAGE_CODE~",   
        
         ~"IP_PRODUCT_WORKSTAGE_INV~".~"INVENTORY_TYPE~"  
    FROM ~"IP_PRODUCT_WORKSTAGE_INV~"  
   WHERE ( ~"IP_PRODUCT_WORKSTAGE_INV~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         ( ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_NAME~" like :arg_model_name ) AND  
         ( SIGN(~"IP_PRODUCT_WORKSTAGE_INV~".~"INVENTORY_QTY~") >= :arg_sign ) and   
         ( ~"IP_PRODUCT_WORKSTAGE_INV~".~"ORGANIZATION_ID~" = :arg_org )    
  GROUP BY  ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_NAME~",   
                  ~"IP_PRODUCT_WORKSTAGE_INV~".~"MODEL_SUFFIX~", 
                  ~"IP_PRODUCT_WORKSTAGE_INV~".~"LINE_CODE~",   
                 ~"IP_PRODUCT_WORKSTAGE_INV~".~"WORKSTAGE_CODE~", 
                ~"IP_PRODUCT_WORKSTAGE_INV~".~"INVENTORY_TYPE~" 
         " arguments=(("arg_model_name", string),("arg_workstage_code", string),("arg_sign", number),("arg_org", number))  sort="workstage_code A model_name A " )
group(level=1 header.height=0 trailer.height=84 by=("workstage_code" ) header.color="536870912" trailer.color="67108864" )
