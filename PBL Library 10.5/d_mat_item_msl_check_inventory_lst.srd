table(column=(type=char(20) updatewhereclause=yes name=im_item_receipt_barcode_item_code dbname="im_item_receipt_barcode.item_code" )
 column=(type=char(300) updatewhereclause=yes name=id_item_item_name dbname="id_item.item_name" )
 column=(type=char(50) updatewhereclause=yes name=im_item_receipt_barcode_lot_no dbname="im_item_receipt_barcode.lot_no" )
 column=(type=char(20) updatewhereclause=yes name=im_item_receipt_barcode_supplier_code dbname="im_item_receipt_barcode.supplier_code" )
 column=(type=char(50) updatewhereclause=yes name=im_item_receipt_barcode_item_barcode dbname="im_item_receipt_barcode.item_barcode" )
 column=(type=number updatewhereclause=yes name=scan_qty dbname="scan_qty" )
 column=(type=number updatewhereclause=yes name=im_item_inventory_inventory_qty dbname="im_item_inventory.inventory_qty" )
 column=(type=number updatewhereclause=yes name=msl_pre_passed_time dbname="msl_pre_passed_time" )
 column=(type=number updatewhereclause=yes name=passed_time dbname="passed_time" )
 column=(type=number updatewhereclause=yes name=passed_rate dbname="passed_rate" )
 column=(type=datetime updatewhereclause=yes name=im_item_inventory_baking_date dbname="im_item_inventory.baking_date" )
 column=(type=char(20) updatewhereclause=yes name=im_item_inventory_location_address_rack dbname="im_item_inventory.location_address_rack" )
 column=(type=char(200) updatewhereclause=yes name=id_item_part_no dbname="id_item.part_no" )
 column=(type=number updatewhereclause=yes name=id_item_msl_max_time dbname="id_item.msl_max_time" )
 column=(type=number updatewhereclause=yes name=msl_remain_hour dbname="msl_remain_hour" )
 column=(type=char(10) updatewhereclause=yes name=id_item_msl_level dbname="id_item.msl_level" )
 column=(type=datetime updatewhereclause=yes name=baking_end_date dbname="baking_end_date" )
 retrieve="select b.item_code, t.item_name, b.lot_no, b.supplier_code, b.item_barcode, 
       decode(b.new_scan_qty, 0, b.scan_qty, b.new_scan_qty) scan_qty, i.INVENTORY_QTY, 

      trunc(nvl(b.msl_passed_time,0),2)                                                                                  msl_pre_passed_time,
      trunc( nvl(F_GET_MSL_PASSED_TIME(b.item_barcode),0), 2)                                            passed_time,  
       trunc( nvl(F_GET_MSL_PASSED_TIME(b.item_barcode),0) / t.msl_max_time * 100 ,2)        passed_rate,

       i.BAKING_DATE, i.LOCATION_ADDRESS_RACK, t.part_no, 
       t.msl_max_time,
       (t.msl_max_time -  trunc( nvl(F_GET_MSL_PASSED_TIME(b.item_barcode),0), 2) )            msl_remain_hour,
      t.msl_level                                                                                                                    msl_level,

      ( select max(output_scan_date)
          from im_item_baking_master             
         where chamber_type     = 'B'
            and item_barcode       = b.item_barcode
            and output_scan_date >= NVL(i.BAKING_DATE , sysdate)                                           
      )   baking_end_date

   from im_item_receipt_barcode b,
        im_item_inventory       i,
        id_item                 t
  where b.lot_no = i.material_mfs (+)
    and b.item_code = t.item_code (+)
    and NVL(b.issue_compare_yn,'N') = 'N'
    and b.barcode_status   = 'N'
    and b.item_code like :arg_item_code
    and t.MSL_level        >= :arg_msl_level
    and trunc( nvl(F_GET_MSL_PASSED_TIME(b.item_barcode),0) / t.msl_max_time * 100 ,2)  >= :arg_passed_rate
    and i.INVENTORY_QTY > 0
    and NVL(t.MSL_MAX_TIME,0) > 0
    AND I.ORGANIZATION_ID = :arg_org_id
   order by trunc( nvl(F_GET_MSL_PASSED_TIME(b.item_barcode),0), 2)  desc
" arguments=(("arg_item_code", string),("arg_msl_level", string),("arg_passed_rate", number),("arg_org_id", number)) )
