 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"im_item_master_plan_4_requir~" )  TABLE(NAME=~"id_item~" ) COLUMN(NAME=~"im_item_master_plan_4_requir.requirment_plan_date~") COLUMN(NAME=~"im_item_master_plan_4_requir.plan_date~") COLUMN(NAME=~"im_item_master_plan_4_requir.organization_id~") COLUMN(NAME=~"im_item_master_plan_4_requir.order_qty~") COLUMN(NAME=~"im_item_master_plan_4_requir.item_code~") COLUMN(NAME=~"im_item_master_plan_4_requir.enter_by~") COLUMN(NAME=~"im_item_master_plan_4_requir.enter_date~") COLUMN(NAME=~"im_item_master_plan_4_requir.last_modify_by~") COLUMN(NAME=~"im_item_master_plan_4_requir.last_modify_date~") COLUMN(NAME=~"im_item_master_plan_4_requir.apply_yn~") COMPUTE(NAME=~"NVL(~~~"IM_ITEM_MASTER_PLAN_4_REQUIR~~~".~~~"TOTAL_INVENTORY_QTY~~~",0) TOTAL_INVENTORY_QTY~") COMPUTE(NAME=~"NVL(~~~"IM_ITEM_MASTER_PLAN_4_REQUIR~~~".~~~"INVENTORY_QTY~~~",0) INVENTORY_QTY~") COMPUTE(NAME=~"NVL(~~~"IM_ITEM_MASTER_PLAN_4_REQUIR~~~".~~~"SAFETY_INVENTORY_QTY~~~",0) SAFETY_INVENTORY_QTY~") COLUMN(NAME=~"im_item_master_plan_4_requir.requirment_plan_seq~") COMPUTE(NAME=~"'N' check_yn~") COLUMN(NAME=~"id_item.item_name~") COLUMN(NAME=~"id_item.item_spec~") COLUMN(NAME=~"id_item.item_uom~")    JOIN (LEFT=~"im_item_master_plan_4_requir.item_code~"    OP =~"=~"RIGHT=~"id_item.item_code~" )    JOIN (LEFT=~"im_item_master_plan_4_requir.organization_id~"    OP =~"=~"RIGHT=~"id_item.organization_id~" )WHERE(    EXP1 =~"( ~~~"IM_ITEM_MASTER_PLAN_4_REQUIR~~~".~~~"REQUIRMENT_PLAN_DATE~~~"~"   OP =~"=~"    EXP2 =~":ARG_DATESET )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_MASTER_PLAN_4_REQUIR~~~".~~~"ITEM_CODE~~~"~"   OP =~"LIKE~"    EXP2 =~":ARG_ITEM_CODE )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IM_ITEM_MASTER_PLAN_4_REQUIR~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG )~" ) ) ARG(NAME = ~"ARG_DATESET~" TYPE = datetime)  ARG(NAME = ~"ARG_ITEM_CODE~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " update="IM_ITEM_MASTER_PLAN_4_REQUIR" updatewhere=0 updatekeyinplace=no arguments=(("ARG_DATESET", datetime),("ARG_ITEM_CODE", string),("ARG_ORG", number))  sort="organization_id A plan_date A " )
