HA$PBExportHeader$d_mat_solder_receipt_cnt_lst.srd
release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=128 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(20) update=yes updatewhereclause=yes name=line_code dbname="line_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=solder_type dbname="solder_type" )
 column=(type=number updatewhereclause=yes name=refrigerator_cnt dbname="refrigerator_cnt" )
 column=(type=number updatewhereclause=yes name=unfreezing_cnt dbname="unfreezing_cnt" )
 column=(type=number updatewhereclause=yes name=mix_cnt dbname="mix_cnt" )
 column=(type=number updatewhereclause=yes name=viscosity_wait_cnt dbname="viscosity_wait_cnt" )
 column=(type=number updatewhereclause=yes name=input_wait_cnt dbname="input_wait_cnt" )
 retrieve="select line_code, 
       solder_type, 
       sum(refrigerator_cnt) refrigerator_cnt, 
       sum(unfreezing_cnt) unfreezing_cnt,
       sum(mix_cnt) mix_cnt,
       sum(viscosity_wait_cnt) viscosity_wait_cnt,
       sum(input_wait_cnt) input_wait_cnt
from (
      select line_code, SOLDER_TYPE,
              case when receipt_date is not null and issue_date is null  then 1 else 0 end                   refrigerator_cnt,
              case when unfreezing_start_date is not null and unfreezing_end_date is null then 1 else 0 end  unfreezing_cnt,
              case when mix_start_date is not null  and mix_end_date is null then 1 else 0 end               mix_cnt,
              case when mix_end_date is not null and viscosity_end_date is null then 1 else 0 end            viscosity_wait_cnt,
              case when mix_end_date is not null and viscosity_end_date is not null and input_date is null then 1 else 0 end              input_wait_cnt  
         from im_item_solder_master
        where ( input_date is null and destroy_date is null )
      )
group by line_code, solder_type" )
