 column=(type=number updatewhereclause=yes name=carrying_out_qty dbname="iman_carrying_out.carrying_out_qty" dbalias=".carrying_out_qty" )
 column=(type=char(20) updatewhereclause=yes name=carrying_out_type dbname="iman_carrying_out.carrying_out_type" dbalias=".carrying_out_type" )
 column=(type=char(20) updatewhereclause=yes name=carrying_out_division dbname="iman_carrying_out.carrying_out_division" dbalias=".carrying_out_division" )
 column=(type=char(20) updatewhereclause=yes name=carrying_out_by dbname="iman_carrying_out.carrying_out_by" dbalias=".carrying_out_by" )
 column=(type=char(20) updatewhereclause=yes name=gate_guard_id dbname="iman_carrying_out.gate_guard_id" dbalias=".gate_guard_id" )
 column=(type=char(1) updatewhereclause=yes name=bring_in_yn dbname="iman_carrying_out.bring_in_yn" dbalias=".bring_in_yn" )
 column=(type=datetime updatewhereclause=yes name=bring_in_plan_date dbname="iman_carrying_out.bring_in_plan_date" dbalias=".bring_in_plan_date" )
 column=(type=char(20) updatewhereclause=yes name=user_name dbname="isys_users.user_name" dbalias=".user_name" )
 column=(type=char(20) updatewhereclause=yes name=department_code dbname="isys_users.department_code" dbalias=".department_code" )
 column=(type=number updatewhereclause=yes name=bring_in_qty dbname="iman_carrying_out.bring_in_qty" dbalias=".bring_in_qty" )
 column=(type=datetime updatewhereclause=yes name=bring_in_date dbname="iman_carrying_out.bring_in_date" dbalias=".bring_in_date" )
 column=(type=char(20) updatewhereclause=yes name=carrying_out_group_no dbname="iman_carrying_out.carrying_out_group_no" dbalias=".carrying_out_group_no" )
 retrieve="  SELECT ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DATE~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM_SPEC~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_RECEIPTOR~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_QTY~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_TYPE~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DIVISION~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_BY~",   
         ~"IMAN_CARRYING_OUT~".~"GATE_GUARD_ID~",   
         ~"IMAN_CARRYING_OUT~".~"BRING_IN_YN~",   
         ~"IMAN_CARRYING_OUT~".~"BRING_IN_PLAN_DATE~",   
         ~"ISYS_USERS~".~"USER_NAME~",   
         ~"ISYS_USERS~".~"DEPARTMENT_CODE~",   
           ~"IMAN_BRING_IN~".~"BRING_IN_QTY~"  ,
            ~"IMAN_BRING_IN~".~"BRING_IN_DATE~" ,
            ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_GROUP_NO~" 
    FROM ~"IMAN_CARRYING_OUT~",               
         ~"ISYS_USERS~" ,
               (select carrying_out_date , carrying_out_seq , organization_id ,sum(bring_in_qty)  bring_in_qty ,bring_in_date
		   from iman_bring_in 
	       where trunc(iman_bring_in.carrying_out_date) >= :arg_dateset
               and trunc(iman_bring_in.carrying_out_date) <= :arg_dateend
		      and iman_bring_in.organization_id = :arg_org 
   	    group by carrying_out_date , carrying_out_seq , organization_id, bring_in_date ) iman_bring_in

   WHERE    (iman_carrying_out.carrying_out_date =  iman_bring_in.carrying_out_date(+) ) AND
                  (iman_carrying_out.carrying_out_seq =  iman_bring_in.carrying_out_seq(+) ) AND
                  (iman_carrying_out.organization_id = iman_bring_in.organization_id(+)) AND
                  (iman_carrying_out.enter_by =  isys_users.user_id(+) )  AND
                  (iman_carrying_out.organization_id = isys_users.organization_id(+)) and
                  ( (TRUNC( ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DATE~") >= :arg_dateset ) AND  
				( TRUNC(~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DATE~") <= :arg_dateend ) AND  
				( ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_RECEIPTOR~" like :arg_supplier_code ) AND  
				( ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM~" like :arg_item_code ) AND  
				(~"ISYS_USERS~".~"DEPARTMENT_CODE~" like :arg_department_code) AND
                  (~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_GROUP_NO~" like :arg_carrying_out_group_no ) AND
				( ~"IMAN_CARRYING_OUT~".~"ORGANIZATION_ID~" = :arg_org ) )    " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_supplier_code", string),("arg_item_code", string),("arg_department_code", string),("arg_carrying_out_group_no", string),("arg_org", number))  sort="carrying_out_date A carrying_out_item A " )
