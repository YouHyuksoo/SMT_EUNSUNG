 retrieve=" SELECT 
 A.SUPPLIER_CODE,  MAX(A.SUPPLIER_NAME) SUPPLIER_NAME, 
 A.ITEM_CODE , MAX(A.ITEM_NAME) ITEM_NAME , MAX(A.ITEM_SPEC) ITEM_SPEC ,A.ORGANIZATION_ID ,
SUM(A.ORDER_AMT) ORDER_AMT , MAX(A.CURRENCY) CURRENCY,MAX(A.DELIVERY) DELIVERY,
SUM(A.R01)		DAY01	,
SUM(A.R02)		DAY02	,
SUM(A.R03)		DAY03	,
SUM(A.R04)		DAY04	,
SUM(A.R05)		DAY05	,
SUM(A.R06)		DAY06	,
SUM(A.R07)		DAY07	,
SUM(A.R08)		DAY08	,
SUM(A.R09)		DAY09	,
SUM(A.R10)		DAY10	,
SUM(A.R11)		DAY11	,
SUM(A.R12)		DAY12	,
SUM(A.R13)		DAY13	,
SUM(A.R14)		DAY14	,
SUM(A.R15)		DAY15	,
SUM(A.R16)		DAY16	,
SUM(A.R17)		DAY17	,
SUM(A.R18)		DAY18	,
SUM(A.R19)		DAY19	,
SUM(A.R20)		DAY20	,
SUM(A.R21)		DAY21	,
SUM(A.R22)		DAY22	,
SUM(A.R23)		DAY23	,
SUM(A.R24)		DAY24	,
SUM(A.R25)		DAY25	,
SUM(A.R26)		DAY26	,
SUM(A.R27)		DAY27	,
SUM(A.R28)		DAY28	,
SUM(A.R29)		DAY29	,
SUM(A.R30)		DAY30	,
SUM(A.R31)		DAY31	
FROM 
(
SELECT A.SUPPLIER_CODE  , B.SUPPLIER_NAME ,A.ITEM_CODE ,C.ITEM_NAME, C.ITEM_SPEC,A.ORGANIZATION_ID ,
A.ORDER_AMT , A.CURRENCY,A.DELIVERY,
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '01' , A.ORDER_QTY , 0 ) R01 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '02' , A.ORDER_QTY , 0 ) R02 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '03' , A.ORDER_QTY , 0 ) R03 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '04' , A.ORDER_QTY , 0 ) R04 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '05' , A.ORDER_QTY , 0 ) R05 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '06' , A.ORDER_QTY , 0 ) R06 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '07' , A.ORDER_QTY , 0 ) R07 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '08' , A.ORDER_QTY , 0 ) R08 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '09' , A.ORDER_QTY , 0 ) R09 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '10' , A.ORDER_QTY , 0 ) R10 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '11' , A.ORDER_QTY , 0 ) R11 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '12' , A.ORDER_QTY , 0 ) R12 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '13' , A.ORDER_QTY , 0 ) R13 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '14' , A.ORDER_QTY , 0 ) R14 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '15' , A.ORDER_QTY , 0 ) R15 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '16' , A.ORDER_QTY , 0 ) R16 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '17' , A.ORDER_QTY , 0 ) R17 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '18' , A.ORDER_QTY , 0 ) R18 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '19' , A.ORDER_QTY , 0 ) R19 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '20' , A.ORDER_QTY , 0 ) R20 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '21' , A.ORDER_QTY , 0 ) R21 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '22' , A.ORDER_QTY , 0 ) R22 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '23' , A.ORDER_QTY , 0 ) R23 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '24' , A.ORDER_QTY , 0 ) R24 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '25' , A.ORDER_QTY , 0 ) R25 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '26' , A.ORDER_QTY , 0 ) R26 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '27' , A.ORDER_QTY , 0 ) R27 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '28' , A.ORDER_QTY , 0 ) R28 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '29' , A.ORDER_QTY , 0 ) R29 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '30' , A.ORDER_QTY , 0 ) R30 ,  
DECODE(  TO_CHAR(A.DELIVERY_DATE,'DD') , '31' , A.ORDER_QTY , 0 ) R31                                                                          
  FROM IM_ITEM_PURCHASE_ORDER   A , 
           ICOM_SUPPLIER  B, 
           ID_ITEM C
WHERE A.SUPPLIER_CODE = B.SUPPLIER_CODE
     AND A.ORGANIZATION_ID = B.ORGANIZATION_ID  
     AND A.ITEM_CODE = C.ITEM_CODE
     AND A.ORGANIZATION_ID = C.ORGANIZATION_ID
     AND TO_CHAR(A.DELIVERY_DATE,'YYYYMM')  =  :arg_yyyymm
     AND A.SUPPLIER_CODE like :arg_supplier_code
     AND A.ITEM_CODE LIKE  :arg_item_code    
     AND TO_CHAR(A.ORGANIZATION_ID)  LIKE :arg_org_id
)  A
GROUP BY A.SUPPLIER_CODE, A.ITEM_CODE , A.ORGANIZATION_ID   



" arguments=(("arg_yyyymm", string),("arg_supplier_code", string),("arg_item_code", string),("arg_org_id", string))  sort="organization_id A supplier_code A item_code A " )
