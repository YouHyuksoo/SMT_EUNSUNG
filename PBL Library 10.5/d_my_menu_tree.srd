 column=(type=number updatewhereclause=yes key=yes name=organization_id dbname="isys_menu.organization_id" )
 retrieve="  SELECT  WINDOW_TYPE ,
         DECODE( :ARG_LANGUAGE , 'K' , WINDOW_GROUP_KOR , 'E' , WINDOW_GROUP_ENG , WINDOW_GROUP_LOCAL ) WINDOW_GROUP ,
         ~"ISYS_MENU~".~"WINDOW_DESCRIPTION_USERDEFINE~" , 
         DECODE( :ARG_LANGUAGE,'E',~"ISYS_MENU~".~"WINDOW_DESCRIPTION_ENG~",'K',~"ISYS_MENU~".~"WINDOW_DESCRIPTION_KOR~",~"ISYS_MENU~".~"WINDOW_DESCRIPTION_LOCAL~") WINDOW_DESCRIPTION , 
         ~"ISYS_MENU~".~"WINDOW_NAME~",   
          ~"ISYS_MENU~".~"APPLICATION_NAME~",   
        ~"ISYS_MENU~".~"USER_ID~",   
         ~"ISYS_MENU~".~"ENTER_DATE~",   
         ~"ISYS_MENU~".~"LAST_MODIFY_DATE~",   
         ~"ISYS_MENU~".~"ENTER_BY~",   
         ~"ISYS_MENU~".~"LAST_MODIFY_BY~"  ,
         ~"ISYS_MENU~".~"ORGANIZATION_ID~"
    FROM ~"ISYS_MENU~"  
   WHERE ( ~"ISYS_MENU~".~"USER_ID~" = :ARG_USER_ID ) 
   AND APPLICATION_NAME = :ARG_APP_NAME 
AND         ( ~"ISYS_MENU~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID )   
            
" update="ISYS_MENU" updatewhere=0 updatekeyinplace=yes arguments=(("ARG_APP_NAME", string),("ARG_USER_ID", string),("ARG_LANGUAGE", string),("ARG_ORGANIZATION_ID", number))  sort="organization_id A window_group A window_type A window_description_userdefine A " )
