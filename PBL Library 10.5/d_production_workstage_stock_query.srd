table(column=(type=char(20) updatewhereclause=yes name=model dbname="model" )
 column=(type=char(20) updatewhereclause=yes name=buyer dbname="buyer" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=number updatewhereclause=yes name=stock dbname="stock" )
 retrieve="		  select operationname, 
					operation_name, 
					seq, 
					item_code, 
					model, 
					buyer, 
					stock
             from TB_WORKSTAGE_STOCK_CURRENT 
	     where model like :arg_model||'%'
		   order by seq , model, buyer, item_code
            " arguments=(("arg_model", string))  sort="model A buyer A item_code A " )
