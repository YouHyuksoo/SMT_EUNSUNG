 retrieve="  SELECT ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DATE~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_SEQ~",   
         ~"IMAN_CARRYING_OUT~".~"ORGANIZATION_ID~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM_SPEC~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_RECEIPTOR~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_QTY~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_TYPE~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DIVISION~",   
         ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_BY~",   
         ~"IMAN_CARRYING_OUT~".~"COMMENTS~",   
         ~"IMAN_CARRYING_OUT~".~"CAR_NO~",   
         ~"IMAN_CARRYING_OUT~".~"INVOICE_NO~",   
         ~"IMAN_CARRYING_OUT~".~"CONFIRM_BY~",   
         ~"IMAN_CARRYING_OUT~".~"CONFIRM_DATE~",   
         ~"IMAN_CARRYING_OUT~".~"CONFIRM_YN~",   
         ~"IMAN_CARRYING_OUT~".~"COMPLETE_YN~",   
         ~"IMAN_CARRYING_OUT~".~"GATE_GUARD_ID~",   
         ~"IMAN_CARRYING_OUT~".~"GATE_GUARD_CONFIRM_YN~",   
         ~"IMAN_CARRYING_OUT~".~"BRING_IN_PLAN_DATE~",   
         ~"IMAN_CARRYING_OUT~".~"BRING_IN_YN~",   
         ~"IMAN_CARRYING_OUT~".~"ENTER_DATE~",   
         ~"IMAN_CARRYING_OUT~".~"ENTER_BY~",   
         ~"IMAN_CARRYING_OUT~".~"LAST_MODIFY_DATE~",   
         ~"IMAN_CARRYING_OUT~".~"LAST_MODIFY_BY~",   
          ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_GROUP_NO~" ,
         ROWID  
    FROM ~"IMAN_CARRYING_OUT~"  
   WHERE ( ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_ITEM~" like :arg_item ) AND  
         ( ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_RECEIPTOR~" like :arg_supplier ) AND  
         ( TRUNC(~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DATE~") >= :arg_dateset ) AND  
         ( TRUNC(~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_DATE~") <= :arg_dateend ) AND  
         ( NVL(~"IMAN_CARRYING_OUT~".~"COMPLETE_YN~" , 'N') = 'Y' or NVL(~"IMAN_CARRYING_OUT~".~"GATE_GUARD_CONFIRM_YN~" , 'N') = 'Y' ) AND  
         ( ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_TYPE~" like :arg_carrying_out_type ) AND  
          ( ~"IMAN_CARRYING_OUT~".~"CARRYING_OUT_GROUP_NO~" like :arg_carrying_out_group_no ) AND  
         ( ~"IMAN_CARRYING_OUT~".~"ORGANIZATION_ID~" = :arg_org )    
" update="IMAN_CARRYING_OUT" updatewhere=1 updatekeyinplace=no arguments=(("arg_item", string),("arg_supplier", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_carrying_out_type", string),("arg_carrying_out_group_no", string),("arg_org", number))  sort="organization_id A carrying_out_date A carrying_out_group_no A carrying_out_seq D " )
