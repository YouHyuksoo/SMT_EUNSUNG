table(column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(4000) updatewhereclause=yes name=lvl dbname="lvl" )
 column=(type=number update=yes updatewhereclause=yes name=bom_work_no dbname="bom_work_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=parent_item_code dbname="parent_item_code" )
