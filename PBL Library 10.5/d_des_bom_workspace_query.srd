 column=(type=number updatewhereclause=yes name=scrap_rate dbname="scrap_rate" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="enter_by" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="enter_date" )
 column=(type=char(20) updatewhereclause=yes name=last_modify_by dbname="last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=last_modify_date dbname="last_modify_date" )
 column=(type=char(1) updatewhereclause=yes name=new_bom_yn dbname="new_bom_yn" )
 column=(type=char(1) updatewhereclause=yes name=set_item_code dbname="set_item_code" )
 column=(type=char(4000) updatewhereclause=yes name=sort_order dbname="sort_order" )
 column=(type=char(1) updatewhereclause=yes name=request_yn dbname="request_yn" )
 column=(type=char(1000) updatewhereclause=yes name=location_info dbname="location_info" )
 column=(type=char(1000) updatewhereclause=yes name=confirm_comment dbname="confirm_comment" )
 column=(type=char(37) updatewhereclause=yes name=rowids dbname="rowids" )
 retrieve="  SELECT 'N' CHECK_YN ,
         LPAD( LEVEL , LEVEL , '.') LVL ,
         BOM_WORK_NO,   
         PARENT_ITEM_CODE,   
         F_GET_ITEM_NAME(PARENT_ITEM_CODE , DATESET , ORGANIZATION_ID ) PARENT_ITEM_NAME ,
         CHILD_ITEM_CODE,   
         F_GET_ITEM_NAME(CHILD_ITEM_CODE , DATESET , ORGANIZATION_ID ) CHILD_ITEM_NAME ,
         F_GET_ITEM_UOM(CHILD_ITEM_CODE , DATESET , ORGANIZATION_ID ) CHILD_ITEM_UOM ,
         ORGANIZATION_ID,   
         DATESET,   
         SORT_SEQUENCE, 
         ITEM_UNIT_QTY,   
         ITEM_UNIT_QTY_EXT,   
         WORKSTAGE_CODE,   
         DATEEND,   
         ITEM_TYPE , LINE_TYPE ,
		 loss_rate,
		 scrap_rate,
         ENTER_BY,   
         ENTER_DATE,   
         LAST_MODIFY_BY,   
         LAST_MODIFY_DATE,   
         NEW_BOM_YN,   
         :ARG_SET_ITEM_CODE SET_ITEM_CODE,
         sys_connect_by_path(trim(to_char(sort_sequence, '0000')),'.') as sort_order ,
		REQUEST_YN ,
         LOCATION_INFO , 
		CONFIRM_COMMENT ,
         ROWIDS
 FROM 
(
  SELECT BOM_WORK_NO,   
         PARENT_ITEM_CODE,   
         CHILD_ITEM_CODE,   
         ORGANIZATION_ID,   
         DATESET,   
         SORT_SEQUENCE,   
         ITEM_UNIT_QTY,   
         ITEM_UNIT_QTY_EXT,   
         WORKSTAGE_CODE,   
         DATEEND,   
         ITEM_TYPE , LINE_TYPE ,
		loss_rate,
		scrap_rate,
         ENTER_BY,   
         ENTER_DATE,   
         LAST_MODIFY_BY,   
         LAST_MODIFY_DATE,   
         NEW_BOM_YN, 
		REQUEST_YN ,  
         LOCATION_INFO ,
         CONFIRM_COMMENT ,
         ROWID ROWIDS
    FROM ID_ENG_BOM_WORKSPACE  
 WHERE BOM_WORK_NO               = :ARG_BOM_WORK_NO 
      AND ORGANIZATION_ID          = :ARG_ORGANIZATION_ID
      AND ( PARENT_ITEM_CODE,  CHILD_ITEM_CODE ) NOT IN ( SELECT NVL(PARENT_ITEM_CODE,'*') ,   
         NVL(CHILD_ITEM_CODE,'*') FROM   ID_ENG_BOM
      WHERE DATESET <= :ARG_DATESET
           AND DATEEND >= :ARG_DATESET
           AND ORGANIZATION_ID     = :ARG_ORGANIZATION_ID )

UNION ALL
	SELECT TO_NUMBER(:ARG_BOM_WORK_NO) BOM_WORK_NO,
			 PARENT_ITEM_CODE,
			 CHILD_ITEM_CODE,
			 ORGANIZATION_ID,
			 DATESET,
			 SORT_SEQUENCE,
			 ITEM_UNIT_QTY,
	           ITEM_UNIT_QTY_EXT,   
			 WORKSTAGE_CODE,
			 DATEEND,
              ITEM_TYPE , LINE_TYPE ,
			loss_rate,
			scrap_rate,
			 ENTER_BY,
			 ENTER_DATE,
			 LAST_MODIFY_BY,
			 LAST_MODIFY_DATE,
			 'N' NEW_BOM_YN,
			 'Y' REQUEST_YN ,
               LOCATION_INFO ,
			 '' CONFIRM_COMMENT ,
                ROWID ROWIDS
        FROM ID_ENG_BOM
      WHERE DATESET <= :ARG_DATESET
           AND DATEEND >= :ARG_DATESET
           AND ORGANIZATION_ID     = :ARG_ORGANIZATION_ID
)

   WHERE BOM_WORK_NO            = :ARG_BOM_WORK_NO 
        AND ORGANIZATION_ID       = :ARG_ORGANIZATION_ID
   START WITH CHILD_ITEM_CODE    = :ARG_SET_ITEM_CODE
       AND ORGANIZATION_ID        = :ARG_ORGANIZATION_ID
 CONNECT BY PRIOR CHILD_ITEM_CODE = PARENT_ITEM_CODE
       AND ORGANIZATION_ID        = :ARG_ORGANIZATION_ID" arguments=(("ARG_BOM_WORK_NO", number),("ARG_SET_ITEM_CODE", string),("ARG_DATESET", datetime),("ARG_ORGANIZATION_ID", number))  sort="organization_id A sort_order A " )
