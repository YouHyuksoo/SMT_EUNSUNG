table(column=(type=number updatewhereclause=yes key=yes name=issue_sequence dbname="ip_product_fg_issue.issue_sequence" )
 column=(type=char(30) updatewhereclause=yes name=barcode dbname="ip_product_fg_issue.barcode" )
 column=(type=datetime updatewhereclause=yes key=yes name=issue_date dbname="ip_product_fg_issue.issue_date" )
 column=(type=char(20) updatewhereclause=yes name=customer_code dbname="ip_product_fg_issue.customer_code" )
 column=(type=char(100) updatewhereclause=yes name=model_name dbname="ip_product_fg_issue.model_name" )
 column=(type=char(1) updatewhereclause=yes name=txn_deficit dbname="ip_product_fg_issue.txn_deficit" )
 column=(type=number updatewhereclause=yes name=qty dbname="ip_product_fg_issue.qty" )
 column=(type=char(10) updatewhereclause=yes name=location_code dbname="ip_product_fg_issue.location_code" )
 column=(type=char(30) updatewhereclause=yes name=ship_no dbname="ip_product_fg_issue.ship_no" )
 column=(type=datetime updatewhereclause=yes name=enter_date dbname="ip_product_fg_issue.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=enter_by dbname="ip_product_fg_issue.enter_by" )
 column=(type=number updatewhereclause=yes name=organization_id dbname="ip_product_fg_issue.organization_id" )
 retrieve=" select issue_sequence, 
          barcode, 
          issue_date, 
          customer_code, 
          model_name, 
          txn_deficit, 
          qty,  
          location_code, 
          ship_no, 
          enter_date, 
          enter_by, 
          organization_id 
  from ip_product_fg_issue  
 where barcode = (
                            select pack_barcode
                              from ip_product_pack_serial
                            where  barcode like  :ARG_SERIAL_NO 
                               AND ORGANIZATION_ID = :ARG_ORG
                 )
 order by issue_sequence

" update="ip_product_fg_issue" updatewhere=0 updatekeyinplace=no arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number))  sort="barcode A issue_date A " )
