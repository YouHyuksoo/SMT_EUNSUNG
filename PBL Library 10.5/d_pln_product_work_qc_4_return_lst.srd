 retrieve="SELECT  ~"IP_PRODUCT_WORK_QC~".~"QC_SEQUENCE~" ,    
~"IP_PRODUCT_WORK_QC~".~"LINE_CODE~" ,       
~"IP_PRODUCT_WORK_QC~".~"WORKSTAGE_CODE~" ,    
~"IP_PRODUCT_WORK_QC~".~"SERIAL_NO~" ,    
~"IP_PRODUCT_WORK_QC~".~"QC_RESULT~" ,     
~"IP_PRODUCT_WORK_QC~".~"BAD_REASON_CODE~" ,           ~"IP_PRODUCT_WORK_QC~".~"BAD_QTY~" ,           ~"IP_PRODUCT_WORK_QC~".~"CHARGER~" ,      
~"IP_PRODUCT_WORK_QC~".~"REPAIR_BY~" ,           ~"IP_PRODUCT_WORK_QC~".~"QC_DATE~" ,           ~"IP_PRODUCT_WORK_QC~".~"REPAIR_DATE~" ,        
~"IP_PRODUCT_WORK_QC~".~"QC_INSPECT_HANDLING~" ,           ~"IP_PRODUCT_WORK_QC~".~"COMMENTS~" ,           ~"IP_PRODUCT_WORK_QC~".~"ORGANIZATION_ID~" ,   
~"IP_PRODUCT_WORK_QC~".~"ENTER_DATE~" ,           ~"IP_PRODUCT_WORK_QC~".~"ENTER_BY~" ,           ~"IP_PRODUCT_WORK_QC~".~"LAST_MODIFY_DATE~" ,      
~"IP_PRODUCT_WORK_QC~".~"LAST_MODIFY_BY~" ,           ~"IP_PRODUCT_WORK_QC~".~"SHIFT_CODE~" ,           ~"IP_PRODUCT_WORK_QC~".~"RECEIPT_DEFICIT~" ,     
~"IP_PRODUCT_WORK_QC~".~"DEFECT_QTY~" ,           ~"IP_PRODUCT_WORK_QC~".~"MACHINE_CODE~" ,           ~"IP_PRODUCT_WORK_QC~".~"REPAIR_RESULT_CODE~" ,    
~"IP_PRODUCT_WORK_QC~".~"ITEM_CODE~" ,           ~"ID_ITEM~".~"MODEL_NAME~" ,           ~"ID_ITEM~".~"MODEL_SUFFIX~" ,           ~"ID_ITEM~".~"MSL_LEVEL~" ,       
~"IP_PRODUCT_WORK_QC~".~"MODEL_NAME~" ,           ~"IP_PRODUCT_WORK_QC~".~"LOCATION_CODE~"  ,
 ~"IP_PRODUCT_WORK_QC~".~"COMPLAINT_NO~"  
FROM ~"IP_PRODUCT_WORK_QC~" ,     
~"ID_ITEM~"     WHERE ( ~"IP_PRODUCT_WORK_QC~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" (+)) and    
( ~"IP_PRODUCT_WORK_QC~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" (+)) and  
( ~"IP_PRODUCT_WORK_QC~".~"COMPLAINT_NO~" like :ARG_COMPLAINT_NO ) and    
( ~"IP_PRODUCT_WORK_QC~".~"SERIAL_NO~" like :ARG_SERIAL_NO ) and    
( ~"IP_PRODUCT_WORK_QC~".~"RECEIPT_DEFICIT~" = '1' ) and      
( ~"IP_PRODUCT_WORK_QC~".~"ORGANIZATION_ID~" = :ARG_ORG )   " arguments=(("ARG_COMPLAINT_NO", string),("ARG_SERIAL_NO", string),("ARG_ORG", number)) )
