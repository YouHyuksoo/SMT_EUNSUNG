 retrieve="select 'N' chk,
         line_code, 
         workstage_code,
         pack_barcode, 
		pack_type, 
		model_name, 
		packing_pcs_qty, 
		pack_qty, 
		pack_date, 
		


		complete_flag, 
		print_flag, 
		reprint, 

		boxing_flag, 
		pallet_flag, 
		ship_flag, 
         receipt_flag,  
		
		
		box_no, 
		pallet_no, 
		ship_no, 
		receipt_no, 

		boxing_date, 
		pallet_date, 
		ship_date, 
         receipt_date, 

		attr1, 
		attr2, 
		attr3, 
		attr4, 
		attr5, 
		attr6, 
		attr7, 
		attr8, 
		organization_id, 
		enter_date, 
		enter_by, 
		last_modify_date, 
		last_modify_by, 
divide_flag, 
parent_barcode



  from ip_product_pack_master
 where pack_barcode like :arg_barcode 
 and model_name like :arg_model
and pack_date >= :arg_sdate
and pack_date <   :arg_edate + 1 
and divide_flag  = 'N'
and pack_type = 'M'
" arguments=(("arg_barcode", string),("arg_model", string),("arg_sdate", datetime),("arg_edate", datetime))  sort="pack_date D model_name A " )
