 column=(type=char(30) updatewhereclause=yes name=serial_no dbname="iq_interlock_check_result.serial_no" )
 column=(type=char(100) updatewhereclause=yes name=line_code dbname="iq_interlock_check_result.line_code" )
 column=(type=char(10) updatewhereclause=yes name=workstage_code dbname="iq_interlock_check_result.workstage_code" )
 column=(type=char(20) updatewhereclause=yes name=machine_code dbname="iq_interlock_check_result.machine_code" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="iq_interlock_check_result.model_name" )
 column=(type=char(10) updatewhereclause=yes name=check_result dbname="iq_interlock_check_result.check_result" )
 column=(type=char(10) updatewhereclause=yes name=pcb_item dbname="iq_interlock_check_result.pcb_item" )
 column=(type=char(30) updatewhereclause=yes name=item_code dbname="iq_interlock_check_result.item_code" )
 retrieve=" SELECT RECEIPT_DATE, 
             SERIAL_NO, 
             LINE_CODE, 
             WORKSTAGE_CODE, 
             MACHINE_CODE, 
             MODEL_NAME, 
             CHECK_RESULT, 
             PCB_ITEM, 
             ITEM_CODE
   FROM IQ_INTERLOCK_CHECK_RESULT
 WHERE  SERIAL_NO LIKE :ARG_SERIAL_NO
      AND NVL (CHECK_RESULT, 'NG') = 'NG'
      AND IS_LAST_YN = 'Y'
      AND ORGANIZATION_ID = :ARG_ORG" arguments=(("ARG_SERIAL_NO", string),("ARG_ORG", number)) )
