 column=(type=char(30) updatewhereclause=yes name=imcn_jig_input_hist_jig_lot_no dbname="imcn_jig_input_hist.jig_lot_no" )
 column=(type=char(100) update=yes updatewhereclause=yes name=jig_spec dbname="imcn_jig.jig_spec" )
 column=(type=char(10) update=yes updatewhereclause=yes name=solder_type dbname="imcn_jig.solder_type" )
 column=(type=number updatewhereclause=yes name=imcn_jig_input_hist_current_hit_value dbname="imcn_jig_input_hist.current_hit_value" )
 column=(type=char(30) updatewhereclause=yes name=ip_product_run_card_run_no dbname="ip_product_run_card.run_no" )
 column=(type=char(30) updatewhereclause=yes name=ip_product_run_card_item_code dbname="ip_product_run_card.item_code" )
 column=(type=char(100) updatewhereclause=yes name=ip_product_run_card_model_name dbname="ip_product_run_card.model_name" )
 column=(type=char(20) updatewhereclause=yes name=imcn_jig_input_hist_enter_by dbname="imcn_jig_input_hist.enter_by" )
 column=(type=datetime updatewhereclause=yes name=imcn_jig_input_hist_enter_date dbname="imcn_jig_input_hist.enter_date" )
 column=(type=char(20) updatewhereclause=yes name=imcn_jig_input_hist_last_modify_by dbname="imcn_jig_input_hist.last_modify_by" )
 column=(type=datetime updatewhereclause=yes name=imcn_jig_input_hist_last_modify_date dbname="imcn_jig_input_hist.last_modify_date" )
 column=(type=char(30) updatewhereclause=yes name=imcn_jig_input_hist_model_name dbname="imcn_jig_input_hist.model_name" )
 retrieve="  select h.input_date, 
           h.line_code, 
           h.jig_type, 
           h.jig_code, 
           h.jig_lot_no,  
           j.jig_spec, 
           j.solder_type, 
           h.current_hit_value, 
           r.run_no, 
           r.item_code, 
           r.model_name,  
           h.enter_by, 
           h.enter_date, 
           h.last_modify_by, 
           h.last_modify_date,
           h.model_name
    from IMCN_JIG_input_hist h,
           ip_product_run_card r,
           imcn_jig                  j
   where h.run_no          = r.run_no
     and h.organization_id = r.organization_id
     and h.jig_code        = j.jig_code
     and h.jig_lot_no      = j.jig_lot_no
     and h.organization_id = j.organization_id
     and h.input_date      >= trunc(:arg_input_sdate)
     and h.input_date      <  trunc(:arg_input_edate) + 1
     and h.line_code         like  :arg_line_code
     and h.jig_type           like  :arg_jig_type
     and h.jig_lot_no         like :arg_jig_lot_no
     and h.organization_id like :arg_org_id
     and r.item_code        like :arg_model_item
    " arguments=(("arg_input_sdate", datetime),("arg_input_edate", datetime),("arg_line_code", string),("arg_jig_type", string),("arg_jig_lot_no", string),("arg_model_item", string),("arg_org_id", number))  sort="imcn_jig_input_hist_input_date A imcn_jig_input_hist_line_code A jig_type A imcn_jig_input_hist_jig_lot_no A " )
