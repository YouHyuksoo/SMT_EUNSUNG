table(column=(type=datetime updatewhereclause=yes name=imcn_jig_input_hist_input_date dbname="imcn_jig_input_hist.input_date" )
 column=(type=char(20) updatewhereclause=yes name=imcn_jig_input_hist_line_code dbname="imcn_jig_input_hist.line_code" )
 column=(type=char(20) updatewhereclause=yes name=jig_type dbname="imcn_jig_input_hist.jig_type" )
