 retrieve=" SELECT A.SUPPLIER_NAME , A.ITEM_CODE ,A.ITEM_NAME ,A.ITEM_SPEC ,A.ITEM_UOM ,A.ORGANIZATION_ID ,
SUM(A.RECEIPT_AMT) RECEIPT_AMT ,
SUM(A.R01)		R01	,
SUM(A.R02)		R02	,
SUM(A.R03)		R03	,
SUM(A.R04)		R04	,
SUM(A.R05)		R05	,
SUM(A.R06)		R06	,
SUM(A.R07)		R07	,
SUM(A.R08)		R08	,
SUM(A.R09)		R09	,
SUM(A.R10)		R10	,
SUM(A.R11)		R11	,
SUM(A.R12)		R12	,
SUM(A.R13)		R13	,
SUM(A.R14)		R14	,
SUM(A.R15)		R15	,
SUM(A.R16)		R16	,
SUM(A.R17)		R17	,
SUM(A.R18)		R18	,
SUM(A.R19)		R19	,
SUM(A.R20)		R20	,
SUM(A.R21)		R21	,
SUM(A.R22)		R22	,
SUM(A.R23)		R23	,
SUM(A.R24)		R24	,
SUM(A.R25)		R25	,
SUM(A.R26)		R26	,
SUM(A.R27)		R27	,
SUM(A.R28)		R28	,
SUM(A.R29)		R29	,
SUM(A.R30)		R30	,
SUM(A.R31)		R31	
FROM 
(
SELECT C.SUPPLIER_NAME , A.ITEM_CODE  , B.ITEM_NAME , B.ITEM_SPEC ,B.ITEM_UOM ,A.ORGANIZATION_ID ,
A.RECEIPT_AMT ,
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '01' , A.RECEIPT_QTY , 0 ) R01 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '02' , A.RECEIPT_QTY , 0 ) R02 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '03' , A.RECEIPT_QTY , 0 ) R03 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '04' , A.RECEIPT_QTY , 0 ) R04 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '05' , A.RECEIPT_QTY , 0 ) R05 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '06' , A.RECEIPT_QTY , 0 ) R06 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '07' , A.RECEIPT_QTY , 0 ) R07 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '08' , A.RECEIPT_QTY , 0 ) R08 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '09' , A.RECEIPT_QTY , 0 ) R09 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '10' , A.RECEIPT_QTY , 0 ) R10 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '11' , A.RECEIPT_QTY , 0 ) R11 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '12' , A.RECEIPT_QTY , 0 ) R12 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '13' , A.RECEIPT_QTY , 0 ) R13 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '14' , A.RECEIPT_QTY , 0 ) R14 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '15' , A.RECEIPT_QTY , 0 ) R15 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '16' , A.RECEIPT_QTY , 0 ) R16 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '17' , A.RECEIPT_QTY , 0 ) R17 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '18' , A.RECEIPT_QTY , 0 ) R18 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '19' , A.RECEIPT_QTY , 0 ) R19 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '20' , A.RECEIPT_QTY , 0 ) R20 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '21' , A.RECEIPT_QTY , 0 ) R21 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '22' , A.RECEIPT_QTY , 0 ) R22 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '23' , A.RECEIPT_QTY , 0 ) R23 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '24' , A.RECEIPT_QTY , 0 ) R24 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '25' , A.RECEIPT_QTY , 0 ) R25 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '26' , A.RECEIPT_QTY , 0 ) R26 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '27' , A.RECEIPT_QTY , 0 ) R27 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '28' , A.RECEIPT_QTY , 0 ) R28 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '29' , A.RECEIPT_QTY , 0 ) R29 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '30' , A.RECEIPT_QTY , 0 ) R30 ,  
DECODE(  TO_CHAR(A.RECEIPT_DATE,'DD') , '31' , A.RECEIPT_QTY , 0 ) R31                                                                          
  FROM IM_ITEM_RECEIPT  A , ID_ITEM B , ICOM_SUPPLIER C
WHERE A.ITEM_CODE = B.ITEM_CODE
     AND A.ORGANIZATION_ID = B.ORGANIZATION_ID
     AND A.SUPPLIER_CODE      = C.SUPPLIER_CODE
     AND A.ORGANIZATION_ID = C.ORGANIZATION_ID
     AND C.SUPPLIER_CODE LIKE :arg_supplier_code
     AND A.ITEM_CODE LIKE :arg_item_code
     AND TO_CHAR(A.RECEIPT_DATE,'YYYYMM')  = :arg_yyyymm
     AND A.ORGANIZATION_ID = :arg_org_id
)  A
GROUP BY A.SUPPLIER_NAME , A.ITEM_CODE , A.ITEM_NAME , A.ITEM_SPEC ,A.ITEM_UOM ,A.ORGANIZATION_ID

" arguments=(("arg_yyyymm", string),("arg_supplier_code", string),("arg_item_code", string),("arg_org_id", number))  sort="organization_id A supplier_name A " )
