 retrieve="  SELECT ~"IMCN_JIG_MASK_CHECK~".~"JIG_CODE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"JIG_LOT_NO~",   
         ~"IMCN_JIG_MASK_CHECK~".~"ORGANIZATION_ID~",   
         ~"IMCN_JIG_MASK_CHECK~".~"JIG_CHECK_SEQUENCE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"JIG_CHECK_DATE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"JIG_CHECK_STATUS~",   
         ~"IMCN_JIG_MASK_CHECK~".~"USED_QTY~",   
         ~"IMCN_JIG_MASK_CHECK~".~"ACTUAL_VALUE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"USED_BY~",   
         ~"IMCN_JIG_MASK_CHECK~".~"LINE_CODE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"CLEAN_YN~",   
         ~"IMCN_JIG_MASK_CHECK~".~"TENSION_CHECK1~",   
         ~"IMCN_JIG_MASK_CHECK~".~"TENSION_CHECK2~",   
         ~"IMCN_JIG_MASK_CHECK~".~"TENSION_CHECK3~",   
         ~"IMCN_JIG_MASK_CHECK~".~"TENSION_CHECK4~",   
         ~"IMCN_JIG_MASK_CHECK~".~"TENSION_CHECK5~",   
         ~"IMCN_JIG_MASK_CHECK~".~"MAX_TENSION~",   
         ~"IMCN_JIG_MASK_CHECK~".~"RETURN_BY~",   
         ~"IMCN_JIG_MASK_CHECK~".~"CONFIRM_YN~",   
         ~"IMCN_JIG_MASK_CHECK~".~"CONFIRM_DATE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"COMMENTS~",   
         ~"IMCN_JIG_MASK_CHECK~".~"ENTER_BY~",   
         ~"IMCN_JIG_MASK_CHECK~".~"ENTER_DATE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"LAST_MODIFY_BY~",   
         ~"IMCN_JIG_MASK_CHECK~".~"LAST_MODIFY_DATE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"BREAK_VALUE~",   
         ~"IMCN_JIG_MASK_CHECK~".~"HIT_VALUE~"
    FROM ~"IMCN_JIG_MASK_CHECK~"
   WHERE 
         (  ~"IMCN_JIG_MASK_CHECK~".~"JIG_LOT_NO~" = :arg_lot_no )" update="IMCN_JIG_MASK_CHECK" updatewhere=0 updatekeyinplace=no arguments=(("arg_lot_no", string))  sort="jig_check_date D " )
