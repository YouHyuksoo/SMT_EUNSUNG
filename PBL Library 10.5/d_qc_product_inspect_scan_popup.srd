table(column=(type=char(30) updatewhereclause=yes name=run_no dbname="ip_product_run_card.run_no" dbalias=".run_no" )
 column=(type=char(10) updatewhereclause=yes name=line_code dbname="ip_product_run_card.line_code" dbalias=".line_code" )
 column=(type=datetime updatewhereclause=yes name=run_date dbname="ip_product_run_card.run_date" dbalias=".run_date" )
 column=(type=char(50) updatewhereclause=yes name=model_name dbname="ip_product_run_card.model_name" dbalias=".model_name" )
 column=(type=number updatewhereclause=yes name=lot_size dbname="ip_product_run_card.lot_size" dbalias=".lot_size" )
 column=(type=number updatewhereclause=yes name=input_qty dbname="input_qty" )
 column=(type=number updatewhereclause=yes name=qc_scan_qty dbname="qc_scan_qty" )
 column=(type=number updatewhereclause=yes name=qc_remain_qty dbname="qc_remain_qty" )
 column=(type=number updatewhereclause=yes name=qc_noscan_qty dbname="qc_noscan_qty" )
 retrieve="  SELECT ~"IP_PRODUCT_RUN_CARD~".~"RUN_NO~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LINE_CODE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"RUN_DATE~",   
         ~"IP_PRODUCT_RUN_CARD~".~"MODEL_NAME~",   
         ~"IP_PRODUCT_RUN_CARD~".~"LOT_SIZE~"  ,
		F_GET_PCB_INPUT_QTY_BY_RUN_NO( RUN_NO , ORGANIZATION_ID ) INPUT_QTY ,
		F_GET_PCB_OUTPUT_QTY_BY_RUN_NO( RUN_NO , ORGANIZATION_ID ) QC_SCAN_QTY ,
         f_get_pcb_remain_qty_by_run_no( RUN_NO , ORGANIZATION_ID ) QC_REMAIN_QTY ,
		f_get_pcb_noscan_qty_by_run_no( RUN_NO , ORGANIZATION_ID ) QC_NOSCAN_QTY
    FROM ~"IP_PRODUCT_RUN_CARD~"  
   WHERE  ( IP_PRODUCT_RUN_CARD.RUN_NO like :arg_run_no ) AND  
         ( IP_PRODUCT_RUN_CARD.MODEL_NAME like :arg_model_name ) AND  
         ( IP_PRODUCT_RUN_CARD.RUN_DATE >= :arg_run_date ) AND  
         ( IP_PRODUCT_RUN_CARD.ORGANIZATION_ID = :arg_org )    
" arguments=(("arg_run_no", string),("arg_model_name", string),("arg_run_date", datetime),("arg_org", number))  sort="run_no A " )
