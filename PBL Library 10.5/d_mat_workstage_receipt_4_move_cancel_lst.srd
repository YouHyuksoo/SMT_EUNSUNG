 retrieve="  SELECT 'N' CHECK_YN,   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DATE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_SEQUENCE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"WORKSTAGE_CODE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"MACHINE_CODE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"MATERIAL_MFS~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"MFS~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_CODE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"LINE_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"LINE_CODE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DEFICIT~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_PRICE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_QTY~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_WEIGHT~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_AMT~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_TYPE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_ACCOUNT~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ISSUE_DATE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ISSUE_SEQUENCE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"WORK_ORDER_NO~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_STATUS~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"TRANSFER_YN~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ENTER_DATE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ENTER_BY~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"LAST_MODIFY_BY~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"INVOICE_NO~",   
         ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"TRANSFER_TYPE~"  
    FROM ~"IM_ITEM_WORKSTAGE_RECEIPT~",   
         ~"ID_ITEM~"  
   WHERE ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~" ) and  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DATE~" >= :arg_dateset ) AND
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DATE~" <= :arg_dateend ) AND
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"MFS~" like :arg_mfs ) AND  
         (~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ITEM_CODE~" like :arg_item_code ) AND  
         (~"IM_ITEM_WORKSTAGE_RECEIPT~".~"WORKSTAGE_CODE~" like :arg_workstage_code ) AND  
         (~"IM_ITEM_WORKSTAGE_RECEIPT~".~"INVOICE_NO~" like :arg_invoice_no ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_STATUS~" = 'N' ) AND  
         (~"IM_ITEM_WORKSTAGE_RECEIPT~".~"TRANSFER_TYPE~" = 'M' ) AND  
         (~"IM_ITEM_WORKSTAGE_RECEIPT~".~"RECEIPT_DEFICIT~" = '2' ) AND  
         ( ~"IM_ITEM_WORKSTAGE_RECEIPT~".~"ORGANIZATION_ID~" = :arg_org )
" update="IM_ITEM_WORKSTAGE_RECEIPT" updatewhere=0 updatekeyinplace=yes arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_mfs", string),("arg_item_code", string),("arg_workstage_code", string),("arg_invoice_no", string),("arg_org", number))  sort="organization_id A receipt_date A receipt_sequence A " )
