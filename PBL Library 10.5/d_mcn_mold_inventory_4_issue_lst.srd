 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"imcn_mold~" )  TABLE(NAME=~"imcn_mold_inventory~" ) COLUMN(NAME=~"imcn_mold.mold_code~") COLUMN(NAME=~"imcn_mold.organization_id~") COLUMN(NAME=~"imcn_mold.drawing_no~") COLUMN(NAME=~"imcn_mold.mold_name~") COLUMN(NAME=~"imcn_mold.mold_group~") COLUMN(NAME=~"imcn_mold.mold_spec~") COLUMN(NAME=~"imcn_mold.raw_material~") COLUMN(NAME=~"imcn_mold.punch_no~") COLUMN(NAME=~"imcn_mold.mold_line_type~") COLUMN(NAME=~"imcn_mold.safety_inventory~") COLUMN(NAME=~"imcn_mold.order_leadtime~") COLUMN(NAME=~"imcn_mold.nation_code~") COLUMN(NAME=~"imcn_mold.last_receipt_date~") COLUMN(NAME=~"imcn_mold.last_issue_date~") COLUMN(NAME=~"imcn_mold.comments~") COLUMN(NAME=~"imcn_mold.enter_by~") COLUMN(NAME=~"imcn_mold.enter_date~") COLUMN(NAME=~"imcn_mold.last_modify_by~") COLUMN(NAME=~"imcn_mold.last_modify_date~") COMPUTE(NAME=~"'N' CHECK_YN~") COLUMN(NAME=~"imcn_mold.supplier_code~") COMPUTE(NAME=~"1 ISSUE_QTY~") COLUMN(NAME=~"imcn_mold_inventory.inventory_qty~") COLUMN(NAME=~"imcn_mold_inventory.mold_version~") COLUMN(NAME=~"imcn_mold_inventory.mold_set_serial~") COLUMN(NAME=~"imcn_mold_inventory.mold_row_qty~") COLUMN(NAME=~"imcn_mold_inventory.mold_use_status~") COLUMN(NAME=~"imcn_mold_inventory.mold_usefull_row_qty~") COLUMN(NAME=~"imcn_mold_inventory.mold_warehouse_code~") COLUMN(NAME=~"imcn_mold_inventory.location_code~") COLUMN(NAME=~"imcn_mold_inventory.break_value~") COLUMN(NAME=~"imcn_mold_inventory.actual_value~") COLUMN(NAME=~"imcn_mold_inventory.mold_in_out~") COLUMN(NAME=~"imcn_mold.mold_type~") COLUMN(NAME=~"imcn_mold_inventory.machine_code~") COLUMN(NAME=~"imcn_mold_inventory.workstage_code~") COLUMN(NAME=~"imcn_mold_inventory.line_code~")    JOIN (LEFT=~"imcn_mold.mold_code~"    OP =~"=~"RIGHT=~"imcn_mold_inventory.mold_code~" )    JOIN (LEFT=~"imcn_mold.organization_id~"    OP =~"=~"RIGHT=~"imcn_mold_inventory.organization_id~" )WHERE(    EXP1 =~"( ~~~"IMCN_MOLD~~~".~~~"MOLD_CODE~~~"~"   OP =~"like~"    EXP2 =~":ARG_MOLD_CODE )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD~~~".~~~"SUPPLIER_CODE~~~"~"   OP =~"like~"    EXP2 =~":arg_supplier_code )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD_INVENTORY~~~".~~~"MOLD_USE_STATUS~~~"~"   OP =~"like~"    EXP2 =~":arg_mold_use_status~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"~~~"IMCN_MOLD~~~".~~~"MOLD_CODE~~~"~"   OP =~"<>~"    EXP2 =~"'*'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( ~~~"IMCN_MOLD~~~".~~~"ORGANIZATION_ID~~~"~"   OP =~"=~"    EXP2 =~":ARG_ORG )~" ) ) ARG(NAME = ~"ARG_MOLD_CODE~" TYPE = string)  ARG(NAME = ~"arg_supplier_code~" TYPE = string)  ARG(NAME = ~"arg_mold_use_status~" TYPE = string)  ARG(NAME = ~"ARG_ORG~" TYPE = number) " arguments=(("ARG_MOLD_CODE", string),("arg_supplier_code", string),("arg_mold_use_status", string),("ARG_ORG", number))  sort="organization_id A mold_use_status D mold_group A mold_code A mold_version A mold_set_serial A " )
