table(column=(type=char(20) updatewhereclause=yes name=line_code dbname="ib_line_master.line_code" )
 column=(type=char(30) updatewhereclause=yes name=machine dbname="ib_line_master.machine" )
 column=(type=char(53) updatewhereclause=yes name=line_barcoe dbname="line_barcoe" )
 retrieve="  SELECT ~"IB_LINE_MASTER~".~"LINE_CODE~",   
              ~"IB_LINE_MASTER~".~"MACHINE~",   
              '*'||line_code||'-'||MACHINE||'*' LINE_BARCOE  
    FROM ~"IB_LINE_MASTER~"  
   WHERE ( ~"IB_LINE_MASTER~".~"LINE_CODE~" = :arg_line_code ) AND  
         ( ~"IB_LINE_MASTER~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_line_code", string),("arg_org", number))  sort="line_code A " )
