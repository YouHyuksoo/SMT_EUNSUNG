 column=(type=number update=yes updatewhereclause=yes name=last_inventory_qty dbname="last_inventory_qty" )
 column=(type=number update=yes updatewhereclause=yes name=last_avg_price dbname="last_avg_price" )
 column=(type=number update=yes updatewhereclause=yes name=last_inventory_amt dbname="last_inventory_amt" )
 column=(type=char(10) update=yes updatewhereclause=yes name=receipt_account dbname="im_item_ledger.receipt_account" )
