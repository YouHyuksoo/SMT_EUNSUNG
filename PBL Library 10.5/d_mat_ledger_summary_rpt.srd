 column=(type=number update=yes updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=char(3) update=yes updatewhereclause=yes name=currency dbname="im_item_ledger.currency" )
 column=(type=char(10) updatewhereclause=yes name=line_type dbname="im_item_ledger.line_type" )
 column=(type=char(100) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(100) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 retrieve="  SELECT ~"IM_ITEM_LEDGER~".~"CLOSE_YYYYMM~",   
         MAX(~"IM_ITEM_LEDGER~".~"RECEIPT_ISSUE_SEQUENCE~") RECEIPT_ISSUE_SEQUENCE,   
         ~"IM_ITEM_LEDGER~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_LEDGER~".~"ITEM_CODE~",   
         SUM(~"IM_ITEM_LEDGER~".~"LAST_INVENTORY_QTY~") LAST_INVENTORY_QTY,   
         AVG(~"IM_ITEM_LEDGER~".~"LAST_AVG_PRICE~") LAST_AVG_PRICE,   
         SUM(~"IM_ITEM_LEDGER~".~"LAST_INVENTORY_AMT~") LAST_INVENTORY_AMT,   
         ~"IM_ITEM_LEDGER~".~"RECEIPT_ACCOUNT~",
         ~"IM_ITEM_LEDGER~".~"RECEIPT_DEFICIT~",   
         ~"IM_ITEM_LEDGER~".~"RECEIPT_DATE~",   
         SUM(~"IM_ITEM_LEDGER~".~"RECEIPT_QTY~") RECEIPT_QTY,   
         AVG(~"IM_ITEM_LEDGER~".~"RECEIPT_PRICE~") RECEIPT_PRICE,   
         SUM(~"IM_ITEM_LEDGER~".~"RECEIPT_AMT~") RECEIPT_AMT,   
         ~"IM_ITEM_LEDGER~".~"ISSUE_ACCOUNT~",   
         ~"IM_ITEM_LEDGER~".~"ISSUE_DATE~",   
         ~"IM_ITEM_LEDGER~".~"ISSUE_DEFICIT~",   
         SUM(~"IM_ITEM_LEDGER~".~"ISSUE_QTY~") ISSUE_QTY,   
         AVG(~"IM_ITEM_LEDGER~".~"ISSUE_PRICE~") ISSUE_PRICE,   
         SUM(~"IM_ITEM_LEDGER~".~"ISSUE_AMT~") ISSUE_AMT,   
         SUM(~"IM_ITEM_LEDGER~".~"INVENTORY_QTY~") INVENTORY_QTY,   
         ~"IM_ITEM_LEDGER~".~"CURRENCY~",   
         ~"IM_ITEM_LEDGER~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~"   
    FROM ~"IM_ITEM_LEDGER~",   
         ~"ID_ITEM~"  
   WHERE ( im_item_ledger.item_code = id_item.item_code (+)) and  
         ( im_item_ledger.organization_id = id_item.organization_id (+)) and  
         ( ( ~"IM_ITEM_LEDGER~".~"CLOSE_YYYYMM~" = :ARG_YYYYMM ) AND  
         ( ~"IM_ITEM_LEDGER~".~"ITEM_CODE~" like :ARG_ITEM_CODE ) AND  
         ( ~"IM_ITEM_LEDGER~".~"ORGANIZATION_ID~" = :ARG_ORG ) )    
GROUP BY  ~"IM_ITEM_LEDGER~".~"CLOSE_YYYYMM~",   
         ~"IM_ITEM_LEDGER~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_LEDGER~".~"ITEM_CODE~",   
         ~"IM_ITEM_LEDGER~".~"RECEIPT_ACCOUNT~",   
         ~"IM_ITEM_LEDGER~".~"RECEIPT_DEFICIT~",   
         ~"IM_ITEM_LEDGER~".~"RECEIPT_DATE~",   
         ~"IM_ITEM_LEDGER~".~"ISSUE_ACCOUNT~",   
         ~"IM_ITEM_LEDGER~".~"ISSUE_DATE~",   
         ~"IM_ITEM_LEDGER~".~"ISSUE_DEFICIT~",   
         ~"IM_ITEM_LEDGER~".~"SUPPLIER_CODE~",   
         ~"IM_ITEM_LEDGER~".~"CURRENCY~",   
         ~"IM_ITEM_LEDGER~".~"LINE_TYPE~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_UOM~"" arguments=(("ARG_YYYYMM", string),("ARG_ITEM_CODE", string),("ARG_ORG", number))  sort="organization_id A close_yyyymm A item_code A receipt_issue_sequence A " )
group(level=1 header.height=0 trailer.height=188 by=("organization_id" , "close_yyyymm" , "item_code" ) header.color="536870912" trailer.color="536870912" )
