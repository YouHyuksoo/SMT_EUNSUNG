 column=(type=char(10) updatewhereclause=yes name=line_type dbname="line_type" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number updatewhereclause=yes name=reel_qty dbname="reel_qty" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="item_spec" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="supplier_code" )
 retrieve="SELECT * FROM 
(
  SELECT
         IM_ITEM_INVENTORY.ITEM_CODE,   
          IM_ITEM_INVENTORY.LINE_TYPE,   
         SUM(IM_ITEM_INVENTORY.INVENTORY_QTY) INVENTORY_QTY,   
         f_get_reel_qty( IM_ITEM_INVENTORY.ITEM_CODE, 1,  SUM(IM_ITEM_INVENTORY.INVENTORY_QTY) , IM_ITEM_INVENTORY.ORGANIZATION_ID ) REEL_QTY , 
         MAX(ID_ITEM.ITEM_SPEC) ITEM_SPEC,   
         MAX(ID_ITEM.ITEM_NAME) ITEM_NAME,
		IM_ITEM_INVENTORY.SUPPLIER_CODE  SUPPLIER_CODE
    FROM IM_ITEM_INVENTORY,   ID_ITEM  
   WHERE ( ID_ITEM.ITEM_CODE = IM_ITEM_INVENTORY.ITEM_CODE ) and  
         ( ID_ITEM.ORGANIZATION_ID = IM_ITEM_INVENTORY.ORGANIZATION_ID ) and  
         ( ( IM_ITEM_INVENTORY.ITEM_CODE like :arg_item_code ) AND  
		( IM_ITEM_INVENTORY.MATERIAL_MFS like :arg_material_mfs ) AND  
         ( nvl(IM_ITEM_INVENTORY.LOCATION_ADDRESS_RACK , '*')  like nvl(:arg_location_code,'*') )     AND
         ( nvl(IM_ITEM_INVENTORY.SUPPLIER_CODE,'*') like :arg_supplier_code )     AND
         ( IM_ITEM_INVENTORY.ORGANIZATION_ID = :ARG_ORGANIZATION_ID ) )    
GROUP BY
         IM_ITEM_INVENTORY.ITEM_CODE,   
         IM_ITEM_INVENTORY.LINE_TYPE,   
         IM_ITEM_INVENTORY.SUPPLIER_CODE ,
         IM_ITEM_INVENTORY.ORGANIZATION_ID
) 

WHERE     (  SIGN(INVENTORY_QTY) >= :arg_sign )  " arguments=(("ARG_ITEM_CODE", string),("ARG_MATERIAL_MFS", string),("ARG_LOCATION_CODE", string),("ARG_SUPPLIER_CODE", string),("ARG_SIGN", number),("ARG_ORGANIZATION_ID", number))  sort="item_code A " )
