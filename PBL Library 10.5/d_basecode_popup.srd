table(column=(type=char(30) update=yes updatewhereclause=yes key=yes name=code_type dbname="isys_basecode.code_type" )
 column=(type=char(100) update=yes updatewhereclause=yes key=yes name=code_name dbname="isys_basecode.code_name" )
 column=(type=number update=yes updatewhereclause=yes key=yes name=organization_id dbname="isys_basecode.organization_id" )
 column=(type=char(100) updatewhereclause=yes name=code_mean dbname="code_mean" )
 column=(type=char(100) updatewhereclause=yes name=code_name_description dbname="code_name_description" )
 column=(type=char(100) update=yes updatewhereclause=yes name=code_group dbname="isys_basecode.code_group" )
 column=(type=char(20) update=yes updatewhereclause=yes name=enter_by dbname="isys_basecode.enter_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=enter_date dbname="isys_basecode.enter_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=last_modify_by dbname="isys_basecode.last_modify_by" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_modify_date dbname="isys_basecode.last_modify_date" )
 retrieve="  SELECT ~"ISYS_BASECODE~".~"CODE_TYPE~",   
         ~"ISYS_BASECODE~".~"CODE_NAME~",   
         ~"ISYS_BASECODE~".~"ORGANIZATION_ID~",   
         DECODE( :ARG_LANGUAGE , 'E' , ~"ISYS_BASECODE~".~"CODE_MEAN_ENG~",   'K' ,  ~"ISYS_BASECODE~".~"CODE_MEAN_KOR~", 'C' , ~"ISYS_BASECODE~".~"CODE_MEAN_LOCAL~" ) CODE_MEAN ,   
         DECODE( :ARG_LANGUAGE , 'E' ,~"ISYS_BASECODE~".~"CODE_NAME_DESCRIPTION_ENG~",   'K' , ~"ISYS_BASECODE~".~"CODE_NAME_DESCRIPTION_KOR~", 'C' ,~"ISYS_BASECODE~".~"CODE_NAME_DESCRIPTION_LOCAL~" ) CODE_NAME_DESCRIPTION,   
         ~"ISYS_BASECODE~".~"CODE_GROUP~",   
         ~"ISYS_BASECODE~".~"ENTER_BY~",   
         ~"ISYS_BASECODE~".~"ENTER_DATE~",   
         ~"ISYS_BASECODE~".~"LAST_MODIFY_BY~",   
         ~"ISYS_BASECODE~".~"LAST_MODIFY_DATE~"  
    FROM ~"ISYS_BASECODE~"   
   WHERE   ( ~"ISYS_BASECODE~".~"CODE_TYPE~" like :ARG_CODE_TYPE ) AND  
         ( ~"ISYS_BASECODE~".~"ORGANIZATION_ID~" = :ARG_ORGANIZATION_ID )    
" update="ISYS_BASECODE" updatewhere=1 updatekeyinplace=no arguments=(("ARG_LANGUAGE", string),("ARG_CODE_TYPE", string),("ARG_ORGANIZATION_ID", number))  sort="organization_id A code_type A code_group A code_name A " )
