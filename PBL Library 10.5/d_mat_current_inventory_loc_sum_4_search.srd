 column=(type=char(20) update=yes updatewhereclause=yes name=item_code dbname="im_item_inventory.item_code" )
 column=(type=number update=yes updatewhereclause=yes name=organization_id dbname="im_item_inventory.organization_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=location_code dbname="im_item_inventory.location_code" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=location_address_rack dbname="location_address_rack" )
 column=(type=char(20) updatewhereclause=yes name=supplier_code dbname="im_item_inventory.supplier_code" )
 column=(type=number update=yes updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 column=(type=number updatewhereclause=yes name=reel_qty dbname="reel_qty" )
 retrieve="SELECT  MAX(~"IM_ITEM_INVENTORY~".~"MATERIAL_MFS~" )  MATERIAL_MFS,      
			~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ,     
			~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ,   
	     	~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~" ,  
			~"ID_ITEM~".~"ITEM_SPEC~" ,    
              ~"ID_ITEM~".~"ITEM_NAME~" ,      
			 NVL(IM_ITEM_INVENTORY.LOCATION_ADDRESS_RACK,'*')  LOCATION_ADDRESS_RACK ,
			 IM_ITEM_INVENTORY.SUPPLIER_CODE SUPPLIER_CODE ,
			 SUM(INVENTORY_QTY) INVENTORY_QTY ,
			 COUNT(*) REEL_QTY
FROM ~"IM_ITEM_INVENTORY~" ,           ~"ID_ITEM~"   
WHERE ( ~"ID_ITEM~".~"ITEM_CODE~" = ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ) and      
( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ) and  
( ~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" like :arg_item_code ) and   
( ~"IM_ITEM_INVENTORY~".~"SUPPLIER_CODE~" like :arg_supplier_code ) and   
( ~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" = :arg_org_id ) and 
    (  SIGN(IM_ITEM_INVENTORY.INVENTORY_QTY) >= :arg_sign )  

GROUP BY     
			~"IM_ITEM_INVENTORY~".~"ITEM_CODE~" ,     
			~"IM_ITEM_INVENTORY~".~"ORGANIZATION_ID~" ,   
	     	~"IM_ITEM_INVENTORY~".~"LOCATION_CODE~" ,  
			~"ID_ITEM~".~"ITEM_SPEC~" ,         
              ~"ID_ITEM~".~"ITEM_NAME~" , 
			 NVL(IM_ITEM_INVENTORY.LOCATION_ADDRESS_RACK ,'*') ,
			 IM_ITEM_INVENTORY.SUPPLIER_CODE  " arguments=(("arg_item_code", string),("arg_supplier_code", string),("arg_sign", number),("arg_org_id", number))  sort="organization_id A location_address_rack A item_code A material_mfs A " )
group(level=1 header.height=0 trailer.height=0 by=("organization_id" , "location_code" ) header.color="65535" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=0 by=("organization_id" , "location_code" , "item_code" ) header.color="65280" trailer.color="536870912" )
