 retrieve="  SELECT ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"PID~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"MACHINE_CODE~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"INSPECT_START_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"INSPECT_END_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"RESULT~",   

         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"ENTER_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"ENTER_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"LAST_MODIFY_DATE~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"LAST_MODIFY_BY~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"ORGANIZATION_ID~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"FILE_NAME~",   
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"RUN_NO~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"LINE_CODE~",
         F_GET_RUN_MODEL_NAME(RUN_NO) MODEL_NAME,

         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"TEST_CHANNEL~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_DATA1~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_RESULT1~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_DATA2~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_RESULT2~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_DATA3~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_RESULT3~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_DATA4~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CURRENT_TEST_RESULT4~",

         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_DATA1~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_RESULT1~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_DATA2~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_RESULT2~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_DATA3~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_RESULT3~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_DATA4~",
         ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"CONNECTIVITY_TEST_RESULT4~"
         
    FROM ~"IQ_MACHINE_INSPECT_DATA_EOL~"  
   WHERE ( ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"INSPECT_START_DATE~" >= TO_CHAR(TRUNC(:ARG_DATESET),'YYYY/MM/DD HH24:MI:SS' ) ) AND  
              ( ~"IQ_MACHINE_INSPECT_DATA_EOL~".~"INSPECT_START_DATE~" <   TO_CHAR(TRUNC(:ARG_DATEEND)+1 ,'YYYY/MM/DD HH24:MI:SS' )) AND  
              (~"IQ_MACHINE_INSPECT_DATA_EOL~".~"PID~" like :ARG_PID  )   AND 
	     	 (NVL(~"IQ_MACHINE_INSPECT_DATA_EOL~".~"LINE_CODE~",'*') LIKE :ARG_LINE_CODE ) AND
              F_GET_RUN_MODEL_NAME( RUN_NO) LIKE :ARG_MODEL_NAME  AND
             RUN_NO  LIKE :ARG_RUN_NO " arguments=(("ARG_DATESET", datetime),("ARG_DATEEND", datetime),("ARG_LINE_CODE", string),("ARG_PID", string),("ARG_MODEL_NAME", string),("ARG_RUN_NO", string))  sort="line_code A pid A " )
