 retrieve="SELECT   ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~",
         ~"IM_ITEM_ISSUE~".~"ISSUE_SEQUENCE~",
         ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~",
         ~"IM_ITEM_ISSUE~".~"MFS~",
         ~"IM_ITEM_ISSUE~".~"LOCATION_CODE~",
         ~"IM_ITEM_ISSUE~".~"ITEM_TYPE~",
         ~"IM_ITEM_ISSUE~".~"LINE_CODE~",
         ~"IM_ITEM_ISSUE~".~"WORKSTAGE_CODE~",
         ~"IM_ITEM_ISSUE~".~"ISSUE_DEFICIT~",
         ~"IM_ITEM_ISSUE~".~"ISSUE_QTY~",
         ~"IM_ITEM_ISSUE~".~"ISSUE_STATUS~",
         ~"IM_ITEM_ISSUE~".~"ISSUE_AMT~",
         ~"IM_ITEM_ISSUE~".~"ISSUE_ACCOUNT~",
         ~"IM_ITEM_ISSUE~".~"LINE_TYPE~",
         ~"IM_ITEM_ISSUE~".~"COMMENTS~",
         ~"IM_ITEM_ISSUE~".~"ENTER_BY~",
         ~"IM_ITEM_ISSUE~".~"LAST_MODIFY_DATE~",
         ~"IM_ITEM_ISSUE~".~"LAST_MODIFY_BY~",
         ~"IM_ITEM_ISSUE~".~"ITEM_CODE~",
         ~"ID_ITEM~".~"ITEM_SPEC~",
         ~"ID_ITEM~".~"ITEM_UOM~",
         ~"ID_ITEM~".~"ITEM_NAME~",
         ~"ID_ITEM~".~"LOCATION_ADDRESS~",
         ~"ID_ITEM~".~"VIRTUAL_RECEIPT_YN~",
         ~"IM_ITEM_ISSUE~".~"SUPPLIER_CODE~",
         ~"IM_ITEM_ISSUE~".~"ENTER_DATE~",
         ~"IM_ITEM_ISSUE~".~"INVOICE_NO~",
         ~"IM_ITEM_ISSUE~".~"PARENT_ITEM_CODE~",
         ~"IM_ITEM_ISSUE~".~"MATERIAL_MFS~",
         ~"IM_ITEM_ISSUE~".~"BARCODE~",
		~"IM_ITEM_ISSUE~".~"ISSUE_TYPE~" ,
		~"IM_ITEM_ISSUE~".~"FEEDER_LOCATION_CODE~" ,
		~"IM_ITEM_ISSUE~".~"FEEDER_SHAFT~" ,

		( SELECT MAX(CHECK_DATE) 
              FROM IB_SMT_CHECKHIST 
            WHERE CHECK_DATE >=IM_ITEM_ISSUE.ISSUE_DATE
                AND SCAN_PARTNAME  LIKE IM_ITEM_ISSUE.ITEM_CODE||'-'||IM_ITEM_ISSUE.MATERIAL_MFS||'%' 
         ) CHECK_DATE,
         f_get_mat_max_unit_price_cfm(   ~"IM_ITEM_ISSUE~".~"ITEM_CODE~",   ~"IM_ITEM_ISSUE~".~"LINE_TYPE~",   ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~",  ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" ) UNIT_PRICE ,
	    IM_ITEM_ISSUE.MODEL_NAME
   FROM ~"IM_ITEM_ISSUE~", ~"ID_ITEM~"
 WHERE (~"IM_ITEM_ISSUE~".~"ITEM_CODE~"           = ~"ID_ITEM~".~"ITEM_CODE~")
	AND (~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" = ~"ID_ITEM~".~"ORGANIZATION_ID~")
	AND (~"IM_ITEM_ISSUE~".~"ENTER_DATE~"  >=:arg_dateset  )
     AND (~"IM_ITEM_ISSUE~".~"ENTER_DATE~" <= :arg_dateend)
	AND (~"IM_ITEM_ISSUE~".~"ITEM_CODE~" LIKE :arg_item_code)
	AND (~"IM_ITEM_ISSUE~".~"LINE_CODE~" LIKE :arg_line_code)
	AND (~"IM_ITEM_ISSUE~".~"MATERIAL_MFS~" LIKE :arg_material_mfs)
	AND (~"IM_ITEM_ISSUE~".~"MFS~" LIKE :arg_mfs)
	AND (~"ID_ITEM~".~"ABC_GRADE~" LIKE :arg_abc_grade)
    AND ( ~"IM_ITEM_ISSUE~".~"LOCATION_CODE~" like :arg_location_code ) 
	AND (~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" = :arg_org_id)" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_item_code", string),("arg_line_code", string),("arg_material_mfs", string),("arg_mfs", string),("arg_abc_grade", string),("arg_location_code", string),("arg_org_id", number))  sort="organization_id A location_code A issue_date A issue_sequence A " )
group(level=1 header.height=0 trailer.height=80 by=("organization_id" , "location_code" ) header.color="536870912" trailer.color="65280" )
