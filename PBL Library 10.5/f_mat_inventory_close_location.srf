//
//==============================================
w_progress_popup.f_set_message("UPDATE im_item_receipt SET CLOSE_YN = 'Y' ")

UPDATE im_item_receipt SET CLOSE_YN = 'Y' , CLOSE_DATE = SYSDATE 
//WHERE receipt_date 
//BETWEEN :LVDT_start_date
//         AND :LVDT_end_date
//	     AND ENTER_DATE <= :lvdt_last_date
WHERE ENTER_DATE 
BETWEEN :LVDT_start_date
         AND :LVDT_end_date
         AND organization_id = :gvi_organization_id ;
			
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -40
end if
w_progress_popup.f_set_message("UPDATE im_item_issue SET CLOSE_YN = 'Y' ")

UPDATE im_item_issue
      SET CLOSE_YN = 'Y' , CLOSE_DATE = SYSDATE 
//WHERE issue_date 
//BETWEEN :LVDT_start_date
//        AND :LVDT_end_date
//	   AND ENTER_DATE <= :lvdt_last_date
WHERE ENTER_DATE 
BETWEEN :LVDT_start_date
        AND :LVDT_end_date
        AND organization_id = :gvi_organization_id ;
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -40
end if

w_progress_popup.f_stepit()  // 4-15
phase = 50

w_progress_popup.f_set_message("mm_issue_qty    = f_get_mm_mfs_issue_qty ")

update im_item_inventory_close_mfs 
  set  mm_issue_qty    = f_get_mm_mfs_issue_qty(material_mfs ,location_code, item_code, :as_yyyymm,line_type , '%', :LVDT_start_date , :LVDT_end_date ,  :gvi_organization_id) , 
		mm_mass_qty   = f_get_mm_mfs_issue_qty(material_mfs ,location_code , item_code, :as_yyyymm,line_type, 'M',  :LVDT_start_date , :LVDT_end_date ,:gvi_organization_id) , 
		mm_bad_qty     = f_get_mm_mfs_issue_qty(material_mfs ,location_code , item_code, :as_yyyymm,line_type, 'B',   :LVDT_start_date , :LVDT_end_date ,:gvi_organization_id),
	//	mm_free_qty     = f_get_mm_mfs_issue_qty(material_mfs ,item_code, :as_yyyymm,line_type, 'F',  :gvi_organization_id),
	//	mm_sale_qty     = f_get_mm_mfs_issue_qty(material_mfs ,item_code, :as_yyyymm,line_type, 'S',  :gvi_organization_id),
		mm_extra_qty   = f_get_mm_mfs_issue_qty(material_mfs ,location_code , item_code, :as_yyyymm,line_type, 'E',  :LVDT_start_date , :LVDT_end_date ,:gvi_organization_id) , 
		mm_receipt_qty = f_get_mm_mfs_receipt_qty(material_mfs , location_code , item_code, :as_yyyymm, line_type , :LVDT_start_date , :LVDT_end_date , :gvi_organization_id), 
		mm_receipt_amt = nvl(f_get_mm_mfs_receipt_amt( material_mfs ,location_code , item_code, :as_yyyymm, line_type , :LVDT_start_date , :LVDT_end_date , :gvi_organization_id),0)
where   close_yyyymm = :as_yyyymm	
and      organization_id = :gvi_organization_id ; 
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -50
end if
w_progress_popup.f_stepit()  // 1-15
//================================================
//
