global function integer f_mat_inventory_close_location (string as_yyyymm);string as_last_yyyymm
long phase 
phase = 10 

datetime lvdt_start_date , lvdt_end_date , Lvdt_last_date

open(w_progress_popup)
w_progress_popup.f_set_range( 1 , 13 )
w_progress_popup.f_setstep(1)

SELECT    F_GET_INVENTORY_CLOSE_DATE( :as_yyyymm , 'START' , :gvi_organization_id ) ,
			 F_GET_INVENTORY_CLOSE_DATE( :as_yyyymm , 'END' , :gvi_organization_id  ) ,
			 F_GET_INVENTORY_CLOSE_DATE( :as_yyyymm , 'LAST' , :gvi_organization_id  ) 
    INTO 	:LVDT_START_date , :Lvdt_end_date , :Lvdt_last_date
  FROM DUAL  ;
  
 if f_sql_check_with_msg(string(phase)) < 0 then 
	return -10
 end if  

msg = f_msgbox1(1161 , string(LVDT_START_date)+'  '+string(Lvdt_end_date)+' Inventory Close ')
if msg = 1 then 
else
	return  0
end if

select to_char(add_months(to_date(:as_yyyymm || '01', 'yyyymmdd') , -1) ,'yyyymm')
into    :as_last_yyyymm
from  dual  ; 
 if f_sql_check_with_msg(string(phase)) < 0 then 
	return -10
  end if
  
