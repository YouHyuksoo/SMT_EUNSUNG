//=============================================
w_progress_popup.f_set_message("130")

if as_yyyymm = f_yyyymm()  then 
	
		UPDATE im_item_inventory a
			SET a.inventory_qty = 0
		where organization_id = :gvi_organization_id  ;
		
			if f_sql_check_with_msg(string(phase)) < 0 then 
				return -120
			end if 		
			
		UPDATE im_item_inventory a
			SET a.inventory_qty =
					 (SELECT b.mm_inventory_qty
						 FROM im_item_inventory_close_mfs b
						WHERE a.material_mfs = b.material_mfs	
					         AND a.item_code = b.item_code
						    AND a.line_type = b.line_type				
					         AND a.location_code = b.location_code
						    AND a.organization_id = b.organization_id
						    AND b.close_yyyymm = :as_yyyymm)
		 WHERE ( a.material_mfs , a.item_code, a.line_type , a.location_code,  a.organization_id)
		 IN (
					 SELECT b.material_mfs ,  b.item_code,b.line_type , b.location_code , b.organization_id
						FROM im_item_inventory_close_mfs b
					  WHERE a.material_mfs = b.material_mfs	 
					AND a.item_code = b.item_code
					AND a.line_type = b.line_type			  
					AND a.location_code = b.location_code
					AND a.organization_id = b.organization_id
					AND b.close_yyyymm = :as_yyyymm
						 );
			
			if f_sql_check_with_msg(string(phase)) < 0 then 
				return -120
			end if 
END IF 
