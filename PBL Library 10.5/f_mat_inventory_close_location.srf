w_progress_popup.f_set_message("60")

phase = 60
update im_item_inventory_close_mfs 
set      mm_inventory_qty = nvl(last_inventory_qty ,0)+  (  nvl(mm_receipt_qty,0) - ( nvl(mm_issue_qty ,0) +  nvl(mm_sale_qty ,0) ) ),
          mm_avg_price = abs(decode(( nvl(last_inventory_qty,0) + nvl(mm_receipt_qty,0)) , 0 , 0 , (nvl(last_inventory_amt, 0) + nvl(mm_receipt_amt,0) + decode( line_type , 'M' , nvl(mm_material_cost_amt,0),0))/( nvl(last_inventory_qty,0) + nvl(mm_receipt_qty,0)) )) 
  //	     mm_inventory_amt = ( nvl(last_inventory_qty ,0)+ nvl(mm_receipt_qty,0) - (nvl(mm_issue_qty ,0) + nvl(mm_sale_qty ,0) ) ) *	 DECODE(( nvl(last_inventory_qty,0) + nvl(mm_receipt_qty,0)) , 0 , 0 , (nvl(last_inventory_amt, 0) + nvl(mm_receipt_amt,0) + decode( line_type , 'M' , nvl(mm_material_cost_amt,0),0))/( nvl(last_inventory_qty,0) + nvl(mm_receipt_qty,0)) )
where   close_yyyymm = :as_yyyymm
and      organization_id = :gvi_organization_id ; 


if f_sql_check_with_msg(string(phase)) < 0 then 
	return -60
end if
w_progress_popup.f_set_message("70")
w_progress_popup.f_stepit()  // 1-15
phase = 80
update im_item_inventory_close_mfs a 
set a.mm_avg_price = ( select max(b.mm_avg_price)
									from im_item_inventory_close_mfs b 
									where a.close_yyyymm = b.close_yyyymm 
									and a.item_code = b.item_code 
									and a.line_type = b.line_type
									and a.organization_id = b.organization_id
									and b.mm_avg_price > 0 )
where  a.close_yyyymm = :as_yyyymm
and      a.organization_id = :gvi_organization_id
and a.mm_avg_price = 0 
and ( a.close_yyyymm , a.item_code , a.line_type, a.organization_id  ) 
in ( select b.close_yyyymm , b.item_code , b.line_type , b.organization_id 
		from im_item_inventory_close_mfs b 
									where a.close_yyyymm = b.close_yyyymm 
									and a.item_code = b.item_code 
									and a.line_type = b.line_type
									and a.organization_id = b.organization_id
									and b.mm_avg_price > 0
		) ;

if f_sql_check_with_msg(string(phase)) < 0 then 
	return -60
end if


update im_item_inventory_close_mfs 
set      mm_inventory_amt = mm_inventory_qty * ABS(mm_avg_price )
where   close_yyyymm = :as_yyyymm
and      organization_id = :gvi_organization_id ; 
if f_sql_check_with_msg(string(phase)) < 0 then 
	return -70
end if

w_progress_popup.f_set_message("80")

UPDATE im_item_inventory_close_mfs
   SET mm_issue_amt = mm_issue_qty * mm_avg_price,
          mm_mass_amt = mm_mass_qty * mm_avg_price,
          mm_bad_amt = mm_bad_qty * mm_avg_price,
          mm_free_amt = mm_free_qty * mm_avg_price,
          mm_sale_amt = mm_sale_qty * mm_avg_price,
         mm_extra_amt = mm_extra_qty * mm_avg_price
 WHERE     close_yyyymm = :as_yyyymm
       AND organization_id = :gvi_organization_id;

if f_sql_check_with_msg(string(phase)) < 0 then 
	return -80
end if 
w_progress_popup.f_stepit()  // 1-15
