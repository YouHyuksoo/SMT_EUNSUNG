w_progress_popup.f_set_message("120")
INSERT INTO im_item_inventory_close
            (close_yyyymm,
             item_code,
             line_type,location_code,
             organization_id,
             last_avg_price,
             last_inventory_amt,
             last_inventory_qty,
             mm_mass_qty,
             mm_mass_amt,
             mm_issue_qty,
             mm_issue_amt,
             mm_receipt_qty,
             mm_material_cost_amt,
             mm_receipt_amt,
             mm_bad_qty,
             mm_bad_amt,
             mm_extra_qty,
             mm_extra_amt,
             mm_avg_price,
             mm_inventory_qty,
             mm_free_amt,
             mm_inventory_amt,
             mm_sale_amt,
             enter_by,
             enter_date,
             last_modify_by,
             last_modify_date,
             mm_free_qty,
             mm_sale_qty
            )
   SELECT   close_yyyymm,
            item_code,
            line_type,location_code,
            organization_id,
           abs(DECODE(
               SUM(last_inventory_qty), 0, AVG(last_avg_price),
               SUM(last_inventory_amt) / SUM(last_inventory_qty)
            )),
            SUM(last_inventory_amt),
            SUM(last_inventory_qty),
            SUM(mm_mass_qty),
            SUM(mm_mass_amt),
            SUM(mm_issue_qty),
            SUM(mm_issue_amt),
            SUM(mm_receipt_qty),
            SUM(mm_material_cost_amt),
            SUM(mm_receipt_amt),
            SUM(mm_bad_qty),
            SUM(mm_bad_amt),
            SUM(mm_extra_qty),
            SUM(mm_extra_amt),
           abs( DECODE(
               SUM(last_inventory_qty + mm_receipt_qty), 0, 0,
               SUM(last_inventory_amt + mm_receipt_amt)
               / SUM(last_inventory_qty + mm_receipt_qty)
            )),
            SUM(mm_inventory_qty),
            SUM(mm_free_amt),
            SUM(mm_inventory_amt),
            SUM(mm_sale_amt),
            MAX(enter_by),
            MAX(enter_date),
            MAX(last_modify_by),
            MAX(last_modify_date),
            SUM(mm_free_qty),
            SUM(mm_sale_qty)
   FROM     im_item_inventory_close_mfs
   WHERE    close_yyyymm = :as_yyyymm
     AND organization_id = :gvi_organization_id
   GROUP BY close_yyyymm,
                  item_code,
                  line_type,
			     location_code,
                  organization_id;


	if f_sql_check_with_msg(string(phase)) < 0 then 
		return -130
	end if 
w_progress_popup.f_stepit()  // 1-15
phase = 130
