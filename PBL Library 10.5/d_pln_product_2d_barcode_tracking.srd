 retrieve="select serial_no,
       F_GET_PID_RUNNO( serial_no, organization_id )       RUN_NO,
       F_GET_PID_BARCODE( serial_no, organization_id )    BARCODE,
       F_GET_PID_MK( serial_no, organization_id )             MK,
       F_GET_PID_SP( serial_no, organization_id )             SP,
       F_GET_PID_SPI( serial_no, organization_id )            SPI,
       F_GET_PID_SMD_AOI( serial_no, organization_id )   SMD_AOI,
       F_GET_PID_ICT( serial_no, organization_id )            ICT,
       F_GET_PID_IMD_AOI( serial_no, organization_id )    IMD_AOI,
       F_GET_PID_IMD_AOI1( serial_no, organization_id )    IMD_AOI1,
       F_GET_PID_IMD_AOI2( serial_no, organization_id )    IMD_AOI2,
       F_GET_PID_RT( serial_no, organization_id )            RT,
       F_GET_PID_RW( serial_no, organization_id )           RW,
       F_GET_PID_WORKQC( serial_no, organization_id )   WORK_QC,
       F_GET_PID_SOLDER( serial_no, organization_id )     SOLDER,
       F_GET_PID_JIG( serial_no, organization_id )            JIG,
       F_GET_PID_SAMPLE( serial_no, organization_id )     SAMPLE,
       F_GET_PID_REEL_MAT( serial_no, organization_id ) REEL_MAT,
       F_GET_PID_PCB_MAT( serial_no, organization_id )  PCB_MAT 
  from ip_product_2d_barcode
