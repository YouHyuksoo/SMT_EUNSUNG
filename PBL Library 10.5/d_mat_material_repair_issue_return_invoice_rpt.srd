 column=(type=char(3) updatewhereclause=yes name=item_uom dbname="id_item.item_uom" )
 column=(type=char(1000) updatewhereclause=yes name=comments dbname="im_item_repair_issue.comments" )
 retrieve="  SELECT ~"IM_ITEM_REPAIR_ISSUE~".~"ISSUE_DATE~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"ISSUE_SEQUENCE~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"MFS~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"ITEM_CODE~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"ITEM_TYPE~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"LINE_TYPE~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"LINE_CODE~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"WORKSTAGE_CODE~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"ISSUE_QTY~",   
         ~"ID_ITEM_A~".~"ITEM_NAME~",   
         ~"ID_ITEM_A~".~"ITEM_SPEC~",   
         ~"ID_ITEM_A~".~"ITEM_UOM~",   
         ~"IM_ITEM_REPAIR_ISSUE~".~"COMMENTS~"  
    FROM ~"IM_ITEM_REPAIR_ISSUE~",   
         ~"ID_ITEM~" ~"ID_ITEM_A~"  
   WHERE ( im_item_repair_issue.item_code = ID_ITEM_A.item_code (+)) and  
         ( im_item_repair_issue.organization_id = ID_ITEM_A.organization_id (+)) and  
    ~"IM_ITEM_REPAIR_ISSUE~".~"ISSUE_DATE~" = :ARG_ISSUE_DATE AND
         ~"IM_ITEM_REPAIR_ISSUE~".~"ISSUE_SEQUENCE~" = :ARG_ISSUE_SEQUENCE AND


         ( ~"IM_ITEM_REPAIR_ISSUE~".~"ISSUE_STATUS~" = 'N' ) AND  
         ( ~"IM_ITEM_REPAIR_ISSUE~".~"ISSUE_DEFICIT~" = '4' ) AND  
         ( ~"IM_ITEM_REPAIR_ISSUE~".~"ORGANIZATION_ID~" = :arg_org )    
" arguments=(("arg_issue_date", datetime),("arg_issue_sequence", number),("arg_org", number))  sort="organization_id A issue_date A issue_sequence A " )
