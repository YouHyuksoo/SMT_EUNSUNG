global function integer f_config_setup ();
//============================================
// $$HEX16$$70b374c7c0d0200008c7c4b3b0c62000c0d074c7c0d230bcbdacc9c0c0bcbdac$$ENDHEX$$
//============================================
Double lvd_DW_TITLE_BG_COLOR
String lvs_dw_bolder_style , LVS_DW_BG_COLOR

SELECT MAX(DW_TITLE_BG_COLOR) , MAX(DW_BOLDER_STYLE) , MAX(DW_BG_COLOR) , NVL( MAX(LOCAL_CURRENCY) , 'CNY') ,
