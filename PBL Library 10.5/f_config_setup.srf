		NVL(MAX(PROD_SALE_PRICE_AUTO_CONFIRM),'N'),  //$$HEX11$$1cc888d49ccd58d5e8b200ac90c7d9b32000b9c278c7$$ENDHEX$$
		NVL(MAX(SHIPPING_INVOICE_TYPE),'A4'),  //$$HEX10$$1cc888d49ccd58d585ba38c11cc191c5ddc22000$$ENDHEX$$A4 , DOT , ALL
