		NVL(MAX(MSL_TIME_CHECK_YN) , 'Y') , //$$HEX4$$9ccde0acdcc22000$$ENDHEX$$MSL $$HEX11$$dcc219ac200008cdfcac20002000ecc580bd20002000$$ENDHEX$$
		NVL(MAX(LIFE_CYCLE_CHECK_YN) , 'N'), //$$HEX4$$9ccde0acdcc22000$$ENDHEX$$MSL $$HEX11$$dcc219ac200008cdfcac20002000ecc580bd20002000$$ENDHEX$$
		NVL(MAX(ISSUE_BY_FEEDER) , 'N') , //$$HEX9$$9ccde0acdcc220003cd554b3c0c915c82000$$ENDHEX$$
