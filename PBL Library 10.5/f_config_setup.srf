		NVL(MAX(MAT_RECEIPT_RETURN_AUTO_PO),'N'),  //$$HEX15$$d0c6acc7ccb8200085c7e0ac18bc88d4dcc2200090c7d9b31cbcfcc82000$$ENDHEX$$
