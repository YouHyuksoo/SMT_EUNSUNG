		NVL(MAX(SHIPPING_AMT_PRECISION),'2'), //$$HEX12$$00952e55d1919d980f5c7065b9700e548476be7c6e78a65e$$ENDHEX$$
		NVL(MAX(PRODUCT_MATERIAL_COST),'B'),//$$HEX10$$a74ec1546551935ed1919d98a18b977bb9650f5f$$ENDHEX$$
		NVL(MAX(BARCODE_AUTO_PRINT),'N') ,//$$HEX6$$ea81a8525362705361670178$$ENDHEX$$
		NVL(MAX(SHOW_ITEM_IMAGE),'N'), //$$HEX7$$88d4a9ba74c7f8bbc0c95cd4dcc2$$ENDHEX$$
		NVL(MAX(SHOW_ITEM_SEARCH),'N'),//$$HEX8$$88d4a9ba74c7f8bbc0c95cd4dcc20900$$ENDHEX$$
		NVL(MAX(PAID_RECEIPT_AUTO_RI),'N'), //$$HEX14$$09677f50d4595862a052e55d6551935eea81a8526551935efa51935e$$ENDHEX$$
		NVL(MAX(ITEM_INVOICE_AUTO_CONFIRM),'N') ,
		NVL(MAX(DOWNLOAD_DOCUMENT) , 'Y' ) ,
		NVL(MAX(USE_SALE_CHARGE_CONDITION) , 'N' ) ,
		NVL(MAX(SHOW_MACHINE_IMAGE) , 'N' ),
		NVL(MAX(PRODUCT_AUTO_SHIPPING_PLAN) , 'N' ) ,
		NVL(MAX(PRODUCT_PLAN_FROM_SALE_PLAN) , 'N' ) ,
		NVL(MAX(SHOW_MOLD_IMAGE) , 'N' ) ,
		NVL(MAX(SHOW_UNIT_PRICE_ERROR_MSG) , 'Y' ) ,
		NVL(MAX(MATERIAL_MFS_REPLACE_LOCATION) , 'N' ) ,
		NVL(MAX(MFS_REPLACE_LOCATION) , 'N' ) ,		
		NVL(MAX(WORK_ORDER_BY_MFS) , 'N' ) ,				
		NVL(MAX(WORK_BOARD_TYPE) , '1' ) ,
		NVL(MAX(MATERIAL_RECEIPT_AUTO_CONFIRM) , 'N' ) ,
		NVL(MAX(ASSEMBLY_RESULT_RECEIPT_WH) , 'Y' ), 		
		NVL(MAX(INVOICE_OPEN_BY_SALE_PLAN) , 'Y' ),
		NVL(MAX(SHOW_CART_IMAGE) , 'N' ) ,
