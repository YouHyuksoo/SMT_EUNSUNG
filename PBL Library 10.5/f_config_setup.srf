		NVL(MAX(DEPARTURE_SUBSITUTE_ARRIVAL),'N' ) ,
		NVL(MAX(TRANSFER_INVOICE_TYPE),'A4') , 
		
		NVL(MAX(PRODUCT_RECEIPT_AUTO_CONFIRM),'N' ) , 			
		NVL(MAX(PRODUCT_SHIPPING_AUTO_CONFIRM),'N' ) , 
