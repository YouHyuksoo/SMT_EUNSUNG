FROM 
(
SELECT
CASE CONFIG_NAME WHEN 'DW_TITLE_BG_COLOR' THEN CONFIG_VALUE ELSE NULL END DW_TITLE_BG_COLOR ,
CASE CONFIG_NAME WHEN 'DW_BOLDER_STYLE' THEN CONFIG_VALUE ELSE NULL END DW_BOLDER_STYLE ,
