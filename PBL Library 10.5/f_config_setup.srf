		NVL(MAX(LOT_DIVIDE_PRINT_LG_LABEL) , 'N'), // $$HEX13$$6fb8b8d2200084bd60d5dcc220007cb7a8bc20001cbc89d52000$$ENDHEX$$
		NVL(MAX(MSL_LABEL_PRINT) , 'N'), // $$HEX9$$68d5b5c220007cb7a8bc20001cbc89d52000$$ENDHEX$$($$HEX18$$30ae74c87cb7a8bcfcac2000f0c58dc13cc75cb8200068d5b5c27cb7a8bc20001cbc89d5$$ENDHEX$$)
		NVL(MAX(LONG_TERM_INVENTORY) , 'N') ,// $$HEX7$$a5c730aeacc7e0acb4cc6cd02000$$ENDHEX$$($$HEX7$$5ccd85c885c7e0ac7cc774c72000$$ENDHEX$$1$$HEX13$$44b1c0c99cb0200090c7acc794b220009ccde0ac2000bbba68d5$$ENDHEX$$)
		NVL( MAX(START_URL) , 'www.jisungsolution.co.kr') 

		
		
		
		
