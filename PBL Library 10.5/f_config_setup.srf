		NVL(MAX(USE_MATERIAL_MFS),'Y'),  //$$HEX9$$d0c6acc7ccb820006fb8b8d200adacb968d5$$ENDHEX$$
		NVL(MAX(PRODUCT_ACTUAL_OVER_PLAN_QTY),'Y'),  //$$HEX20$$1cc888d4ddc0b0c0e4c201c874c72000c4ac8dd644c7200008cdfcac60d518c2200088c74cc72000$$ENDHEX$$
		NVL(MAX(ASSEMBLY_ACTUAL_OVER_PLAN_QTY),'Y'),  //$$HEX23$$18bc1cc888d4ddc0b0c0e4c201c874c72000c4ac8dd644c7200008cdfcac60d518c2200088c74cc7200009000900$$ENDHEX$$
		NVL(MAX(ASSEMBLY_ACTUAL_AUTO_TRANS),'Y'),  //$$HEX14$$18bc1cc888d4ddc0b0c0e4c201c890c7d9b3200078c718c278c7c4ac$$ENDHEX$$
		NVL(MAX(PRODUCT_SHIPPING_PLAN_OQC_YN),'N'),  //$$HEX10$$9ccd58d504c8200088d4c8c9200080acacc068d5$$ENDHEX$$. 
		NVL(MAX(MATERIAL_RECYCLE_AUTO_ISSUE),'N') , //$$HEX10$$9ccd58d504c8200088d4c8c9200080acacc068d5$$ENDHEX$$. 		
		NVL(MAX(PRODUCT_MFS_AUTO_SET),'N'),  //$$HEX9$$1cc888bc200090c7d9b32000ddc031c12000$$ENDHEX$$, $$HEX23$$74c7d9b33cbbd9b32000d0c51cc12000ddc0b0c0c4ac8dd63cc75cb8200074c7d9b3dcc2200038cce0ac68d52000$$ENDHEX$$. 				
		NVL(MAX(FREE_SUB_BOM_EXP_ERR_IGNORE),'N'),  //$$HEX8$$34bbc1c0acc009ae85c7e0acdcc22000$$ENDHEX$$bom $$HEX8$$04c81cac24c658b9200034bbdcc22000$$ENDHEX$$
		NVL(MAX(WQC_REQUEST_INVENTORY_MOVE),'N'),  //$$HEX15$$f5ac15c880acacc0e0c2adccdcc22000acc7e0ac200074c7d9b309000900$$ENDHEX$$
		NVL(MAX(LQC_AUTO_REQUEST),'N'),  //LQC $$HEX10$$88d4c8c980acacc0200090c7d9b32000e0c2adcc$$ENDHEX$$
		NVL(MAX(OQC_AUTO_REQUEST),'N'),  //OQC $$HEX10$$88d4c8c980acacc0200090c7d9b32000e0c2adcc$$ENDHEX$$
		NVL(MAX(ALLOW_WS_MINUS_INVENTORY) , 'Y' ), //$$HEX10$$f5ac15c84cc718c2acc7e0ac200078c715c82000$$ENDHEX$$
