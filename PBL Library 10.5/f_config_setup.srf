		NVL(MAX(WORKODER_GEN_BY_PROD_PLAN),'N' ),  //$$HEX24$$1cc888d491c7c5c5c0c9dcc2dcc22000a8bae0b420009ccde0ac08c615c844c7200090c7d9b33cc75cb82000ccb9ecb4$$ENDHEX$$
		NVL(MAX(ASSEMBLY_OQC_AUTO_PASS),'N' ),  //$$HEX4$$18bc1cc888d42000$$ENDHEX$$OQC $$HEX5$$90c7d9b369d5a9ac2000$$ENDHEX$$
		
