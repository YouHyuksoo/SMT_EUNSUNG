CASE CONFIG_NAME WHEN 'BARCODE_AUTO_PRINT' THEN CONFIG_VALUE ELSE NULL END BARCODE_AUTO_PRINT ,
CASE CONFIG_NAME WHEN 'SHOW_ITEM_IMAGE' THEN CONFIG_VALUE ELSE NULL END SHOW_ITEM_IMAGE ,
CASE CONFIG_NAME WHEN 'SHOW_ITEM_SEARCH' THEN CONFIG_VALUE ELSE NULL END SHOW_ITEM_SEARCH,
CASE CONFIG_NAME WHEN 'PAID_RECEIPT_AUTO_RI' THEN CONFIG_VALUE ELSE NULL END PAID_RECEIPT_AUTO_RI,
CASE CONFIG_NAME WHEN 'ITEM_INVOICE_AUTO_CONFIRM' THEN CONFIG_VALUE ELSE NULL END ITEM_INVOICE_AUTO_CONFIRM,
CASE CONFIG_NAME WHEN 'DOWNLOAD_DOCUMENT' THEN CONFIG_VALUE ELSE NULL END DOWNLOAD_DOCUMENT,
CASE CONFIG_NAME WHEN 'USE_SALE_CHARGE_CONDITION' THEN CONFIG_VALUE ELSE NULL END USE_SALE_CHARGE_CONDITION,
CASE CONFIG_NAME WHEN 'SHOW_MACHINE_IMAGE' THEN CONFIG_VALUE ELSE NULL END SHOW_MACHINE_IMAGE,
CASE CONFIG_NAME WHEN 'PRODUCT_AUTO_SHIPPING_PLAN' THEN CONFIG_VALUE ELSE NULL END PRODUCT_AUTO_SHIPPING_PLAN,
CASE CONFIG_NAME WHEN 'PRODUCT_PLAN_FROM_SALE_PLAN' THEN CONFIG_VALUE ELSE NULL END PRODUCT_PLAN_FROM_SALE_PLAN,
CASE CONFIG_NAME WHEN 'SHOW_MOLD_IMAGE' THEN CONFIG_VALUE ELSE NULL END SHOW_MOLD_IMAGE,
CASE CONFIG_NAME WHEN 'SHOW_UNIT_PRICE_ERROR_MSG' THEN CONFIG_VALUE ELSE NULL END SHOW_UNIT_PRICE_ERROR_MSG,
CASE CONFIG_NAME WHEN 'MATERIAL_MFS_REPLACE_LOCATION' THEN CONFIG_VALUE ELSE NULL END MATERIAL_MFS_REPLACE_LOCATION,
CASE CONFIG_NAME WHEN 'MFS_REPLACE_LOCATION' THEN CONFIG_VALUE ELSE NULL END MFS_REPLACE_LOCATION,			
CASE CONFIG_NAME WHEN 'WORK_ORDER_BY_MFS' THEN CONFIG_VALUE ELSE NULL END WORK_ORDER_BY_MFS,
CASE CONFIG_NAME WHEN 'WORK_BOARD_TYPE' THEN CONFIG_VALUE ELSE NULL END WORK_BOARD_TYPE,
CASE CONFIG_NAME WHEN 'MATERIAL_RECEIPT_AUTO_CONFIRM' THEN CONFIG_VALUE ELSE NULL END MATERIAL_RECEIPT_AUTO_CONFIRM,
CASE CONFIG_NAME WHEN 'ASSEMBLY_RESULT_RECEIPT_WH' THEN CONFIG_VALUE ELSE NULL END ASSEMBLY_RESULT_RECEIPT_WH,
CASE CONFIG_NAME WHEN 'INVOICE_OPEN_BY_SALE_PLAN' THEN CONFIG_VALUE ELSE NULL END INVOICE_OPEN_BY_SALE_PLAN,
CASE CONFIG_NAME WHEN 'SHOW_CART_IMAGE' THEN CONFIG_VALUE ELSE NULL END SHOW_CART_IMAGE ,
CASE CONFIG_NAME WHEN 'PRODUCT_ST_BY_ITEM' THEN CONFIG_VALUE ELSE NULL END PRODUCT_ST_BY_ITEM ,
CASE CONFIG_NAME WHEN 'UNIT_PRICE_CHECK_YN_4_PO' THEN CONFIG_VALUE ELSE NULL END UNIT_PRICE_CHECK_YN_4_PO	,
	
CASE CONFIG_NAME WHEN 'LABEL_TYPE' THEN CONFIG_VALUE ELSE NULL END LABEL_TYPE	,
CASE CONFIG_NAME WHEN 'MATERIAL_FIFO_YN' THEN CONFIG_VALUE ELSE NULL END MATERIAL_FIFO_YN	,
CASE CONFIG_NAME WHEN 'REEL_DIVIDE_COMPARE_YN' THEN CONFIG_VALUE ELSE NULL END REEL_DIVIDE_COMPARE_YN,
CASE CONFIG_NAME WHEN 'USE_GMES_YN' THEN CONFIG_VALUE ELSE NULL END USE_GMES_YN			,
CASE CONFIG_NAME WHEN 'USE_SIMPLE_MODEL_MASTER' THEN CONFIG_VALUE ELSE NULL END USE_SIMPLE_MODEL_MASTER,
CASE CONFIG_NAME WHEN 'SLIP_PROCESS' THEN CONFIG_VALUE ELSE NULL END SLIP_PROCESS,
CASE CONFIG_NAME WHEN 'USE_MSL_LEVEL_VALUE' THEN CONFIG_VALUE ELSE NULL END USE_MSL_LEVEL_VALUE	,
CASE CONFIG_NAME WHEN 'RECEIPT_LOT_CHECK_YN' THEN CONFIG_VALUE ELSE NULL END 		RECEIPT_LOT_CHECK_YN 	,
CASE CONFIG_NAME WHEN 'MATERIAL_ISSUE_COMPARE_YN' THEN CONFIG_VALUE ELSE NULL END 		MATERIAL_ISSUE_COMPARE_YN ,
CASE CONFIG_NAME WHEN 'MSL_TIME_CHECK_YN' THEN CONFIG_VALUE ELSE NULL END 		MSL_TIME_CHECK_YN,
CASE CONFIG_NAME WHEN 'LIFE_CYCLE_CHECK_YN' THEN CONFIG_VALUE ELSE NULL END 		LIFE_CYCLE_CHECK_YN,
CASE CONFIG_NAME WHEN 'ISSUE_BY_FEEDER' THEN CONFIG_VALUE ELSE NULL END 		ISSUE_BY_FEEDER ,
CASE CONFIG_NAME WHEN 'USE_TRAY_DIVIDE' THEN CONFIG_VALUE ELSE NULL END 		USE_TRAY_DIVIDE ,
CASE CONFIG_NAME WHEN 'LOT_DIVIDE_PRINT_LG_LABEL' THEN CONFIG_VALUE ELSE NULL END 		LOT_DIVIDE_PRINT_LG_LABEL,
CASE CONFIG_NAME WHEN 'MSL_LABEL_PRINT' THEN CONFIG_VALUE ELSE NULL END 		MSL_LABEL_PRINT	,
CASE CONFIG_NAME WHEN 'LONG_TERM_INVENTORY' THEN CONFIG_VALUE ELSE NULL END 		LONG_TERM_INVENTORY ,
CASE CONFIG_NAME WHEN 'START_URL' THEN CONFIG_VALUE ELSE NULL END 		START_URL
	
FROM ISYS_CONFIG
WHERE ORGANIZATION_ID = :GVI_ORGANIZATION_ID  
     AND NVL(USE_YN ,'N') = 'Y'
)  ;

  IF F_SQL_CHECK() < 0 THEN  
	  RETURN -1
  END IF

  IF SQLCA.SQLCODE = 100 THEN 
	Gvs_system_access_yn = 'N'
  ELSE
	
	 if isnull(lvd_DW_TITLE_BG_COLOR) then 
		Gvd_title_background = -1
 	 else
		 Gvd_title_background = lvd_DW_TITLE_BG_COLOR
	 end if
	 
	 if isnull(lvs_dw_bolder_style) then 
 	 else	 
		 Gvs_border_style     = lvs_dw_bolder_style
    end if
	 
	 if isnull(lvs_DW_BG_COLOR) then 
		Gvs_datawindow_color = ''
	 else
		 Gvs_datawindow_color = LVS_DW_BG_COLOR
  	 end if
	 

  END IF 
  RETURN 0

