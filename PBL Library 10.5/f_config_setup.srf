		NVL(MAX(ASSEMBLY_LQC_AUTO_PASS),'N' ) , //$$HEX4$$18bc1cc888d42000$$ENDHEX$$LQC $$HEX16$$90c7d9b3200069d5a9ac20000900090020002000200009000900200020002000$$ENDHEX$$
		NVL(MAX(ARRIVAL_EXCESS_ORDER_QTY),'N' ),  //$$HEX13$$fcc838bb18c2c9b7200008cdfcac2000c4b329cc00aca5b22000$$ENDHEX$$
