release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no grid.lines=0 )
header(height=140 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(100) updatewhereclause=yes name=item_code dbname="id_item.item_code" dbalias=".item_code" )
 column=(type=char(300) updatewhereclause=yes name=item_name dbname="id_item.item_name" dbalias="B.item_name" )
 column=(type=char(300) updatewhereclause=yes name=item_spec dbname="id_item.item_spec" dbalias="B.item_spec" )
 column=(type=char(30) updatewhereclause=yes name=a_loc dbname="id_item.a_loc" dbalias=".a_loc" )
 column=(type=char(30) updatewhereclause=yes name=b_loc dbname="id_item.b_loc" dbalias=".b_loc" )
 column=(type=char(2) updatewhereclause=yes name=diff_check dbname="diff_check" )
 column=(type=char(1) updatewhereclause=yes name=model_name dbname="id_item.model_name" dbalias=".model_name" )
 column=(type=char(1) updatewhereclause=yes name=com_model_name dbname="id_item.com_model_name" dbalias=".com_model_name" )
 retrieve="SELECT  a.item_code  item_code ,
			b.item_name item_name , 
             b.item_spec item_spec ,
			a.a_loc a_loc , a.b_loc b_loc ,   
             decode( a.a_loc , a.b_loc , 'OK' , 'X' )  DIFF_CHECK ,  
             :arg_model_name model_name ,
             :arg_comp_model_name com_model_name

  FROM   (  SELECT
						    item_code , 
						    MAX (nvl(a_loc,'*')) a_loc, 
						    MAX (nvl(b_loc,'*')) b_loc

                   FROM   (
							SELECT   a.item_code  item_code , 
										 a.location_code  a_loc, 
										 '' b_loc
								FROM   ib_product_plandata a
								WHERE a.line_code  = :arg_line_code
								AND a.model_name    = :arg_model_name
								AND a.pcb_item            = :arg_topbot
								AND a.organization_id = :arg_org

								UNION 

							  SELECT b.item_code item_code, 
									      '' a_loc, 
										   b.location_code b_loc
								FROM   ib_product_plandata b
								WHERE   b.line_code   = :arg_comp_line_code
								AND b.model_name     = :arg_comp_model_name
								AND b.pcb_item            = :arg_topbot
								AND b.organization_id = :arg_org
                                )
          GROUP BY   item_code )  A , id_item B
 WHERE A.ITEM_CODE = B.ITEM_CODE(+)
     AND A.A_LOC <> '*' AND  A.B_LOC <> '*' 
" arguments=(("ARG_LINE_CODE", string),("ARG_MODEL_NAME", string),("ARG_COMP_LINE_CODE", string),("ARG_COMP_MODEL_NAME", string),("ARG_TOPBOT", string),("ARG_ORG", number))  sort="diff_check A item_code A " )
group(level=1 header.height=0 trailer.height=72 by=("diff_check" ) header.color="536870912" trailer.color="65280" )
