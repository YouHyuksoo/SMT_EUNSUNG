 column=(type=char(30) update=yes updatewhereclause=yes name=machine_code dbname="im_item_issue.machine_code" )
 column=(type=char(50) update=yes updatewhereclause=yes name=invoice_no dbname="im_item_issue.invoice_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=made_by dbname="im_item_issue.made_by" )
 column=(type=char(20) update=yes updatewhereclause=yes name=parent_item_code dbname="im_item_issue.parent_item_code" )
 column=(type=char(30) update=yes updatewhereclause=yes name=material_mfs dbname="im_item_issue.material_mfs" )
 retrieve="  SELECT ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_SEQUENCE~",   
         ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~",   
         ~"IM_ITEM_ISSUE~".~"MFS~",   
         ~"IM_ITEM_ISSUE~".~"LOCATION_CODE~",   
         ~"IM_ITEM_ISSUE~".~"ITEM_TYPE~",   
         ~"IM_ITEM_ISSUE~".~"LINE_CODE~",   
         ~"IM_ITEM_ISSUE~".~"WORKSTAGE_CODE~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_DEFICIT~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_QTY~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_STATUS~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_AMT~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_ACCOUNT~",   
         ~"IM_ITEM_ISSUE~".~"LINE_TYPE~",   
         ~"IM_ITEM_ISSUE~".~"COMMENTS~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_PRICE~",   
         ~"IM_ITEM_ISSUE~".~"ENTER_DATE~",   
         ~"IM_ITEM_ISSUE~".~"ENTER_BY~",   
         ~"IM_ITEM_ISSUE~".~"LAST_MODIFY_DATE~",   
         ~"IM_ITEM_ISSUE~".~"LAST_MODIFY_BY~",   
         ~"IM_ITEM_ISSUE~".~"ITEM_CODE~",   
         ~"IM_ITEM_ISSUE~".~"SUPPLIER_CODE~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         ~"IM_ITEM_ISSUE~".~"WORK_ORDER_NO~",   
         ~"IM_ITEM_ISSUE~".~"ISSUE_TYPE~",   
         ~"ID_ITEM~".~"ITEM_UOM~",   
         ~"IM_ITEM_ISSUE~".~"MACHINE_CODE~",   
         ~"IM_ITEM_ISSUE~".~"INVOICE_NO~",   
         ~"IM_ITEM_ISSUE~".~"MADE_BY~",   
         ~"IM_ITEM_ISSUE~".~"PARENT_ITEM_CODE~",   
         ~"IM_ITEM_ISSUE~".~"MATERIAL_MFS~"  
    FROM ~"IM_ITEM_ISSUE~",   
         ~"ID_ITEM~"  
   WHERE ( id_item.item_code = im_item_issue.item_code (+)) and  
         ( id_item.organization_id = im_item_issue.organization_id (+)) and  
         ( ( ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~" >= :arg_dateset ) AND  
         ( ~"IM_ITEM_ISSUE~".~"ISSUE_DATE~" < :arg_dateend +1 ) AND  
         ( ~"IM_ITEM_ISSUE~".~"LINE_CODE~" like :arg_line_code ) AND  
         ( ~"IM_ITEM_ISSUE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IM_ITEM_ISSUE~".~"INVOICE_NO~" like :arg_invoice_no ) AND  
	    ( ~"IM_ITEM_ISSUE~".~"ISSUE_TYPE~" like :arg_issue_type ) AND  		
         ( ~"IM_ITEM_ISSUE~".~"MATERIAL_MFS~" like :arg_material_mfs ) AND  
         ( ~"IM_ITEM_ISSUE~".~"ISSUE_DEFICIT~" = '4' ) AND  
         ( ~"IM_ITEM_ISSUE~".~"ISSUE_STATUS~" <> 'C' ) AND  
         ( ~"IM_ITEM_ISSUE~".~"ORGANIZATION_ID~" = :arg_org ) )    
" arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_item_code", string),("arg_invoice_no", string),("arg_material_mfs", string),("arg_issue_type", string),("arg_org", number))  sort="issue_type A issue_date D issue_sequence D " )
