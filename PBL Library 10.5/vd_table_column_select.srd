table(column=(type=char(30) updatewhereclause=yes name=column_name dbname="user_tab_columns.column_name" )
 column=(type=char(106) updatewhereclause=yes name=data_type dbname="user_tab_columns.data_type" )
 column=(type=char(100) updatewhereclause=yes name=column_desc dbname="column_desc" )
 retrieve="  SELECT ~"USER_TAB_COLUMNS~".~"COLUMN_NAME~",   
               ~"USER_TAB_COLUMNS~".~"DATA_TYPE~",   
                DECODE( :ARG_LANGUAGE , 'K' , WORD_KOR , 'E' , WORD_ENG , WORD_LOCAL ) COLUMN_DESC
    FROM ~"USER_TAB_COLUMNS~",~"ISYS_WORD_DICTIONARY~"  
   WHERE    ( user_tab_columns.column_name = isys_word_dictionary.column_name (+)) and         
                   ( ~"USER_TAB_COLUMNS~".~"TABLE_NAME~" = :ARG_TABLE_NAME )" arguments=(("ARG_LANGUAGE", string),("ARG_TABLE_NAME", string)) )
