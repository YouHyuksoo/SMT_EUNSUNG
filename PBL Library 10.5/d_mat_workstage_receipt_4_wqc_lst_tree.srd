 column=(type=char(1) updatewhereclause=yes name=check_yn dbname="check_yn" values="	Y/	N" )
 column=(type=char(37) updatewhereclause=yes name=rowid dbname="im_item_workstage_receipt.rowid" )
 retrieve="  SELECT A.RECEIPT_DATE RECEIPT_DATE,   A.RECEIPT_SEQUENCE RECEIPT_SEQUENCE ,
         A.MFS,   
         A.ORGANIZATION_ID,   
         A.ITEM_CODE,   
         A.LINE_TYPE,   
         A.RECEIPT_TYPE,   
         A.RECEIPT_QTY RECEIPT_QTY,   
         A.LINE_CODE,   
         A.RECEIPT_STATUS,   
         A.WORKSTAGE_CODE,   
         A.MACHINE_CODE,   
         A.RECEIPT_ACCOUNT,   
	  A.INVOICE_NO,
         ID_ITEM.ITEM_NAME,   
         ID_ITEM.ITEM_SPEC,   
         ID_ITEM.ITEM_UOM,   
         ID_ITEM.ITEM_DIVISION ,
         ID_ITEM.DRAWING_NO ,
	   0 REQUEST_QTY ,
	   'N' CHECK_YN ,
         A.ROWID
    FROM IM_ITEM_WORKSTAGE_RECEIPT A,   
         ID_ITEM  
   WHERE 
         ( A.ITEM_CODE = ID_ITEM.ITEM_CODE ) and  
         ( A.ORGANIZATION_ID = ID_ITEM.ORGANIZATION_ID ) and  
         ( ( A.RECEIPT_DATE >= :arg_dateset ) AND  
         ( A.RECEIPT_DATE <= :arg_dateend ) AND  
         ( A.LINE_CODE like :arg_line_code ) AND  
         ( A.WORKSTAGE_CODE like :arg_workstage_code ) AND  
         ( A.MFS like :arg_mfs ) AND  
         ( A.ITEM_CODE like :arg_item_code ) AND  
         ( ID_ITEM.ITEM_DIVISION NOT IN ( 'F' , 'G' )) AND  
         ( A.RECEIPT_STATUS = 'N' ) AND
         ( A.ORGANIZATION_ID = :arg_org_id ) )    " arguments=(("arg_dateset", datetime),("arg_dateend", datetime),("arg_line_code", string),("arg_workstage_code", string),("arg_mfs", string),("arg_item_code", string),("arg_org_id", number))  sort="organization_id A item_division A workstage_code A mfs A item_code A " )
