table(column=(type=char(30) updatewhereclause=yes name=machine_code dbname="imcn_machine.machine_code" dbalias=".machine_code" )
 column=(type=char(100) updatewhereclause=yes name=machine_name dbname="imcn_machine.machine_name" dbalias=".machine_name" )
 column=(type=number updatewhereclause=yes name=total_operation_time dbname="imcn_machine_daily_operation.total_operation_time" dbalias=".total_operation_time" )
 column=(type=datetime updatewhereclause=yes name=plan_date dbname="imcn_machine_daily_operation.plan_date" dbalias=".plan_date" )
 column=(type=datetime updatewhereclause=yes name=start_time dbname="imcn_machine_daily_operation.start_time" dbalias=".start_time" )
 column=(type=datetime updatewhereclause=yes name=end_time dbname="imcn_machine_daily_operation.end_time" dbalias=".end_time" )
 column=(type=char(1) updatewhereclause=yes name=machine_status_code dbname="imcn_machine_daily_operation.machine_status_code" dbalias=".machine_status_code" )
 retrieve="  SELECT ~"IMCN_MACHINE~".~"MACHINE_CODE~",   
         ~"IMCN_MACHINE~".~"MACHINE_NAME~",   
         ~"IMCN_MACHINE_DAILY_OPERATION~".~"TOTAL_OPERATION_TIME~",  
           ~"IMCN_MACHINE_DAILY_OPERATION~".~"PLAN_DATE~",
         ~"IMCN_MACHINE_DAILY_OPERATION~".~"START_TIME~",   
         ~"IMCN_MACHINE_DAILY_OPERATION~".~"END_TIME~",   
         ~"IMCN_MACHINE_DAILY_OPERATION~".~"MACHINE_STATUS_CODE~"  
    FROM ~"IMCN_MACHINE~",   
         ~"IMCN_MACHINE_DAILY_OPERATION~"  
   WHERE ( imcn_machine.machine_code = imcn_machine_daily_operation.machine_code (+)) and  
         ( imcn_machine.organization_id = imcn_machine_daily_operation.organization_id (+)) and  
         ( ( ~"IMCN_MACHINE~".~"MACHINE_CODE~" like :arg_machine_code ) AND  
         (  ~"IMCN_MACHINE~".~"MACHINE_TYPE~" like :arg_machine_type ) AND  
         ( ~"IMCN_MACHINE_DAILY_OPERATION~".~"PLAN_DATE~" >= :arg_dateset ) AND  
         ( ~"IMCN_MACHINE_DAILY_OPERATION~".~"PLAN_DATE~" <= :arg_dateend ) AND  
		(~"IMCN_MACHINE_DAILY_OPERATION~".~"MACHINE_STATUS_CODE~"  <> 'S' ) AND
         ( ~"IMCN_MACHINE~".~"ORGANIZATION_ID~" = :arg_org ) )    
" arguments=(("arg_machine_code", string),("arg_machine_type", string),("arg_dateset", datetime),("arg_dateend", datetime),("arg_org", number))  sort="machine_code A plan_date A " )
group(level=1 header.height=0 trailer.height=104 by=("machine_code" , "plan_date" ) newpage=yes header.color="536870912" trailer.color="65535" )
