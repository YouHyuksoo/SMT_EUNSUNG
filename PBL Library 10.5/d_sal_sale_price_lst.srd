 retrieve="  SELECT ~"IS_PRODUCT_SALE_PRICE~".~"CUSTOMER_CODE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"DATESET~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"ORGANIZATION_ID~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"ITEM_CODE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"PRODUCT_SALE_PRICE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"SALE_CURRENCY~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"DATEEND~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"ENTER_DATE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"ENTER_BY~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"LAST_MODIFY_DATE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"LAST_MODIFY_BY~",   
         ~"ICOM_CUSTOMER~".~"CUSTOMER_NAME~",   
         ~"ID_ITEM~".~"ITEM_SPEC~",   
         ~"ID_ITEM~".~"ITEM_NAME~",   
         is_product_sale_price.rowid,   
         ~"IS_PRODUCT_SALE_PRICE~".~"PRODUCT_LINE_TYPE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"PRICE_TYPE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"PRICE_CHANGE_REASON~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"CONFIRM_DATE~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"CONFIRM_BY~",   
         ~"IS_PRODUCT_SALE_PRICE~".~"PRICE_CHANGE_CONFIRM_YN~"  ,
         DECODE(  SIGN( IS_PRODUCT_SALE_PRICE.DATEEND - TRUNC(SYSDATE)) , 1 , DECODE( SIGN( IS_PRODUCT_SALE_PRICE.DATESET - TRUNC(SYSDATE) ) , 1 , 'FUTURE' , 'RUNNING' )  , 'EXPIRED') STATUS
    FROM ~"IS_PRODUCT_SALE_PRICE~",   
         ~"ICOM_CUSTOMER~",   
         ~"ID_ITEM~"  
   WHERE ( is_product_sale_price.customer_code = icom_customer.customer_code (+)) and  
         ( is_product_sale_price.organization_id = icom_customer.organization_id(+)) and  
         ( ~"IS_PRODUCT_SALE_PRICE~".~"ITEM_CODE~" = ~"ID_ITEM~".~"ITEM_CODE~" ) and  
         ( ~"ID_ITEM~".~"ORGANIZATION_ID~" = ~"IS_PRODUCT_SALE_PRICE~".~"ORGANIZATION_ID~" ) and  
         ( ( ~"IS_PRODUCT_SALE_PRICE~".~"ITEM_CODE~" like :arg_item_code ) AND  
         ( ~"IS_PRODUCT_SALE_PRICE~".~"CUSTOMER_CODE~" like :arg_customer_code ) AND  
         ( ~"IS_PRODUCT_SALE_PRICE~".~"ORGANIZATION_ID~" = :arg_org_id ) )    
" arguments=(("arg_item_code", string),("arg_customer_code", string),("arg_org_id", number))  sort="organization_id A customer_code A item_code A dateset A " )
