table(column=(type=char(4000) updatewhereclause=yes name=pack_label dbname="pack_label" )
 column=(type=char(50) updatewhereclause=yes key=yes name=pack_barcode dbname="ip_product_pack_master.pack_barcode" )
 column=(type=char(30) updatewhereclause=yes name=model_name dbname="ip_product_pack_master.model_name" )
 column=(type=char(32) updatewhereclause=yes name=partno_barcode39 dbname="partno_barcode39" )
