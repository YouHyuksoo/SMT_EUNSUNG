 column=(type=char(4000) updatewhereclause=yes name=customer_model_barcode128 dbname="customer_model_barcode128" )
 retrieve="
select 
       f_bacode_code128('B',pack_barcode) as pack_label , 
       pack_barcode  , 
       model_name, 
       '*'||model_name||'*' as PartNo_Barcode39, 
       
       pack_type, 
       pack_qty, 
       '*'||pack_qty||'*' as pack_qty_barcode39, 
       
       to_char(pack_date,'yyyy/mm/dd hh24:Mi:ss') pack_date, 
       nvl(attr5, 'VN-DONGDO')  company , 
       sysdate as print_date , 
       f_get_org_name(organization_id) as org_name, 
       f_get_model_info(model_name, organization_id, 'CUSTOMER_MODEL_NAME') as Customer_model_name, 
       
       f_bacode_code128('B', f_get_model_info(model_name, organization_id, 'CUSTOMER_MODEL_NAME') ) as Customer_Model_Barcode128
      
      
  from ip_product_pack_master
         
where pack_barcode = :arg_barcode " update="ip_product_pack_master" updatewhere=0 updatekeyinplace=no arguments=(("arg_barcode", string)) )
