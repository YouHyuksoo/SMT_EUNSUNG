 retrieve="  SELECT  RUN_NO,
               LINE_CODE,
               WORKSTAGE_CODE, 
               SUM(IO_QTY)      RESULT, 
               MIN(IO_DATE)     FIRST_DATE, 
               MAX(IO_DATE)     LAST_DATE
     FROM IP_PRODUCT_WORKSTAGE_IO
    WHERE RUN_NO = :ARG_RUN_NO
    GROUP BY RUN_NO, LINE_CODE, WORKSTAGE_CODE
    ORDER BY RUN_NO, LINE_CODE, WORKSTAGE_CODE" arguments=(("ARG_RUN_NO", string)) )
