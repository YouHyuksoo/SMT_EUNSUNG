release 10.5;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.printername="" print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.canusedefaultprinter=yes print.prompt=no print.buttons=no print.preview.buttons=no print.cliptext=no print.overrideprintjob=no print.collate=yes print.preview.outline=yes hidegrayline=no  crosstab.dynamic = yes row.resize=1 grid.lines=0 )
header[1](height=0 color="536870912" )
header[2](height=160 color="536870912" )
summary(height=72 color="65280" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=model_name dbname="model_name" )
 column=(type=char(20) updatewhereclause=yes name=model_suffix dbname="model_suffix" )
 column=(type=char(20) updatewhereclause=yes name=item_code dbname="item_code" )
 column=(type=char(20) updatewhereclause=yes name=pcb_item dbname="pcb_item" )
 column=(type=number updatewhereclause=yes name=inventory_qty dbname="inventory_qty" )
 retrieve="select model_name, 
       model_suffix,
       item_code, 
       pcb_item, 
       f_get_workstage_name_sort(workstage_code)||' '||workstage_code   workstage_name, 
       sum(inventory_qty)                                  inventory_qty
  from ip_product_run_card_inv
 where model_name  like :arg_model
   and model_suffix    like :arg_suffix
   and workstage_code like :arg_workstage_code
   and inventory_qty   <> 0
   and organization_id = :arg_org
 group by model_name, 
               model_suffix,
               item_code, 
               pcb_item,
               workstage_code 
" arguments=(("arg_model", string),("arg_suffix", string),("arg_workstage_code", string),("arg_org", number))  sort="model_name A model_suffix A item_code A pcb_item A " )
