# PowerBuilder 원본 소스 (참조용, git 추적 제외)
/SOLUM MES_DISP/

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# DB config (contains credentials)
/config/database.json

# Slack settings (contains webhook URL)
/data/slack-settings.json

# CTQ 모니터 런타임 상태 (서버 실행 중 자동 변경)
/data/monitor-state.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/
.superpowers/

# Claude Code 런타임 lock
/.claude/scheduled_tasks.lock

# AI 챗 세션 임시 파일 (원자적 쓰기 .tmp-*)
/data/ai-chats/

# graphify 지식 그래프 (graphify update . 로 재생성 가능)
/graphify-out/

# Serena MCP 캐시 (자동 재생성)
/.serena/

# 임시 분석 산출물 (PB analyzer 등 일회성)
/analysis/

# 소스 외 바이너리/미디어 자산 (주로 PBL Library 참조 리소스)
# 앱 자산(public/, src/의 png·svg·mp4)은 추적 유지
*.wav
*.bmp
*.jpg
*.jpeg
*.gif
*.ico
*.ttf
*.xls
*.xlsx
