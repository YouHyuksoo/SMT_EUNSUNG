{
  "name": "eunsung-mes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "pnpm --filter @eunsung/frontend dev",
    "dev:backend": "pnpm --filter @eunsung/backend dev",
    "build": "pnpm --filter @eunsung/frontend build",
    "start": "pnpm --filter @eunsung/frontend start",
    "lint": "pnpm --filter @eunsung/frontend lint",
    "typecheck": "pnpm --filter @eunsung/frontend typecheck",
    "test": "pnpm --filter @eunsung/frontend test",
    "typecheck:frontend": "pnpm --filter @eunsung/frontend exec tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "oracledb",
      "puppeteer",
      "sharp",
      "unrs-resolver"
    ]
  }
}
